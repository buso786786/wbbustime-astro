---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  robots?: string;
}

const {
  title,
  description,
  canonical,
  robots
} = Astro.props;

const canonicalUrl = canonical || (Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname);

const siteName = "Sonia Buddy";
const fullTitle = `${title} | ${siteName}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <title>{fullTitle}</title>
    <slot name="head" />
  </head>

  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a href="/" class="site-logo" aria-label="Sonia Buddy Home">
          <span class="site-logo-text">Sonia Buddy</span>
        </a>

        <nav class="site-nav" aria-label="Main navigation">
          <a href="/">Home</a>
          <a href="/bus-search">Bus Search</a>
          <a href="/rent-vehicle">Rent Vehicle</a>

          <div class="lang-toggle" aria-label="Language">
            <button type="button" data-lang="en" class="active">EN</button>
            <button type="button" data-lang="bn">বাংলা</button>
          </div>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="container">
        <div class="footer-content">
          <div class="footer-section">
            <h3>Sonia Buddy</h3>
            <p>West Bengal Bus Timetables & Vehicle Rental</p>
            <p>পশ্চিমবঙ্গে বাস টাইমটেবিল ও ভাড়া গাড়ি</p>
          </div>

          <div class="footer-section">
            <h4>Quick Links</h4>
            <ul>
              <li><a href="/">Home</a></li>
              <li><a href="/bus-search">Bus Search</a></li>
              <li><a href="/rent-vehicle">Rent Vehicle</a></li>
              <li><a href="/about">About</a></li>
              <li><a href="/faq">FAQ</a></li>
              <li><a href="/contact">Contact</a></li>
            </ul>
          </div>

          <div class="footer-section">
            <h4>Legal</h4>
            <ul>
              <li><a href="/privacy-policy">Privacy Policy</a></li>
              <li><a href="/terms-and-conditions">Terms & Conditions</a></li>
            </ul>
          </div>
        </div>

        <div class="footer-bottom">
          <p>&copy; 2026 Sonia Buddy. All rights reserved.</p>
          <p>Your trusted travel companion in West Bengal / পশ্চিমবঙ্গে আপনার বিশ্বস্ত ভ্রমণ সঙ্গী</p>
        </div>
      </div>
    </footer>

    <script>
  (function() {
    const langButtons = document.querySelectorAll('.lang-toggle button');
    const body = document.body;
    const html = document.documentElement;

    const readLang = () => {
      try {
        return (
          localStorage.getItem('soniabuddy_lang') ||
          localStorage.getItem('soniabuddy_rent_lang_v1') ||
          'en'
        );
      } catch {
        return 'en';
      }
    };

    const applyLang = (lang) => {
      const safeLang = lang === 'bn' ? 'bn' : 'en';

      body.setAttribute('data-lang', safeLang);
      html.setAttribute('lang', safeLang === 'bn' ? 'bn' : 'en');

      document.querySelectorAll('[data-en][data-bn]').forEach((el) => {
        const text = el.getAttribute(safeLang === 'bn' ? 'data-bn' : 'data-en');
        if (text !== null) el.textContent = text;
      });

      document.querySelectorAll('[data-placeholder-en][data-placeholder-bn]').forEach((el) => {
        const text = el.getAttribute(
          safeLang === 'bn' ? 'data-placeholder-bn' : 'data-placeholder-en'
        );
        if (text !== null) el.setAttribute('placeholder', text);
      });

      langButtons.forEach((btn) => {
        btn.classList.toggle('active', btn.getAttribute('data-lang') === safeLang);
      });
    };

    const saveLang = (lang) => {
      try {
        localStorage.setItem('soniabuddy_lang', lang);
        localStorage.setItem('soniabuddy_rent_lang_v1', lang);
      } catch {
        // ignore
      }
    };

    const currentLang = readLang();
    applyLang(currentLang);

    langButtons.forEach((button) => {
      button.addEventListener('click', function(event) {
        const target = event.currentTarget;
        const lang = target.getAttribute('data-lang') || 'en';

        saveLang(lang);
        applyLang(lang);

        window.dispatchEvent(
          new CustomEvent('soniabuddy:lang-change', {
            detail: { lang },
          })
        );

        try {
          window.dispatchEvent(
            new StorageEvent('storage', {
              key: 'soniabuddy_rent_lang_v1',
              newValue: lang,
            })
          );
        } catch {
          // ignore
        }
      });
    });
  })();
</script>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
  }

  .site-header {
    background: #1e40af;
    color: #ffffff;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.14);
    position: relative;
    z-index: 50;
  }

  .site-header-inner {
    max-width: 1200px;
    margin: 0 auto;
    min-height: 56px;
    padding: 0.45rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .site-logo {
    text-decoration: none;
    color: #ffffff;
    flex: 0 0 auto;
  }

  .site-logo-text {
    display: inline-block;
    font-size: 1.25rem;
    line-height: 1;
    font-weight: 800;
    letter-spacing: -0.02em;
    white-space: nowrap;
  }

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.35rem;
    min-width: 0;
  }

  .site-nav a {
    color: #ffffff;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.88rem;
    line-height: 1;
    padding: 0.48rem 0.7rem;
    border-radius: 999px;
    white-space: nowrap;
    transition: background 0.2s, opacity 0.2s;
  }

  .site-nav a:hover {
    background: rgba(255, 255, 255, 0.12);
  }

  .lang-toggle {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    margin-left: 0.25rem;
    flex: 0 0 auto;
  }

  .lang-toggle button {
    min-height: 34px;
    border: 1px solid rgba(255, 255, 255, 0.32);
    border-radius: 0.45rem;
    background: rgba(255, 255, 255, 0.16);
    color: #ffffff;
    padding: 0.35rem 0.7rem;
    cursor: pointer;
    font-weight: 800;
    font-size: 0.78rem;
    line-height: 1;
  }

  .lang-toggle button.active {
    background: #f97316;
    border-color: #f97316;
  }

  main {
    min-height: calc(100vh - 120px);
  }

  footer {
    background: #0f172a;
    color: white;
    padding: 2rem 0 1rem;
    margin-top: auto;
  }

  footer .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .footer-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .footer-section h3,
  .footer-section h4 {
    margin: 0 0 1rem 0;
    font-size: 1.1rem;
  }

  .footer-section p {
    margin: 0 0 0.5rem 0;
    color: #94a3b8;
  }

  .footer-section ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-section li {
    margin-bottom: 0.5rem;
  }

  .footer-section a {
    color: #94a3b8;
    text-decoration: none;
  }

  .footer-section a:hover {
    color: white;
  }

  .footer-bottom {
    border-top: 1px solid #334155;
    padding-top: 1rem;
    text-align: center;
    color: #94a3b8;
  }

  .footer-bottom p {
    margin: 0 0 0.5rem 0;
  }

  @media (max-width: 768px) {
    .site-header-inner {
      min-height: 48px;
      padding: 0.38rem 0.55rem;
      gap: 0.45rem;
      align-items: center;
    }

    .site-logo-text {
      font-size: 1rem;
    }

    .site-nav {
      gap: 0.2rem;
      overflow-x: auto;
      scrollbar-width: none;
      justify-content: flex-start;
    }

    .site-nav::-webkit-scrollbar {
      display: none;
    }

    .site-nav a {
      font-size: 0.74rem;
      padding: 0.38rem 0.5rem;
    }

    .lang-toggle {
      gap: 0.25rem;
      margin-left: 0.1rem;
    }

    .lang-toggle button {
      min-height: 30px;
      padding: 0.32rem 0.5rem;
      font-size: 0.7rem;
      border-radius: 0.4rem;
    }

    .footer-content {
      grid-template-columns: 1fr;
      text-align: center;
    }
  }

  @media (max-width: 420px) {
    .site-header-inner {
      padding-left: 0.45rem;
      padding-right: 0.45rem;
    }

    .site-logo-text {
      font-size: 0.92rem;
    }

    .site-nav a {
      font-size: 0.7rem;
      padding: 0.35rem 0.42rem;
    }

    .lang-toggle button {
      padding: 0.3rem 0.42rem;
    }
  }
</style>