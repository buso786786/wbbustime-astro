---
import BaseLayout from "../layouts/BaseLayout.astro";
import { supabase } from "../lib/supabase";
import { listRentCities } from "../lib/rentCities";

const PHOTO_BUCKET = "rent-listing-photos";

type RentCity = {
  id: string;
  name: string | null;
  name_en: string | null;
  name_bn: string | null;
  district_en: string | null;
  district_bn: string | null;
  search_keywords_en: string | null;
  search_keywords_bn: string | null;
};

type RentListing = {
  id: string;
  owner_name: string | null;
  owner_phone: string | null;
  owner_whatsapp: string | null;
  vehicle_type: string | null;
  vehicle_model: string | null;
  seats: number | null;
  purposes: string[] | null;
  base_city_id: string | null;
  service_city_ids: string[] | null;
  price_text: string | null;
  photos: string[] | null;
  description: string | null;
  status: string | null;
  created_at: string | null;
  updated_at: string | null;
  
  is_promoted?: boolean;
};

const cities = (await listRentCities({ onlyActive: true })) as RentCity[];

const { data: listingsData, error: listingsError } = await supabase
  .from("rent_listings")
  .select(`
    id,
    owner_name,
    owner_phone,
    owner_whatsapp,
    vehicle_type,
    vehicle_model,
    seats,
    purposes,
    base_city_id,
    service_city_ids,
    price_text,
    photos,
    description,
    status,
    created_at,
    updated_at
  `)
  .eq("status", "active")
  .order("updated_at", { ascending: false })
  .limit(100);

if (listingsError) {
  console.error("Rent listings fetch error:", listingsError);
}

const listings = (listingsData ?? []) as RentListing[];
const listingIds = listings.map((listing) => listing.id);

let membershipsData: any[] = [];
let membershipsError: any = null;

if (listingIds.length) {
  const result = await supabase
    .from("rent_memberships")
    .select(`
      listing_id,
      plan_type,
      status,
      ads_status,
      starts_at,
      expires_at
    `)
    .in("listing_id", listingIds)
    .eq("status", "active");

  membershipsData = result.data ?? [];
  membershipsError = result.error;
}

if (membershipsError) {
  console.error("Rent memberships fetch error:", membershipsError);
}

const nowMs = Date.now();

function membershipIsLive(membership: any) {
  const startsOk =
    !membership.starts_at || new Date(membership.starts_at).getTime() <= nowMs;

  const expiresOk =
    membership.expires_at && new Date(membership.expires_at).getTime() > nowMs;

  return startsOk && expiresOk;
}

const promotedListingIds = new Set(
  membershipsData
    .filter((membership) => {
      return (
        membership.plan_type === "featured" &&
        membership.ads_status === "active" &&
        membershipIsLive(membership)
      );
    })
    .map((membership) => membership.listing_id)
);

const verifiedListingIds = new Set(
  membershipsData
    .filter((membership) => {
      return (
        membership.plan_type === "basic" &&
        membershipIsLive(membership)
      );
    })
    .map((membership) => membership.listing_id)
);

function cityName(city: RentCity | undefined | null) {
  if (!city) return "";
  return city.name_en || city.name_bn || city.name || "";
}

function cityDistrict(city: RentCity | undefined | null) {
  if (!city) return "";
  return city.district_en || city.district_bn || "";
}

function publicPhotoUrl(path: string | null | undefined) {
  if (!path) return "";
  if (path.startsWith("http://") || path.startsWith("https://")) return path;

  const { data } = supabase.storage.from(PHOTO_BUCKET).getPublicUrl(path);
  return data.publicUrl;
}

const citiesForClient = cities.map((city) => {
  const nameEn = city.name_en || city.name || "";
  const nameBn = city.name_bn || "";
  const districtEn = city.district_en || "";
  const districtBn = city.district_bn || "";
  const keywordsEn = city.search_keywords_en || "";
  const keywordsBn = city.search_keywords_bn || "";

  return {
    id: city.id,
    name: cityName(city),
    district: cityDistrict(city),
    name_en: nameEn,
    name_bn: nameBn,
    district_en: districtEn,
    district_bn: districtBn,
    search_keywords_en: keywordsEn,
    search_keywords_bn: keywordsBn,
    search_text: [
      nameEn,
      nameBn,
      city.name || "",
      districtEn,
      districtBn,
      keywordsEn,
      keywordsBn,
    ].join(" "),
  };
});

const listingsForClient = listings.map((listing) => {
  const baseCity = cities.find((city) => city.id === listing.base_city_id);
  const serviceCities = (listing.service_city_ids ?? [])
    .map((id) => cities.find((city) => city.id === id))
    .filter(Boolean) as RentCity[];

  return {
    ...listing,
    is_promoted: promotedListingIds.has(listing.id),
    is_verified_badge: verifiedListingIds.has(listing.id),
    base_city_name: cityName(baseCity),
    service_city_names: serviceCities.map(cityName),
    photo_urls: (listing.photos ?? []).slice(0, 4).map(publicPhotoUrl),
  };
});
