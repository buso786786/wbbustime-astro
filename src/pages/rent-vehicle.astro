    serviceCityIds: state.serviceCities.map((city) => city.id).slice(0, 3),
    purposes: getActiveChipValues("rent-type-chips"),
    priceText: getInputValue("rent-price"),
    description: getInputValue("rent-description"),
    consent: isChecked("consent-checkbox"),
  };
}

function saveCreateListingDraft() {
  try {
    localStorage.setItem(RENT_DRAFT_KEY, JSON.stringify(collectCreateListingDraft()));
  } catch (error) {
    console.error("Draft save failed:", error);
  }
}

function clearCreateListingDraft() {
  try {
    localStorage.removeItem(RENT_DRAFT_KEY);
    localStorage.removeItem(RENT_PENDING_SUBMIT_KEY);
  } catch {
    // ignore
  }
}

function restoreCreateListingDraft() {
  let draft = null;

  try {
    const raw = localStorage.getItem(RENT_DRAFT_KEY);
    if (!raw) return false;
    draft = JSON.parse(raw);
  } catch {
    return false;
  }

  setInputValue("owner-name", draft.ownerName || "");
  setInputValue("owner-phone", draft.phone || "");
  setInputValue("owner-whatsapp", draft.whatsapp || "");
  setInputValue("vehicle-reg", draft.regNumber || "");
  setInputValue("vehicle-model", draft.vehicleModel || "");
  setInputValue("vehicle-seats", draft.seats || "");
  setInputValue("rent-price", draft.priceText || "");
  setInputValue("rent-description", draft.description || "");
  setCheckboxValue("consent-checkbox", Boolean(draft.consent));

  setChipActive("create-vehicle-chips", draft.vehicleType || "");
  setChipActive("rent-type-chips", draft.purposes || []);

  if (draft.baseCityId) {
    const city = cities.find((c) => c.id === draft.baseCityId);
    if (city) state.baseCity = city;
  }

  if (Array.isArray(draft.serviceCityIds)) {
    state.serviceCities = draft.serviceCityIds
      .map((id) => cities.find((c) => c.id === id))
      .filter(Boolean)
      .slice(0, 3);
  }

  refreshCityDisplays();
  return true;
}

