const RENT_DRAFT_KEY = "wbbustime_astro_rent_listing_draft_v1";
const RENT_PENDING_SUBMIT_KEY = "wbbustime_astro_rent_pending_submit_v1";
const MAX_RENT_PHOTOS = 4;
let selectedPhotoFiles = [];
let currentUser = null;

function normalizePhone10(value) {
  const digits = String(value || "").replace(/\D/g, "");

  if (digits.length === 12 && digits.startsWith("91")) {
    return digits.slice(2);
  }

  if (digits.length === 11 && digits.startsWith("0")) {
    return digits.slice(1);
  }

  return digits;
}

function normalizeRegNumber(value) {
  return String(value || "").replace(/[\s-]/g, "").toUpperCase();
}

function getInputValue(id) {
  const el = document.getElementById(id);
  return el ? String(el.value || "").trim() : "";
}

function setInputValue(id, value) {
  const el = document.getElementById(id);
  if (el) el.value = value || "";
}

function isChecked(id) {
  const el = document.getElementById(id);
  return Boolean(el && el.checked);
}

function setCheckboxValue(id, checked) {
  const el = document.getElementById(id);
  if (el) el.checked = Boolean(checked);
}

function getActiveChipValue(groupId) {
  const active = document.querySelector(`#${groupId} .rent-chip.active`);
  return active ? String(active.dataset.value || active.textContent || "").trim() : "";
}

function getActiveChipValues(groupId) {
  return Array.from(document.querySelectorAll(`#${groupId} .rent-chip.active`))
    .map((chip) => String(chip.dataset.value || chip.textContent || "").trim())
    .filter(Boolean);
}

function setChipActive(groupId, values) {
  const valueSet = new Set(Array.isArray(values) ? values : [values].filter(Boolean));

  document.querySelectorAll(`#${groupId} .rent-chip`).forEach((chip) => {
    const value = String(chip.dataset.value || chip.textContent || "").trim();
    chip.classList.toggle("active", valueSet.has(value));
  });
}

function showSubmitMessage(message, type = "info") {
  const box = document.getElementById("submit-message");
  if (!box) return;

  box.textContent = message;
  box.classList.remove("hidden", "success", "error", "info");
  box.classList.add(type);
}

function collectCreateListingDraft() {
  return {
    ownerName: getInputValue("owner-name"),
    phone: getInputValue("owner-phone"),
    whatsapp: getInputValue("owner-whatsapp"),
    vehicleType: getActiveChipValue("create-vehicle-chips"),
    regNumber: getInputValue("vehicle-reg"),
    vehicleModel: getInputValue("vehicle-model"),
    seats: getInputValue("vehicle-seats"),
    baseCityId: state.baseCity ? state.baseCity.id : null,
    serviceCityIds: state.serviceCities.map((city) => city.id).slice(0, 3),
    purposes: getActiveChipValues("rent-type-chips"),
    priceText: getInputValue("rent-price"),
    description: getInputValue("rent-description"),
    consent: isChecked("consent-checkbox"),
  };
}

function saveCreateListingDraft() {
  try {
    localStorage.setItem(RENT_DRAFT_KEY, JSON.stringify(collectCreateListingDraft()));
  } catch (error) {
    console.error("Draft save failed:", error);
  }
}

function clearCreateListingDraft() {
  try {
    localStorage.removeItem(RENT_DRAFT_KEY);
    localStorage.removeItem(RENT_PENDING_SUBMIT_KEY);
  } catch {
    // ignore
  }
}

function restoreCreateListingDraft() {
  let draft = null;

  try {
    const raw = localStorage.getItem(RENT_DRAFT_KEY);
    if (!raw) return false;
    draft = JSON.parse(raw);
  } catch {
    return false;
  }

  setInputValue("owner-name", draft.ownerName || "");
  setInputValue("owner-phone", draft.phone || "");
  setInputValue("owner-whatsapp", draft.whatsapp || "");
  setInputValue("vehicle-reg", draft.regNumber || "");
  setInputValue("vehicle-model", draft.vehicleModel || "");
  setInputValue("vehicle-seats", draft.seats || "");
  setInputValue("rent-price", draft.priceText || "");
  setInputValue("rent-description", draft.description || "");
  setCheckboxValue("consent-checkbox", Boolean(draft.consent));

  setChipActive("create-vehicle-chips", draft.vehicleType || "");
  setChipActive("rent-type-chips", draft.purposes || []);

  if (draft.baseCityId) {
    const city = cities.find((c) => c.id === draft.baseCityId);
    if (city) state.baseCity = city;
  }

  if (Array.isArray(draft.serviceCityIds)) {
    state.serviceCities = draft.serviceCityIds
      .map((id) => cities.find((c) => c.id === id))
      .filter(Boolean)
      .slice(0, 3);
  }

  refreshCityDisplays();
  return true;
}

async function getCurrentUser() {
  const { data, error } = await supabase.auth.getSession();

  if (error) {
    console.error("Get session failed:", error);
    return null;
  }

  return data.session?.user || null;
}

async function updateAuthStatus() {
  currentUser = await getCurrentUser();

  const text = document.getElementById("auth-status-text");
  const loginBtn = document.getElementById("google-login-btn");
  const submitBtn = document.getElementById("submit-listing-btn");

  if (currentUser?.email) {
    if (text) text.textContent = `Logged in as ${currentUser.email}. Complete the form and submit your listing.`;
    if (loginBtn) {
      loginBtn.textContent = "Logged in";
      loginBtn.setAttribute("disabled", "disabled");
      loginBtn.classList.add("btn-disabled");
    }
    if (submitBtn) submitBtn.textContent = "Submit Listing";
    return currentUser;
  }

  if (text) text.textContent = "Login with Google before submitting your listing. Your form draft will be saved.";
  if (loginBtn) {
    loginBtn.textContent = "Login with Google";
    loginBtn.removeAttribute("disabled");
    loginBtn.classList.remove("btn-disabled");
  }
  if (submitBtn) submitBtn.textContent = "Save Draft & Login";
  return null;
}

async function loginWithGoogleAndSaveDraft() {
  saveCreateListingDraft();
  localStorage.setItem(RENT_PENDING_SUBMIT_KEY, "1");

  const { error } = await supabase.auth.signInWithOAuth({
    provider: "google",
    options: {
      redirectTo: `${window.location.origin}/rent-vehicle?tab=register`,
    },
  });

  if (error) {
    showSubmitMessage(error.message, "error");
  }
}

function validateCreateListingForm(input) {
  if (!input.owner_name) return "Owner name required.";

  if (!/^\d{10}$/.test(input.owner_phone)) {
    return "Valid 10 digit phone number required.";
  }

  if (!/^\d{10}$/.test(input.owner_whatsapp)) {
    return "Valid 10 digit WhatsApp number required.";
  }

  if (!input.vehicle_type) return "Vehicle type required.";
  if (!input.reg_number) return "Vehicle registration number required.";
  if (!input.vehicle_model) return "Vehicle model required.";

  if (!input.seats || Number(input.seats) < 1) {
    return "Seats required.";
  }

  if (!input.base_city_id) return "Base city required.";

  if (!input.service_city_ids || input.service_city_ids.length < 1) {
    return "At least 1 service city required.";
  }

  if (!input.purposes || input.purposes.length < 1) {
    return "At least 1 rent type required.";
  }

  if (!input.price_text) return "Price required.";
  if (!input.description) return "Description required.";

  if (!selectedPhotoFiles.length) {
    return "At least 1 vehicle photo required.";
  }

  if (selectedPhotoFiles.length > MAX_RENT_PHOTOS) {
    return "Maximum 4 photos allowed.";
  }

  if (!input.consent_accepted) {
    return "Please accept consent before submit.";
  }

  return "";
}

async function checkDuplicateRegNumber(regNumber) {
  const cleanReg = normalizeRegNumber(regNumber);

  if (!cleanReg) {
    return {
      exists: false,
      error: "Vehicle registration number required.",
    };
  }

  const { count, error } = await supabase
    .from("rent_listings")
    .select("id", { count: "exact", head: true })
    .eq("reg_number", cleanReg)
    .neq("status", "cancelled");

  if (error) {
    return {
      exists: false,
      error: error.message,
    };
  }

  return {
    exists: (count || 0) > 0,
    error: "",
  };
}

function updatePhotoPreview() {
  const slots = Array.from(document.querySelectorAll(".photo-upload-box"));

  slots.forEach((slot, index) => {
    const file = selectedPhotoFiles[index];

    if (!file) {
      slot.innerHTML = `<span class="photo-placeholder">+</span>`;
      slot.classList.remove("has-photo");
      return;
    }

    const url = URL.createObjectURL(file);
    slot.classList.add("has-photo");
    slot.innerHTML = `
      <img src="${url}" alt="Selected rent photo ${index + 1}" />
      <span class="photo-remove" data-remove-photo-index="${index}">×</span>
    `;
  });
}

function addPhotoFiles(files) {
  const imageFiles = Array.from(files || []).filter((file) => file.type.startsWith("image/"));
  const remaining = MAX_RENT_PHOTOS - selectedPhotoFiles.length;

  if (remaining <= 0) {
    showSubmitMessage("Maximum 4 photos allowed.", "error");
    return;
  }

  selectedPhotoFiles = [...selectedPhotoFiles, ...imageFiles.slice(0, remaining)].slice(0, MAX_RENT_PHOTOS);
  updatePhotoPreview();
}

async function uploadSelectedPhotos(userId) {
  const uploaded = [];

  for (let i = 0; i < selectedPhotoFiles.length; i++) {
    const file = selectedPhotoFiles[i];
    const ext = file.type === "image/webp" ? "webp" : file.type === "image/png" ? "png" : "jpg";
    const path = `${userId}/${Date.now()}-${i}.${ext}`;

    const { error } = await supabase.storage
      .from("rent-listing-photos")
      .upload(path, file, {
        cacheControl: "31536000",
        upsert: false,
        contentType: file.type || "image/jpeg",
      });

    if (error) {
      throw new Error(`Photo upload failed: ${error.message}`);
    }

    uploaded.push(path);
  }

  return uploaded;
}

function clearCreateListingForm() {
  [
    "owner-name",
    "owner-phone",
    "owner-whatsapp",
    "vehicle-reg",
    "vehicle-model",
    "vehicle-seats",
    "rent-price",
    "rent-description",
  ].forEach((id) => {
    const el = document.getElementById(id);
    if (el) el.value = "";
  });

  const consent = document.getElementById("consent-checkbox");
  if (consent) consent.checked = false;

  document
    .querySelectorAll("#create-vehicle-chips .rent-chip, #rent-type-chips .rent-chip")
    .forEach((chip) => chip.classList.remove("active"));

  state.baseCity = null;
  state.serviceCities = [];
  selectedPhotoFiles = [];

  const photoInput = document.getElementById("rent-photo-input");
  if (photoInput) photoInput.value = "";

  updatePhotoPreview();
  updateSelectedDisplay("baseCity");
  updateSelectedDisplay("serviceCities");
  clearCreateListingDraft();
}

async function submitCreateListing() {
  const btn = document.getElementById("submit-listing-btn");
  if (!btn) return;

  const user = await getCurrentUser();

  if (!user?.id || !user?.email) {
    saveCreateListingDraft();
    showSubmitMessage("Please login with Google first. Your form draft is saved.", "info");
    await loginWithGoogleAndSaveDraft();
    return;
  }

  const ownerPhone = normalizePhone10(getInputValue("owner-phone"));
  const ownerWhatsapp = normalizePhone10(getInputValue("owner-whatsapp"));

  const input = {
    owner_user_id: user.id,
    owner_email: user.email,
    owner_name: getInputValue("owner-name"),
    owner_phone: ownerPhone,
    owner_whatsapp: ownerWhatsapp,
    vehicle_type: getActiveChipValue("create-vehicle-chips"),
    reg_number: normalizeRegNumber(getInputValue("vehicle-reg")),
    vehicle_model: getInputValue("vehicle-model"),
    seats: Number(getInputValue("vehicle-seats") || 0),
    purposes: getActiveChipValues("rent-type-chips"),
    base_city_id: state.baseCity ? state.baseCity.id : null,
    service_city_ids: state.serviceCities.map((city) => city.id).slice(0, 3),
    price_text: getInputValue("rent-price"),
    description: getInputValue("rent-description"),
    photos: [],
    status: "active",
    is_verified: false,
    consent_accepted: isChecked("consent-checkbox"),
    consent_accepted_at: new Date().toISOString(),
    updated_at: new Date().toISOString(),
  };

  const errorMessage = validateCreateListingForm(input);

  if (errorMessage) {
    showSubmitMessage(errorMessage, "error");
    return;
  }

  const duplicateCheck = await checkDuplicateRegNumber(input.reg_number);

  if (duplicateCheck.error) {
    showSubmitMessage(duplicateCheck.error, "error");
    return;
  }

  if (duplicateCheck.exists) {
    showSubmitMessage(
      "This registration number is already listed. Same vehicle cannot be listed again.",
      "error"
    );
    return;
  }

  btn.disabled = true;
  btn.textContent = "Uploading photos...";
  showSubmitMessage("Uploading photos...", "info");

  try {
    const uploadedPhotos = await uploadSelectedPhotos(user.id);

    btn.textContent = "Submitting...";
    showSubmitMessage("Saving listing...", "info");

    const insertPayload = {
      ...input,
      photos: uploadedPhotos,
    };

    const { data, error } = await supabase
      .from("rent_listings")
      .insert(insertPayload)
      .select("id")
      .single();

    if (error) throw error;

    showSubmitMessage(
      "Listing submitted successfully. Your listing is now live.",
      "success"
    );

    clearCreateListingForm();

    btn.disabled = false;
    btn.textContent = "Submit Listing";

    console.log("Created rent listing:", data);
  } catch (error) {
    console.error("Create listing failed:", error);

    showSubmitMessage(
      error && error.message
        ? error.message
        : "Listing submit failed. Check Supabase RLS/storage policy/columns.",
      "error"
    );

    btn.disabled = false;
    btn.textContent = "Submit Listing";
  }
}

function setupPhotoUpload() {
  const input = document.getElementById("rent-photo-input");
  const grid = document.getElementById("photo-upload-grid");

  grid?.addEventListener("click", (event) => {
    const remove = event.target.closest(".photo-remove");
    if (remove) {
      event.preventDefault();
      event.stopPropagation();
      const index = Number(remove.dataset.removePhotoIndex);
      selectedPhotoFiles = selectedPhotoFiles.filter((_, i) => i !== index);
      updatePhotoPreview();
      return;
    }

    input?.click();
  });

  input?.addEventListener("change", () => {
    addPhotoFiles(input.files);
    input.value = "";
  });
}

async function handlePostLoginRestore() {
  const restored = restoreCreateListingDraft();
  const user = await updateAuthStatus();
  const hadPendingSubmit = localStorage.getItem(RENT_PENDING_SUBMIT_KEY) === "1";

  if (restored && user?.email && hadPendingSubmit) {
    localStorage.removeItem(RENT_PENDING_SUBMIT_KEY);
    showSubmitMessage(
      "Login complete. Draft restored. Please select photos again, then click Submit Listing.",
      "info"
    );
  }
}

