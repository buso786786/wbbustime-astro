async function trackRentListingEvent(listing, eventType) {
  if (!listing?.id || !eventType) return;

  const payload = {
    listing_id: listing.id,
    event_type: eventType,
    city_id: listing.base_city_id || state.mainCity?.id || null,
    vehicle_type: listing.vehicle_type || null,
    rent_type: Array.isArray(listing.purposes) ? listing.purposes[0] || null : null,
    user_agent: navigator.userAgent || null,
  };

  try {
    const { error } = await supabase.from("rent_listing_events").insert(payload);
    if (error) {
      console.warn("Rent event track failed:", error.message, payload);
    }
  } catch (error) {
    console.warn("Rent event track failed:", error, payload);
  }
}

function setupRentCardAnalyticsObserver() {
  const cards = document.querySelectorAll(".rent-pro-card[data-listing-id]");
  if (!cards.length) return;

  if (!("IntersectionObserver" in window)) {
    cards.forEach((card) => {
      const listing = getListingById(card.dataset.listingId);
      if (!listing) return;

      const viewKey = `${listing.id}:listing_view`;
      if (!trackedRentViews.has(viewKey)) {
        trackedRentViews.add(viewKey);
        void trackRentListingEvent(listing, "listing_view");
      }

      if (listing.is_promoted) {
        const adKey = `${listing.id}:ad_impression`;
        if (!trackedRentViews.has(adKey)) {
          trackedRentViews.add(adKey);
          void trackRentListingEvent(listing, "ad_impression");
        }
      }
    });
    return;
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;

        const card = entry.target;
        const listing = getListingById(card.dataset.listingId);

        if (!listing) {
          observer.unobserve(card);
          return;
        }

        const viewKey = `${listing.id}:listing_view`;
        if (!trackedRentViews.has(viewKey)) {
          trackedRentViews.add(viewKey);
          void trackRentListingEvent(listing, "listing_view");
        }

        if (listing.is_promoted) {
          const adKey = `${listing.id}:ad_impression`;
          if (!trackedRentViews.has(adKey)) {
            trackedRentViews.add(adKey);
            void trackRentListingEvent(listing, "ad_impression");
          }
        }

        observer.unobserve(card);
      });
    },
    { threshold: 0.35 }
  );

  cards.forEach((card) => {
    const listingId = card.dataset.listingId;
    if (!listingId || trackedRentViews.has(`${listingId}:listing_view`)) return;
    observer.observe(card);
  });
}
