---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Rent Vehicle with Driver - SoniaBuddy"
  description="Find car, bus, toto, pickup van and ambulance rental with driver near your city."
>
  <section class="rent-page">
    <div class="rent-container">
      <header class="hero">
        <p class="eyebrow">SoniaBuddy Rent</p>
        <h1>Find Rent Vehicle with Driver</h1>
        <p>Car, Bus, Toto, Pickup Van and Ambulance rental near your city.</p>
      </header>

      <div id="message-box" class="message hidden"></div>

      <section class="search-card">
        <div class="field">
          <label for="city-input">City</label>
          <input id="city-input" type="text" placeholder="Example: Kolkata, Durgapur, Asansol" />
        </div>

        <div class="field">
          <label for="vehicle-select">Vehicle Type</label>
          <select id="vehicle-select">
            <option value="">All vehicles</option>
            <option value="car">Car</option>
            <option value="bus">Bus</option>
            <option value="toto">Toto</option>
            <option value="pickup">Pickup Van</option>
            <option value="ambulance">Ambulance</option>
          </select>
        </div>

        <div class="field">
          <label for="purpose-select">Purpose</label>
          <select id="purpose-select">
            <option value="">Any purpose</option>
            <option value="wedding">Wedding</option>
            <option value="tour">Tour</option>
            <option value="local">Local</option>
            <option value="school-office">School / Office</option>
            <option value="emergency">Emergency</option>
            <option value="goods-parcel">Goods / Parcel</option>
          </select>
        </div>

        <button id="search-btn" class="btn btn-primary" type="button">Search Rent</button>
      </section>

      <section class="quick-links">
        <button class="chip vehicle-chip" type="button" data-vehicle="car">🚗 Car</button>
        <button class="chip vehicle-chip" type="button" data-vehicle="bus">🚌 Bus</button>
        <button class="chip vehicle-chip" type="button" data-vehicle="toto">🛺 Toto</button>
        <button class="chip vehicle-chip" type="button" data-vehicle="pickup">🚚 Pickup</button>
        <button class="chip vehicle-chip" type="button" data-vehicle="ambulance">🚑 Ambulance</button>
      </section>

      <div class="top-row">
        <h2>Available Vehicles</h2>
        <a class="btn btn-outline" href="/owner/rent-dashboard">Owner Dashboard</a>
      </div>

      <div id="loader" class="notice-card">Loading listings...</div>
      <div id="listings-grid" class="listings-grid"></div>
    </div>
  </section>

  <div id="report-modal" class="modal hidden">
    <div class="modal-card">
      <div class="modal-head">
        <h2>Report Listing</h2>
        <button id="close-report" type="button">×</button>
      </div>

      <form id="report-form" class="report-form">
        <input id="report-listing-id" type="hidden" />

        <label>
          Reason
          <select id="report-reason" required>
            <option value="">Select reason</option>
            <option value="wrong_phone">Wrong phone number</option>
            <option value="fake_listing">Fake listing</option>
            <option value="duplicate">Duplicate listing</option>
            <option value="not_responding">Owner not responding</option>
            <option value="other">Other</option>
          </select>
        </label>

        <label>
          Your phone optional
          <input id="report-phone" type="tel" placeholder="Your phone number" />
        </label>

        <label>
          Message optional
          <textarea id="report-message-text" rows="3" placeholder="Short details"></textarea>
        </label>

        <button class="btn btn-danger" type="submit">Submit Report</button>
      </form>
    </div>
  </div>

  <script>
    import { supabase } from '../lib/supabase';

    const PHOTO_BUCKET = 'rent-photos';

    let listings = [];

    function esc(value) {
      return String(value || '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');
    }

    function slugify(value) {
      return String(value || '')
        .toLowerCase()
        .trim()
        .replace(/&/g, 'and')
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-+|-+$/g, '');
    }

    function photoUrl(path) {
      if (!path) return '';
      if (path.startsWith('http://') || path.startsWith('https://')) return path;
      const { data } = supabase.storage.from(PHOTO_BUCKET).getPublicUrl(path);
      return data.publicUrl;
    }

    function normalizePhone(phone) {
      const raw = String(phone || '').replace(/\D/g, '');
      if (!raw) return '';
      if (raw.length === 10) return `91${raw}`;
      return raw;
    }

    function showMessage(text, type = 'info') {
      const box = document.getElementById('message-box');
      if (!box) return;
      box.textContent = text;
      box.className = `message ${type}`;
    }

    function hideMessage() {
      const box = document.getElementById('message-box');
      if (box) box.classList.add('hidden');
    }

    function getCityName(listing) {
      return listing.rent_cities?.name_en || listing.rent_cities?.name_bn || 'west-bengal';
    }

    function getDetailUrl(listing) {
      const purpose = Array.isArray(listing.purposes) && listing.purposes[0] ? listing.purposes[0] : 'rent';
      const vehicle = listing.vehicle_type || 'vehicle';
      const city = getCityName(listing);

      return `/rent-vehicle/${slugify(purpose) || 'rent'}/${slugify(vehicle) || 'vehicle'}/${slugify(city) || 'west-bengal'}/${listing.id}`;
    }

    async function trackEvent(listing, eventType) {
      if (!listing?.id) return;

      try {
        await supabase.from('rent_listing_events').insert({
          listing_id: listing.id,
          event_type: eventType,
          city_id: listing.base_city_id || null,
          vehicle_type: listing.vehicle_type || null,
          rent_type: Array.isArray(listing.purposes) ? listing.purposes[0] || null : null,
          user_agent: navigator.userAgent,
        });
      } catch {
        // tracking should not block user
      }
    }

    function renderPhotos(listing) {
      const photos = Array.isArray(listing.photos) ? listing.photos.filter(Boolean).slice(0, 4) : [];

      return `
        <div class="photo-grid">
          ${[0, 1, 2, 3].map((index) => {
            const url = photos[index] ? photoUrl(photos[index]) : '';
            return `
              <button class="photo-box photo-open" type="button" data-listing-id="${esc(listing.id)}" data-photo="${esc(url)}">
                ${url ? `<img src="${esc(url)}" alt="${esc(listing.vehicle_model || listing.vehicle_type || 'Vehicle')}" loading="lazy" />` : `<span>📷</span>`}
              </button>
            `;
          }).join('')}
        </div>
      `;
    }

    function renderListingCard(listing) {
      const cityName = getCityName(listing);
      const purposes = Array.isArray(listing.purposes) ? listing.purposes.filter(Boolean) : [];
      const callPhone = normalizePhone(listing.owner_phone);
      const whatsappPhone = normalizePhone(listing.owner_whatsapp || listing.owner_phone);
      const detailUrl = getDetailUrl(listing);

      return `
        <article class="listing-card" data-listing-id="${esc(listing.id)}">
          ${renderPhotos(listing)}

          <div class="card-body">
            <div class="title-row">
              <div>
                <h3>${esc(listing.vehicle_model || listing.vehicle_type || 'Rent Vehicle')}</h3>
                <p>${esc(listing.vehicle_type || 'Vehicle')} in ${esc(cityName)}</p>
              </div>
              ${listing.is_verified ? `<span class="verified">✓ Verified</span>` : ''}
            </div>

            <div class="meta-grid">
              <span>📍 ${esc(cityName)}</span>
              <span>💺 ${esc(listing.seats || '-')} seats</span>
              <span>💰 ${esc(listing.price_text || 'Contact owner')}</span>
              <span>👤 ${esc(listing.owner_name || 'Owner')}</span>
            </div>

            <div class="chips">
              ${
                purposes.length
                  ? purposes.map((item) => `<span>${esc(item)}</span>`).join('')
                  : `<span>Rent</span>`
              }
            </div>

            ${listing.description ? `<p class="desc">${esc(listing.description).slice(0, 140)}</p>` : ''}

            <div class="action-row">
              ${
                callPhone
                  ? `<a class="btn btn-call contact-click" data-listing-id="${esc(listing.id)}" data-event="call_click" href="tel:+${esc(callPhone)}">📞 Call</a>`
                  : ''
              }

              ${
                whatsappPhone
                  ? `<a class="btn btn-wa contact-click" data-listing-id="${esc(listing.id)}" data-event="whatsapp_click" target="_blank" rel="noopener noreferrer" href="https://wa.me/${esc(whatsappPhone)}?text=${encodeURIComponent('Hi, I saw your rent vehicle listing on SoniaBuddy. Is it available?')}">💬 WhatsApp</a>`
                  : ''
              }

              <a class="btn btn-outline details-click" data-listing-id="${esc(listing.id)}" href="${esc(detailUrl)}">View Details</a>

              <button class="btn btn-report report-btn" type="button" data-listing-id="${esc(listing.id)}">
                🚩 Report
              </button>
            </div>
          </div>
        </article>
      `;
    }

    function filterListings() {
      const cityText = String(document.getElementById('city-input')?.value || '').toLowerCase().trim();
      const vehicle = String(document.getElementById('vehicle-select')?.value || '').toLowerCase().trim();
      const purpose = String(document.getElementById('purpose-select')?.value || '').toLowerCase().trim();

      return listings.filter((listing) => {
        const cityName = getCityName(listing).toLowerCase();
        const vehicleType = String(listing.vehicle_type || '').toLowerCase();
        const purposes = Array.isArray(listing.purposes)
          ? listing.purposes.map((item) => String(item).toLowerCase())
          : [];

        const cityOk = !cityText || cityName.includes(cityText);
        const vehicleOk = !vehicle || vehicleType.includes(vehicle);
        const purposeOk = !purpose || purposes.some((item) => item.includes(purpose));

        return cityOk && vehicleOk && purposeOk;
      });
    }

    function renderListings() {
      const loader = document.getElementById('loader');
      const grid = document.getElementById('listings-grid');

      if (loader) loader.classList.add('hidden');
      if (!grid) return;

      const rows = filterListings();

      if (!rows.length) {
        grid.innerHTML = `
          <div class="notice-card">
            <strong>No rent vehicles found.</strong>
            <p>Try another city or vehicle type.</p>
          </div>
        `;
        return;
      }

      grid.innerHTML = rows.map(renderListingCard).join('');
    }

    async function loadListings() {
      hideMessage();

      const loader = document.getElementById('loader');
      if (loader) {
        loader.textContent = 'Loading listings...';
        loader.classList.remove('hidden');
      }

      const { data, error } = await supabase
        .from('rent_listings')
        .select(`
          id,
          owner_name,
          owner_phone,
          owner_whatsapp,
          reg_number,
          vehicle_type,
          vehicle_model,
          seats,
          purposes,
          base_city_id,
          service_city_ids,
          price_text,
          photos,
          description,
          status,
          created_at,
          updated_at,
          is_verified,
          rent_cities:base_city_id (
            id,
            name_en,
            name_bn,
            district_en,
            district_bn
          )
        `)
        .eq('status', 'active')
        .order('updated_at', { ascending: false })
        .limit(200);

      if (error) {
        if (loader) loader.classList.add('hidden');
        showMessage(error.message, 'error');
        return;
      }

      listings = Array.isArray(data) ? data : [];
      renderListings();

      listings.slice(0, 20).forEach((listing) => {
        trackEvent(listing, 'listing_view');
      });
    }

    function openReportModal(listingId) {
      const modal = document.getElementById('report-modal');
      const input = document.getElementById('report-listing-id');

      if (input) input.value = listingId;
      if (modal) modal.classList.remove('hidden');
    }

    function closeReportModal() {
      const modal = document.getElementById('report-modal');
      const form = document.getElementById('report-form');

      if (modal) modal.classList.add('hidden');
      if (form) form.reset();
    }

    async function submitReport(event) {
      event.preventDefault();

      const listingId = document.getElementById('report-listing-id')?.value || '';
      const reason = document.getElementById('report-reason')?.value || '';
      const phone = document.getElementById('report-phone')?.value || '';
      const message = document.getElementById('report-message-text')?.value || '';

      if (!listingId || !reason) {
        showMessage('Please select report reason.', 'error');
        return;
      }

      showMessage('Submitting report...', 'info');

      const { error } = await supabase.from('rent_listing_reports').insert({
        listing_id: listingId,
        reason,
        reporter_phone: phone || null,
        message: message || null,
        status: 'pending',
      });

      if (error) {
        showMessage(error.message, 'error');
        return;
      }

      showMessage('Report submitted. Admin will review it.', 'success');
      closeReportModal();
    }

    document.addEventListener('DOMContentLoaded', () => {
      document.getElementById('search-btn')?.addEventListener('click', renderListings);

      document.getElementById('city-input')?.addEventListener('input', renderListings);
      document.getElementById('vehicle-select')?.addEventListener('change', renderListings);
      document.getElementById('purpose-select')?.addEventListener('change', renderListings);

      document.querySelectorAll('.vehicle-chip').forEach((btn) => {
        btn.addEventListener('click', () => {
          const vehicle = btn.dataset.vehicle || '';
          const select = document.getElementById('vehicle-select');
          if (select) select.value = vehicle;
          renderListings();
        });
      });

      document.getElementById('close-report')?.addEventListener('click', closeReportModal);
      document.getElementById('report-modal')?.addEventListener('click', (event) => {
        if (event.target?.id === 'report-modal') closeReportModal();
      });
      document.getElementById('report-form')?.addEventListener('submit', submitReport);

      document.addEventListener('click', (event) => {
        const target = event.target;

        const reportBtn = target.closest('.report-btn');
        if (reportBtn) {
          openReportModal(reportBtn.dataset.listingId || '');
          return;
        }

        const photoBtn = target.closest('.photo-open');
        if (photoBtn) {
          const listing = listings.find((item) => item.id === photoBtn.dataset.listingId);
          const url = photoBtn.dataset.photo;

          if (listing) trackEvent(listing, 'photo_open');
          if (url) window.open(url, '_blank', 'noopener,noreferrer');
          return;
        }

        const contactBtn = target.closest('.contact-click');
        if (contactBtn) {
          const listing = listings.find((item) => item.id === contactBtn.dataset.listingId);
          const eventType = contactBtn.dataset.event || 'contact_click';
          if (listing) trackEvent(listing, eventType);
          return;
        }

        const detailsBtn = target.closest('.details-click');
        if (detailsBtn) {
          const listing = listings.find((item) => item.id === detailsBtn.dataset.listingId);
          if (listing) trackEvent(listing, 'view_details_click');
        }
      });

      loadListings();
    });
  </script>

  <style>
    .rent-page {
      min-height: 100vh;
      padding: 2rem 1rem 4rem;
      background:
        radial-gradient(circle at top left, rgba(255, 107, 0, 0.16), transparent 30%),
        linear-gradient(135deg, #0b0628 0%, #13084a 55%, #1e103f 100%);
      color: white;
    }

    .rent-container {
      max-width: 1120px;
      margin: 0 auto;
    }

    .hero {
      text-align: center;
      margin-bottom: 1.25rem;
    }

    .eyebrow {
      margin: 0 0 0.35rem;
      color: #ff8a00;
      font-size: 0.8rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .hero h1 {
      margin: 0 0 0.55rem;
      font-size: clamp(1.9rem, 5vw, 3rem);
      line-height: 1.04;
    }

    .hero p {
      margin: 0 auto;
      max-width: 650px;
      color: rgba(255, 255, 255, 0.72);
      line-height: 1.5;
    }

    .search-card {
      display: grid;
      grid-template-columns: 1fr 0.75fr 0.75fr auto;
      gap: 0.75rem;
      align-items: end;
      padding: 1rem;
      border-radius: 1.1rem;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.14);
      margin-bottom: 1rem;
    }

    .field {
      display: grid;
      gap: 0.35rem;
    }

    .field label {
      color: rgba(255, 255, 255, 0.75);
      font-size: 0.82rem;
      font-weight: 900;
    }

    .field input,
    .field select {
      width: 100%;
      min-height: 44px;
      border: 1px solid rgba(255, 255, 255, 0.18);
      border-radius: 0.8rem;
      background: rgba(255, 255, 255, 0.09);
      color: white;
      padding: 0.72rem 0.85rem;
      font: inherit;
      box-sizing: border-box;
    }

    .field option {
      color: #111827;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 42px;
      padding: 0.65rem 0.9rem;
      border-radius: 0.8rem;
      border: 0;
      font-weight: 900;
      text-decoration: none;
      cursor: pointer;
      font-size: 0.88rem;
      white-space: nowrap;
    }

    .btn-primary,
    .btn-call {
      color: white;
      background: linear-gradient(135deg, #ff6b00, #ff8a00);
    }

    .btn-wa {
      color: white;
      background: linear-gradient(135deg, #16a34a, #22c55e);
    }

    .btn-outline {
      color: white;
      background: rgba(255, 255, 255, 0.07);
      border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .btn-report,
    .btn-danger {
      color: #fecaca;
      background: rgba(239, 68, 68, 0.16);
      border: 1px solid rgba(239, 68, 68, 0.34);
    }

    .quick-links {
      display: flex;
      gap: 0.55rem;
      flex-wrap: wrap;
      margin-bottom: 1.25rem;
    }

    .chip {
      border: 1px solid rgba(255, 255, 255, 0.16);
      border-radius: 999px;
      padding: 0.55rem 0.8rem;
      background: rgba(255, 255, 255, 0.07);
      color: white;
      font-weight: 900;
      cursor: pointer;
    }

    .top-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.8rem;
      margin-bottom: 1rem;
    }

    .top-row h2 {
      margin: 0;
      font-size: 1.25rem;
    }

    .notice-card,
    .message,
    .listing-card,
    .modal-card {
      border-radius: 1rem;
      border: 1px solid rgba(255, 255, 255, 0.14);
      background: rgba(255, 255, 255, 0.07);
    }

    .notice-card {
      padding: 1rem;
      color: rgba(255, 255, 255, 0.82);
    }

    .message {
      padding: 0.9rem 1rem;
      margin-bottom: 1rem;
      font-weight: 900;
    }

    .message.info {
      color: #93c5fd;
      background: rgba(59, 130, 246, 0.12);
      border-color: rgba(59, 130, 246, 0.3);
    }

    .message.success {
      color: #86efac;
      background: rgba(34, 197, 94, 0.12);
      border-color: rgba(34, 197, 94, 0.3);
    }

    .message.error {
      color: #fca5a5;
      background: rgba(239, 68, 68, 0.12);
      border-color: rgba(239, 68, 68, 0.3);
    }

    .hidden {
      display: none !important;
    }

    .listings-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .listing-card {
      overflow: hidden;
    }

    .photo-grid {
      display: grid;
      grid-template-columns: 1.4fr 0.8fr;
      grid-template-rows: repeat(2, 120px);
      gap: 0.35rem;
      padding: 0.55rem;
    }

    .photo-box {
      border: 0;
      padding: 0;
      border-radius: 0.75rem;
      overflow: hidden;
      background: rgba(255, 255, 255, 0.07);
      color: rgba(255, 255, 255, 0.5);
      cursor: pointer;
    }

    .photo-box:first-child {
      grid-row: span 2;
    }

    .photo-box img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .card-body {
      padding: 0.9rem;
    }

    .title-row {
      display: flex;
      justify-content: space-between;
      gap: 0.7rem;
      align-items: flex-start;
      margin-bottom: 0.7rem;
    }

    .title-row h3 {
      margin: 0 0 0.25rem;
      font-size: 1.05rem;
    }

    .title-row p {
      margin: 0;
      color: rgba(255, 255, 255, 0.65);
      font-size: 0.86rem;
    }

    .verified {
      display: inline-flex;
      border-radius: 999px;
      padding: 0.28rem 0.55rem;
      background: rgba(59, 130, 246, 0.16);
      color: #93c5fd;
      font-size: 0.72rem;
      font-weight: 900;
      white-space: nowrap;
    }

    .meta-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.45rem;
      margin-bottom: 0.7rem;
    }

    .meta-grid span {
      padding: 0.55rem;
      border-radius: 0.75rem;
      background: rgba(255, 255, 255, 0.06);
      color: rgba(255, 255, 255, 0.75);
      font-size: 0.82rem;
    }

    .chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      margin-bottom: 0.65rem;
    }

    .chips span {
      display: inline-flex;
      border-radius: 999px;
      padding: 0.3rem 0.55rem;
      background: rgba(255, 255, 255, 0.08);
      color: rgba(255, 255, 255, 0.78);
      font-size: 0.75rem;
      font-weight: 900;
    }

    .desc {
      margin: 0 0 0.8rem;
      color: rgba(255, 255, 255, 0.68);
      font-size: 0.86rem;
      line-height: 1.45;
    }

    .action-row {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.5rem;
    }

    .modal {
      position: fixed;
      inset: 0;
      z-index: 1000;
      padding: 1rem;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(0, 0, 0, 0.64);
    }

    .modal-card {
      width: min(520px, 100%);
      padding: 1rem;
      color: white;
      background: #120a35;
    }

    .modal-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 0.9rem;
    }

    .modal-head h2 {
      margin: 0;
      font-size: 1.2rem;
    }

    .modal-head button {
      width: 34px;
      height: 34px;
      border: 0;
      border-radius: 999px;
      cursor: pointer;
      color: white;
      background: rgba(255, 255, 255, 0.1);
      font-size: 1.4rem;
      line-height: 1;
    }

    .report-form {
      display: grid;
      gap: 0.75rem;
    }

    .report-form label {
      display: grid;
      gap: 0.35rem;
      color: rgba(255, 255, 255, 0.75);
      font-size: 0.85rem;
      font-weight: 900;
    }

    .report-form input,
    .report-form select,
    .report-form textarea {
      width: 100%;
      border: 1px solid rgba(255, 255, 255, 0.18);
      border-radius: 0.8rem;
      background: rgba(255, 255, 255, 0.08);
      color: white;
      padding: 0.75rem 0.85rem;
      font: inherit;
      box-sizing: border-box;
    }

    .report-form option {
