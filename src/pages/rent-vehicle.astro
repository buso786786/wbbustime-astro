  <script define:vars={{ listingsForClient, citiesForClient }}>
    window.rentListingsData = listingsForClient;
    window.rentCitiesData = citiesForClient;
  </script>

  <script>
    import { supabase } from "../lib/supabase";
    const listings = Array.isArray(window.rentListingsData) ? window.rentListingsData : [];
    const cities = Array.isArray(window.rentCitiesData) ? window.rentCitiesData : [];

    const params = new URLSearchParams(window.location.search);
    const tab = params.get("tab") || "find";
    const typeParam = params.get("type") || "";

    const state = {
      mainCity: null,
      nearbyCities: [],
      baseCity: null,
      serviceCities: [],
      vehicleType: "",
      purpose: "",
    };

    const selectorIdMap = {
      mainCity: {
        search: "main-city-search",
        dropdown: "main-city-dropdown",
        selected: "main-city-selected",
      },
      nearbyCities: {
        search: "nearby-cities-search",
        dropdown: "nearby-cities-dropdown",
        selected: "nearby-cities-selected",
      },
      baseCity: {
        search: "base-city-search",
        dropdown: "base-city-dropdown",
        selected: "base-city-selected",
      },
      serviceCities: {
        search: "service-cities-search",
        dropdown: "service-cities-dropdown",
        selected: "service-cities-selected",
      },
    };

    const typeToVehicle = {
      car: "Car",
      bus: "Bus",
      "wedding-bus": "Bus",
      toto: "Toto",
      auto: "Auto",
      pickup: "Pickup",
      ambulance: "Ambulance",
      "tour-car": "Car",
      "school-bus": "Bus",
    };

    const typeToPurpose = {
      "wedding-bus": "Wedding",
      "tour-car": "Tour",
      "school-bus": "School/Office",
      ambulance: "Emergency",
    };

    if (typeParam && typeToVehicle[typeParam]) {
      state.vehicleType = typeToVehicle[typeParam];
    }

    if (typeParam && typeToPurpose[typeParam]) {
      state.purpose = typeToPurpose[typeParam];
    }

    function esc(value) {
      return String(value || "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function onlyDigits(value) {
      return String(value || "").replace(/\D/g, "");
    }

    function getDisplayName(city) {
      if (!city) return "";
      return city.name || city.name_en || city.name_bn || "";
    }

    function includesText(value, term) {
      return String(value || "").toLowerCase().includes(term);
    }

    function cityMatchesSearch(city, searchTerm) {
      const term = String(searchTerm || "").trim().toLowerCase();
      if (!term) return true;

      return (
        includesText(city.name, term) ||
        includesText(city.name_en, term) ||
        includesText(city.name_bn, term) ||
        includesText(city.district, term) ||
        includesText(city.search_keywords_en, term) ||
        includesText(city.search_keywords_bn, term)
      );
    }

    function getSelectedForType(type) {
      if (type === "mainCity") return state.mainCity ? [state.mainCity] : [];
      if (type === "nearbyCities") return state.nearbyCities;
      if (type === "baseCity") return state.baseCity ? [state.baseCity] : [];
      if (type === "serviceCities") return state.serviceCities;
      return [];
    }

    function filterCities(searchTerm, type) {
      let selectedIds = getSelectedForType(type).map((city) => city.id);

if (type === "nearbyCities" && state.mainCity) {
  selectedIds.push(state.mainCity.id);
}

if (type === "serviceCities" && state.baseCity) {
  selectedIds.push(state.baseCity.id);
}

      return cities
        .filter((city) => city && city.id)
        .filter((city) => !selectedIds.includes(city.id))
        .filter((city) => cityMatchesSearch(city, searchTerm))
        .slice(0, 30);
    }

    function renderDropdown(filteredCities, dropdown, selectorType) {
      dropdown.innerHTML = "";

      if (!filteredCities.length) {
        dropdown.innerHTML = `<div class="dropdown-no-results">No cities found</div>`;
        return;
      }

      filteredCities.forEach((city) => {
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "dropdown-item";
        btn.dataset.cityId = city.id;
        btn.dataset.selectorType = selectorType;

        btn.innerHTML = `
          <span class="city-name">${esc(getDisplayName(city))}</span>
          ${city.district ? `<span class="city-district">${esc(city.district)}</span>` : ""}
        `;

        dropdown.appendChild(btn);
      });
    }

    function closeDropdown(type) {
      const ids = selectorIdMap[type];
      const dropdown = document.getElementById(ids.dropdown);
      if (dropdown) dropdown.classList.add("hidden");
    }

    function clearSearch(type) {
  const ids = selectorIdMap[type];
  const input = document.getElementById(ids.search);

  if (input) {
    input.value = "";
    input.blur();
  }
}

    function updateSelectedDisplay(type) {
      const ids = selectorIdMap[type];
      const container = document.getElementById(ids.selected);
      if (!container) return;

      const selectedCities = getSelectedForType(type);
      container.innerHTML = "";

      if (!selectedCities.length) {
        container.innerHTML = `<div class="no-selection">No city selected</div>`;
        return;
      }

      selectedCities.forEach((city) => {
        const tag = document.createElement("span");
        tag.className = "city-tag";
        tag.innerHTML = `
          <span>${esc(getDisplayName(city))}</span>
          <button type="button" class="remove-btn" data-city-id="${city.id}" data-type="${type}" aria-label="Remove city">×</button>
        `;
        container.appendChild(tag);
      });
    }

    function refreshCityDisplays() {
      updateSelectedDisplay("mainCity");
      updateSelectedDisplay("nearbyCities");
      updateSelectedDisplay("baseCity");
      updateSelectedDisplay("serviceCities");
      updateSearchButton();
      renderListings();
    }

    function handleCitySelection(cityId, selectorType) {
      const city = cities.find((c) => c.id === cityId);
      if (!city) return;

      if (selectorType === "mainCity") state.mainCity = city;
      if (selectorType === "baseCity") state.baseCity = city;

      if (selectorType === "nearbyCities") {
        if (state.nearbyCities.some((c) => c.id === city.id)) return;
        if (state.nearbyCities.length >= 3) {
          alert("Maximum 3 nearby cities allowed");
          return;
        }
        state.nearbyCities.push(city);
      }

      if (selectorType === "serviceCities") {
        if (state.serviceCities.some((c) => c.id === city.id)) return;
        if (state.serviceCities.length >= 3) {
          alert("Maximum 3 service cities allowed");
          return;
        }
        state.serviceCities.push(city);
      }

      clearSearch(selectorType);
      closeDropdown(selectorType);
      refreshCityDisplays();
    }

    function removeSelected(cityId, type) {
      if (type === "mainCity") state.mainCity = null;
      if (type === "baseCity") state.baseCity = null;
      if (type === "nearbyCities") {
        state.nearbyCities = state.nearbyCities.filter((c) => c.id !== cityId);
      }
      if (type === "serviceCities") {
        state.serviceCities = state.serviceCities.filter((c) => c.id !== cityId);
      }

      refreshCityDisplays();
    }

    function setupSelector(type) {
      const ids = selectorIdMap[type];
      const searchInput = document.getElementById(ids.search);
      const dropdown = document.getElementById(ids.dropdown);

      if (!searchInput || !dropdown) return;

      function showFiltered() {
        const filtered = filterCities(searchInput.value, type);
        renderDropdown(filtered, dropdown, type);
        dropdown.classList.remove("hidden");
      }

      searchInput.addEventListener("focus", showFiltered);
searchInput.addEventListener("click", showFiltered);
searchInput.addEventListener("input", showFiltered);

searchInput.addEventListener("keydown", (event) => {
  if (event.key === "Escape") {
    dropdown.classList.add("hidden");
    searchInput.blur();
  }
});
    }

    function updateSearchButton() {
      const btn = document.getElementById("rent-search-btn");
      if (!btn) return;

      const hasCity = Boolean(state.mainCity);
      btn.disabled = !hasCity;
      btn.textContent = hasCity ? "🔍 Search rentals" : "🔍 Select a city to search";
    }

    function whatsappNumber(listing) {
      const raw = onlyDigits(listing.owner_whatsapp || listing.owner_phone || "");
      if (raw.length === 10) return `91${raw}`;
      return raw;
    }

    function listingMatches(listing) {
      const cityIds = [
        state.mainCity?.id,
        ...state.nearbyCities.map((city) => city.id),
      ].filter(Boolean);

      if (cityIds.length > 0) {
        const serviceIds = Array.isArray(listing.service_city_ids)
          ? listing.service_city_ids
          : [];

        const cityMatch =
          cityIds.includes(listing.base_city_id) ||
          serviceIds.some((id) => cityIds.includes(id));

        if (!cityMatch) return false;
      }

      if (state.vehicleType && listing.vehicle_type !== state.vehicleType) {
        return false;
      }

      if (state.purpose) {
        const purposes = Array.isArray(listing.purposes) ? listing.purposes : [];
        if (!purposes.includes(state.purpose)) return false;
      }

      return true;
    }

