function normalizeLangValue(value) {
  const clean = String(value || "").trim().toLowerCase();
  if (clean === "bn" || clean === "bengali" || clean === "bangla" || clean === "বাংলা") return "bn";
  if (clean === "en" || clean === "english") return "en";
  return "";
}

function readRentLang() {
  const fromUrl = normalizeLangValue(new URLSearchParams(window.location.search).get("lang"));
  if (fromUrl) return fromUrl;

  const keys = [
    "soniabuddy_rent_lang_v1",
    "soniabuddy_lang",
    "soniabuddy_language",
    "site_lang",
    "site-language",
    "language",
    "lang",
    "wbbus_language",
    "wbbustime_language"
  ];

  for (const key of keys) {
    const value = normalizeLangValue(localStorage.getItem(key));
    if (value) return value;
  }

  return "en";
}

let rentLang = readRentLang();

function setRentLang(nextLang) {
  const clean = normalizeLangValue(nextLang) || "en";
  rentLang = clean;
  localStorage.setItem(RENT_LANG_KEY, rentLang);
  document.documentElement.lang = rentLang === "bn" ? "bn" : "en";
  applyRentLanguage();
refreshCityDisplays();
updateSearchButton();
}

function rentT(text) {
  const key = String(text || "").trim();
  return rentLang === "bn" ? (rentBnText[key] || key) : key;
}

function rentLabel(value) {
  return rentT(String(value || "").trim());
}

function applyRentLanguage() {
  document.documentElement.lang = rentLang === "bn" ? "bn" : "en";

  const textSelectors = [
    ".rent-page h1",
    ".rent-page h2",
    ".rent-page h3",
    ".rent-page h4",
    ".rent-page label:not(.checkbox-label)",
    ".rent-page .checkbox-label span",
    ".rent-page .rent-tab",
    ".rent-page .btn",
    ".rent-page .field-note",
    ".rent-page .trust-card p",
    ".rent-page .owner-cta-card p",
    ".rent-page .create-notice-card p",
    ".rent-page .membership-price",
    ".rent-page .membership-desc",
    ".rent-page .login-required-card p",
    ".rent-page .clear-filter-btn",
    ".rent-page .rent-chip",
    ".rent-page .no-selection"
  ].join(",");

  document.querySelectorAll(textSelectors).forEach((el) => {
    if (!el.dataset.enText) {
      el.dataset.enText = String(el.textContent || "").trim();
    }

    const enText = el.dataset.enText;
    el.textContent = rentT(enText);
  });

  document.querySelectorAll("input[placeholder], textarea[placeholder]").forEach((el) => {
    if (!el.dataset.enPlaceholder) {
      el.dataset.enPlaceholder = el.getAttribute("placeholder") || "";
    }

    const enPlaceholder = el.dataset.enPlaceholder;
    el.setAttribute("placeholder", rentT(enPlaceholder));
  });

  const resultLabel = document.getElementById("result-label");
  if (resultLabel) resultLabel.textContent = rentT("listings");

  updateSearchButton();
}

