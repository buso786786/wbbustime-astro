function normalizePhone10(value) {
  const digits = String(value || "").replace(/\D/g, "");

  if (digits.length === 12 && digits.startsWith("91")) {
    return digits.slice(2);
  }

  if (digits.length === 11 && digits.startsWith("0")) {
    return digits.slice(1);
  }

  return digits;
}

function normalizeRegNumber(value) {
  return String(value || "").replace(/[\s-]/g, "").toUpperCase();
}

function getInputValue(id) {
  const el = document.getElementById(id);
  return el ? String(el.value || "").trim() : "";
}

function setInputValue(id, value) {
  const el = document.getElementById(id);
  if (el) el.value = value || "";
}

function isChecked(id) {
  const el = document.getElementById(id);
  return Boolean(el && el.checked);
}

function setCheckboxValue(id, checked) {
  const el = document.getElementById(id);
  if (el) el.checked = Boolean(checked);
}

function getActiveChipValue(groupId) {
  const active = document.querySelector(`#${groupId} .rent-chip.active`);
  return active ? String(active.dataset.value || active.textContent || "").trim() : "";
}

function getActiveChipValues(groupId) {
  return Array.from(document.querySelectorAll(`#${groupId} .rent-chip.active`))
    .map((chip) => String(chip.dataset.value || chip.textContent || "").trim())
    .filter(Boolean);
}

function setChipActive(groupId, values) {
  const valueSet = new Set(Array.isArray(values) ? values : [values].filter(Boolean));

  document.querySelectorAll(`#${groupId} .rent-chip`).forEach((chip) => {
    const value = String(chip.dataset.value || chip.textContent || "").trim();
    chip.classList.toggle("active", valueSet.has(value));
  });
}

function showSubmitMessage(message, type = "info") {
  const box = document.getElementById("submit-message");
  if (!box) return;

  box.textContent = message;
  box.classList.remove("hidden", "success", "error", "info");
  box.classList.add(type);
}

function collectCreateListingDraft() {
  return {
    ownerName: getInputValue("owner-name"),
    phone: getInputValue("owner-phone"),
    whatsapp: getInputValue("owner-whatsapp"),
    vehicleType: getActiveChipValue("create-vehicle-chips"),
