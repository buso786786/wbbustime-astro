---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Rent with Driver in West Bengal"
  description="Find car, bus, toto, pickup van and ambulance rental with driver in West Bengal."
>
  <div class="debug-label">PAGE: RENT VEHICLE</div>

  <section class="rent-page">
    <div class="container rent-container">
      <!-- Page header -->
      <div class="rent-hero-card">
        <div class="rent-header-content">
          <div class="rent-icon">🚗</div>
          <div>
            <h1>Rent with Driver</h1>
            <p>Car, Bus, Toto, Pickup Van, Ambulance rental in West Bengal</p>
          </div>
        </div>
        <a href="/owner/rent-dashboard" class="btn btn-outline btn-small">Dashboard</a>
      </div>

      <!-- Tabs -->
      <div class="rent-actions">
        <a href="/rent-vehicle?tab=find" id="find-tab" class="rent-tab active">Find Rent</a>
        <a href="/rent-vehicle?tab=register" id="create-tab" class="rent-tab">Create Listing</a>
      </div>

      <!-- Find Rent Section -->
      <section id="find-section" class="rent-panel">
        <div class="form-section-card">
          <h3 class="form-section-title">Search Rentals</h3>
          
          <div class="form-group">
            <label for="rent-city">Where do you need vehicle?</label>
            <select id="rent-city">
              <option value="">Select city</option>
              <option value="kolkata">Kolkata</option>
              <option value="durgapur">Durgapur</option>
              <option value="asansol">Asansol</option>
              <option value="siliguri">Siliguri</option>
              <option value="bardhaman">Bardhaman</option>
            </select>
          </div>

          <div class="form-group">
            <label for="nearby-city">Nearby cities (max 3)</label>
            <input id="nearby-city" type="text" placeholder="Add nearby city" />
          </div>

          <div class="form-group">
            <label>Vehicle type</label>
            <div class="rent-chip-row" id="vehicle-chips">
              <button type="button" class="rent-chip" data-type="car">Car</button>
              <button type="button" class="rent-chip" data-type="bus">Bus</button>
              <button type="button" class="rent-chip" data-type="toto">Toto</button>
              <button type="button" class="rent-chip" data-type="auto">Auto</button>
              <button type="button" class="rent-chip" data-type="pickup">Pickup</button>
              <button type="button" class="rent-chip" data-type="ambulance">Ambulance</button>
            </div>
          </div>

          <div class="form-group">
            <label>Purpose</label>
            <div class="rent-chip-row" id="purpose-chips">
              <button type="button" class="rent-chip">Cheap Rent</button>
              <button type="button" class="rent-chip">Wedding</button>
              <button type="button" class="rent-chip">Tour</button>
              <button type="button" class="rent-chip">Local</button>
              <button type="button" class="rent-chip">School/Office</button>
              <button type="button" class="rent-chip">Emergency</button>
              <button type="button" class="rent-chip">Goods/Parcel</button>
            </div>
          </div>

          <button id="rent-search-btn" class="rent-search-btn" type="button" disabled>
            🔍 Select a city to search
          </button>
        </div>

        <h2 class="rent-section-heading">Available rentals</h2>
        
        <!-- Demo rental cards -->
        <div class="rental-cards-grid">
          <!-- Card A: Swift Dzire -->
          <div class="rental-card">
            <div class="rental-image">
              <div class="rental-placeholder">🚗</div>
            </div>
            <div class="rental-details">
              <h3>Swift Dzire with Driver</h3>
              <p class="rental-meta">Car · 4 seats · Kolkata</p>
              <p class="rental-purposes">Tour, Local</p>
              <p class="rental-price">Starting ₹2500/day</p>
              <span class="rental-badge badge-free">Free Trial</span>
            </div>
            <div class="rental-actions">
              <button class="btn btn-small btn-primary">Call Now</button>
              <button class="btn btn-small btn-outline">WhatsApp</button>
              <button class="btn btn-small btn-outline">View Details</button>
            </div>
          </div>

          <!-- Card B: Wedding Bus -->
          <div class="rental-card">
            <div class="rental-image">
              <div class="rental-placeholder">🚌</div>
            </div>
            <div class="rental-details">
              <h3>Wedding Bus Rental</h3>
              <p class="rental-meta">Bus · 40 seats · Durgapur</p>
              <p class="rental-purposes">Wedding, Tour</p>
              <p class="rental-price">Starting ₹12000/day</p>
              <span class="rental-badge badge-verified">✓ Verified</span>
            </div>
            <div class="rental-actions">
              <button class="btn btn-small btn-primary">Call Now</button>
              <button class="btn btn-small btn-outline">WhatsApp</button>
              <button class="btn btn-small btn-outline">View Details</button>
            </div>
          </div>

          <!-- Card C: Ambulance -->
          <div class="rental-card">
            <div class="rental-image">
              <div class="rental-placeholder">🚑</div>
            </div>
            <div class="rental-details">
              <h3>Ambulance Service</h3>
              <p class="rental-meta">Ambulance · Emergency · Asansol</p>
              <p class="rental-purposes">Emergency</p>
              <p class="rental-price">Call for price</p>
              <span class="rental-badge badge-free">Free Trial</span>
            </div>
            <div class="rental-actions">
              <button class="btn btn-small btn-primary">Call Now</button>
              <button class="btn btn-small btn-outline">WhatsApp</button>
              <button class="btn btn-small btn-outline">View Details</button>
            </div>
          </div>
        </div>

        <!-- Owner CTA card -->
        <div class="owner-cta-card">
          <h3>Own a vehicle?</h3>
          <p>Create a listing and get first 3 months free.</p>
          <a href="/rent-vehicle?tab=register" class="btn btn-primary">Create Listing</a>
        </div>

        <!-- Trust/info cards -->
        <div class="trust-cards">
          <div class="trust-card">
            <span class="trust-icon">🎉</span>
            <p>First 3 months free</p>
          </div>
          <div class="trust-card">
            <span class="trust-icon">🔒</span>
            <p>Public contact after approval</p>
          </div>
          <div class="trust-card">
            <span class="trust-icon">📍</span>
            <p>City-based matching</p>
          </div>
        </div>
      </section>

      <!-- Create Listing Section -->
      <section id="create-section" class="rent-panel hidden">
        <!-- Top notice card -->
        <div class="create-notice-card">
          <div class="notice-content">
            <h3>Add your vehicle listing</h3>
            <p>Add car, bus, toto, pickup van or ambulance rental details. New listings get first 3 months free.</p>
          </div>
          <a href="/owner/rent-dashboard" class="btn btn-outline btn-small">Dashboard</a>
        </div>

        <!-- Section A: Owner Contact -->
        <div class="form-section-card">
          <h3 class="form-section-title">Owner Contact</h3>
          <div class="form-row">
            <div class="form-group">
              <label for="owner-name">Owner name</label>
              <input id="owner-name" type="text" placeholder="Enter owner name" />
            </div>
            <div class="form-group">
              <label for="owner-phone">Phone</label>
              <input id="owner-phone" type="tel" placeholder="Enter phone number" />
            </div>
          </div>
          <div class="form-group">
            <label for="owner-whatsapp">WhatsApp</label>
            <input id="owner-whatsapp" type="tel" placeholder="Enter WhatsApp number" />
            <p class="field-note">+91 optional</p>
          </div>
        </div>

        <!-- Section B: Vehicle Details -->
        <div class="form-section-card">
          <h3 class="form-section-title">Vehicle Details</h3>
          <div class="form-group">
            <label>Vehicle type</label>
            <div class="rent-chip-row" id="create-vehicle-chips">
              <button type="button" class="rent-chip" data-type="car">Car</button>
              <button type="button" class="rent-chip" data-type="bus">Bus</button>
              <button type="button" class="rent-chip" data-type="toto">Toto</button>
              <button type="button" class="rent-chip" data-type="auto">Auto</button>
              <button type="button" class="rent-chip" data-type="pickup">Pickup</button>
              <button type="button" class="rent-chip" data-type="ambulance">Ambulance</button>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="vehicle-reg">Vehicle Registration Number</label>
              <input id="vehicle-reg" type="text" placeholder="WB XX XX XXXX" />
            </div>
            <div class="form-group">
              <label for="vehicle-model">Model / variant</label>
              <input id="vehicle-model" type="text" placeholder="e.g., Swift Dzire ZXI" />
            </div>
          </div>
          <div class="form-group">
            <label for="vehicle-seats">Seats</label>
            <input id="vehicle-seats" type="number" placeholder="Enter seating capacity" />
          </div>
        </div>

        <!-- Section C: Service Area -->
        <div class="form-section-card">
          <h3 class="form-section-title">Service Area</h3>
          <div class="form-group">
            <label for="base-city">City</label>
            <input id="base-city" type="text" placeholder="Enter base city" />
          </div>
          <div class="form-group">
            <label for="service-cities">Nearby service cities (max 3)</label>
            <input id="service-cities" type="text" placeholder="Add service cities" />
          </div>
        </div>

        <!-- Section D: Rent Details -->
        <div class="form-section-card">
          <h3 class="form-section-title">Rent Details</h3>
          <div class="form-group">
            <label>Rent type</label>
            <div class="rent-chip-row" id="rent-type-chips">
              <button type="button" class="rent-chip">Cheap Rent</button>
              <button type="button" class="rent-chip">Wedding</button>
              <button type="button" class="rent-chip">Tour</button>
              <button type="button" class="rent-chip">Local</button>
              <button type="button" class="rent-chip">School/Office</button>
              <button type="button" class="rent-chip">Emergency</button>
              <button type="button" class="rent-chip">Goods/Parcel</button>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="rent-price">Price</label>
              <input id="rent-price" type="text" placeholder="e.g., ₹2500/day" />
            </div>
          </div>
          <div class="form-group">
            <label for="rent-description">Description</label>
            <textarea id="rent-description" rows="3" placeholder="Describe your vehicle and services..."></textarea>
          </div>
        </div>

        <!-- Section E: Photos -->
        <div class="form-section-card">
          <h3 class="form-section-title">Photos (max 4)</h3>
          <div class="photo-upload-grid">
            <div class="photo-upload-box">
              <span class="photo-placeholder">+</span>
            </div>
            <div class="photo-upload-box">
              <span class="photo-placeholder">+</span>
            </div>
            <div class="photo-upload-box">
              <span class="photo-placeholder">+</span>
            </div>
            <div class="photo-upload-box">
              <span class="photo-placeholder">+</span>
            </div>
          </div>
        </div>

        <!-- Section F: Consent + Login -->
        <div class="form-section-card">
          <div class="form-group">
            <label class="checkbox-label">
              <input type="checkbox" id="consent-checkbox" />
              <span>I confirm the information above is accurate and consent to making my contact details visible to users searching for rental vehicles.</span>
            </label>
          </div>

          <div class="login-required-card">
            <h4>Login required before submit</h4>
            <p>Please login with Google first, then submit your vehicle listing.</p>
            <button class="btn btn-primary btn-small btn-disabled">Login with Google</button>
          </div>

          <button class="rent-search-btn btn-disabled" type="button" disabled>
            Submit Listing
          </button>
        </div>

        <!-- Membership preview -->
        <div class="membership-preview">
          <h3 class="form-section-title">After free trial</h3>
          <div class="membership-cards">
            <div class="membership-card">
              <h4>Small Vehicle Plan</h4>
              <p class="membership-price">₹199 / 3 months</p>
              <p class="membership-desc">Toto and Auto visibility</p>
            </div>
            <div class="membership-card">
              <h4>Car / Pickup / Ambulance Plan</h4>
              <p class="membership-price">₹1000 / 3 months</p>
              <p class="membership-desc">Sponsored visibility</p>
            </div>
            <div class="membership-card">
              <h4>Bus Plan</h4>
              <p class="membership-price">₹1500 / 3 months</p>
              <p class="membership-desc">Bus, Wedding Bus, Tour Bus and School Bus visibility</p>
            </div>
          </div>
          <div class="verified-badge-card">
            <h4>Verified Badge</h4>
            <p class="membership-price">₹299 / 3 months</p>
            <p class="membership-desc">Trust badge for your listings</p>
          </div>
        </div>
      </section>
    </div>
  </section>

  <script>
    const params = new URLSearchParams(window.location.search);
    const tab = params.get("tab") || "find";
    const type = params.get("type") || "car";

    const findTab = document.getElementById("find-tab");
    const createTab = document.getElementById("create-tab");
    const findSection = document.getElementById("find-section");
    const createSection = document.getElementById("create-section");

    function showTab(activeTab) {
      const isCreate = activeTab === "create" || activeTab === "register";

      findTab?.classList.toggle("active", !isCreate);
      createTab?.classList.toggle("active", isCreate);

      findSection?.classList.toggle("hidden", isCreate);
      createSection?.classList.toggle("hidden", !isCreate);
    }

    showTab(tab);

    // Vehicle type chips highlighting based on URL parameter
    const vehicleChips = document.querySelectorAll("#vehicle-chips .rent-chip");
    const createVehicleChips = document.querySelectorAll("#create-vehicle-chips .rent-chip");

    function highlightChip(chips, type) {
      chips.forEach((chip) => {
        const chipType = chip.getAttribute("data-type");
        // Highlight exact match or nearest match
        if (chipType === type) {
          chip.classList.add("active");
        }
      });
    }

    highlightChip(vehicleChips, type);
    highlightChip(createVehicleChips, type);

    vehicleChips.forEach((chip) => {
      chip.addEventListener("click", () => {
        vehicleChips.forEach((c) => c.classList.remove("active"));
        chip.classList.add("active");
      });
    });

    createVehicleChips.forEach((chip) => {
      chip.addEventListener("click", () => {
        createVehicleChips.forEach((c) => c.classList.remove("active"));
        chip.classList.add("active");
      });
    });

    const purposeChips = document.querySelectorAll("#purpose-chips .rent-chip");
    purposeChips.forEach((chip) => {
      chip.addEventListener("click", () => {
        chip.classList.toggle("active");
      });
    });

    const rentTypeChips = document.querySelectorAll("#rent-type-chips .rent-chip");
    rentTypeChips.forEach((chip) => {
      chip.addEventListener("click", () => {
        chip.classList.toggle("active");
      });
    });

    const citySelect = document.getElementById("rent-city");
    const searchBtn = document.getElementById("rent-search-btn");

    citySelect?.addEventListener("change", () => {
      const hasCity = citySelect.value.length > 0;
      if (searchBtn) {
        searchBtn.disabled = !hasCity;
        searchBtn.textContent = hasCity ? "🔍 Search rentals" : "🔍 Select a city to search";
      }
    });
  </script>

  <style>
    .rent-page {
      background: linear-gradient(135deg, #0b0628 0%, #13084a 55%, #1e103f 100%);
      min-height: 100vh;
      padding: 2rem 0 4rem;
      color: white;
    }

    .rent-container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 1rem;
    }

    .rent-hero-card {
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.14);
      border-radius: 1rem;
      padding: 1.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1.5rem;
      margin-bottom: 1.5rem;
    }

    .rent-header-content {
      display: flex;
      align-items: center;
      gap: 1rem;
      flex: 1;
    }

    .rent-icon {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      background: #ff6b00;
      display: grid;
      place-items: center;
    }

    .rent-hero-card h1 {
      font-size: 1.75rem;
      margin: 0 0 0.35rem;
      color: white;
    }

    .rent-hero-card p {
      margin: 0;
      color: rgba(255, 255, 255, 0.72);
      font-size: 0.95rem;
    }

    .rent-actions {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
    }

    .rent-tab {
      text-align: center;
      text-decoration: none;
      color: white;
      border: 1px solid rgba(255, 255, 255, 0.18);
      border-radius: 999px;
      padding: 0.75rem 1.5rem;
      font-weight: 700;
      flex: 1;
    }

    .rent-tab.active {
      background: linear-gradient(135deg, #ff6b00, #ff8a00);
      border-color: #ff6b00;
    }

    .rent-panel {
      margin-bottom: 1.5rem;
    }

    .hidden {
      display: none !important;
    }

    .btn {
      padding: 0.75rem 1.5rem;
      border-radius: 0.75rem;
      font-weight: 700;
      text-decoration: none;
      display: inline-block;
      cursor: pointer;
      transition: all 0.2s;
      text-align: center;
      font-size: 0.95rem;
    }

    .btn-primary {
      background: linear-gradient(135deg, #ff6b00, #ff8a00);
      color: white;
      border: none;
    }

    .btn-primary:hover {
      background: linear-gradient(135deg, #e65a00, #ff6b00);
      transform: translateY(-2px);
    }

    .btn-outline {
      background: transparent;
      color: white;
      border: 2px solid rgba(255, 255, 255, 0.3);
    }

    .btn-outline:hover {
      background: rgba(255, 255, 255, 0.1);
      border-color: rgba(255, 255, 255, 0.5);
    }

    .btn-small {
      padding: 0.5rem 1rem;
      font-size: 0.85rem;
    }

    .btn-disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    .form-section-card {
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.14);
      border-radius: 1rem;
      padding: 1.25rem;
      margin-bottom: 1.5rem;
    }

    .form-section-title {
      margin: 0 0 1rem;
      font-size: 1.1rem;
      color: #ff8a00;
    }

    .form-group {
      margin-bottom: 1rem;
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .form-group label {
      display: block;
      font-weight: 700;
      color: white;
      margin-bottom: 0.5rem;
      font-size: 0.9rem;
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%;
      background: rgba(10, 7, 42, 0.72);
      color: white;
      border: 1px solid rgba(255, 255, 255, 0.18);
      border-radius: 0.75rem;
      padding: 0.875rem 1rem;
      font-size: 0.95rem;
      outline: none;
    }

    .form-group textarea {
      resize: vertical;
      min-height: 80px;
    }

    .form-group option {
      color: #111827;
    }

    .field-note {
      margin: 0.25rem 0 0;
      color: rgba(255, 255, 255, 0.5);
      font-size: 0.8rem;
    }

    .rent-chip-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .rent-chip {
      border: 1px solid rgba(255, 255, 255, 0.18);
      background: rgba(255, 255, 255, 0.06);
      color: white;
      border-radius: 999px;
      padding: 0.5rem 1rem;
      font-weight: 700;
      cursor: pointer;
      font-size: 0.85rem;
    }

    .rent-chip.active {
      background: linear-gradient(135deg, #ff6b00, #ff8a00);
      border-color: #ff6b00;
    }

    .rent-search-btn {
      width: 100%;
      border: 0;
      border-radius: 0.75rem;
      padding: 1rem;
      background: linear-gradient(135deg, #ff6b00, #ff8a00);
      color: white;
      font-weight: 800;
      font-size: 1rem;
      cursor: pointer;
      margin-top: 0.5rem;
    }

    .rent-search-btn:disabled {
      opacity: 0.55;
      cursor: not-allowed;
    }

    .rent-section-heading {
      margin-top: 2rem;
      margin-bottom: 1rem;
      font-size: 1.25rem;
      color: white;
    }

    /* Rental cards */
    .rental-cards-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .rental-card {
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.14);
      border-radius: 1rem;
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
    }

    .rental-image {
      width: 100%;
      height: 120px;
      border-radius: 0.75rem;
      background: rgba(255, 255, 255, 0.04);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1rem;
    }

    .rental-placeholder {
      font-size: 2.5rem;
    }

    .rental-details h3 {
      margin: 0 0 0.5rem;
      font-size: 1.1rem;
    }

    .rental-meta {
      margin: 0 0 0.5rem;
      color: rgba(255, 255, 255, 0.7);
      font-size: 0.85rem;
    }

    .rental-purposes {
      margin: 0 0 0.5rem;
      color: rgba(255, 255, 255, 0.6);
      font-size: 0.85rem;
    }

    .rental-price {
      margin: 0 0 0.75rem;
      color: #ff8a00;
      font-weight: 700;
      font-size: 1rem;
    }

    .rental-badge {
      display: inline-block;
      padding: 0.25rem 0.75rem;
      border-radius: 999px;
      font-size: 0.75rem;
      font-weight: 700;
      margin-bottom: 1rem;
    }

    .badge-free {
      background: rgba(255, 107, 0, 0.2);
      color: #ff8a00;
    }

    .badge-verified {
      background: rgba(34, 197, 94, 0.2);
      color: #22c55e;
    }

    .rental-actions {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      margin-top: auto;
    }

    .rental-actions .btn {
      width: 100%;
    }

    /* Owner CTA card */
    .owner-cta-card {
      background: linear-gradient(135deg, rgba(255, 107, 0, 0.15), rgba(255, 138, 0, 0.1));
      border: 1px solid rgba(255, 107, 0, 0.3);
      border-radius: 1rem;
      padding: 1.5rem;
      text-align: center;
      margin-bottom: 1.5rem;
    }

    .owner-cta-card h3 {
      margin: 0 0 0.5rem;
      font-size: 1.25rem;
    }

    .owner-cta-card p {
      margin: 0 0 1rem;
      color: rgba(255, 255, 255, 0.8);
    }

    /* Trust cards */
    .trust-cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }

    .trust-card {
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.14);
      border-radius: 1rem;
      padding: 1rem;
