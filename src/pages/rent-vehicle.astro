---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Rent with Driver in West Bengal"
  description="Find car, bus, toto, pickup van and ambulance rental with driver in West Bengal."
>
  <div class="debug-label">PAGE: RENT VEHICLE</div>

  <section class="rent-page">
    <div class="container rent-container">
      <div class="rent-hero-card">
        <div class="rent-header-content">
          <div class="rent-icon">🚗</div>
          <div>
            <h1>Rent with Driver</h1>
            <p>Car, Bus, Toto, Pickup Van, Ambulance rental in West Bengal</p>
          </div>
        </div>

        <div class="rent-actions">
          <a href="/rent-vehicle?tab=find" id="find-tab" class="rent-tab active">Find Rent</a>
          <a href="/rent-vehicle?tab=create" id="create-tab" class="rent-tab">Create Listing</a>
        </div>
      </div>

      <section id="find-section" class="rent-panel">
        <div class="form-group">
          <label for="rent-city">Where do you need vehicle?</label>
          <select id="rent-city">
            <option value="">Select city</option>
            <option value="kolkata">Kolkata</option>
            <option value="durgapur">Durgapur</option>
            <option value="asansol">Asansol</option>
            <option value="siliguri">Siliguri</option>
            <option value="bardhaman">Bardhaman</option>
          </select>
        </div>

        <div class="form-group">
          <label for="nearby-city">Nearby cities (max 3)</label>
          <input id="nearby-city" type="text" placeholder="Add nearby city" />
        </div>

        <div class="form-group">
          <label>Vehicle type</label>
          <div class="rent-chip-row" id="vehicle-chips">
            <button type="button" class="rent-chip" data-type="car">Car</button>
            <button type="button" class="rent-chip" data-type="bus">Bus</button>
            <button type="button" class="rent-chip" data-type="toto">Toto</button>
            <button type="button" class="rent-chip" data-type="auto">Auto</button>
            <button type="button" class="rent-chip" data-type="pickup">Pickup</button>
            <button type="button" class="rent-chip" data-type="ambulance">Ambulance</button>
          </div>
        </div>

        <div class="form-group">
          <label>Purpose</label>
          <div class="rent-chip-row" id="purpose-chips">
            <button type="button" class="rent-chip">Cheap Rent</button>
            <button type="button" class="rent-chip">Wedding</button>
            <button type="button" class="rent-chip">Tour</button>
            <button type="button" class="rent-chip">Local</button>
            <button type="button" class="rent-chip">School/Office</button>
            <button type="button" class="rent-chip">Emergency</button>
            <button type="button" class="rent-chip">Goods/Parcel</button>
          </div>
        </div>

        <button id="rent-search-btn" class="rent-search-btn" type="button" disabled>
          🔍 Select a city to search
        </button>

        <h2 class="rent-section-heading">Available rentals</h2>
        <div class="rent-empty-card">
          Select city and vehicle type to see available rentals.
        </div>
      </section>

      <section id="create-section" class="rent-panel hidden">
        <h2 class="rent-section-heading">Create Vehicle Listing</h2>

        <div class="form-row">
          <div class="form-group">
            <label for="owner-name">Owner name</label>
            <input id="owner-name" type="text" placeholder="Enter owner name" />
          </div>

          <div class="form-group">
            <label for="owner-phone">Phone number</label>
            <input id="owner-phone" type="tel" placeholder="Enter phone number" />
          </div>
        </div>

        <div class="form-group">
          <label for="owner-vehicle-type">Vehicle type</label>
          <select id="owner-vehicle-type">
            <option value="">Select vehicle type</option>
            <option value="car">Car</option>
            <option value="bus">Bus</option>
            <option value="toto">Toto</option>
            <option value="auto">Auto</option>
            <option value="pickup">Pickup Van</option>
            <option value="ambulance">Ambulance</option>
          </select>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="base-city">Base city</label>
            <input id="base-city" type="text" placeholder="Enter base city" />
          </div>

          <div class="form-group">
            <label for="service-cities">Service cities</label>
            <input id="service-cities" type="text" placeholder="Add service cities" />
          </div>
        </div>

        <div class="form-group">
          <label>Vehicle photos (up to 4)</label>
          <div class="photo-upload-grid">
            <div class="photo-upload-box">
              <span class="photo-placeholder">+</span>
            </div>
            <div class="photo-upload-box">
              <span class="photo-placeholder">+</span>
            </div>
            <div class="photo-upload-box">
              <span class="photo-placeholder">+</span>
            </div>
            <div class="photo-upload-box">
              <span class="photo-placeholder">+</span>
            </div>
          </div>
        </div>

        <div class="form-group">
          <label class="checkbox-label">
            <input type="checkbox" id="consent-checkbox" />
            <span>I consent to the terms and conditions and privacy policy for vehicle listing.</span>
          </label>
        </div>

        <button class="rent-search-btn" type="button">
          Submit listing
        </button>

        <p class="rent-note">Listing submission will be connected soon.</p>
      </section>
    </div>
  </section>

  <script>
    const params = new URLSearchParams(window.location.search);
    const tab = params.get("tab") || "find";
    const type = params.get("type") || "car";

    const findTab = document.getElementById("find-tab");
    const createTab = document.getElementById("create-tab");
    const findSection = document.getElementById("find-section");
    const createSection = document.getElementById("create-section");

    function showTab(activeTab) {
      const isCreate = activeTab === "create";

      findTab?.classList.toggle("active", !isCreate);
      createTab?.classList.toggle("active", isCreate);

      findSection?.classList.toggle("hidden", isCreate);
      createSection?.classList.toggle("hidden", !isCreate);
    }

    showTab(tab);

    const vehicleChips = document.querySelectorAll("#vehicle-chips .rent-chip");
    vehicleChips.forEach((chip) => {
      if (chip.getAttribute("data-type") === type) {
        chip.classList.add("active");
      }

      chip.addEventListener("click", () => {
        vehicleChips.forEach((c) => c.classList.remove("active"));
        chip.classList.add("active");
      });
    });

    const purposeChips = document.querySelectorAll("#purpose-chips .rent-chip");
    purposeChips.forEach((chip) => {
      chip.addEventListener("click", () => {
        chip.classList.toggle("active");
      });
    });

    const citySelect = document.getElementById("rent-city");
    const searchBtn = document.getElementById("rent-search-btn");

    citySelect?.addEventListener("change", () => {
      const hasCity = citySelect.value.length > 0;
      if (searchBtn) {
        searchBtn.disabled = !hasCity;
        searchBtn.textContent = hasCity ? "🔍 Search rentals" : "🔍 Select a city to search";
      }
    });
  </script>

  <style>
    .rent-page {
      background: linear-gradient(135deg, #0b0628 0%, #13084a 55%, #1e103f 100%);
      min-height: 100vh;
      padding: 2rem 0 4rem;
      color: white;
    }

    .rent-container {
      max-width: 960px;
      margin: 0 auto;
    }

    .rent-hero-card,
    .rent-panel {
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.14);
      border-radius: 28px;
      padding: 2rem;
      box-shadow: 0 18px 50px rgba(0, 0, 0, 0.25);
    }

    .rent-hero-card {
      display: flex;
      justify-content: space-between;
      gap: 1.5rem;
      align-items: center;
      margin-bottom: 1.5rem;
    }

    .rent-header-content {
      display: flex;
      align-items: center;
      gap: 1rem;
      flex: 1;
    }

    .rent-icon {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      background: #ff6b00;
      display: grid;
      place-items: center;
      margin-bottom: 0.8rem;
    }

    .rent-hero-card h1 {
      font-size: 2rem;
      margin: 0 0 0.35rem;
      color: white;
    }

    .rent-hero-card p {
      margin: 0;
      color: rgba(255, 255, 255, 0.72);
    }

    .rent-actions {
      display: flex;
      flex-direction: row;
      gap: 0.5rem;
      min-width: 170px;
    }

    .rent-tab {
      text-align: center;
      text-decoration: none;
      color: white;
      border: 1px solid rgba(255, 255, 255, 0.18);
      border-radius: 999px;
      padding: 0.8rem 1rem;
      font-weight: 700;
    }

    .rent-tab.active {
      background: linear-gradient(135deg, #ff6b00, #ff8a00);
      border-color: #ff6b00;
    }

    .rent-panel {
      margin-bottom: 1.5rem;
    }

    .hidden {
      display: none !important;
    }

    .form-group {
      margin-bottom: 1rem;
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .form-group label {
      display: block;
      font-weight: 700;
      color: white;
      margin-bottom: 0.55rem;
    }

    .form-group input,
    .form-group select {
      width: 100%;
      background: rgba(10, 7, 42, 0.72);
      color: white;
      border: 1px solid rgba(255, 255, 255, 0.18);
      border-radius: 999px;
      padding: 0.95rem 1rem;
      font-size: 1rem;
      outline: none;
    }

    .form-group option {
      color: #111827;
    }

    .rent-chip-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .rent-chip {
      border: 1px solid rgba(255, 255, 255, 0.18);
      background: rgba(255, 255, 255, 0.06);
      color: white;
      border-radius: 999px;
      padding: 0.55rem 1rem;
      font-weight: 700;
      cursor: pointer;
    }

    .rent-chip.active {
      background: linear-gradient(135deg, #ff6b00, #ff8a00);
      border-color: #ff6b00;
    }

    .rent-search-btn {
      width: 100%;
      border: 0;
      border-radius: 12px;
      padding: 1rem;
      background: linear-gradient(135deg, #ff6b00, #ff8a00);
      color: white;
      font-weight: 800;
      font-size: 1rem;
      cursor: pointer;
      margin-top: 0.5rem;
    }

    .rent-search-btn:disabled {
      opacity: 0.55;
      cursor: not-allowed;
    }

    .rent-section-heading {
      margin-top: 2rem;
      margin-bottom: 1rem;
      font-size: 1.25rem;
      color: white;
    }

    .rent-empty-card {
      border-radius: 18px;
      border: 1px dashed rgba(255, 255, 255, 0.2);
      padding: 1.25rem;
      color: rgba(255, 255, 255, 0.65);
      background: rgba(255, 255, 255, 0.04);
    }

    .rent-note {
      color: rgba(255, 255, 255, 0.7);
      text-align: center;
      margin-top: 0.75rem;
      font-size: 0.9rem;
    }

    .photo-upload-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0.75rem;
    }

    .photo-upload-box {
      aspect-ratio: 1;
      border: 2px dashed rgba(255, 255, 255, 0.2);
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.04);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.2s;
    }

    .photo-upload-box:hover {
      border-color: rgba(255, 107, 0, 0.4);
      background: rgba(255, 107, 0, 0.1);
    }

    .photo-placeholder {
      font-size: 2rem;
      color: rgba(255, 255, 255, 0.4);
      font-weight: 300;
    }

    .checkbox-label {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      cursor: pointer;
    }

    .checkbox-label input[type="checkbox"] {
      width: auto;
      margin-top: 0.25rem;
      flex-shrink: 0;
    }

    .checkbox-label span {
      color: rgba(255, 255, 255, 0.85);
      line-height: 1.5;
      font-size: 0.95rem;
    }

    @media (max-width: 700px) {
      .rent-hero-card {
        flex-direction: column;
        align-items: stretch;
        gap: 1rem;
      }

      .rent-header-content {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.5rem;
      }

      .rent-icon {
        width: 36px;
        height: 36px;
        font-size: 1.25rem;
        margin-bottom: 0.5rem;
      }

      .rent-hero-card h1 {
        font-size: 1.5rem;
      }

      .rent-hero-card p {
        font-size: 0.9rem;
      }

      .rent-actions {
        width: 100%;
        flex-direction: row;
      }

      .rent-tab {
        flex: 1;
        padding: 0.75rem 0.5rem;
        font-size: 0.9rem;
      }

      .rent-hero-card,
      .rent-panel {
        padding: 1.25rem;
        border-radius: 18px;
      }

      .form-row {
        grid-template-columns: 1fr;
        gap: 0.75rem;
      }

      .photo-upload-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 0.5rem;
      }

      .rent-section-heading {
        font-size: 1.1rem;
        margin-top: 1.5rem;
      }
    }
  </style>
</BaseLayout>
