---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/admin-compact.css';
---

<BaseLayout title="Rent Reports Admin - SoniaBuddy" description="Review rent listing reports." robots="noindex,nofollow">
  <div id="admin-access-cover" class="admin-access-cover"><div class="admin-access-card"><strong>Official Admin Work Only</strong><p>This area is restricted for SoniaBuddy internal admin work.</p></div></div>

  <section class="admin-page">
    <div class="admin-container">
      <div class="admin-header">
        <div><p class="eyebrow">SoniaBuddy Admin</p><h1>Rent Reports</h1><p>Review reports, resolve issues and cancel fake listings.</p></div>
        <button id="refresh-btn" class="btn btn-primary" type="button">Refresh</button>
      </div>

      <div id="auth-box" class="notice-card">Checking admin access...</div>
      <div id="message-box" class="message hidden"></div>

      <div id="filter-card" class="filter-card hidden">
        <button class="filter-btn active" type="button" data-filter="pending">Pending</button>
        <button class="filter-btn" type="button" data-filter="reviewed">Reviewed</button>
        <button class="filter-btn" type="button" data-filter="resolved">Resolved</button>
        <button class="filter-btn" type="button" data-filter="rejected">Rejected</button>
        <button class="filter-btn" type="button" data-filter="all">All</button>
        <input id="report-search-input" class="admin-search-input" type="search" placeholder="Search Gmail, phone, listing id, vehicle..." />
      </div>

      <div id="loader" class="notice-card hidden">Loading reports...</div>
      <div id="reports-grid" class="admin-dynamic-grid"></div>
    </div>
  </section>

  <script>
    import { supabase } from '../../lib/supabase';

    const ADMIN_EMAILS = ['buso786786@gmail.com', 'zisakho2024@gmail.com'];
    let currentUser = null;
    let reports = [];
    let listingMap = new Map();
    let activeFilter = 'pending';
    let searchQuery = '';

    function esc(value) { return String(value || '').replaceAll('&', '&amp;').replaceAll('<', '&lt;').replaceAll('>', '&gt;').replaceAll('"', '&quot;').replaceAll("'", '&#039;'); }
    function fmt(value) { if (!value) return '-'; try { return new Intl.DateTimeFormat('en-IN', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }).format(new Date(value)); } catch { return '-'; } }
    function showMessage(text, type = 'info') { const box = document.getElementById('message-box'); if (!box) return; box.textContent = text; box.className = `message ${type}`; }
    function isAdmin() { return Boolean(currentUser?.email && ADMIN_EMAILS.includes(currentUser.email.toLowerCase())); }

    async function guardAdmin() {
  const cover = document.getElementById('admin-access-cover');
  const authBox = document.getElementById('auth-box');

  try {
    const { data, error } = await supabase.auth.getSession();

    if (error) {
      currentUser = null;
      cover?.classList.remove('hidden');

      if (authBox) {
        authBox.innerHTML = '<strong>Admin access blocked.</strong><p>Session check failed.</p>';
      }

      return false;
    }

    const user = data.session?.user || null;
    const email = user?.email?.toLowerCase() || '';

    if (user && ADMIN_EMAILS.includes(email)) {
      currentUser = user;
      cover?.classList.add('hidden');
      return true;
    }

    currentUser = null;

    if (user) {
      await supabase.auth.signOut();
    }

    cover?.classList.remove('hidden');

    if (authBox) {
      authBox.innerHTML = '<strong>Official Admin Work Only</strong><p>Admin session not allowed.</p>';
    }

    return false;
  } catch {
    currentUser = null;
    cover?.classList.remove('hidden');

    if (authBox) {
      authBox.innerHTML = '<strong>Admin access blocked.</strong><p>Unable to verify admin session.</p>';
    }

    return false;
  }
}

    function filteredReports() {
      let rows = reports;
      if (activeFilter !== 'all') rows = rows.filter((report) => (report.status || 'pending') === activeFilter);
      const q = searchQuery.trim().toLowerCase();
      if (q) {
        rows = rows.filter((report) => {
          const listing = listingMap.get(report.listing_id) || {};
          return [report.id, report.listing_id, report.reason, report.message, report.reporter_name, report.reporter_email, report.reporter_phone, report.status, listing.owner_name, listing.owner_email, listing.owner_phone, listing.owner_whatsapp, listing.vehicle_type, listing.vehicle_model, listing.reg_number].filter(Boolean).join(' ').toLowerCase().includes(q);
        });
      }
      return rows;
    }

    function render() {
      document.getElementById('loader')?.classList.add('hidden');
      const grid = document.getElementById('reports-grid');
      if (!grid) return;
      const rows = filteredReports();
      grid.innerHTML = rows.length ? rows.map((report) => {
        const listing = listingMap.get(report.listing_id) || {};
        const status = report.status || 'pending';
        return `<article class="admin-row-card"><div class="row-title"><div><h3>${esc(report.reason || 'Report')}</h3><p class="sub">${esc(status)} · ${fmt(report.created_at)}</p></div><span class="pill ${status === 'pending' ? 'pending' : 'active'}">${esc(status)}</span></div><div class="info-grid"><span><strong>Message</strong>${esc(report.message || 'N/A')}</span><span><strong>Reporter</strong>${esc(report.reporter_email || report.reporter_phone || report.reporter_name || 'Anonymous')}</span><span><strong>Owner</strong>${esc(listing.owner_name || '-')}</span><span><strong>Email</strong>${esc(listing.owner_email || '-')}</span><span><strong>Phone</strong>${esc(listing.owner_phone || '-')}</span><span><strong>Vehicle</strong>${esc(listing.vehicle_type || '-')}</span><span><strong>Model</strong>${esc(listing.vehicle_model || '-')}</span><span><strong>Listing status</strong>${esc(listing.status || '-')}</span></div><div class="actions"><button class="btn btn-outline report-status-btn" type="button" data-id="${esc(report.id)}" data-status="reviewed">Reviewed</button><button class="btn btn-outline report-status-btn" type="button" data-id="${esc(report.id)}" data-status="rejected">Reject Report</button><button class="btn btn-primary report-status-btn" type="button" data-id="${esc(report.id)}" data-status="resolved">Resolve</button>${report.listing_id ? `<button class="btn btn-danger cancel-listing-btn" type="button" data-listing-id="${esc(report.listing_id)}">Cancel Listing</button>` : ''}</div></article>`;
      }).join('') : '<div class="notice-card"><strong>No reports found.</strong></div>';
    }

    async function loadReports() {
  if (!isAdmin()) {
    document.getElementById('loader')?.classList.add('hidden');
    return;
  }

  document.getElementById('loader')?.classList.remove('hidden');
  const { data, error } = await supabase
        .from('rent_listing_reports')
        .select('id,listing_id,reason,message,reporter_name,reporter_email,reporter_phone,status,created_at')
        .order('created_at', { ascending: false })
        .limit(500);
      if (error) { document.getElementById('loader')?.classList.add('hidden'); showMessage(error.message, 'error'); return; }
      reports = Array.isArray(data) ? data : [];

      const ids = [...new Set(reports.map((report) => report.listing_id).filter(Boolean))];
      listingMap = new Map();
      if (ids.length) {
        const result = await supabase.from('rent_listings').select('id,owner_name,owner_email,owner_phone,owner_whatsapp,vehicle_type,vehicle_model,reg_number,status').in('id', ids);
        (result.data || []).forEach((listing) => listingMap.set(listing.id, listing));
      }
      render();
    }

    async function updateReport(id, status) {
  if (!isAdmin()) return;

  const { error } = await supabase.from('rent_listing_reports').update({ status }).eq('id', id);
      if (error) return showMessage(error.message, 'error');
      await loadReports();
    }

    async function cancelListing(id) {
  if (!isAdmin()) return;

  if (!confirm('Cancel this listing and remove from public search?')) return;
      const { error } = await supabase.from('rent_listings').update({ status: 'cancelled', updated_at: new Date().toISOString() }).eq('id', id);
      if (error) return showMessage(error.message, 'error');
      showMessage('Listing cancelled.', 'success');
      await loadReports();
    }

    document.addEventListener('DOMContentLoaded', async () => {
      const ok = await guardAdmin();
      const auth = document.getElementById('auth-box');
      if (!ok) { if (auth) auth.innerHTML = '<strong>Admin access blocked.</strong>'; return; }
      if (auth) auth.innerHTML = `<strong>Logged in as</strong> ${esc(currentUser.email)} <button id="logout-btn" class="btn btn-outline btn-small" type="button">Logout</button>`;
      document.getElementById('filter-card')?.classList.remove('hidden');
      document.getElementById('logout-btn')?.addEventListener('click', async () => { await supabase.auth.signOut(); location.reload(); });
      document.getElementById('refresh-btn')?.addEventListener('click', loadReports);
      document.querySelectorAll('.filter-btn').forEach((btn) => btn.addEventListener('click', () => { document.querySelectorAll('.filter-btn').forEach((b) => b.classList.remove('active')); btn.classList.add('active'); activeFilter = btn.dataset.filter || 'pending'; render(); }));
      document.getElementById('report-search-input')?.addEventListener('input', (event) => { searchQuery = event.target?.value || ''; render(); });
      document.addEventListener('click', (event) => { const target = event.target; if (!(target instanceof Element)) return; const statusBtn = target.closest('.report-status-btn'); if (statusBtn) return updateReport(statusBtn.dataset.id, statusBtn.dataset.status); const cancelBtn = target.closest('.cancel-listing-btn'); if (cancelBtn) return cancelListing(cancelBtn.dataset.listingId); });
      await loadReports();
    });
  </script>

  <style is:global>
    .admin-page{min-height:100vh;padding:1rem 1rem 3rem;background:radial-gradient(circle at top left,rgba(255,107,0,.16),transparent 30%),linear-gradient(135deg,#0b0628 0%,#13084a 55%,#1e103f 100%);color:#fff}.admin-container{max-width:1180px;margin:0 auto}.admin-header{display:flex;justify-content:space-between;gap:1rem;align-items:flex-start;margin-bottom:1rem}.eyebrow{margin:0 0 .35rem;color:#ff8a00;font-size:.75rem;font-weight:900;letter-spacing:.08em;text-transform:uppercase}h1{margin:0 0 .35rem;font-size:clamp(1.7rem,4vw,2.35rem);color:#fff}.admin-header p{margin:0;color:rgba(255,255,255,.72);font-size:.92rem}.btn{display:inline-flex;align-items:center;justify-content:center;min-height:34px;padding:.5rem .75rem;border-radius:.65rem;border:0;font-weight:900;text-decoration:none;cursor:pointer;font-size:.78rem;line-height:1;white-space:nowrap}.btn-primary{color:white;background:linear-gradient(135deg,#ff6b00,#ff8a00)}.btn-outline{color:white;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.22)}.btn-danger{color:white;background:rgba(239,68,68,.72);border:1px solid rgba(239,68,68,.35)}.btn-small{min-height:28px;padding:.38rem .65rem;font-size:.72rem}.notice-card,.message,.filter-card,.admin-row-card{border-radius:.9rem;border:1px solid rgba(255,255,255,.14);background:rgba(255,255,255,.07);color:#fff}.notice-card{padding:.9rem 1rem;margin-bottom:1rem;color:rgba(255,255,255,.82)}.hidden{display:none!important}.message{padding:.9rem 1rem;margin-bottom:1rem;font-weight:900}.message.info{color:#93c5fd;background:rgba(59,130,246,.12)}.message.success{color:#86efac;background:rgba(34,197,94,.12)}.message.error{color:#fca5a5;background:rgba(239,68,68,.12)}.filter-card{padding:.65rem;display:flex;gap:.45rem;flex-wrap:wrap;margin-bottom:1rem}.filter-btn{border:1px solid rgba(255,255,255,.18);background:rgba(255,255,255,.06);color:rgba(255,255,255,.76);border-radius:999px;padding:.42rem .7rem;font-weight:900;cursor:pointer;font-size:.76rem}.filter-btn.active{color:white;background:linear-gradient(135deg,#ff6b00,#ff8a00);border-color:transparent}.admin-search-input{min-height:36px;flex:1 1 260px;border-radius:999px;border:1px solid rgba(255,255,255,.18);background:rgba(255,255,255,.06);color:#fff;padding:.42rem .75rem;font-size:.78rem;font-weight:800;outline:none}.admin-search-input::placeholder{color:rgba(255,255,255,.5)}.admin-dynamic-grid{display:grid;grid-template-columns:1fr;gap:.75rem}.admin-row-card{padding:.75rem;display:grid;gap:.55rem}.row-title{display:flex;justify-content:space-between;gap:.75rem;align-items:flex-start}.row-title h3{margin:0 0 .2rem;font-size:.95rem;line-height:1.15;color:#fff}.sub{margin:0;color:rgba(255,255,255,.72);font-size:.75rem}.pill{display:inline-flex;align-items:center;min-height:22px;padding:.18rem .45rem;border-radius:999px;font-size:.64rem;font-weight:900;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.14);color:rgba(255,255,255,.82);white-space:nowrap}.pill.active{background:rgba(34,197,94,.15);color:#86efac}.pill.pending{background:rgba(250,204,21,.14);color:#fde68a}.info-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:.35rem}.info-grid span{min-width:0;padding:.42rem .5rem;border-radius:.5rem;background:rgba(255,255,255,.045);border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.86);font-size:.72rem;line-height:1.25;word-break:break-word}.info-grid strong{display:block;margin-bottom:.12rem;color:white;font-size:.64rem;opacity:.75}.actions{display:flex;flex-wrap:wrap;gap:.4rem;align-items:center;justify-content:flex-start}.admin-access-cover{position:fixed;inset:0;z-index:99999;min-height:100vh;padding:1rem;background:linear-gradient(135deg,#0b0628 0%,#13084a 55%,#1e103f 100%);display:flex;align-items:flex-start;justify-content:center}.admin-access-card{width:min(100%,980px);margin-top:4.5rem;padding:1rem;border-radius:1rem;background:rgba(250,204,21,.12);border:1px solid rgba(250,204,21,.32);color:#fde68a}.admin-access-card strong{display:block;margin-bottom:.35rem;color:#facc15;font-weight:950;font-size:1rem}.admin-access-card p{margin:0;color:rgba(255,255,255,.86);line-height:1.45}@media(max-width:760px){.admin-page{padding:.8rem .75rem 2rem}.admin-header{flex-direction:column}.info-grid{grid-template-columns:repeat(2,minmax(0,1fr))}}
  </style>
</BaseLayout>
