---
import BaseLayout from '../../layouts/BaseLayout.astro';

const adminCards = [
  {
    title: 'Rent Listings',
    desc: 'Verify badge, cancel/restore listings and check owner details.',
    href: '/admin/rent-listings',
    icon: '✅',
  },
  {
    title: 'Rent Events',
    desc: 'Views, call clicks, WhatsApp clicks and listing analytics.',
    href: '/admin/rent-events',
    icon: '📈',
  },
  {
    title: 'Rent Memberships',
    desc: 'Verified Badge, Visibility Boost, payment/admin activation.',
    href: '/admin/rent-memberships',
    icon: '💳',
  },
  {
    title: 'Rent Reports',
    desc: 'User reports, reject report, resolve and cancel fake listings.',
    href: '/admin/rent-reports',
    icon: '🚩',
  },
  
];
---

<BaseLayout
  title="Admin Panel - SoniaBuddy"
  description="SoniaBuddy admin tools for rent listings, reports, membership and analytics."
>
  <main class="sb-admin-page">
    <div class="sb-admin-container">
      <header class="sb-admin-header">
        <div>
          <p class="sb-eyebrow">SoniaBuddy Admin</p>
          <h1>Admin Control Panel</h1>
          <p>
            Manage rent listings, reports, verified badge, visibility boost and analytics.
          </p>
        </div>

        <a class="sb-top-btn" href="/">Back to Home</a>
      </header>

      <section class="sb-admin-grid">
        {adminCards.map((card) => (
          <a class="sb-admin-card" href={card.href}>
            <span class="sb-admin-icon">{card.icon}</span>
            <div>
              <h2>{card.title}</h2>
              <p>{card.desc}</p>
            </div>
            <span class="sb-open-btn">Open</span>
          </a>
        ))}
      </section>
    </div>
  </main>

  <style>
    :global(body) {
      background: #12072f;
    }

    .sb-admin-page {
      min-height: 100vh;
      padding: 2rem 1rem 4rem;
      background:
        radial-gradient(circle at top left, rgba(255, 122, 0, 0.22), transparent 28%),
        linear-gradient(135deg, #12072f 0%, #17094b 52%, #250b38 100%);
      color: #ffffff !important;
    }

    .sb-admin-container {
      width: min(1120px, 100%);
      margin: 0 auto;
    }

    .sb-admin-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1.4rem;
    }

    .sb-eyebrow {
      margin: 0 0 0.35rem;
      color: #ff8a00 !important;
      font-size: 0.78rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .sb-admin-header h1 {
      margin: 0 0 0.5rem;
      color: #ffffff !important;
      font-size: clamp(1.8rem, 5vw, 2.8rem);
      line-height: 1.05;
      font-weight: 1000;
    }

    .sb-admin-header p {
      margin: 0;
      max-width: 650px;
      color: rgba(255, 255, 255, 0.78) !important;
      line-height: 1.5;
    }

    .sb-top-btn,
    .sb-open-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 42px;
      padding: 0.7rem 1rem;
      border-radius: 0.85rem;
      border: 1px solid rgba(255, 255, 255, 0.22);
      color: #ffffff !important;
      background: rgba(255, 255, 255, 0.08);
      text-decoration: none;
      font-weight: 900;
      white-space: nowrap;
    }

    .sb-admin-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .sb-admin-card {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 1rem;
      min-height: 125px;
      padding: 1rem;
      border-radius: 1.1rem;
      border: 1px solid rgba(255, 255, 255, 0.16);
      background: rgba(255, 255, 255, 0.08);
      color: #ffffff !important;
      text-decoration: none;
      box-shadow: 0 18px 45px rgba(0, 0, 0, 0.18);
    }

    .sb-admin-card:hover {
      border-color: rgba(255, 138, 0, 0.55);
      background: rgba(255, 255, 255, 0.12);
      transform: translateY(-1px);
    }

    .sb-admin-icon {
      width: 52px;
      height: 52px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 16px;
      background: rgba(255, 122, 0, 0.18);
      font-size: 1.45rem;
    }

    .sb-admin-card h2 {
      margin: 0 0 0.35rem;
      color: #ffffff !important;
      font-size: 1.05rem;
      font-weight: 1000;
    }

    .sb-admin-card p {
      margin: 0;
      color: rgba(255, 255, 255, 0.76) !important;
      font-size: 0.9rem;
      line-height: 1.45;
    }

    .sb-open-btn {
      min-height: 38px;
      padding: 0.55rem 0.9rem;
      background: linear-gradient(135deg, #ff6b00, #ff8a00);
      border: 0;
    }

    @media (max-width: 760px) {
      .sb-admin-header {
        flex-direction: column;
      }

      .sb-top-btn {
        width: 100%;
      }

      .sb-admin-grid {
        grid-template-columns: 1fr;
      }

      .sb-admin-card {
        grid-template-columns: auto 1fr;
      }

      .sb-open-btn {
        grid-column: 1 / -1;
        width: 100%;
      }
    }
  </style>
</BaseLayout>