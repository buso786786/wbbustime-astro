---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/admin-compact.css';
---

<BaseLayout
  title="Admin Panel - SoniaBuddy"
  description="SoniaBuddy secure admin control panel."
  robots="noindex,nofollow"
>
  <div id="admin-access-cover" class="admin-access-cover">
    <div class="admin-access-card">
      <strong>Official Admin Work Only</strong>
      <p>This area is restricted for SoniaBuddy internal admin work. Unauthorized access or misuse is not allowed.</p>
    </div>
  </div>

  <section class="admin-page">
    <div class="admin-container">
      <div class="admin-header hidden" id="admin-header">
        <div>
          <p class="eyebrow">SoniaBuddy Admin</p>
          <h1>Admin Control Panel</h1>
          <p id="admin-subtitle">Checking admin access...</p>
        </div>
        <button id="logout-btn" class="btn btn-outline hidden" type="button">Logout</button>
      </div>

      <div id="auth-box" class="notice-card">
        <strong>Checking admin access...</strong>
      </div>

      <div id="admin-grid" class="admin-grid hidden">
        <a class="admin-card" href="/admin/rent-listings">
          <div class="admin-icon">✅</div>
          <div>
            <h2>Rent Listings</h2>
            <p>Review listings, reject spam, remove junk and restore valid listings.</p>
          </div>
          <span class="open-pill">Open</span>
        </a>

        <a class="admin-card" href="/admin/rent-memberships">
          <div class="admin-icon">💳</div>
          <div>
            <h2>Rent Memberships</h2>
            <p>Review payment rows, approve paid ads, stop ads and clean old rows.</p>
          </div>
          <span class="open-pill">Open</span>
        </a>

        <a class="admin-card" href="/admin/rent-events">
          <div class="admin-icon">📈</div>
          <div>
            <h2>Rent Events</h2>
            <p>Views, calls, WhatsApp clicks and analytics cleanup.</p>
          </div>
          <span class="open-pill">Open</span>
        </a>

        <a class="admin-card" href="/admin/rent-reports">
          <div class="admin-icon">🚩</div>
          <div>
            <h2>Rent Reports</h2>
            <p>Review reports, dismiss false reports, resolve issues and cancel fake listings.</p>
          </div>
          <span class="open-pill">Open</span>
        </a>
      </div>
    </div>
  </section>

  <script>
    import { supabase } from '../../lib/supabase';

    const ADMIN_EMAILS = ['buso786786@gmail.com', 'zisakho2024@gmail.com'];

    function esc(value) {
      return String(value || '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');
    }

    async function guardAdmin() {
      const cover = document.getElementById('admin-access-cover');
      const { data } = await supabase.auth.getSession();
      const user = data.session?.user || null;
      const email = user?.email?.toLowerCase() || '';

      if (ADMIN_EMAILS.includes(email)) {
        cover?.classList.add('hidden');
        return user;
      }

      cover?.classList.remove('hidden');
      return null;
    }

    document.addEventListener('DOMContentLoaded', async () => {
      const user = await guardAdmin();
      const authBox = document.getElementById('auth-box');

      if (!user) {
        if (authBox) {
          authBox.innerHTML = '<strong>Official Admin Work Only</strong><p>Admin session not allowed.</p>';
        }
        return;
      }

      document.getElementById('admin-header')?.classList.remove('hidden');
      document.getElementById('admin-grid')?.classList.remove('hidden');
      document.getElementById('logout-btn')?.classList.remove('hidden');

      if (authBox) authBox.innerHTML = `<strong>Admin:</strong> ${esc(user.email)}`;
      const subtitle = document.getElementById('admin-subtitle');
      if (subtitle) subtitle.textContent = 'Manage rent listings, memberships, analytics and reports.';

      document.getElementById('logout-btn')?.addEventListener('click', async () => {
        await supabase.auth.signOut();
        window.location.reload();
      });
    });
  </script>

  <style is:global>
    .admin-page {
      min-height: 100vh;
      padding: 1rem;
      background: linear-gradient(135deg, #0b0628 0%, #13084a 55%, #1e103f 100%);
      color: #fff;
    }
    .admin-container { max-width: 1180px; margin: 0 auto; }
    .hidden { display: none !important; }
    .admin-header { display: flex; justify-content: space-between; gap: 1rem; margin-bottom: 1rem; }
    .eyebrow { color: #ff8a00; font-weight: 900; text-transform: uppercase; font-size: .75rem; margin: 0 0 .3rem; }
    h1 { margin: .1rem 0; font-size: 2rem; color: #fff; }
    .notice-card, .admin-card { border-radius: .9rem; border: 1px solid rgba(255,255,255,.14); background: rgba(255,255,255,.07); }
    .notice-card { padding: 1rem; margin-bottom: 1rem; }
    .admin-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; }
    .admin-card { display: grid; grid-template-columns: 52px 1fr auto; gap: .8rem; align-items: center; padding: 1rem; color: #fff; text-decoration: none; }
    .admin-icon { font-size: 1.4rem; }
    .admin-card h2 { margin: 0 0 .25rem; font-size: 1rem; color: #fff; }
    .admin-card p { margin: 0; color: rgba(255,255,255,.75); font-size: .84rem; line-height: 1.35; }
    .open-pill, .btn { display: inline-flex; align-items: center; justify-content: center; border-radius: .75rem; background: linear-gradient(135deg,#ff6b00,#ff8a00); color: #fff; padding: .48rem .75rem; font-weight: 900; border: 0; text-decoration: none; cursor: pointer; }
    .btn-outline { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.22); }
    .admin-access-cover { position: fixed; inset: 0; z-index: 99999; background: linear-gradient(135deg,#0b0628,#13084a 55%,#1e103f); display: flex; align-items: flex-start; justify-content: center; padding: 1rem; }
    .admin-access-card { width: min(100%, 980px); margin-top: 4.5rem; padding: 1rem; border-radius: 1rem; background: rgba(250,204,21,.12); border: 1px solid rgba(250,204,21,.32); color: #fde68a; }
    .admin-access-card strong { display: block; color: #facc15; margin-bottom: .35rem; }
    @media(max-width:760px){ .admin-grid{grid-template-columns:1fr}.admin-card{grid-template-columns:42px 1fr auto}.admin-header{flex-direction:column} }
  </style>
</BaseLayout>
