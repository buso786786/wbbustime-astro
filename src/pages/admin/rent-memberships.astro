---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/admin-compact.css';
---

<BaseLayout
  title="Rent Memberships Admin - SoniaBuddy"
  description="Approve paid ads, disable active ads and keep SoniaBuddy ads clean."
  robots="noindex,nofollow"
>
  <div id="admin-access-cover" class="admin-access-cover">
    <div class="admin-access-card">
      <strong>Official Admin Work Only</strong>
      <p>This area is restricted for SoniaBuddy internal admin work.</p>
    </div>
  </div>

  <section class="admin-page">
    <div class="admin-container">
      <div class="admin-header">
        <div>
          <p class="eyebrow">SoniaBuddy Admin</p>
          <h1>Rent Ads Control</h1>
          <p>Approve paid visibility ads, disable active ads and keep this panel clean.</p>
        </div>
        <button id="refresh-btn" class="btn btn-primary" type="button">Refresh</button>
      </div>

      <div id="auth-box" class="notice-card">Checking admin access...</div>
      <div id="message-box" class="message hidden"></div>

      <div id="stats-grid" class="stats-grid hidden">
        <div class="stat-card">
          <span>Ads Waiting</span>
          <strong id="stat-waiting">0</strong>
        </div>
        <div class="stat-card">
          <span>Active Ads</span>
          <strong id="stat-active-ads">0</strong>
        </div>
      </div>

      <div id="filter-card" class="filter-card hidden">
        <select id="status-filter" class="input-select" aria-label="Ads filter">
          <option value="ads_waiting">Ads waiting approval</option>
          <option value="active_ads">Active ads</option>
          <option value="all_ads">All ads</option>
        </select>

        <input
          id="membership-search-input"
          class="admin-search-input"
          type="search"
          placeholder="Search email, phone, listing id..."
        />
      </div>

      <div id="loader" class="notice-card hidden">Loading ads...</div>
      <div id="memberships-grid" class="grid"></div>
    </div>
  </section>

  <script>
    import { supabase } from '../../lib/supabase';

    const ADMIN_EMAILS = ['buso786786@gmail.com', 'zisakho2024@gmail.com'];

    let currentUser = null;
    let memberships = [];
    let listingsById = {};
    let searchQuery = '';

    function esc(value) {
      return String(value || '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');
    }

    function formatDate(value) {
      if (!value) return '-';
      try {
        return new Intl.DateTimeFormat('en-IN', {
          day: '2-digit',
          month: 'short',
          year: 'numeric',
        }).format(new Date(value));
      } catch {
        return '-';
      }
    }

    function showMessage(text, type = 'info') {
      const box = document.getElementById('message-box');
      if (!box) return;
      box.textContent = text;
      box.className = `message ${type}`;
    }

    function hideMessage() {
      document.getElementById('message-box')?.classList.add('hidden');
    }

    function isAdmin() {
      return Boolean(
        currentUser?.email &&
          ADMIN_EMAILS.includes(currentUser.email.toLowerCase())
      );
    }

    async function guardAdminPage() {
  const cover = document.getElementById('admin-access-cover');
  const authBox = document.getElementById('auth-box');

  try {
    const { data, error } = await supabase.auth.getSession();

    if (error) {
      currentUser = null;
      cover?.classList.remove('hidden');

      if (authBox) {
        authBox.innerHTML = '<strong>Admin access blocked.</strong><p>Session check failed.</p>';
      }

      return false;
    }

    const user = data.session?.user || null;
    const email = user?.email?.toLowerCase() || '';

    if (user && ADMIN_EMAILS.includes(email)) {
      currentUser = user;
      cover?.classList.add('hidden');
      return true;
    }

    currentUser = null;

    if (user) {
      await supabase.auth.signOut();
    }

    cover?.classList.remove('hidden');

    if (authBox) {
      authBox.innerHTML = '<strong>Official Admin Work Only</strong><p>Admin session not allowed.</p>';
    }

    return false;
  } catch {
    currentUser = null;
    cover?.classList.remove('hidden');

    if (authBox) {
      authBox.innerHTML = '<strong>Admin access blocked.</strong><p>Unable to verify admin session.</p>';
    }

    return false;
  }
}

    function isLive(membership) {
      const now = Date.now();
      const startsOk =
        !membership.starts_at || new Date(membership.starts_at).getTime() <= now;
      const expiresOk =
        membership.expires_at && new Date(membership.expires_at).getTime() > now;

      return startsOk && expiresOk;
    }

    function rowType(membership) {
      if (
        membership.plan_type === 'featured' &&
        membership.payment_status === 'paid' &&
        membership.ads_status === 'paid_pending_start'
      ) {
        return 'ads_waiting';
      }

      if (
        membership.plan_type === 'featured' &&
        membership.payment_status === 'paid' &&
        membership.ads_status === 'active' &&
        isLive(membership)
      ) {
        return 'active_ads';
      }

      return 'hide';
    }

    function filteredRows() {
      const filter = document.getElementById('status-filter')?.value || 'ads_waiting';
      let rows = memberships.filter((membership) => rowType(membership) !== 'hide');

      if (filter !== 'all_ads') {
        rows = rows.filter((membership) => rowType(membership) === filter);
      }

      const q = searchQuery.trim().toLowerCase();

      if (q) {
        rows = rows.filter((membership) => {
          const listing = listingsById[membership.listing_id] || {};

          return [
            membership.id,
            membership.listing_id,
            membership.owner_email,
            membership.plan_type,
            membership.status,
            membership.payment_status,
            membership.ads_status,
            listing.owner_email,
            listing.owner_name,
            listing.owner_phone,
            listing.owner_whatsapp,
            listing.vehicle_type,
            listing.vehicle_model,
            listing.reg_number,
          ]
            .filter(Boolean)
            .join(' ')
            .toLowerCase()
            .includes(q);
        });
      }

      return rows;
    }

    function updateStats() {
      const setText = (id, value) => {
        const element = document.getElementById(id);
        if (element) element.textContent = String(value);
      };

      setText(
        'stat-waiting',
        memberships.filter((membership) => rowType(membership) === 'ads_waiting').length
      );
      setText(
        'stat-active-ads',
        memberships.filter((membership) => rowType(membership) === 'active_ads').length
      );
    }

    function renderMembershipCard(membership) {
      const listing = listingsById[membership.listing_id] || {};
      const type = rowType(membership);
      const title = listing.vehicle_model || listing.vehicle_type || 'Visibility Ads';
      const listingShortId = String(membership.listing_id || '').slice(0, 8) || '-';
      const email = membership.owner_email || listing.owner_email || '-';

      return `
        <article class="card row-card">
          <div class="row-title">
            <div>
              <h3>${esc(title)}</h3>
              <p class="sub">Listing: ${esc(listingShortId)} · ${esc(email)}</p>
            </div>
            <span class="pill ${type === 'active_ads' ? 'active' : 'pending'}">
              ${type === 'active_ads' ? 'active ads' : 'ads waiting'}
            </span>
          </div>

          <div class="info-grid">
            <span><strong>Plan</strong>${esc(membership.plan_type || '-')}</span>
            <span><strong>Status</strong>${esc(membership.status || '-')}</span>
            <span><strong>Payment</strong>${esc(membership.payment_status || '-')}</span>
            <span><strong>Ads</strong>${esc(membership.ads_status || '-')}</span>
            <span><strong>Owner</strong>${esc(listing.owner_name || '-')}</span>
            <span><strong>Phone</strong>${esc(listing.owner_phone || '-')}</span>
            <span><strong>Vehicle</strong>${esc(listing.vehicle_type || '-')}</span>
            <span><strong>Reg No</strong>${esc(listing.reg_number || '-')}</span>
            <span><strong>Start</strong>${formatDate(membership.starts_at)}</span>
            <span><strong>Expire</strong>${formatDate(membership.expires_at)}</span>
          </div>

          <div class="actions">
            ${
              type === 'ads_waiting'
                ? `<button class="btn btn-primary approve-ads-btn" type="button" data-id="${esc(membership.id)}">Approve Ads</button>`
                : ''
            }
            ${
              type === 'active_ads'
                ? `<button class="btn btn-danger stop-ads-btn" type="button" data-id="${esc(membership.id)}">Disable Ads</button>`
                : ''
            }
          </div>
        </article>
      `;
    }

    function renderMemberships() {
      updateStats();

      const loader = document.getElementById('loader');
      const grid = document.getElementById('memberships-grid');

      loader?.classList.add('hidden');
      if (!grid) return;

      const rows = filteredRows();

      if (!rows.length) {
        grid.innerHTML = `
          <div class="notice-card">
            <strong>No ads rows found.</strong>
            <p>Only paid visibility ads waiting for approval or currently active ads appear here.</p>
          </div>
        `;
        return;
      }

      grid.innerHTML = rows.map(renderMembershipCard).join('');
    }

    async function loadMemberships() {
  if (!isAdmin()) {
    document.getElementById('loader')?.classList.add('hidden');
    return;
  }

  hideMessage();

  const loader = document.getElementById('loader');
  loader?.classList.remove('hidden');

  const { data, error } = await supabase
        .from('rent_memberships')
        .select('id,listing_id,owner_email,plan_type,status,payment_status,ads_status,starts_at,expires_at,created_at,updated_at')
        .eq('plan_type', 'featured')
        .eq('payment_status', 'paid')
        .in('ads_status', ['paid_pending_start', 'active'])
        .order('created_at', { ascending: false })
        .limit(500);

      if (error) {
        loader?.classList.add('hidden');
        showMessage(error.message, 'error');
        return;
      }

      memberships = Array.isArray(data) ? data : [];

      const listingIds = [
        ...new Set(memberships.map((membership) => membership.listing_id).filter(Boolean)),
      ];

      listingsById = {};

      if (listingIds.length) {
        const result = await supabase
          .from('rent_listings')
          .select('id,owner_email,owner_name,owner_phone,owner_whatsapp,vehicle_type,vehicle_model,reg_number,status')
          .in('id', listingIds);

        if (result.error) {
          console.warn('Listing fetch failed:', result.error.message);
        }

        (result.data || []).forEach((listing) => {
          listingsById[listing.id] = listing;
        });
      }

      renderMemberships();
    }

    async function approveAds(id) {
  if (!isAdmin()) return;
  if (!id) return;
  if (!confirm('Approve ads and start 90 days visibility?')) return;

      const now = new Date();
      const expiresAt = new Date(now);
      expiresAt.setDate(expiresAt.getDate() + 90);

      const { error } = await supabase
        .from('rent_memberships')
        .update({
          status: 'active',
          payment_status: 'paid',
          ads_status: 'active',
          starts_at: now.toISOString(),
          expires_at: expiresAt.toISOString(),
          updated_at: now.toISOString(),
        })
        .eq('id', id);

      if (error) {
        showMessage(error.message, 'error');
        return;
      }

      showMessage('Ads approved and started for 90 days.', 'success');
      await loadMemberships();
    }

    async function disableAds(id) {
  if (!isAdmin()) return;
  if (!id) return;
  if (!confirm('Disable ads now? This listing will stop getting paid ads visibility.')) return;

      const now = new Date().toISOString();

      const { error } = await supabase
        .from('rent_memberships')
        .update({
          ads_status: 'stopped',
          expires_at: now,
          updated_at: now,
        })
        .eq('id', id);

      if (error) {
        showMessage(error.message, 'error');
        return;
      }

      showMessage('Ads disabled.', 'success');
      await loadMemberships();
    }

    document.addEventListener('DOMContentLoaded', async () => {
      const ok = await guardAdminPage();
      const authBox = document.getElementById('auth-box');

      if (!ok) {
        if (authBox) authBox.innerHTML = '<strong>Admin access blocked.</strong>';
        return;
      }

      if (authBox) {
        authBox.innerHTML = `
          <strong>Logged in as</strong> ${esc(currentUser.email)}
          <button id="logout-btn" class="btn btn-outline btn-small" type="button">Logout</button>
        `;
      }

      document.getElementById('stats-grid')?.classList.remove('hidden');
      document.getElementById('filter-card')?.classList.remove('hidden');

      document.getElementById('logout-btn')?.addEventListener('click', async () => {
        await supabase.auth.signOut();
        location.reload();
      });

      document.getElementById('refresh-btn')?.addEventListener('click', loadMemberships);
      document.getElementById('status-filter')?.addEventListener('change', renderMemberships);
      document.getElementById('membership-search-input')?.addEventListener('input', (event) => {
        searchQuery = event.target?.value || '';
        renderMemberships();
      });

      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;

        const approveBtn = target.closest('.approve-ads-btn');
        if (approveBtn) {
          approveAds(approveBtn.dataset.id);
          return;
        }

        const stopBtn = target.closest('.stop-ads-btn');
        if (stopBtn) {
          disableAds(stopBtn.dataset.id);
        }
      });

      await loadMemberships();
    });
  </script>

  <style is:global>
    .admin-page {
      min-height: 100vh;
      padding: 1rem 1rem 3rem;
      background:
        radial-gradient(circle at top left, rgba(255, 107, 0, 0.16), transparent 30%),
        linear-gradient(135deg, #0b0628 0%, #13084a 55%, #1e103f 100%);
      color: #fff;
    }

    .admin-container {
      max-width: 1180px;
      margin: 0 auto;
    }

    .admin-header {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: flex-start;
      margin-bottom: 1rem;
    }

    .eyebrow {
      margin: 0 0 0.35rem;
      color: #ff8a00;
      font-size: 0.75rem;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    h1 {
      margin: 0 0 0.35rem;
      font-size: clamp(1.7rem, 4vw, 2.35rem);
      color: #fff;
    }

    .admin-header p {
      margin: 0;
      color: rgba(255, 255, 255, 0.72);
      font-size: 0.92rem;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 34px;
      padding: 0.5rem 0.75rem;
      border-radius: 0.65rem;
      border: 0;
      font-weight: 900;
      text-decoration: none;
      cursor: pointer;
      font-size: 0.78rem;
      line-height: 1;
      white-space: nowrap;
    }

    .btn-primary {
      color: white;
      background: linear-gradient(135deg, #ff6b00, #ff8a00);
    }

    .btn-outline {
      color: white;
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.22);
    }

    .btn-danger {
      color: white;
      background: rgba(239, 68, 68, 0.72);
      border: 1px solid rgba(239, 68, 68, 0.35);
    }

    .btn-small {
      min-height: 28px;
      padding: 0.38rem 0.65rem;
      font-size: 0.72rem;
    }

    .notice-card,
    .message,
    .filter-card,
    .stat-card,
    .card {
      border-radius: 0.9rem;
      border: 1px solid rgba(255, 255, 255, 0.14);
      background: rgba(255, 255, 255, 0.07);
    }

    .notice-card {
      padding: 0.9rem 1rem;
      margin-bottom: 1rem;
      color: rgba(255, 255, 255, 0.82);
    }

    .hidden {
      display: none !important;
    }

    .message {
      padding: 0.9rem 1rem;
      margin-bottom: 1rem;
      font-weight: 900;
    }

    .message.info {
      color: #93c5fd;
      background: rgba(59, 130, 246, 0.12);
      border-color: rgba(59, 130, 246, 0.3);
    }

    .message.success {
      color: #86efac;
      background: rgba(34, 197, 94, 0.12);
      border-color: rgba(34, 197, 94, 0.3);
    }

    .message.error {
      color: #fca5a5;
      background: rgba(239, 68, 68, 0.12);
      border-color: rgba(239, 68, 68, 0.3);
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.65rem;
      margin-bottom: 1rem;
    }

    .stat-card {
      padding: 0.75rem;
      text-align: center;
    }

    .stat-card span {
      display: block;
      color: rgba(255, 255, 255, 0.66);
      font-size: 0.76rem;
      font-weight: 800;
      margin-bottom: 0.28rem;
    }

    .stat-card strong {
      display: block;
      color: #ff8a00;
      font-size: 1.35rem;
      line-height: 1;
    }

    .filter-card {
      padding: 0.65rem;
      display: flex;
      gap: 0.45rem;
      flex-wrap: wrap;
      margin-bottom: 1rem;
    }

    .admin-search-input,
    .input-select {
      min-height: 36px;
      flex: 1 1 260px;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.18);
      background: rgba(255, 255, 255, 0.06);
      color: #fff;
      padding: 0.42rem 0.75rem;
      font-size: 0.78rem;
      font-weight: 800;
      outline: none;
    }

    .input-select option {
      background: #241451;
      color: #ffffff;
    }

    .input-select:focus,
    .admin-search-input:focus {
      border-color: rgba(255, 138, 0, 0.65);
      box-shadow: 0 0 0 2px rgba(255, 138, 0, 0.16);
    }

    .admin-search-input::placeholder {
      color: rgba(255, 255, 255, 0.5);
    }

    .grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .row-card {
      padding: 0.75rem;
      display: grid;
      gap: 0.55rem;
    }

    .row-title {
      display: flex;
      justify-content: space-between;
      gap: 0.75rem;
      align-items: flex-start;
    }

    .row-title h3 {
      margin: 0 0 0.2rem;
      font-size: 0.95rem;
      line-height: 1.15;
      color: #fff;
    }

    .sub {
      margin: 0;
      color: rgba(255, 255, 255, 0.72);
      font-size: 0.75rem;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      min-height: 22px;
      padding: 0.18rem 0.45rem;
      border-radius: 999px;
      font-size: 0.64rem;
      font-weight: 900;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.14);
      color: rgba(255, 255, 255, 0.82);
      white-space: nowrap;
    }

    .pill.active {
      background: rgba(34, 197, 94, 0.15);
      color: #86efac;
    }

    .pill.pending {
      background: rgba(250, 204, 21, 0.14);
      color: #fde68a;
    }

    .info-grid {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 0.35rem;
    }

    .info-grid span {
      min-width: 0;
      padding: 0.42rem 0.5rem;
      border-radius: 0.5rem;
      background: rgba(255, 255, 255, 0.045);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: rgba(255, 255, 255, 0.86);
      font-size: 0.72rem;
      line-height: 1.25;
      word-break: break-word;
    }

    .info-grid strong {
      display: block;
      margin-bottom: 0.12rem;
      color: white;
      font-size: 0.64rem;
      opacity: 0.75;
    }

    .actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      align-items: center;
      justify-content: flex-start;
    }

    .admin-access-cover {
      position: fixed;
      inset: 0;
      z-index: 99999;
      min-height: 100vh;
      padding: 1rem;
      background: linear-gradient(135deg, #0b0628 0%, #13084a 55%, #1e103f 100%);
      display: flex;
      align-items: flex-start;
      justify-content: center;
    }

    .admin-access-card {
      width: min(100%, 980px);
      margin-top: 4.5rem;
      padding: 1rem;
      border-radius: 1rem;
      background: rgba(250, 204, 21, 0.12);
      border: 1px solid rgba(250, 204, 21, 0.32);
      color: #fde68a;
    }

    .admin-access-card strong {
      display: block;
      margin-bottom: 0.35rem;
      color: #facc15;
      font-weight: 950;
      font-size: 1rem;
    }

    .admin-access-card p {
      margin: 0;
      color: rgba(255, 255, 255, 0.86);
      line-height: 1.45;
    }

    @media (max-width: 820px) {
      .admin-page {
        padding: 0.8rem 0.75rem 2rem;
      }

      .admin-header {
        flex-direction: column;
      }

      .stats-grid,
      .info-grid {
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (max-width: 520px) {
      .stats-grid,
      .info-grid {
        grid-template-columns: 1fr;
      }

      .filter-card,
      .input-select,
      .admin-search-input {
        width: 100%;
      }
    }
  </style>
</BaseLayout>
