---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/admin-compact.css';
---

<BaseLayout title="Rent Events Admin - SoniaBuddy" description="Track rent listing views, calls and analytics." robots="noindex,nofollow">
  <div id="admin-access-cover" class="admin-access-cover"><div class="admin-access-card"><strong>Official Admin Work Only</strong><p>This area is restricted for SoniaBuddy internal admin work.</p></div></div>

  <section class="admin-page">
    <div class="admin-container">
      <div class="admin-header">
        <div><p class="eyebrow">SoniaBuddy Admin</p><h1>Rent Events</h1><p>Analytics summary with clean/remove controls.</p></div>
        <button id="refresh-btn" class="btn btn-primary" type="button">Refresh</button>
      </div>

      <div id="auth-box" class="notice-card">Checking admin access...</div>
      <div id="message-box" class="message hidden"></div>

      <div id="stats-grid" class="stats-grid hidden">
        <div class="stat-card"><span>Total</span><strong id="stat-total">0</strong></div>
        <div class="stat-card"><span>Views</span><strong id="stat-views">0</strong></div>
        <div class="stat-card"><span>Calls</span><strong id="stat-calls">0</strong></div>
        <div class="stat-card"><span>WhatsApp</span><strong id="stat-wa">0</strong></div>
      </div>

      <div id="filter-card" class="filter-card hidden">
        <button class="filter-btn active" type="button" data-filter="all">All</button>
        <button class="filter-btn" type="button" data-filter="listing_view">Views</button>
        <button class="filter-btn" type="button" data-filter="call_click">Calls</button>
        <button class="filter-btn" type="button" data-filter="whatsapp_click">WhatsApp</button>
        <button class="filter-btn" type="button" data-filter="view_details_click">Details</button>
        <button class="filter-btn" type="button" data-filter="photo_open">Photos</button>
        <input id="event-search-input" class="admin-search-input" type="search" placeholder="Search email, phone, listing id, vehicle..." />
      </div>

      <div id="loader" class="notice-card hidden">Loading events...</div>
      <h2 class="subhead hidden" id="summary-title">Listing summary</h2>
      <div id="summary-grid" class="admin-dynamic-grid"></div>
      <h2 class="subhead hidden" id="events-title">Raw events</h2>
      <div id="events-grid" class="admin-dynamic-grid"></div>
    </div>
  </section>

  <script>
    import { supabase } from '../../lib/supabase';

    const ADMIN_EMAILS = ['buso786786@gmail.com', 'zisakho2024@gmail.com'];
    let currentUser = null;
    let events = [];
    let listingsById = {};
    let activeFilter = 'all';
    let searchQuery = '';

    function esc(value) { return String(value || '').replaceAll('&', '&amp;').replaceAll('<', '&lt;').replaceAll('>', '&gt;').replaceAll('"', '&quot;').replaceAll("'", '&#039;'); }
    function fmt(value) { if (!value) return '-'; try { return new Intl.DateTimeFormat('en-IN', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }).format(new Date(value)); } catch { return '-'; } }
    function showMessage(text, type = 'info') { const box = document.getElementById('message-box'); if (!box) return; box.textContent = text; box.className = `message ${type}`; }
    function isAdmin() { return Boolean(currentUser?.email && ADMIN_EMAILS.includes(currentUser.email.toLowerCase())); }
    function eventType(event) { return event.event_type || event.type || '-'; }

    async function guardAdmin() {
      const cover = document.getElementById('admin-access-cover');
      const { data } = await supabase.auth.getSession();
      currentUser = data.session?.user || null;
      if (isAdmin()) { cover?.classList.add('hidden'); return true; }
      cover?.classList.remove('hidden');
      return false;
    }

    function filteredEvents() {
      let rows = events;
      if (activeFilter !== 'all') rows = rows.filter((event) => eventType(event) === activeFilter);
      const q = searchQuery.trim().toLowerCase();
      if (q) {
        rows = rows.filter((event) => {
          const listing = listingsById[event.listing_id] || {};
          return [event.id, event.listing_id, eventType(event), event.city_id, event.vehicle_type, event.rent_type, listing.owner_email, listing.owner_name, listing.owner_phone, listing.owner_whatsapp, listing.vehicle_type, listing.vehicle_model, listing.reg_number].filter(Boolean).join(' ').toLowerCase().includes(q);
        });
      }
      return rows;
    }

    function groupedEvents() {
      const map = new Map();
      filteredEvents().forEach((event) => {
        const id = event.listing_id || 'no-listing';
        if (!map.has(id)) {
          map.set(id, { id, listing: listingsById[id] || {}, views: 0, calls: 0, wa: 0, details: 0, photos: 0, membership: 0, total: 0, last: event.created_at });
        }
        const item = map.get(id);
        item.total += 1;
        item.last = event.created_at || item.last;
        if (eventType(event) === 'listing_view') item.views += 1;
        if (eventType(event) === 'call_click') item.calls += 1;
        if (eventType(event) === 'whatsapp_click') item.wa += 1;
        if (eventType(event) === 'view_details_click') item.details += 1;
        if (eventType(event) === 'photo_open') item.photos += 1;
        if (eventType(event) === 'membership_click') item.membership += 1;
      });
      return Array.from(map.values()).sort((a, b) => b.total - a.total);
    }

    function updateStats() {
      const rows = filteredEvents();
      const setText = (id, value) => { const el = document.getElementById(id); if (el) el.textContent = String(value); };
      setText('stat-total', rows.length);
      setText('stat-views', rows.filter((event) => eventType(event) === 'listing_view').length);
      setText('stat-calls', rows.filter((event) => eventType(event) === 'call_click').length);
      setText('stat-wa', rows.filter((event) => eventType(event) === 'whatsapp_click').length);
    }

    function render() {
      updateStats();
      document.getElementById('loader')?.classList.add('hidden');
      document.getElementById('summary-title')?.classList.remove('hidden');
      document.getElementById('events-title')?.classList.remove('hidden');
      const summaryGrid = document.getElementById('summary-grid');
      const eventsGrid = document.getElementById('events-grid');
      const groups = groupedEvents();

      if (summaryGrid) {
        summaryGrid.innerHTML = groups.length ? groups.map((group) => {
          const listing = group.listing || {};
          return `<article class="admin-row-card"><div class="row-title"><div><h3>${esc(listing.vehicle_model || listing.vehicle_type || 'Listing')}</h3><p class="sub">Listing: ${esc(String(group.id).slice(0, 8))} · ${esc(listing.owner_email || '-')} · ${esc(listing.owner_phone || '-')}</p></div><span class="pill active">${group.total} events</span></div><div class="info-grid"><span><strong>Views</strong>${group.views}</span><span><strong>Calls</strong>${group.calls}</span><span><strong>WhatsApp</strong>${group.wa}</span><span><strong>Details</strong>${group.details}</span><span><strong>Photos</strong>${group.photos}</span><span><strong>Membership</strong>${group.membership}</span><span><strong>Last</strong>${fmt(group.last)}</span><span><strong>Reg</strong>${esc(listing.reg_number || '-')}</span></div><div class="actions"><button class="btn btn-danger clear-listing-events-btn" type="button" data-listing-id="${esc(group.id)}">🗑 Clear Events</button></div></article>`;
        }).join('') : '<div class="notice-card">No listing summary found.</div>';
      }

      const rows = filteredEvents().slice(0, 150);
      if (eventsGrid) {
        eventsGrid.innerHTML = rows.length ? rows.map((event) => `<article class="admin-row-card raw-event"><div class="row-title"><div><h3>${esc(eventType(event))}</h3><p class="sub">${esc(String(event.listing_id || '-').slice(0, 12))} · ${fmt(event.created_at)}</p></div><span class="pill">event</span></div></article>`).join('') : '<div class="notice-card">No events found.</div>';
      }
    }

    async function loadEvents() {
      document.getElementById('loader')?.classList.remove('hidden');
      const { data, error } = await supabase
        .from('rent_listing_events')
        .select('id,listing_id,event_type,city_id,vehicle_type,rent_type,user_agent,created_at')
        .order('created_at', { ascending: false })
        .limit(1000);
      if (error) { document.getElementById('loader')?.classList.add('hidden'); showMessage(error.message, 'error'); return; }
      events = Array.isArray(data) ? data : [];

      const ids = [...new Set(events.map((event) => event.listing_id).filter(Boolean))];
      listingsById = {};
      if (ids.length) {
        const result = await supabase.from('rent_listings').select('id,owner_email,owner_name,owner_phone,owner_whatsapp,vehicle_type,vehicle_model,reg_number').in('id', ids);
        (result.data || []).forEach((listing) => { listingsById[listing.id] = listing; });
      }
      render();
    }

    async function clearEventsForListing(id) {
      if (!confirm('Delete analytics events for this listing? This cleans admin panel but removes old stats.')) return;
      const { error } = await supabase.from('rent_listing_events').delete().eq('listing_id', id);
      if (error) return showMessage(error.message, 'error');
      showMessage('Events removed for listing.', 'success');
      await loadEvents();
    }

    document.addEventListener('DOMContentLoaded', async () => {
      const ok = await guardAdmin();
      const auth = document.getElementById('auth-box');
      if (!ok) { if (auth) auth.innerHTML = '<strong>Admin access blocked.</strong>'; return; }
      if (auth) auth.innerHTML = `<strong>Logged in as</strong> ${esc(currentUser.email)} <button id="logout-btn" class="btn btn-outline btn-small" type="button">Logout</button>`;
      document.getElementById('stats-grid')?.classList.remove('hidden');
      document.getElementById('filter-card')?.classList.remove('hidden');
      document.getElementById('logout-btn')?.addEventListener('click', async () => { await supabase.auth.signOut(); location.reload(); });
      document.getElementById('refresh-btn')?.addEventListener('click', loadEvents);
      document.querySelectorAll('.filter-btn').forEach((btn) => btn.addEventListener('click', () => { document.querySelectorAll('.filter-btn').forEach((b) => b.classList.remove('active')); btn.classList.add('active'); activeFilter = btn.dataset.filter || 'all'; render(); }));
      document.getElementById('event-search-input')?.addEventListener('input', (event) => { searchQuery = event.target?.value || ''; render(); });
      document.addEventListener('click', (event) => { const target = event.target; if (!(target instanceof Element)) return; const btn = target.closest('.clear-listing-events-btn'); if (btn) clearEventsForListing(btn.dataset.listingId); });
      await loadEvents();
    });
  </script>

  <style is:global>
    .admin-page{min-height:100vh;padding:1rem 1rem 3rem;background:radial-gradient(circle at top left,rgba(255,107,0,.16),transparent 30%),linear-gradient(135deg,#0b0628 0%,#13084a 55%,#1e103f 100%);color:#fff}.admin-container{max-width:1180px;margin:0 auto}.admin-header{display:flex;justify-content:space-between;gap:1rem;align-items:flex-start;margin-bottom:1rem}.eyebrow{margin:0 0 .35rem;color:#ff8a00;font-size:.75rem;font-weight:900;letter-spacing:.08em;text-transform:uppercase}h1{margin:0 0 .35rem;font-size:clamp(1.7rem,4vw,2.35rem);color:#fff}.admin-header p{margin:0;color:rgba(255,255,255,.72);font-size:.92rem}.subhead{font-size:1rem;margin:1rem 0 .5rem;color:#fff}.btn{display:inline-flex;align-items:center;justify-content:center;min-height:34px;padding:.5rem .75rem;border-radius:.65rem;border:0;font-weight:900;text-decoration:none;cursor:pointer;font-size:.78rem;line-height:1;white-space:nowrap}.btn-primary{color:white;background:linear-gradient(135deg,#ff6b00,#ff8a00)}.btn-outline{color:white;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.22)}.btn-danger{color:white;background:rgba(239,68,68,.72);border:1px solid rgba(239,68,68,.35)}.btn-small{min-height:28px;padding:.38rem .65rem;font-size:.72rem}.notice-card,.message,.filter-card,.stat-card,.admin-row-card{border-radius:.9rem;border:1px solid rgba(255,255,255,.14);background:rgba(255,255,255,.07);color:#fff}.notice-card{padding:.9rem 1rem;margin-bottom:1rem;color:rgba(255,255,255,.82)}.hidden{display:none!important}.message{padding:.9rem 1rem;margin-bottom:1rem;font-weight:900}.message.info{color:#93c5fd;background:rgba(59,130,246,.12)}.message.success{color:#86efac;background:rgba(34,197,94,.12)}.message.error{color:#fca5a5;background:rgba(239,68,68,.12)}.filter-card{padding:.65rem;display:flex;gap:.45rem;flex-wrap:wrap;margin-bottom:1rem}.filter-btn{border:1px solid rgba(255,255,255,.18);background:rgba(255,255,255,.06);color:rgba(255,255,255,.76);border-radius:999px;padding:.42rem .7rem;font-weight:900;cursor:pointer;font-size:.76rem}.filter-btn.active{color:white;background:linear-gradient(135deg,#ff6b00,#ff8a00);border-color:transparent}.admin-search-input{min-height:36px;flex:1 1 260px;border-radius:999px;border:1px solid rgba(255,255,255,.18);background:rgba(255,255,255,.06);color:#fff;padding:.42rem .75rem;font-size:.78rem;font-weight:800;outline:none}.admin-search-input::placeholder{color:rgba(255,255,255,.5)}.stats-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:.65rem;margin-bottom:1rem}.stat-card{padding:.75rem;text-align:center}.stat-card span{display:block;color:rgba(255,255,255,.66);font-size:.76rem;font-weight:800;margin-bottom:.28rem}.stat-card strong{display:block;color:#ff8a00;font-size:1.35rem;line-height:1}.admin-dynamic-grid{display:grid;grid-template-columns:1fr;gap:.75rem}.admin-row-card{padding:.75rem;display:grid;gap:.55rem}.raw-event{opacity:.95}.row-title{display:flex;justify-content:space-between;gap:.75rem;align-items:flex-start}.row-title h3{margin:0 0 .2rem;font-size:.95rem;line-height:1.15;color:#fff}.sub{margin:0;color:rgba(255,255,255,.72);font-size:.75rem}.pill{display:inline-flex;align-items:center;min-height:22px;padding:.18rem .45rem;border-radius:999px;font-size:.64rem;font-weight:900;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.14);color:rgba(255,255,255,.82);white-space:nowrap}.pill.active{background:rgba(34,197,94,.15);color:#86efac}.info-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:.35rem}.info-grid span{min-width:0;padding:.42rem .5rem;border-radius:.5rem;background:rgba(255,255,255,.045);border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.86);font-size:.72rem;line-height:1.25;word-break:break-word}.info-grid strong{display:block;margin-bottom:.12rem;color:white;font-size:.64rem;opacity:.75}.actions{display:flex;flex-wrap:wrap;gap:.4rem;align-items:center;justify-content:flex-start}.admin-access-cover{position:fixed;inset:0;z-index:99999;min-height:100vh;padding:1rem;background:linear-gradient(135deg,#0b0628 0%,#13084a 55%,#1e103f 100%);display:flex;align-items:flex-start;justify-content:center}.admin-access-card{width:min(100%,980px);margin-top:4.5rem;padding:1rem;border-radius:1rem;background:rgba(250,204,21,.12);border:1px solid rgba(250,204,21,.32);color:#fde68a}.admin-access-card strong{display:block;margin-bottom:.35rem;color:#facc15;font-weight:950;font-size:1rem}.admin-access-card p{margin:0;color:rgba(255,255,255,.86);line-height:1.45}@media(max-width:760px){.admin-page{padding:.8rem .75rem 2rem}.admin-header{flex-direction:column}.stats-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.info-grid{grid-template-columns:repeat(2,minmax(0,1fr))}}
  </style>
</BaseLayout>
