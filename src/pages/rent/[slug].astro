---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { supabase } from '../../lib/supabase';
import '../../styles/rent-seo.css';

const SITE_URL = 'https://soniabuddy.in';
const PHOTO_BUCKET = 'rent-listing-photos';

type RentCity = {
  id: string;
  name?: string | null;
  name_en?: string | null;
  name_bn?: string | null;
  district_en?: string | null;
  district_bn?: string | null;
  search_keywords_en?: string | null;
  search_keywords_bn?: string | null;
};

type RentListing = {
  id: string;
  owner_name: string | null;
  owner_phone: string | null;
  owner_whatsapp: string | null;
  vehicle_type: string | null;
  vehicle_model: string | null;
  seats: number | null;
  purposes: string[] | null;
  base_city_id: string | null;
  service_city_ids: string[] | null;
  price_text: string | null;
  photos: string[] | null;
  description: string | null;
  status: string | null;
  updated_at: string | null;
  is_verified: boolean | null;
};

type VehicleInfo = {
  key: string;
  label: string;
  title: string;
  slugPart: string;
  emoji: string;
};

type SeoPage = {
  slug: string;
  city: RentCity;
  pageType: 'vehicle' | 'use-case';
  vehicleType: string;
  vehicleKey: string;
  vehicleLabel: string;
  vehicleTitle: string;
  emoji: string;
  useCaseKey?: string;
  useCaseLabel?: string;
  useCaseTitle?: string;
  relatedVehicleLabels?: string[];
  listings: RentListing[];
};

type UseCaseInfo = {
  key: string;
  label: string;
  title: string;
  slugPart: string;
  emoji: string;
  relatedVehicleKeys: string[];
  relatedVehicleLabels: string[];
  purposeWords: string[];
  titleSuffix: string;
};

function cleanText(value: unknown) {
  return String(value || '').trim();
}

function slugify(value: unknown) {
  return cleanText(value)
    .toLowerCase()
    .replace(/&/g, ' and ')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');
}

function titleCase(value: unknown) {
  return cleanText(value)
    .toLowerCase()
    .replace(/\b\w/g, (char) => char.toUpperCase());
}

function cityName(city: RentCity | undefined | null) {
  if (!city) return '';
  return cleanText(city.name_en || city.name || city.name_bn);
}

function displayCityName(city: RentCity | undefined | null) {
  return titleCase(cityName(city));
}

function vehicleInfo(value: unknown): VehicleInfo {
  const v = cleanText(value).toLowerCase();

  if (v.includes('ambulance')) {
    return {
      key: 'ambulance',
      label: 'Ambulance',
      title: 'Ambulance Service',
      slugPart: 'ambulance-service',
      emoji: '🚑',
    };
  }

  if (v.includes('pickup')) {
    return {
      key: 'pickup-van',
      label: 'Pickup Van',
      title: 'Pickup Van Rental',
      slugPart: 'pickup-van-rental',
      emoji: '🚚',
    };
  }

  if (v.includes('bus')) {
    return {
      key: 'bus',
      label: 'Bus',
      title: 'Bus Rental with Driver',
      slugPart: 'bus-rental',
      emoji: '🚌',
    };
  }

  if (v.includes('toto')) {
    return {
      key: 'toto',
      label: 'Toto',
      title: 'Toto Rental',
      slugPart: 'toto-rental',
      emoji: '🛺',
    };
  }

  if (v.includes('auto')) {
    return {
      key: 'auto',
      label: 'Auto',
      title: 'Auto Rental',
      slugPart: 'auto-rental',
      emoji: '🛺',
    };
  }

  return {
    key: 'car',
    label: 'Car',
    title: 'Car Rental with Driver',
    slugPart: 'car-rental',
    emoji: '🚗',
  };
}


const USE_CASE_PAGES: UseCaseInfo[] = [
  {
    key: 'wedding',
    label: 'Wedding',
    title: 'Wedding Car and Bus Rental',
    slugPart: 'wedding-car-bus-rental',
    emoji: '💒',
    relatedVehicleKeys: ['car', 'bus', 'pickup-van', 'auto', 'toto'],
    relatedVehicleLabels: ['Car', 'Bus', 'Pickup Van', 'Auto', 'Toto'],
    purposeWords: ['wedding', 'marriage', 'bride', 'groom', 'event'],
    titleSuffix: 'Bride/Groom Car, Guest Bus, Full Day Package',
  },
  {
    key: 'tour',
    label: 'Tour',
    title: 'Tour Car and Bus Rental',
    slugPart: 'tour-car-bus-rental',
    emoji: '🧳',
    relatedVehicleKeys: ['car', 'bus', 'auto', 'toto'],
    relatedVehicleLabels: ['Car', 'Bus', 'Auto', 'Toto'],
    purposeWords: ['tour', 'picnic', 'outstation', 'family trip', 'group travel'],
    titleSuffix: 'Tour Car, Tour Bus, Full Day and Outstation',
  },
  {
    key: 'local',
    label: 'Local',
    title: 'Local Car, Toto and Auto Rental',
    slugPart: 'local-car-toto-auto-rental',
    emoji: '📍',
    relatedVehicleKeys: ['car', 'toto', 'auto', 'pickup-van'],
    relatedVehicleLabels: ['Car', 'Toto', 'Auto', 'Pickup Van'],
    purposeWords: ['local', 'local trip', 'station pickup', 'market', 'short distance', 'daily local'],
    titleSuffix: 'Local Trip, Station Pickup, Market Travel',
  },
  {
    key: 'emergency',
    label: 'Emergency',
    title: 'Emergency Ambulance Rental',
    slugPart: 'emergency-ambulance-rental',
    emoji: '🚑',
    relatedVehicleKeys: ['ambulance', 'car'],
    relatedVehicleLabels: ['Ambulance', 'Car'],
    purposeWords: ['emergency', 'ambulance', 'hospital', 'patient', 'clinic', 'nursing home'],
    titleSuffix: 'Ambulance, Hospital Transfer, Patient Transport',
  },
  {
    key: 'goods',
    label: 'Goods/Parcel',
    title: 'Goods Pickup Van Rental',
    slugPart: 'goods-pickup-van-rental',
    emoji: '📦',
    relatedVehicleKeys: ['pickup-van', 'auto', 'toto'],
    relatedVehicleLabels: ['Pickup Van', 'Auto', 'Toto'],
    purposeWords: ['goods', 'parcel', 'delivery', 'shifting', 'transport', 'business'],
    titleSuffix: 'Pickup Van, Parcel, Local Goods Transport',
  },
  {
    key: 'school-office',
    label: 'School/Office',
    title: 'School Office Car and Bus Rental',
    slugPart: 'school-office-car-bus-rental',
    emoji: '🏫',
    relatedVehicleKeys: ['car', 'bus', 'auto', 'toto'],
    relatedVehicleLabels: ['Car', 'Bus', 'Auto', 'Toto'],
    purposeWords: ['school', 'office', 'staff', 'student', 'daily', 'monthly'],
    titleSuffix: 'School, Office, Staff and Daily Travel',
  },
];

function useCaseInfo(key: string | undefined | null) {
  return USE_CASE_PAGES.find((item) => item.key === key) || USE_CASE_PAGES[0];
}

function normalizePurpose(value: unknown) {
  return cleanText(value).toLowerCase().replace(/[-_/]+/g, ' ');
}

function listingPurposeText(listing: RentListing) {
  const parts = Array.isArray(listing.purposes) ? listing.purposes : [];
  return parts.map(normalizePurpose).join(' ');
}

function listingMatchesUseCasePage(listing: RentListing, useCaseKey: string) {
  const useCase = useCaseInfo(useCaseKey);
  const vehicle = vehicleInfo(listing.vehicle_type);
  const purposeText = listingPurposeText(listing);
  const hasPurposeMatch = useCase.purposeWords.some((word) => purposeText.includes(normalizePurpose(word)));
  const vehicleRelated = useCase.relatedVehicleKeys.includes(vehicle.key);

  if (hasPurposeMatch) return vehicleRelated || useCase.key === 'emergency' || useCase.key === 'goods';
  return vehicleRelated;
}

function collectUseCasePurposes(useCaseKey: string | undefined | null) {
  const useCase = useCaseInfo(useCaseKey);

  const map: Record<string, string[]> = {
    wedding: ['Wedding', 'Bride/Groom Travel', 'Guest Pickup', 'Full Day Package', 'Family Travel', 'Decoration/Goods Support'],
    tour: ['Tour', 'Outstation', 'Picnic', 'Group Travel', 'Full Day Rental', 'Per KM Price'],
    local: ['Local Trip', 'Station Pickup', 'Market Trip', 'Short Distance', 'Daily Local Travel', 'Fixed Price'],
    emergency: ['Emergency', 'Ambulance', 'Hospital Transfer', 'Patient Transport', 'Clinic Transfer', '24/7 Availability'],
    goods: ['Goods Transport', 'Parcel Delivery', 'Pickup Van', 'House Shifting', 'Local Delivery', 'Small Business Delivery'],
    'school-office': ['School/Office', 'Staff Transport', 'Student Travel', 'Daily Pickup', 'Monthly Rental', 'Route Based Price'],
  };

  return map[useCase.key] || map.wedding;
}

function useCaseContent(city: string, page: SeoPage, ownerText: string, seatText: string) {
  const useCase = useCaseInfo(page.useCaseKey);
  const vehicleText = (page.relatedVehicleLabels || useCase.relatedVehicleLabels).join(', ');

  const content: Record<string, string[]> = {
    wedding: [
      `Find wedding car and bus rental in ${city} for bride and groom travel, guest pickup, family movement, decoration support and full day wedding booking. SoniaBuddy shows local owner listings for ${vehicleText}, so users can compare photos, seats, model, price text and direct call or WhatsApp contact in one page.`,
      `For wedding rent, different vehicles solve different needs. Cars are useful for bride/groom and family travel, buses are useful for guest pickup and group movement, while pickup vans may help with decoration, sound or wedding goods transport. Some owners may offer fixed price packages, full day rates or per kilometre pricing depending on date, distance, route and waiting time.`,
      `Before booking, confirm final rent, pickup point, reporting time, return time, decoration permission, night charge, toll, parking and driver allowance directly with the owner. This page has ${ownerText} and ${seatText}, but SoniaBuddy is only a listing platform; final price, availability and service quality are managed by individual owners.`,
    ],
    tour: [
      `Find tour car and bus rental in ${city} for family trips, picnic, group travel, outstation journeys and full day sightseeing. SoniaBuddy lists local owners with ${vehicleText}, helping users compare seating capacity, vehicle condition, photos, price text and direct owner contact before planning a trip.`,
      `Tour rental needs can be different from local travel. A small family may need a car with driver, while a picnic or group journey may need a bus. Owners may provide fixed tour packages, full day rates, per kilometre pricing or outstation plans based on destination, distance, date, waiting time and night halt requirements.`,
      `Users should confirm route, pickup time, number of passengers, luggage space, driver allowance, toll, parking and extra kilometre charges before booking. SoniaBuddy does not set final rent; it only helps users discover active local listings and contact vehicle owners directly by phone or WhatsApp.`,
    ],
    local: [
      `Find local car, toto and auto rental in ${city} for station pickup, market trip, family movement, short distance travel and nearby city visits. SoniaBuddy helps users compare ${vehicleText} listings from local owners with available photos, seats, price text, purpose tags and direct contact options.`,
      `Local rental is useful when users need quick pickup, flexible timing or short-route travel with a known local owner. Cars may be used for family or nearby travel, toto and auto options are useful for short distance and city movement, while pickup vans may help with small goods or local delivery needs.`,
      `Before confirming a local trip, call or WhatsApp the owner and ask about fixed price, waiting time, pickup location, return timing and extra charges. SoniaBuddy is only a listing platform, so final availability, rent and service details must be confirmed directly with the vehicle owner.`,
    ],
    emergency: [
      `Find emergency ambulance rental in ${city} for hospital transfer, patient transport, clinic movement, nursing home travel and urgent medical trips. SoniaBuddy lists local ambulance and related emergency transport contacts so users can quickly compare owner details, phone number, WhatsApp availability and service area.`,
      `Emergency travel needs fast confirmation. Ambulance listings may support hospital pickup, patient shifting or medical transfer, while some car owners may help with urgent non-critical hospital travel if clearly listed. Users should always confirm vehicle availability, pickup point, destination hospital, timing and any medical support requirement before starting.`,
      `SoniaBuddy does not operate ambulance services directly and does not guarantee emergency response time. It only shows active owner listings. For serious medical emergencies, users should also contact official emergency numbers and nearby hospitals while confirming the listed owner by phone.`,
    ],
    goods: [
      `Find goods pickup van rental in ${city} for parcel delivery, local goods movement, small business transport, house shifting support and market supply trips. SoniaBuddy shows local ${vehicleText} listings with owner contact, price text, photos and service area so users can compare before hiring.`,
      `Goods transport pricing can depend on distance, item size, loading time, labour requirement, route, waiting time and return trip. Pickup vans are useful for larger goods, while auto or toto listings may help for small parcels or local delivery if the owner provides that service.`,
      `Before booking, confirm vehicle size, load capacity, pickup point, delivery location, loading/unloading responsibility, waiting charge and final rent directly with the owner. SoniaBuddy is only a listing platform and does not handle goods safety, payment or transport responsibility.`,
    ],
    'school-office': [
      `Find school and office car or bus rental in ${city} for student pickup, staff transport, daily route travel, monthly rental and scheduled local movement. SoniaBuddy helps users compare ${vehicleText} listings with seats, owner name, price text, photos and direct contact options.`,
      `School-office transport is different from one-time booking because timing, route, safety, passenger count and monthly price matter. Cars may work for small groups, while buses are suitable for students or staff groups. Auto and toto listings may also be useful for short local route travel if available.`,
      `Before confirming, discuss route, pickup time, drop time, monthly or daily price, holidays, driver details, seating capacity and emergency contact with the owner. SoniaBuddy only lists vehicle owners; final agreement, safety checks and payment terms must be managed directly between user and owner.`,
    ],
  };

  return content[useCase.key] || content.wedding;
}

function listingCityIds(listing: RentListing) {
  const ids = new Set<string>();

  if (listing.base_city_id) ids.add(listing.base_city_id);

  if (Array.isArray(listing.service_city_ids)) {
    listing.service_city_ids.forEach((id) => {
      if (id) ids.add(id);
    });
  }

  return Array.from(ids);
}

function listingMatchesPage(listing: RentListing, cityId: string, page: SeoPage) {
  if (!listingCityIds(listing).includes(cityId)) return false;

  if (page.pageType === 'use-case' && page.useCaseKey) {
    return listingMatchesUseCasePage(listing, page.useCaseKey);
  }

  const vehicle = vehicleInfo(listing.vehicle_type);
  return vehicle.key === page.vehicleKey;
}

function collectPurposes(listings: RentListing[], vehicleLabel: string) {
  const found = new Set<string>();

  listings.forEach((listing) => {
    if (Array.isArray(listing.purposes)) {
      listing.purposes.forEach((purpose) => {
        const p = titleCase(purpose);
        if (p) found.add(p);
      });
    }
  });

  const staticPurposesByVehicle: Record<string, string[]> = {
    Car: [
      'Cheap Rent',
      'Wedding',
      'Tour',
      'Local Trip',
      'Outstation',
      'Family Trip',
      'Station Pickup',
      'Airport Pickup',
    ],
    Bus: [
      'Wedding',
      'Tour',
      'Group Travel',
      'School Office',
      'Picnic',
      'Event Transport',
      'Outstation',
    ],
    Toto: [
      'Local Trip',
      'Market Trip',
      'Station Pickup',
      'Short Distance',
      'Daily Local Travel',
    ],
    Auto: [
      'Local Trip',
      'Station Pickup',
      'Short Distance',
      'Daily Local Travel',
    ],
    'Pickup Van': [
      'Goods Transport',
      'Parcel Delivery',
      'House Shifting',
      'Local Delivery',
      'Small Business Delivery',
    ],
    Ambulance: [
      'Emergency',
      'Hospital Transfer',
      'Patient Transport',
      'Clinic Transfer',
      'Nursing Home Transfer',
    ],
  };

  const staticPurposes = staticPurposesByVehicle[vehicleLabel] || staticPurposesByVehicle.Car;

  staticPurposes.forEach((purpose) => found.add(purpose));

  return Array.from(found).slice(0, 8);
}
function purposeHeading(purpose: string, vehicleLabel: string, city: string) {
  const p = titleCase(purpose);

  if (vehicleLabel === 'Ambulance') return `${p} Ambulance Service in ${city}`;
  if (vehicleLabel === 'Pickup Van') return `${p} Pickup Van Rental in ${city}`;
  if (vehicleLabel === 'Bus') return `${p} Bus Rental in ${city}`;
  if (vehicleLabel === 'Toto') return `${p} Toto Rental in ${city}`;
  if (vehicleLabel === 'Auto') return `${p} Auto Rental in ${city}`;

  return `${p} Car Rental in ${city}`;
}

function titleForListing(listing: RentListing) {
  const vehicle = vehicleInfo(listing.vehicle_type);
  const model = cleanText(listing.vehicle_model);
  const seats = listing.seats ? `${listing.seats} seater` : '';

  return [vehicle.label, model].filter(Boolean).join(' · ');
}

function modelText(listing: RentListing) {
  return cleanText(listing.vehicle_model);
}

function onlyDigits(value: unknown) {
  return String(value || '').replace(/\D/g, '');
}

function whatsappNumber(listing: RentListing) {
  const raw = onlyDigits(listing.owner_whatsapp || listing.owner_phone || '');
  if (raw.length === 10) return `91${raw}`;
  return raw;
}

function publicPhotoUrl(path: string | null | undefined) {
  if (!path) return '';
  if (path.startsWith('http://') || path.startsWith('https://')) return path;

  const { data } = supabase.storage.from(PHOTO_BUCKET).getPublicUrl(path);
  return data.publicUrl;
}

function firstPhoto(listing: RentListing) {
  const photos = Array.isArray(listing.photos) ? listing.photos : [];
  return publicPhotoUrl(photos[0]);
}

export async function getStaticPaths() {
  try {
    function localClean(value: unknown) {
      return String(value || '').trim();
    }

    function localSlugify(value: unknown) {
      return localClean(value)
        .toLowerCase()
        .replace(/&/g, ' and ')
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-+|-+$/g, '');
    }

    function localCityName(city: any) {
      return localClean(city?.name_en || city?.name || city?.name_bn);
    }

    function localVehicle(value: unknown): VehicleInfo {
      const v = localClean(value).toLowerCase();

      if (v.includes('ambulance')) {
        return { key: 'ambulance', label: 'Ambulance', title: 'Ambulance Service', slugPart: 'ambulance-service', emoji: '🚑' };
      }

      if (v.includes('pickup')) {
        return { key: 'pickup-van', label: 'Pickup Van', title: 'Pickup Van Rental', slugPart: 'pickup-van-rental', emoji: '🚚' };
      }

      if (v.includes('bus')) {
        return { key: 'bus', label: 'Bus', title: 'Bus Rental with Driver', slugPart: 'bus-rental', emoji: '🚌' };
      }

      if (v.includes('toto')) {
        return { key: 'toto', label: 'Toto', title: 'Toto Rental', slugPart: 'toto-rental', emoji: '🛺' };
      }

      if (v.includes('auto')) {
        return { key: 'auto', label: 'Auto', title: 'Auto Rental', slugPart: 'auto-rental', emoji: '🛺' };
      }

      return { key: 'car', label: 'Car', title: 'Car Rental with Driver', slugPart: 'car-rental', emoji: '🚗' };
    }

    function localListingCityIds(listing: any) {
      const ids = new Set<string>();

      if (listing?.base_city_id) ids.add(listing.base_city_id);

      if (Array.isArray(listing?.service_city_ids)) {
        listing.service_city_ids.forEach((id: string) => {
          if (id) ids.add(id);
        });
      }

      return Array.from(ids);
    }

    const { data: citiesData, error: cityError } = await supabase
      .from('rent_cities')
      .select('id,name,name_en,name_bn,district_en,district_bn,search_keywords_en,search_keywords_bn')
      .eq('active', true);

    if (cityError) {
      console.error('RENT SEO CITY ERROR:', cityError.message);
      return [];
    }

    const { data: listingsData, error: listingError } = await supabase
      .from('rent_listings')
      .select(`
        id,
        owner_name,
        owner_phone,
        owner_whatsapp,
        vehicle_type,
        vehicle_model,
        seats,
        purposes,
        base_city_id,
        service_city_ids,
        price_text,
        photos,
        description,
        status,
        updated_at,
        is_verified
      `)
      .eq('status', 'active')
      .limit(500);

    if (listingError) {
      console.error('RENT SEO LISTING ERROR:', listingError.message);
      return [];
    }

    const cities = Array.isArray(citiesData) ? citiesData : [];
    const listings = Array.isArray(listingsData) ? listingsData : [];

    console.log('RENT SEO cities:', cities.length);
    console.log('RENT SEO active listings:', listings.length);

    const cityById = new Map<string, any>(cities.map((city: any) => [city.id, city]));
    const pageMap = new Map<string, SeoPage>();

    const localUseCasePages = [
      {
        key: 'wedding',
        label: 'Wedding',
        title: 'Wedding Car and Bus Rental',
        slugPart: 'wedding-car-bus-rental',
        emoji: '💒',
        relatedVehicleKeys: ['car', 'bus', 'pickup-van', 'auto', 'toto'],
        relatedVehicleLabels: ['Car', 'Bus', 'Pickup Van', 'Auto', 'Toto'],
        purposeWords: ['wedding', 'marriage', 'bride', 'groom', 'event'],
      },
      {
        key: 'tour',
        label: 'Tour',
        title: 'Tour Car and Bus Rental',
        slugPart: 'tour-car-bus-rental',
        emoji: '🧳',
        relatedVehicleKeys: ['car', 'bus', 'auto', 'toto'],
        relatedVehicleLabels: ['Car', 'Bus', 'Auto', 'Toto'],
        purposeWords: ['tour', 'picnic', 'outstation', 'family trip', 'group travel'],
      },
      {
        key: 'local',
        label: 'Local',
        title: 'Local Car, Toto and Auto Rental',
        slugPart: 'local-car-toto-auto-rental',
        emoji: '📍',
        relatedVehicleKeys: ['car', 'toto', 'auto', 'pickup-van'],
        relatedVehicleLabels: ['Car', 'Toto', 'Auto', 'Pickup Van'],
        purposeWords: ['local', 'local trip', 'station pickup', 'market', 'short distance', 'daily local'],
      },
      {
        key: 'emergency',
        label: 'Emergency',
        title: 'Emergency Ambulance Rental',
        slugPart: 'emergency-ambulance-rental',
        emoji: '🚑',
        relatedVehicleKeys: ['ambulance', 'car'],
        relatedVehicleLabels: ['Ambulance', 'Car'],
        purposeWords: ['emergency', 'ambulance', 'hospital', 'patient', 'clinic', 'nursing home'],
      },
      {
        key: 'goods',
        label: 'Goods/Parcel',
        title: 'Goods Pickup Van Rental',
        slugPart: 'goods-pickup-van-rental',
        emoji: '📦',
        relatedVehicleKeys: ['pickup-van', 'auto', 'toto'],
        relatedVehicleLabels: ['Pickup Van', 'Auto', 'Toto'],
        purposeWords: ['goods', 'parcel', 'delivery', 'shifting', 'transport', 'business'],
      },
      {
        key: 'school-office',
        label: 'School/Office',
        title: 'School Office Car and Bus Rental',
        slugPart: 'school-office-car-bus-rental',
        emoji: '🏫',
        relatedVehicleKeys: ['car', 'bus', 'auto', 'toto'],
        relatedVehicleLabels: ['Car', 'Bus', 'Auto', 'Toto'],
        purposeWords: ['school', 'office', 'staff', 'student', 'daily', 'monthly'],
      },
    ];

    function localNormalizePurpose(value: unknown) {
      return localClean(value).toLowerCase().replace(/[-_/]+/g, ' ');
    }

    function localListingPurposeText(listing: any) {
      const parts = Array.isArray(listing?.purposes) ? listing.purposes : [];
      return parts.map(localNormalizePurpose).join(' ');
    }

    function localListingMatchesUseCasePage(listing: any, useCase: any) {
      const vehicle = localVehicle(listing.vehicle_type);
      const purposeText = localListingPurposeText(listing);
      const hasPurposeMatch = useCase.purposeWords.some((word: string) => purposeText.includes(localNormalizePurpose(word)));
      const vehicleRelated = useCase.relatedVehicleKeys.includes(vehicle.key);

      if (hasPurposeMatch) return vehicleRelated || useCase.key === 'emergency' || useCase.key === 'goods';
      return vehicleRelated;
    }

    for (const listing of listings as any[]) {
      const vehicle = localVehicle(listing.vehicle_type);
      const cityIds = localListingCityIds(listing);

      for (const cityId of cityIds) {
        const city = cityById.get(cityId);
        if (!city) continue;

        const name = localCityName(city);
        const cSlug = localSlugify(name);
        if (!cSlug) continue;

        const slug = `${vehicle.slugPart}-in-${cSlug}`;
        const existing = pageMap.get(slug);

        if (existing) {
          existing.listings.push(listing as RentListing);
          continue;
        }

        pageMap.set(slug, {
          slug,
          city: city as RentCity,
          pageType: 'vehicle',
          vehicleType: localClean(listing.vehicle_type),
          vehicleKey: vehicle.key,
          vehicleLabel: vehicle.label,
          vehicleTitle: vehicle.title,
          emoji: vehicle.emoji,
          listings: [listing as RentListing],
        });
      }
    }

    for (const city of cities as any[]) {
      const name = localCityName(city);
      const cSlug = localSlugify(name);
      if (!cSlug) continue;

      const cityListings = (listings as any[]).filter((listing) =>
        localListingCityIds(listing).includes(city.id)
      );

      if (!cityListings.length) continue;

      for (const useCase of localUseCasePages) {
        const matchedListings = cityListings.filter((listing) =>
          localListingMatchesUseCasePage(listing, useCase)
        );

        if (!matchedListings.length) continue;

        const slug = `${useCase.slugPart}-in-${cSlug}`;

        pageMap.set(slug, {
          slug,
          city: city as RentCity,
          pageType: 'use-case',
          vehicleType: 'all',
          vehicleKey: 'all',
          vehicleLabel: useCase.label,
          vehicleTitle: useCase.title,
          emoji: useCase.emoji,
          useCaseKey: useCase.key,
          useCaseLabel: useCase.label,
          useCaseTitle: useCase.title,
          relatedVehicleLabels: useCase.relatedVehicleLabels,
          listings: matchedListings as RentListing[],
        });
      }
    }

    const pages = Array.from(pageMap.values());

    console.log('RENT SEO pages created:', pages.map((page) => page.slug).join(', '));

    return pages.map((page) => ({
      params: {
        slug: page.slug,
      },
      props: {
        page,
      },
    }));
  } catch (error) {
    console.error('RENT SEO getStaticPaths crashed:', error);
    return [];
  }
}

const { page } = Astro.props as { page: SeoPage };

const city = displayCityName(page.city);

const cityId = page.city.id;

const listings = page.listings
  .filter((listing) => listingMatchesPage(listing, cityId, page))
  .slice(0, 50);

const isUseCasePage = page.pageType === 'use-case';
const useCase = useCaseInfo(page.useCaseKey);
const pageTitleText = isUseCasePage ? `${useCase.title} in ${city}` : `${page.vehicleTitle} in ${city}`;
const pageBadgeText = isUseCasePage
  ? `${useCase.emoji} ${useCase.label} Rental`
  : `${page.emoji} ${page.vehicleLabel} Rental`;
const relatedVehicleText = isUseCasePage
  ? (page.relatedVehicleLabels || useCase.relatedVehicleLabels).join(', ')
  : page.vehicleLabel;

const purposes = isUseCasePage ? collectUseCasePurposes(page.useCaseKey) : collectPurposes(listings, page.vehicleLabel);
const primaryPurpose = titleCase(purposes[0] || 'Local Trip');
const purposeList = purposes.map((purpose) => titleCase(purpose)).join(', ');

const canonicalUrl = `${SITE_URL}/rent/${page.slug}/`;
const shortUseCaseTitle: Record<string, string> = {
  wedding: `Wedding Car and Bus Rental in ${city}`,
  tour: `Tour Car and Bus Rental in ${city}`,
  local: `Local Car, Toto and Auto Rental in ${city}`,
  emergency: `Emergency Ambulance Rental in ${city}`,
  goods: `Goods Pickup Van Rental in ${city}`,
  'school-office': `School Office Car and Bus Rental in ${city}`,
};

const shortUseCaseSuffix: Record<string, string> = {
  wedding: 'Bride Car, Guest Bus, Local Owners',
  tour: 'Local Driver Vehicle Rent',
  local: 'Short Trip, Station Pickup',
  emergency: 'Local Ambulance & Car Listings',
  goods: 'Local Parcel Transport',
  'school-office': 'Staff & Student Transport',
};

const title = isUseCasePage
  ? `${shortUseCaseTitle[useCase.key] || `${useCase.title} in ${city}`} | ${shortUseCaseSuffix[useCase.key] || 'Local Vehicle Owners'} | SoniaBuddy`
  : `${page.vehicleLabel} Rental in ${city} | Local ${page.vehicleLabel} Rent with Driver | SoniaBuddy`;

const description = isUseCasePage
  ? `Find ${shortUseCaseTitle[useCase.key]?.toLowerCase() || useCase.title.toLowerCase()} with active local owner listings. Compare ${relatedVehicleText.toLowerCase()}, seats, model, price text, call number and WhatsApp contact on SoniaBuddy.`
  : `Find ${page.vehicleLabel.toLowerCase()} rental in ${city} with driver. Compare active local owner listings, seats, vehicle model, price text, call number and WhatsApp contact on SoniaBuddy.`;
const verifiedCount = listings.filter((listing) => listing.is_verified).length;
const seatValues = listings
  .map((listing) => listing.seats)
  .filter((seat): seat is number => typeof seat === 'number' && seat > 0);

const minSeats = seatValues.length ? Math.min(...seatValues) : null;
const maxSeats = seatValues.length ? Math.max(...seatValues) : null;

const seatText =
  minSeats && maxSeats
    ? minSeats === maxSeats
      ? `${minSeats} seater options`
      : `${minSeats} to ${maxSeats} seater options`
    : 'different seating options';

const ownerText =
  listings.length === 1
    ? '1 active local owner listing'
    : `${listings.length} active local owner listings`;

const seoContentParagraphs = isUseCasePage ? useCaseContent(city, page, ownerText, seatText) : [];
const listingSectionTitle = isUseCasePage
  ? `Available ${relatedVehicleText} Listings for ${useCase.label} in ${city}`
  : `Available ${page.vehicleLabel} Listings in ${city}`;

const heroIntro = isUseCasePage
  ? `Find ${useCase.title.toLowerCase()} in ${city} with ${relatedVehicleText.toLowerCase()} options. SoniaBuddy helps users compare ${ownerText}, ${seatText}, price text, owner name, call option and WhatsApp contact in one simple page.`
  : `Find ${page.vehicleTitle.toLowerCase()} in ${city} for ${purposeList}. SoniaBuddy helps users compare ${ownerText}, ${seatText}, price text, owner name, call option and WhatsApp contact in one simple page.`;

const firstContentHeading = isUseCasePage
  ? `${useCase.label} rental options in ${city}`
  : `${page.vehicleTitle} use cases in ${city}`;

const aboutNeedText = isUseCasePage
  ? `${useCase.label.toLowerCase()} rental with ${relatedVehicleText.toLowerCase()}`
  : `${page.vehicleLabel.toLowerCase()} options`;

const chooseLabel = isUseCasePage ? useCase.label : page.vehicleLabel;
const faqTitleText = isUseCasePage ? useCase.title : `${page.vehicleLabel} Rental`;
const faqFindText = isUseCasePage ? useCase.title.toLowerCase() : page.vehicleTitle.toLowerCase();
const faqBookText = isUseCasePage ? `${useCase.label.toLowerCase()} rental` : page.vehicleLabel.toLowerCase();

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: pageTitleText,
  description,
  provider: {
    '@type': 'Organization',
    name: 'SoniaBuddy',
    url: SITE_URL,
  },
  areaServed: {
    '@type': 'City',
    name: city,
  },
  serviceType: [
    pageTitleText,
    ...purposes.map((purpose) => purposeHeading(purpose, page.vehicleLabel, city)),
  ].join(', '),
  url: canonicalUrl,
};

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: isUseCasePage ? `${useCase.title} listings in ${city}` : `${page.vehicleTitle} listings in ${city}`,
  itemListElement: listings.slice(0, 30).map((listing, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    item: {
      '@type': 'Service',
      name: titleForListing(listing),
      description: listing.description || description,
      serviceType: pageTitleText,
      provider: {
        '@type': 'Organization',
        name: listing.owner_name || 'Local vehicle owner',
      },
      areaServed: {
        '@type': 'City',
        name: city,
      },
    },
  })),
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: SITE_URL,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Rent Vehicle',
      item: `${SITE_URL}/rent-vehicle`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: pageTitleText,
      item: canonicalUrl,
    },
  ],
};
---

<BaseLayout title={title} description={description} canonical={canonicalUrl}>
  <Fragment slot="head">
    
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <script type="application/ld+json" set:html={JSON.stringify(serviceJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(itemListJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  </Fragment>

    <main class="rent-seo-page">
    <section class="hero">
      <div class="hero-badge">{pageBadgeText}</div>

      <h1>{pageTitleText}</h1>

      <p>{heroIntro}</p>
    </section>
         <section class="seo-listing-card">
      <div class="section-heading-row">
        <h2>{listingSectionTitle}</h2>
        <p>{listings.length} active listing{listings.length === 1 ? '' : 's'} found from local owners.</p>
      </div>

      <div class="seo-rent-grid">
        {listings.map((listing) => {
          const phone = onlyDigits(listing.owner_phone);
          const wa = whatsappNumber(listing);
          const img = firstPhoto(listing);
          const listingVehicle = vehicleInfo(listing.vehicle_type);
          const listingModel = modelText(listing);
          const listingPurposes = Array.isArray(listing.purposes) ? listing.purposes.filter(Boolean) : [];
          
          return (
            <article class="seo-rent-card">
              <div class="seo-rent-photo">
                {img ? (
                  <img src={img} alt={`${listingVehicle.label} ${listingModel || 'rental'} in ${city}`} loading="lazy" decoding="async" />
                ) : (
                  <span>{listingVehicle.emoji}</span>
                )}
              </div>

              <div class="seo-rent-body">
                <div class="seo-rent-headline">
                  <h3>{titleForListing(listing)}</h3>
                  <span class="vehicle-type-pill">{listingVehicle.label}</span>
                  {listing.is_verified && <span class="verified-pill">Verified</span>}
                </div>

                <p class="owner-line">Owner: {listing.owner_name || 'Local vehicle owner'}</p>

                <div class="facts">
  <span>Vehicle: {listingVehicle.label}</span>
  {listingModel && <span>Model: {listingModel}</span>}
  {listing.price_text && <span>Price: {listing.price_text}</span>}
  {listingPurposes.length > 0 && (
    <span class="purpose-fact">Purpose: {listingPurposes.map((purpose) => titleCase(purpose)).join(' • ')}</span>
  )}
</div>

                

                <div class="seo-rent-actions">
                  {phone ? (
                    <a class="mini-btn call" href={`tel:${phone}`}>📞 Call</a>
                  ) : (
                    <span class="mini-btn disabled">No Phone</span>
                  )}

                  {wa ? (
                    <a class="mini-btn wa" href={`https://wa.me/${wa}`} target="_blank" rel="noopener noreferrer">
                      💬 WhatsApp
                    </a>
                  ) : (
                    <span class="mini-btn disabled">No WhatsApp</span>
                  )}
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </section>
    <section class="content-card">
      <h2>{firstContentHeading}</h2>

      <div class="chips">
        {purposes.map((purpose) => (
          <span>{titleCase(purpose)}</span>
        ))}
      </div>

      {isUseCasePage ? (
        seoContentParagraphs.map((paragraph) => <p>{paragraph}</p>)
      ) : (
        <p>
          People usually need {page.vehicleLabel.toLowerCase()} rental in {city} for {purposeList}.
          These use cases include both active owner listing data and common rental needs such as cheap rent,
          wedding travel, tour plans, local trips, family travel, outstation journeys, station pickup and airport pickup.
          Before booking, compare seat capacity, vehicle condition, pickup location, trip duration and final rent.
          Always confirm whether toll, parking, waiting time, night charge or extra kilometer charge is included in the quoted price.
        </p>
      )}
    </section>

    

    <section class="content-card">
      <h2>About {pageTitleText}</h2>

      <p>
        SoniaBuddy is a local vehicle rental discovery page for people who need {aboutNeedText} in {city}.
        This page is generated from active owner listings and helps users compare available vehicles, seating capacity,
        owner name, price text, purpose tags, call option and 💬 WhatsApp contact before making a booking decision.
        Current listings include {ownerText}, {seatText}, and {verifiedCount > 0 ? `${verifiedCount} verified listing${verifiedCount === 1 ? '' : 's'}` : 'owner-submitted listings'}.
      </p>

      <p>
        SoniaBuddy does not set the final rent amount. Users should confirm the final price directly with the owner
        because cost can change based on distance, pickup point, date, waiting time, night charge, toll, parking and route.
      </p>

      <p class="bn-line">
        বাংলা: {city} এলাকায় {page.vehicleLabel} ভাড়া খুঁজতে এই পেজে সক্রিয় গাড়ির মালিকদের তথ্য, আসন সংখ্যা, ব্যবহার, ফোন এবং 💬 WhatsApp যোগাযোগ দেখা যায়।
      </p>
    </section>

    <section class="content-card">
      <h2>How to choose the right {chooseLabel} rental in {city}</h2>

      <p>
        Start by checking the number of seats, vehicle model, owner name and price text shown in the listing.
        For family travel, choose a vehicle with enough luggage space and comfortable seating.
        For wedding or group travel, confirm reporting time, return time, decoration permission and waiting charges.
        For outstation or longer trips, ask about per-kilometer charges, driver allowance, toll, parking and night halt charges.
        Calling the owner directly is the fastest way to confirm availability and avoid misunderstanding before the trip.
      </p>

      <p class="bn-line">
        বাংলা: বুকিং করার আগে গাড়ির আসন সংখ্যা, ভাড়া, পিকআপ পয়েন্ট, সময়, দূরত্ব এবং অতিরিক্ত চার্জ মালিকের সঙ্গে নিশ্চিত করুন।
      </p>
    </section>

    <section class="faq-card">
      <h2>FAQs about {faqTitleText} in {city}</h2>

      <details open>
        <summary>How can I find {faqFindText} in {city}?</summary>
        <p>
          You can check the active listings on this page and contact the vehicle owner directly by phone or WhatsApp.
          Each listing may include vehicle model, seats, purpose, price text and owner details.
        </p>
      </details>

      <details>
        <summary>Is the rent price fixed on SoniaBuddy?</summary>
        <p>
          No. SoniaBuddy shows owner listings and contact details. The final rent should be confirmed with the owner because price can change by distance, date, pickup point, waiting time, route and vehicle type.
        </p>
      </details>

      <details>
        <summary>Can I book {faqBookText} for {primaryPurpose.toLowerCase()}?</summary>
        <p>
          Yes, if the listing includes {primaryPurpose.toLowerCase()} or a similar purpose, you can contact the owner and confirm availability.
          Always mention your date, pickup location, destination and number of passengers.
        </p>
      </details>

      <details>
        <summary>What should I confirm before calling a {faqBookText} owner?</summary>
        <p>
          Confirm vehicle seats, total rent, pickup time, pickup place, destination, waiting charge, toll, parking and whether WhatsApp communication is available for sharing trip details.
        </p>
      </details>

      <details>
        <summary>Can vehicle owners add their listing on SoniaBuddy?</summary>
        <p>
          Yes. Vehicle owners can register their vehicle on SoniaBuddy. After the listing becomes active, it can appear on city-based rental pages like this one.
        </p>
      </details>
    </section>
  </main>
</BaseLayout>

<style>
