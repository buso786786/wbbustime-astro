    .faq-card,
    .seo-listing-card,
    .content-grid article {
      border-radius: 0.72rem;
      padding: 0.6rem;
    }

    .seo-rent-card {
  grid-template-columns: 104px minmax(0, 1fr);
  gap: 0.55rem;
  padding: 0.62rem;
}

.seo-rent-photo {
  width: 104px;
  height: 104px;
}

    .mini-btn {
      min-height: 25px;
      padding: 0.28rem 0.44rem;
    }
  }
  .purpose-fact {
  flex-basis: 100%;
}

</style>