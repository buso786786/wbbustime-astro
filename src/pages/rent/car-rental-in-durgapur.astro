---
import BaseLayout from '../../layouts/BaseLayout.astro';

const SITE_URL = 'https://soniabuddy.in';
const canonicalUrl = `${SITE_URL}/rent/car-rental-in-durgapur/`;

const title = 'Car Rental with Driver in Durgapur | SoniaBuddy';
const description =
  'Find car rental with driver in Durgapur for wedding, tour, local trip and outstation travel. Contact local vehicle owners on SoniaBuddy.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Car Rental with Driver in Durgapur',
  description,
  provider: {
    '@type': 'Organization',
    name: 'SoniaBuddy',
    url: SITE_URL,
  },
  areaServed: {
    '@type': 'City',
    name: 'Durgapur',
  },
  serviceType:
    'Car rental with driver, wedding car rental, tour car rental, local trip car rental, outstation car rental',
  url: canonicalUrl,
};
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <main class="rent-seo-page">
    <section class="hero">
      <div class="hero-badge">🚗 Car Rental</div>
      <h1>Car Rental with Driver in Durgapur</h1>
      <p>
        Find car rental with driver in Durgapur for wedding, tour, local trip and outstation travel.
        SoniaBuddy helps users discover local vehicle owners and contact them directly where phone or WhatsApp is available.
      </p>

      <div class="hero-actions">
        <a class="btn btn-primary" href="/rent-vehicle?vehicle=car&city=durgapur">Find Car Now</a>
        <a class="btn btn-outline" href="/rent-vehicle?tab=register">Register Your Vehicle</a>
      </div>
    </section>

    <section class="content-card">
      <h2>Car rental options in Durgapur</h2>
      <div class="chips">
        <span>Wedding</span>
        <span>Tour</span>
        <span>Local trip</span>
        <span>Outstation</span>
        <span>Airport pickup</span>
      </div>
      <p>
        This page is for users searching car rental in Durgapur. You can check available vehicles,
        compare basic details and contact local owners directly.
      </p>
    </section>

    <section class="content-grid">
      <article>
        <h2>Wedding Car Rental in Durgapur</h2>
        <p>Find local car owners for wedding travel, guest pickup and family trips in Durgapur.</p>
      </article>

      <article>
        <h2>Tour Car Rental in Durgapur</h2>
        <p>Use SoniaBuddy to find car rental options for short tours, local sightseeing and outstation travel.</p>
      </article>

      <article>
        <h2>Local Trip Car Rental in Durgapur</h2>
        <p>Search car rental with driver for station pickup, city travel, office trip and daily travel needs.</p>
      </article>

      <article>
        <h2>Outstation Car Rental in Durgapur</h2>
        <p>Contact vehicle owners for outstation trip availability, route, timing and price discussion.</p>
      </article>
    </section>

    <section class="faq-card">
      <h2>FAQs</h2>

      <details open>
        <summary>Can I find car rental with driver in Durgapur?</summary>
        <p>Yes, SoniaBuddy helps users find local car rental listings with driver in Durgapur.</p>
      </details>

      <details>
        <summary>Can I book car for wedding or tour?</summary>
        <p>You can contact owners directly and ask about wedding, tour, local trip or outstation availability.</p>
      </details>

      <details>
        <summary>Can vehicle owners register their car?</summary>
        <p>Yes, owners can register their car from the rent vehicle page and manage it from owner dashboard.</p>
      </details>
    </section>
  </main>
</BaseLayout>

<style>
  .rent-seo-page {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 2rem 0 4rem;
  }

  .hero,
  .content-card,
  .faq-card,
  .content-grid article {
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.09), rgba(255, 255, 255, 0.035));
    border-radius: 1.35rem;
    padding: 1.25rem;
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.18);
  }

  .hero {
    padding: 1.7rem;
    margin-bottom: 1rem;
  }

  .hero-badge {
    display: inline-flex;
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    background: rgba(255, 138, 0, 0.16);
    color: #ffb24d;
    font-weight: 900;
    font-size: 0.85rem;
    margin-bottom: 0.8rem;
  }

  h1 {
    font-size: clamp(1.85rem, 5vw, 3.2rem);
    line-height: 1.08;
    margin: 0 0 0.75rem;
    color: #fff;
  }

  h2 {
    color: #fff;
    margin: 0 0 0.75rem;
    font-size: 1.2rem;
  }

  p,
  summary {
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 1.1rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0.7rem 1rem;
    border-radius: 0.8rem;
    text-decoration: none;
    font-weight: 900;
  }

  .btn-primary {
    background: linear-gradient(135deg, #ff8a00, #ff5a00);
    color: #12051f;
  }

  .btn-outline {
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.06);
  }

  .content-card,
  .faq-card {
    margin-top: 1rem;
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 0.8rem 0 1rem;
  }

  .chips span {
    padding: 0.45rem 0.7rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    font-weight: 800;
    font-size: 0.85rem;
  }

  .content-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  details {
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    padding: 0.8rem 0;
  }

  details:first-of-type {
    border-top: 0;
  }

  summary {
    cursor: pointer;
    font-weight: 900;
    color: #fff;
  }

  @media (max-width: 720px) {
    .rent-seo-page {
      width: min(100% - 1rem, 1120px);
      padding-top: 1rem;
    }

    .hero,
    .content-card,
    .faq-card,
    .content-grid article {
      border-radius: 1rem;
      padding: 1rem;
    }

    .content-grid {
      grid-template-columns: 1fr;
    }

    .hero-actions .btn {
      width: 100%;
    }
  }
</style>