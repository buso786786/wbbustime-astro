---
import BaseLayout from '../layouts/BaseLayout.astro';

// Static demo stops - will be replaced by Supabase later
const demoStops = [
	{ en: "Tarakeswar", bn: "তারকেশ্বর" },
	{ en: "Arambagh", bn: "আরামবাগ" },
	{ en: "Digha", bn: "দীঘা" },
	{ en: "Kolkata", bn: "কলকাতা" },
	{ en: "Durgapur", bn: "দুর্গাপুর" },
	{ en: "Bankura", bn: "বাঁকুড়া" }
];
---

<BaseLayout
	title="Home"
	description="Find Bus Timetable & Rent Vehicles in West Bengal. Search local bus timings and find cars, buses, toto, pickup vans and ambulances with driver."
>
	<div class="debug-label">PAGE: HOME</div>
	<section class="hero homepage-hero">
		<div class="container">
			<h1>West Bengal Bus Time Table & Routes</h1>
			<p>
				Plan daily journeys across West Bengal with up-to-date bus routes, stoppages and timings for both private and government buses. Search by source and destination to see schedules, fares and travel duration in seconds. WBBusTime also helps users find rent with driver services including car rental, bus rental, toto rent, pickup van and ambulance rental in West Bengal.
			</p>
			<div class="homepage-cta-row">
				<a href="/bus-search" class="btn btn-primary btn-large">Route Finder Search</a>
				<a href="/all-routes" class="btn btn-outline btn-small">See All</a>
			</div>
		</div>
	</section>

	<section>
		<div class="container">
			<div class="card rent-card">
				<h3>Find Rent with Driver</h3>
				<p>Car, Bus, Toto, Pickup Van, Ambulance rental in West Bengal</p>
				<div class="rent-chips">
					<a href="/rent-vehicle?type=toto&tab=find" class="chip">Toto Rent</a>
					<a href="/rent-vehicle?type=pickup&tab=find" class="chip">Pickup Van</a>
					<a href="/rent-vehicle?type=ambulance&tab=find" class="chip">Ambulance</a>
					<a href="/rent-vehicle?type=tour-car&tab=find" class="chip">Tour Car</a>
					<a href="/rent-vehicle?type=school-bus&tab=find" class="chip">School Bus</a>
					<a href="/rent-vehicle?type=car&tab=find" class="chip">Car Rent</a>
					<a href="/rent-vehicle?type=bus&tab=find" class="chip">Bus Rent</a>
					<a href="/rent-vehicle?type=wedding-bus&tab=find" class="chip">Wedding Bus</a>
				</div>
			</div>
		</div>
	</section>

	<section>
		<div class="container">
			<div class="section-title">
				<h2>Popular Bus Routes</h2>
			</div>
			<div class="grid grid-3">
				<a href="/bus-search?from=Kolkata&to=Durgapur" class="popular-item">
					<h4>Kolkata to Durgapur</h4>
				</a>
				<a href="/bus-search?from=Kolkata&to=Siliguri" class="popular-item">
					<h4>Kolkata to Siliguri</h4>
				</a>
				<a href="/bus-search?from=Kolkata&to=Asansol" class="popular-item">
					<h4>Kolkata to Asansol</h4>
				</a>
				<a href="/all-routes" class="popular-item">
					<h4>See all routes</h4>
				</a>
			</div>
		</div>
	</section>


	<script type="application/ld+json">
	{
		"@context": "https://schema.org",
		"@type": "Organization",
		"name": "Sonia Buddy",
		"description": "West Bengal Bus Timetables & Vehicle Rental",
		"url": "https://soniabuddy.com",
		"logo": "https://soniabuddy.com/logo.png",
		"sameAs": []
	}
	</script>

	<style>
		.homepage-hero {
			background: linear-gradient(135deg, #0b0628 0%, #13084a 55%, #1e103f 100%);
			padding: 4rem 0;
			color: white;
		}

		.homepage-hero h1 {
			font-size: 2.5rem;
			margin-bottom: 1rem;
		}

		.homepage-hero p {
			max-width: 800px;
			margin-bottom: 2rem;
			color: rgba(255, 255, 255, 0.85);
			line-height: 1.6;
		}

		.homepage-cta-row {
			display: flex;
			gap: 1rem;
			flex-wrap: wrap;
		}

		.btn-large {
			padding: 1rem 2rem;
			font-size: 1.1rem;
		}

		.btn-small {
			padding: 0.75rem 1.5rem;
			font-size: 0.95rem;
		}

		.btn-primary {
			background: linear-gradient(135deg, #ff6b00 0%, #ff8a00 100%);
			color: white;
			border: none;
			border-radius: 999px;
			font-weight: 700;
			text-decoration: none;
			transition: all 0.2s;
		}

		.btn-primary:hover {
			background: linear-gradient(135deg, #e65a00 0%, #ff6b00 100%);
			transform: translateY(-2px);
		}

		.btn-outline {
			background: transparent;
			color: white;
			border: 2px solid rgba(255, 255, 255, 0.3);
			border-radius: 999px;
			font-weight: 700;
			text-decoration: none;
			transition: all 0.2s;
		}

		.btn-outline:hover {
			background: rgba(255, 255, 255, 0.1);
			border-color: rgba(255, 255, 255, 0.5);
		}

		.rent-card {
			background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
			border: 1px solid #fcd34d;
			border-radius: 1rem;
			padding: 1.5rem;
		}

		.rent-card h3 {
			margin-bottom: 0.5rem;
			color: #1e1b4b;
		}

		.rent-card p {
			margin-bottom: 1rem;
			color: #4b5563;
		}

		.rent-chips {
			display: flex;
			gap: 0.5rem;
			flex-wrap: wrap;
		}

		.chip {
			background: rgba(255, 255, 255, 0.7);
			color: #1e1b4b;
			padding: 0.5rem 1rem;
			border-radius: 999px;
			font-size: 0.875rem;
			font-weight: 600;
			text-decoration: none;
			transition: all 0.2s;
		}

		.chip:hover {
			background: white;
			transform: translateY(-2px);
		}

		.popular-item {
			background: rgba(255, 255, 255, 0.05);
			border: 1px solid rgba(255, 255, 255, 0.1);
			border-radius: 0.75rem;
			padding: 1.25rem;
			text-decoration: none;
			color: white;
			transition: all 0.2s;
		}

		.popular-item:hover {
			background: rgba(255, 255, 255, 0.1);
			transform: translateY(-2px);
		}

		.popular-item h4 {
			margin: 0;
			font-size: 1.1rem;
		}

		@media (max-width: 768px) {
			.homepage-hero {
				padding: 2rem 0;
			}

			.homepage-hero h1 {
				font-size: 1.75rem;
			}

			.homepage-cta-row {
				flex-direction: column;
			}

			.btn-large,
			.btn-small {
				width: 100%;
				text-align: center;
			}
		}
	</style>
</BaseLayout>
