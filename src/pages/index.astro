---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildRentCityGroups, getVehicleLinks } from '../lib/rentSeoLinks';
import { buildBusStopSuggestions } from '../lib/busSeoLinks';

const rentCitySeoLinks = (await buildRentCityGroups()).slice(0, 3).map((group) => ({
  city: group.city,
  links: getVehicleLinks(group).slice(0, 5),
}));

const stopSuggestions = await buildBusStopSuggestions();
---

<BaseLayout
  title="Home"
  description="Find Bus Timetable & Rent Vehicles in West Bengal. Search local bus timings and find cars, buses, toto, pickup vans and ambulances with driver."
>
  <main class="home-page">
    <section class="home-hero">
      <div class="container home-container">
        <div class="home-copy">
          <span class="home-badge" data-en="West Bengal travel helper" data-bn="পশ্চিমবঙ্গ ভ্রমণ সহায়ক">West Bengal travel helper</span>
          <h1
  data-en="West Bengal Bus Timetable, Route Finder & Vehicle Rental"
  data-bn="পশ্চিমবঙ্গ বাস টাইমটেবিল, রুট ফাইন্ডার ও ভাড়া গাড়ি"
>
  West Bengal Bus Timetable, Route Finder & Vehicle Rental
</h1>
          <p
  data-en="Search West Bengal bus routes, daily timetable pages, route finder results and driver-included rental services in one place."
  data-bn="পশ্চিমবঙ্গের বাস রুট, দৈনিক টাইমটেবিল, রুট ফাইন্ডার এবং ড্রাইভারসহ ভাড়া গাড়ি এক জায়গায় খুঁজুন।"
>
  Search West Bengal bus routes, daily timetable pages, route finder results and driver-included rental services in one place.
</p>
        </div>

        <div class="rent-card home-main-card">
          <div class="card-title-row">
            <div>
              <h2 data-en="Find Rent with Driver" data-bn="ড্রাইভারসহ ভাড়া গাড়ি খুঁজুন">Find Rent with Driver</h2>
              <p>Car, Bus, Toto, Pickup Van, Ambulance rental in West Bengal</p>
            </div>
            <a href="/rent-vehicle/?tab=find" class="mini-link">Open Rent</a>
          </div>

          <div class="rent-chips">
            <a href="/rent-vehicle/?type=car&tab=find" class="chip">Car Rent</a>
            <a href="/rent-vehicle/?type=bus&tab=find" class="chip">Bus Rent</a>
            <a href="/rent-vehicle/?type=toto&tab=find" class="chip">Toto Rent</a>
            <a href="/rent-vehicle/?type=pickup&tab=find" class="chip">Pickup Van</a>
            <a href="/rent-vehicle/?type=ambulance&tab=find" class="chip">Ambulance</a>
          </div>
        </div>
      </div>
    </section>

    <section class="quick-section">
      <div class="container home-container">
        <div class="bus-finder-card">
          <div class="card-title-row">
            <div>
              <h2 data-en="Find Your Bus" data-bn="আপনার বাস খুঁজুন">Find Your Bus</h2>
              <p data-en="Type English or Bengali stop name." data-bn="English বা বাংলা স্টপ নাম লিখুন।">Type English or Bengali stop name.</p>
            </div>
          </div>

          <form id="home-bus-search-form" class="home-bus-form" autocomplete="off">
            <div class="home-input-wrap">
              <input
                id="home-from"
                type="text"
                name="from"
                placeholder="Enter departure city / ছাড়ার জায়গা"
                data-placeholder-en="Enter departure city"
                data-placeholder-bn="ছাড়ার জায়গা"
                autocomplete="off"
                required
              />
              <div id="home-from-list" class="suggest-box" hidden></div>
            </div>
            <button type="button" id="home-swap-btn" class="home-swap-btn" aria-label="Swap from and to">
  ⇄
</button>
            <div class="home-input-wrap">
              <input
                id="home-to"
                type="text"
                name="to"
                placeholder="Enter destination city / যাওয়ার জায়গা"
                data-placeholder-en="Enter destination city"
                data-placeholder-bn="যাওয়ার জায়গা"
                autocomplete="off"
                required
              />
              <div id="home-to-list" class="suggest-box" hidden></div>
            </div>

            <button type="submit" class="home-bus-submit" data-en="Search" data-bn="খুঁজুন">Search</button>
          </form>
        </div>

        <div class="homepage-cta-row">
          <a href="/route-finder/" class="btn-primary btn-pill">Route Finder Search</a>
          <a href="/bus-search/" class="btn-soft btn-pill">Bus Search</a>
          <a href="/all-routes/" class="btn-soft btn-pill">All Routes</a>
        </div>
      </div>
    </section>

    <section class="rent-city-seo-block">
      <div class="container home-container">
        <div class="section-heading-row">
          <div>
            <h2>Find Rent by City</h2>
            <p>Real rent vehicle SEO links from active listings.</p>
          </div>
          <a href="/rent-cities/" class="see-all-rent">See All</a>
        </div>

        {rentCitySeoLinks.length > 0 ? (
          <div class="rent-city-grid">
            {rentCitySeoLinks.map((cityGroup) => (
              <article class="rent-city-card">
                <h3>{cityGroup.city} Rent Vehicle</h3>
                <div class="rent-link-list">
                  {cityGroup.links.map((item) => (
                    <a href={item.url}>{item.label}</a>
                  ))}
                </div>
              </article>
            ))}
          </div>
        ) : (
          <div class="rent-empty-note">
            <p>No active rent city links found yet.</p>
            <a href="/rent-vehicle/">Open Rent Vehicle</a>
          </div>
        )}
      </div>
    </section>
  </main>

  <script type="application/json" id="stop-suggestion-data" set:html={JSON.stringify(stopSuggestions)} />

  <script>
    const suggestionDataEl = document.getElementById('stop-suggestion-data');
    const suggestions = suggestionDataEl ? JSON.parse(suggestionDataEl.textContent || '[]') : [];

    const form = document.getElementById('home-bus-search-form');
    const fromInput = document.getElementById('home-from');
const toInput = document.getElementById('home-to');
const swapBtn = document.getElementById('home-swap-btn');
const fromList = document.getElementById('home-from-list');
const toList = document.getElementById('home-to-list');

    const normalize = (value) =>
      String(value || '')
        .toLowerCase()
        .normalize('NFKD')
        .replace(/\s+/g, ' ')
        .trim();

    const hideList = (box) => {
      if (!box) return;
      box.hidden = true;
      box.innerHTML = '';
    };

    const hideAll = () => {
      hideList(fromList);
      hideList(toList);
    };

   const scoreSuggestion = (item, query) => {
  const q = normalize(query);
  const value = normalize(item.value);
  const label = normalize(item.label);
  const searchText = normalize(item.search);

  if (!q) return null;

  if (value === q || label === q) return { item, score: 1000 };
  if (value.startsWith(q)) return { item, score: 900 };
  if (label.startsWith(q)) return { item, score: 850 };

  const words = `${value} ${label} ${searchText}`.split(/\s+/).filter(Boolean);
  if (words.some((word) => word.startsWith(q))) return { item, score: 760 };

  if (searchText.includes(q)) return { item, score: 600 };

  return null;
};

const search = (query) => {
  const q = normalize(query);
  if (!q) return [];

  return suggestions
    .map((item) => scoreSuggestion(item, q))
    .filter(Boolean)
    .sort((a, b) => b.score - a.score || a.item.label.localeCompare(b.item.label))
    .slice(0, 8)
    .map((result) => result.item);
};

    const showList = (input, box, otherBox) => {
      if (!input || !box) return;
      hideList(otherBox);

      const results = search(input.value);
      if (!results.length) {
        hideList(box);
        return;
      }

      box.innerHTML = results
  .map(
    (item) => `
      <button type="button" class="suggest-item" data-value="${item.value}">
        <span class="suggest-icon">⌖</span>
        <span class="suggest-text">${item.label}</span>
      </button>
    `
  )
  .join('');

      box.hidden = false;

      box.querySelectorAll('.suggest-item').forEach((btn) => {
        btn.addEventListener('mousedown', (event) => {
          event.preventDefault();
          input.value = btn.getAttribute('data-value') || '';
          hideAll();
          if (input === fromInput) toInput?.focus();
        });
      });
    };

    fromInput?.addEventListener('input', () => showList(fromInput, fromList, toList));
    toInput?.addEventListener('input', () => showList(toInput, toList, fromList));

    document.addEventListener('mousedown', (event) => {
      if (!event.target.closest('.home-input-wrap')) hideAll();
    });
    swapBtn?.addEventListener('click', () => {
  const fromValue = fromInput?.value || '';
  const toValue = toInput?.value || '';

  if (fromInput) fromInput.value = toValue;
  if (toInput) toInput.value = fromValue;

  hideAll();
  fromInput?.focus();
});
    form?.addEventListener('submit', (event) => {
      event.preventDefault();

      const from = String(fromInput?.value || '').trim();
      const to = String(toInput?.value || '').trim();

      if (!from || !to) return;

      window.location.href = `/bus-search?from=${encodeURIComponent(from)}&to=${encodeURIComponent(to)}`;
    });
  </script>

  <style>
    :global(html),
    :global(body) {
      background: #f4f9ff !important;
    }

    :global(body) {
      color: #0f172a;
    }

    .home-page {
      background:
        radial-gradient(circle at top left, rgba(56, 189, 248, 0.22), transparent 34rem),
        linear-gradient(180deg, #f8fbff 0%, #eef7ff 46%, #ffffff 100%);
      min-height: 100vh;
      padding-bottom: 1.2rem;
    }

    .home-container {
      max-width: 1120px;
    }

    .home-hero {
      padding: 1.05rem 0 0.7rem;
    }

    .home-copy {
      padding: 0.15rem 0 0.75rem;
    }

    .home-badge {
      display: inline-flex;
      width: fit-content;
      padding: 0.28rem 0.62rem;
      border-radius: 999px;
      background: #e0f2fe;
      color: #0369a1;
      font-size: 0.78rem;
      font-weight: 900;
      margin-bottom: 0.5rem;
      border: 1px solid #bae6fd;
    }

    .home-copy h1 {
      margin: 0;
      color: #082f49;
      font-size: clamp(1.45rem, 4.5vw, 2.35rem);
      line-height: 1.06;
      letter-spacing: -0.03em;
      max-width: 780px;
    }

    .home-copy p {
      margin: 0.55rem 0 0;
      max-width: 820px;
      color: #334155;
      font-size: 0.95rem;
      line-height: 1.55;
    }

    .home-main-card,
    .bus-finder-card {
      background: linear-gradient(135deg, #170a42 0%, #100532 100%);
      border: 1px solid rgba(249, 115, 22, 0.35);
      border-radius: 1rem;
      padding: 1rem;
      box-shadow: 0 16px 34px rgba(15, 23, 42, 0.12);
      color: #ffffff;
    }

    .card-title-row {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 0.8rem;
      margin-bottom: 0.7rem;
    }

    .card-title-row h2 {
      margin: 0;
      color: #ffffff;
      font-size: 1.18rem;
      line-height: 1.12;
    }

    .card-title-row p,
    .rent-card p {
      margin: 0.28rem 0 0;
      color: rgba(255, 255, 255, 0.82);
      font-size: 0.88rem;
      line-height: 1.35;
    }

    .mini-link {
      flex: 0 0 auto;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 30px;
      padding: 0.32rem 0.62rem;
      border-radius: 999px;
      background: #ff7a00;
      color: #ffffff;
      text-decoration: none;
      font-size: 0.74rem;
      font-weight: 900;
      white-space: nowrap;
    }

    .rent-chips {
      display: flex;
      gap: 0.42rem;
      flex-wrap: wrap;
    }

    .chip {
      background: linear-gradient(135deg, #e0f2fe 0%, #dbeafe 100%);
      color: #0f172a;
      border: 1px solid #93c5fd;
      box-shadow: 0 2px 8px rgba(37, 99, 235, 0.12);
      border-radius: 999px;
      padding: 0.5rem 1rem;
      text-decoration: none;
      font-weight: 700;
    }

    .quick-section {
      padding: 0.7rem 0 0;
    }

    .bus-finder-card {
      padding: 0.85rem;
    }

    .home-bus-form {
  display: grid;
  grid-template-columns: 1fr auto 1fr auto;
  gap: 0.55rem;
  align-items: start;

    }

    .home-input-wrap {
      position: relative;
      min-width: 0;
    }

    .home-input-wrap input {
      width: 100%;
      min-height: 42px;
      padding: 0.66rem 0.8rem;
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 0.62rem;
      background: rgba(255, 255, 255, 0.06);
      color: #ffffff;
      font-size: 0.9rem;
      outline: none;
    }

    .home-input-wrap input::placeholder {
      color: rgba(255, 255, 255, 0.6);
    }

    .home-input-wrap input:focus {
      border-color: #ff8a00;
      background: rgba(255, 255, 255, 0.11);
      box-shadow: 0 0 0 3px rgba(255, 138, 0, 0.16);
    }

    :global(.suggest-box) {
  position: absolute;
  z-index: 1000;
  top: calc(100% + 0.42rem);
  left: 0;
  right: 0;
  max-height: 310px;
  overflow-y: auto;
  background: #151050;
  border: 1px solid rgba(255, 122, 0, 0.55);
  border-radius: 0 0 1rem 1rem;
  box-shadow: 0 22px 44px rgba(0, 0, 0, 0.36);
  padding: 0.42rem;
}

:global(.suggest-item) {
  width: 100%;
  border: 0;
  border-radius: 0.78rem;
  background: transparent;
  color: #ffffff;
  display: flex;
  align-items: center;
  gap: 0.65rem;
  padding: 0.78rem 0.85rem;
  cursor: pointer;
  text-align: left;
  font: inherit;
  line-height: 1.25;
}

:global(.suggest-icon) {
  flex: 0 0 auto;
  width: 22px;
  height: 22px;
  border-radius: 999px;
  display: inline-grid;
  place-items: center;
  color: #ff7a00;
  font-size: 1rem;
  font-weight: 900;
}

:global(.suggest-text) {
  display: block;
  color: #ffffff;
  font-size: 0.92rem;
  font-weight: 750;
}

:global(.suggest-item:hover),
:global(.suggest-item:focus) {
  background: rgba(255, 122, 0, 0.16);
  outline: none;
}
    .home-swap-btn {
  width: 42px;
  height: 42px;
  border: 1px solid rgba(255, 122, 0, 0.65);
  border-radius: 999px;
  background: rgba(255, 122, 0, 0.16);
  color: #ffffff;
  font-size: 1.25rem;
  font-weight: 900;
  cursor: pointer;
}

.home-swap-btn:hover {
  background: rgba(255, 122, 0, 0.28);
}
    .home-bus-submit {
      min-height: 42px;
      border: 0;
      border-radius: 0.62rem;
      padding: 0.62rem 1.45rem;
      background: linear-gradient(135deg, #ff6b00 0%, #ff8a00 100%);
      color: #ffffff;
      font-size: 0.92rem;
      font-weight: 900;
      cursor: pointer;
      white-space: nowrap;
    }

    .homepage-cta-row {
      display: flex;
      gap: 0.55rem;
      flex-wrap: wrap;
      margin-top: 0.65rem;
    }

    .btn-pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 40px;
      border-radius: 999px;
      padding: 0.56rem 1.2rem;
      font-size: 0.9rem;
      font-weight: 900;
      text-decoration: none;
    }

    .btn-primary {
      background: linear-gradient(135deg, #ff6b00 0%, #ff8a00 100%);
      color: #ffffff;
    }

    .btn-soft {
      background: #e0f2fe;
      color: #075985;
      border: 1px solid #bae6fd;
    }

    .rent-city-seo-block {
      margin: 1rem 0 1.25rem;
    }

    .section-heading-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      margin-bottom: 0.75rem;
    }

    .section-heading-row h2 {
      margin: 0;
      color: #0f172a;
      font-size: 1.15rem;
    }

    .section-heading-row p {
      margin: 0.25rem 0 0;
      color: #475569;
      font-size: 0.9rem;
    }

    .see-all-rent {
      flex: 0 0 auto;
      border-radius: 999px;
      background: #fff7ed;
      border: 1px solid #fed7aa;
      color: #ea580c;
      font-weight: 800;
      text-decoration: none;
      padding: 0.5rem 0.75rem;
      font-size: 0.85rem;
    }

    .rent-city-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.75rem;
    }

    .rent-city-card {
      background: #ffffff;
      border: 1px solid #dbeafe;
      border-radius: 1rem;
      padding: 0.85rem;
      box-shadow: 0 8px 22px rgba(15, 23, 42, 0.04);
    }

    .rent-city-card h3 {
      margin: 0 0 0.6rem;
      color: #0f172a;
      font-size: 1rem;
    }

    .rent-link-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
    }

    .rent-link-list a {
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      background: #eff6ff;
      border: 1px solid #bfdbfe;
      color: #075985;
      text-decoration: none;
      font-weight: 800;
      font-size: 0.82rem;
      padding: 0.45rem 0.65rem;
    }

    .rent-empty-note {
      background: #ffffff;
      color: #0f172a;
      border: 1px solid #dbeafe;
      border-radius: 1rem;
      padding: 1rem;
    }

    .rent-empty-note p {
      margin: 0 0 0.6rem;
      color: #475569;
    }

    .rent-empty-note a {
      color: #2563eb;
      font-weight: 900;
      text-decoration: none;
    }

    @media (max-width: 820px) {
  .home-bus-form {
    grid-template-columns: 1fr;
  }

  .home-swap-btn {
    justify-self: center;
    transform: rotate(90deg);
  }

  .home-bus-submit {
    width: 100%;
  }
}

    @media (max-width: 800px) {
      .rent-city-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>