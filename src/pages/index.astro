---
import BaseLayout from '../layouts/BaseLayout.astro';

// Home search suggestions. Later this can be replaced by Supabase stop list.
const demoStops = [
  { en: 'Tarakeswar', bn: 'তারকেশ্বর' },
  { en: 'Arambagh', bn: 'আরামবাগ' },
  { en: 'Digha', bn: 'দীঘা' },
  { en: 'Kolkata', bn: 'কলকাতা' },
  { en: 'Durgapur', bn: 'দুর্গাপুর' },
  { en: 'Bankura', bn: 'বাঁকুড়া' },
];
---

<BaseLayout
  title="Home"
  description="Find Bus Timetable & Rent Vehicles in West Bengal. Search local bus timings and find cars, buses, toto, pickup vans and ambulances with driver."
>
  <main class="home-page">
    <section class="home-hero">
      <div class="container home-container">
        <div class="home-copy">
          <span class="home-badge">West Bengal travel helper</span>
          <h1>West Bengal Bus Timetable, Route Finder & Vehicle Rental</h1>
          <p>
          Search West Bengal bus routes, daily timetable pages, route finder results and driver-included rental services in one place. Find car rental, bus rental, toto rent, pickup van, ambulance, wedding bus, tour car and school bus options by city.
        </p>
        </div>

        <div class="rent-card home-main-card">
          <div class="card-title-row">
            <div>
              <h2>Find Rent with Driver</h2>
              <p>Car, Bus, Toto, Pickup Van, Ambulance rental in West Bengal</p>
            </div>
            <a href="/rent-vehicle?tab=find" class="mini-link">Open Rent</a>
          </div>

          <div class="rent-chips">
            <a href="/rent-vehicle?type=car&tab=find" class="chip">Car Rent</a>
            <a href="/rent-vehicle?type=bus&tab=find" class="chip">Bus Rent</a>
            <a href="/rent-vehicle?type=wedding-bus&tab=find" class="chip">Wedding Bus</a>
            <a href="/rent-vehicle?type=toto&tab=find" class="chip">Toto Rent</a>
            <a href="/rent-vehicle?type=pickup&tab=find" class="chip">Pickup Van</a>
            <a href="/rent-vehicle?type=ambulance&tab=find" class="chip">Ambulance</a>
            <a href="/rent-vehicle?type=tour-car&tab=find" class="chip">Tour Car</a>
            <a href="/rent-vehicle?type=school-bus&tab=find" class="chip">School Bus</a>
          </div>
        </div>
      </div>
    </section>

    <section class="quick-section">
      <div class="container home-container">
        <div class="bus-finder-card">
          <div class="card-title-row">
            <div>
              <h2>Find Your Bus</h2>
              <p>Type English or Bengali stop name.</p>
            </div>
            <a href="/all-routes" class="mini-link outline">See All</a>
          </div>

          <form id="home-bus-search-form" action="/bus-search" method="get" autocomplete="off">
            <div class="bus-finder-form">
              <div class="suggest-box">
                <input
                  id="from-stop"
                  type="text"
                  name="from"
                  placeholder="Enter departure city / ছাড়ার জায়গা"
                  data-stop-input="from"
                  required
                />
                <div class="suggest-panel" id="from-suggestions" hidden></div>
              </div>

              <div class="suggest-box">
                <input
                  id="to-stop"
                  type="text"
                  name="to"
                  placeholder="Enter destination city / যাওয়ার জায়গা"
                  data-stop-input="to"
                  required
                />
                <div class="suggest-panel" id="to-suggestions" hidden></div>
              </div>

              <button type="submit" class="btn-search">Search</button>
            </div>
          </form>
        </div>

        <div class="homepage-cta-row">
          <a href="/route-finder" class="btn-primary btn-pill">Route Finder Search</a>
          <a href="/bus-search" class="btn-soft btn-pill">Bus Search</a>
        </div>
      </div>
    </section>

    <section class="popular-section">
      <div class="container home-container">
        <div class="section-title compact-title">
          <h2>Popular Bus Routes</h2>
        </div>

        <div class="grid grid-3 route-grid">
          <a href="/bus-timetable/kolkata-to-durgapur/" class="popular-item">
            <h3>Kolkata to Durgapur</h3>
          </a>
          <a href="/bus-timetable/kolkata-to-siliguri/" class="popular-item">
            <h3>Kolkata to Siliguri</h3>
          </a>
          <a href="/bus-timetable/kolkata-to-asansol/" class="popular-item">
            <h3>Kolkata to Asansol</h3>
          </a>
          <a href="/all-routes" class="popular-item more-route">
            <h3>See all routes</h3>
          </a>
        </div>
      </div>
    </section>
  </main>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Sonia Buddy",
      "description": "Search West Bengal bus timetable, route finder and driver-included vehicle rental services. Find car, bus, toto, pickup van, ambulance, wedding bus, tour car and school bus options by city."
      "url": "https://soniabuddy.in",
      "logo": "https://soniabuddy.in/logo.png",
      "sameAs": []
    }
  </script>

  <script define:vars={{ demoStops }}>
    window.homeStopSuggestions = demoStops;
  </script>

  <script>
    const stops = Array.isArray(window.homeStopSuggestions) ? window.homeStopSuggestions : [];

    function norm(value) {
      return String(value || '')
        .trim()
        .toLowerCase()
        .normalize('NFKD')
        .replace(/[\u0300-\u036f]/g, '');
    }

    function stopLabel(stop) {
      const en = String(stop.en || '').trim();
      const bn = String(stop.bn || '').trim();
      return bn ? `${en} / ${bn}` : en;
    }

    function matchStops(term) {
      const q = norm(term);
      if (!q) return stops.slice(0, 6);

      return stops
        .filter((stop) => {
          const en = norm(stop.en);
          const bn = norm(stop.bn);
          const label = norm(stopLabel(stop));
          return en.includes(q) || bn.includes(q) || label.includes(q);
        })
        .slice(0, 8);
    }

    function setupStopSuggest(inputId, panelId) {
      const input = document.getElementById(inputId);
      const panel = document.getElementById(panelId);
      if (!input || !panel) return;

      function render() {
        const list = matchStops(input.value);
        panel.innerHTML = '';

        if (!list.length) {
          panel.innerHTML = '<div class="suggest-empty">No stop found</div>';
          panel.hidden = false;
          return;
        }

        list.forEach((stop) => {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'suggest-item';
          btn.innerHTML = `<strong>${stop.en || ''}</strong>${stop.bn ? `<span>${stop.bn}</span>` : ''}`;
          btn.addEventListener('mousedown', (event) => {
            event.preventDefault();
            input.value = stop.en || stop.bn || '';
            panel.hidden = true;
          });
          panel.appendChild(btn);
        });

        panel.hidden = false;
      }

      input.addEventListener('focus', render);
      input.addEventListener('input', render);
      input.addEventListener('click', render);
      input.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') panel.hidden = true;
      });
    }

    document.addEventListener('DOMContentLoaded', () => {
      setupStopSuggest('from-stop', 'from-suggestions');
      setupStopSuggest('to-stop', 'to-suggestions');

      document.addEventListener('mousedown', (event) => {
        if (!event.target.closest('.suggest-box')) {
          document.querySelectorAll('.suggest-panel').forEach((panel) => {
            panel.hidden = true;
          });
        }
      });
    });
  </script>

  <style>
    :global(html),
    :global(body) {
      background: #f4f9ff !important;
    }

    :global(body) {
      color: #0f172a;
    }

    .home-page {
      background:
        radial-gradient(circle at top left, rgba(56, 189, 248, 0.22), transparent 34rem),
        linear-gradient(180deg, #f8fbff 0%, #eef7ff 46%, #ffffff 100%);
      min-height: 100vh;
      padding-bottom: 1.2rem;
    }

    .home-container {
      max-width: 1120px;
    }

    .home-hero {
      padding: 1.05rem 0 0.7rem;
    }

    .home-copy {
      padding: 0.15rem 0 0.75rem;
    }

    .home-badge {
      display: inline-flex;
      width: fit-content;
      padding: 0.28rem 0.62rem;
      border-radius: 999px;
      background: #e0f2fe;
      color: #0369a1;
      font-size: 0.78rem;
      font-weight: 900;
      margin-bottom: 0.5rem;
      border: 1px solid #bae6fd;
    }

    .home-copy h1 {
      margin: 0;
      color: #082f49;
      font-size: clamp(1.45rem, 4.5vw, 2.35rem);
      line-height: 1.06;
      letter-spacing: -0.03em;
      max-width: 780px;
    }

    .home-copy p {
      margin: 0.55rem 0 0;
      max-width: 820px;
      color: #334155;
      font-size: 0.95rem;
      line-height: 1.55;
    }

    .home-main-card,
    .bus-finder-card {
      background: linear-gradient(135deg, #170a42 0%, #100532 100%);
      border: 1px solid rgba(249, 115, 22, 0.35);
      border-radius: 1rem;
      padding: 1rem;
      box-shadow: 0 16px 34px rgba(15, 23, 42, 0.12);
      color: #ffffff;
    }

    .card-title-row {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 0.8rem;
      margin-bottom: 0.7rem;
    }

    .card-title-row h2 {
      margin: 0;
      color: #ffffff;
      font-size: 1.18rem;
      line-height: 1.12;
    }

    .card-title-row p,
    .rent-card p {
      margin: 0.28rem 0 0;
      color: rgba(255, 255, 255, 0.82);
      font-size: 0.88rem;
      line-height: 1.35;
    }

    .mini-link {
      flex: 0 0 auto;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 30px;
      padding: 0.32rem 0.62rem;
      border-radius: 999px;
      background: #ff7a00;
      color: #ffffff;
      text-decoration: none;
      font-size: 0.74rem;
      font-weight: 900;
      white-space: nowrap;
    }

    .mini-link.outline {
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .rent-chips {
      display: flex;
      gap: 0.42rem;
      flex-wrap: wrap;
    }

    .chip {
  background: linear-gradient(135deg, #e0f2fe 0%, #dbeafe 100%);
  color: #0f172a;
  border: 1px solid #93c5fd;
  box-shadow: 0 2px 8px rgba(37, 99, 235, 0.12);

  border-radius: 999px;
  padding: 0.5rem 1rem;
}

.chip:hover {
  background: linear-gradient(135deg, #bfdbfe 0%, #93c5fd 100%);
  color: #0f172a;
  transform: translateY(-1px);
}

    .quick-section,
    .popular-section {
      padding: 0.7rem 0 0;
    }

    .bus-finder-card {
      padding: 0.85rem;
    }

    .bus-finder-form {
      display: grid;
      grid-template-columns: 1fr 1fr auto;
      gap: 0.55rem;
      align-items: start;
    }

    .suggest-box {
      position: relative;
      min-width: 0;
    }

    .bus-finder-form input {
      width: 100%;
      min-height: 42px;
      padding: 0.66rem 0.8rem;
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 0.62rem;
      background: rgba(255, 255, 255, 0.06);
      color: #ffffff;
      font-size: 0.9rem;
    }

    .bus-finder-form input::placeholder {
      color: rgba(255, 255, 255, 0.55);
    }

    .bus-finder-form input:focus {
      outline: none;
      border-color: #ff8a00;
      background: rgba(255, 255, 255, 0.11);
    }

    .suggest-panel {
      position: absolute;
      z-index: 20;
      left: 0;
      right: 0;
      top: calc(100% + 0.28rem);
      overflow: hidden;
      border-radius: 0.72rem;
      border: 1px solid rgba(15, 23, 42, 0.12);
      background: #ffffff;
      box-shadow: 0 18px 32px rgba(15, 23, 42, 0.22);
    }

    .suggest-item,
    .suggest-empty {
      width: 100%;
      border: 0;
      background: #ffffff;
      padding: 0.62rem 0.75rem;
      text-align: left;
      display: flex;
      flex-direction: column;
      gap: 0.08rem;
      cursor: pointer;
    }

    .suggest-item:hover {
      background: #eff6ff;
    }

    .suggest-item strong {
      color: #0f172a;
      font-size: 0.85rem;
      line-height: 1.15;
    }

    .suggest-item span,
    .suggest-empty {
      color: #64748b;
      font-size: 0.78rem;
      font-weight: 700;
    }

    .btn-search {
      min-height: 42px;
      border: 0;
      border-radius: 0.62rem;
      padding: 0.62rem 1.45rem;
      background: linear-gradient(135deg, #ff6b00 0%, #ff8a00 100%);
      color: #ffffff;
      font-size: 0.92rem;
      font-weight: 900;
      cursor: pointer;
      white-space: nowrap;
    }

    .homepage-cta-row {
      display: flex;
      gap: 0.55rem;
      flex-wrap: wrap;
      margin-top: 0.65rem;
    }

    .btn-pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 40px;
      border-radius: 999px;
      padding: 0.56rem 1.2rem;
      font-size: 0.9rem;
      font-weight: 900;
      text-decoration: none;
    }

    .btn-primary {
      background: linear-gradient(135deg, #ff6b00 0%, #ff8a00 100%);
      color: #ffffff;
    }

    .btn-soft {
      background: #e0f2fe;
      color: #075985;
      border: 1px solid #bae6fd;
    }

    .compact-title {
      text-align: left;
      margin: 0 0 0.55rem;
    }

    .compact-title h2 {
      margin: 0;
      color: #082f49;
      font-size: 1.08rem;
    }

    .route-grid {
      gap: 0.55rem;
    }

    .popular-item {
      background: #ffffff;
      border: 1px solid #dbeafe;
      border-radius: 0.85rem;
      padding: 0.8rem;
      text-decoration: none;
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
    }

    .popular-item h3 {
      margin: 0;
      color: #0f172a;
      font-size: 0.94rem;
      line-height: 1.25;
    }

    .more-route {
      background: #eff6ff;
    }

    @media (max-width: 820px) {
      .bus-finder-form {
        grid-template-columns: 1fr;
      }

      .btn-search {
        width: 100%;
      }
    }

    @media (max-width: 640px) {
      .home-hero {
        padding-top: 0.75rem;
      }

      .home-copy p {
        font-size: 0.86rem;
      }

      .home-main-card,
      .bus-finder-card {
        border-radius: 0.82rem;
        padding: 0.75rem;
      }

      .card-title-row {
        align-items: flex-start;
        margin-bottom: 0.55rem;
      }

      .card-title-row h2 {
        font-size: 1.05rem;
      }

      .card-title-row p {
        font-size: 0.8rem;
      }

      .mini-link {
        min-height: 28px;
        padding: 0.28rem 0.5rem;
        font-size: 0.68rem;
      }

      .chip {
        padding: 0.34rem 0.58rem;
        font-size: 0.72rem;
      }

      .homepage-cta-row .btn-pill {
        flex: 1 1 160px;
      }
    }
  </style>
</BaseLayout>
