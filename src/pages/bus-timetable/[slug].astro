      gap: 0.7rem;
      margin-bottom: 1rem;
    }

    .summary-grid div {
      background: white;
      border: 1px solid #dbeafe;
      border-radius: 1rem;
      padding: 0.8rem;
      box-shadow: 0 6px 18px rgba(15, 23, 42, 0.04);
    }

    .summary-grid span,
