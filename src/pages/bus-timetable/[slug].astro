      border-color: #38bdf8;
      background: #e0f2fe;
    }

    .mini-bus-card span {
      font-weight: 800;
    }

    .mini-bus-card small {
      color: #64748b;
    }

    .table-note {
      font-size: 0.9rem;
      margin-bottom: 0.75rem !important;
    }

    .desktop-table {
      width: 100%;
      overflow: hidden;
      border-radius: 0.9rem;
      border: 1px solid #e2e8f0;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      table-layout: fixed;
    }

    th,
    td {
      text-align: left;
      border-bottom: 1px solid #e2e8f0;
      padding: 0.7rem;
