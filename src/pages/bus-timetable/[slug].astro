---
import BaseLayout from '../../layouts/BaseLayout.astro';

const SITE_URL = 'https://soniabuddy.in';

const SUPABASE_URL =
  import.meta.env.VITE_SUPABASE_URL || 'https://ytxtyphbguszjndtpakm.supabase.co';

const SUPABASE_ANON_KEY =
  import.meta.env.VITE_SUPABASE_ANON_KEY ||
  'sb_publishable_NCILoAG5w2kh9ciKd3QM8w_TTUfHkC4';

type StopTime = {
  stoppage_name?: string | null;
  up_time?: string | null;
  down_time?: string | null;
};

type BusRoute = {
  id: string;
  bus_name: string | null;
  source: string | null;
  destination: string | null;
  bus_type: string | null;
  image_url: string | null;
  route_data: StopTime[] | null;
};

type StopRow = {
  name: string;
  up_time: string;
  down_time: string;
};

type BusCard = {
  id: string;
  bus_name: string;
  bus_type: string;
  image_url: string | null;
  source: string;
  destination: string;
  departure: string;
  arrival: string;
  direction: 'up' | 'down';
  stops: StopRow[];
};

const clean = (value: string | null | undefined) => String(value || '').trim();

const slugify = (value: string) =>
  clean(value)
    .normalize('NFKD')
    .toLowerCase()
    .replace(/[^\p{Letter}\p{Number}]+/gu, '-')
    .replace(/^-+|-+$/g, '');

const normalKey = (value: string) =>
  clean(value)
    .normalize('NFKD')
    .toLowerCase()
    .replace(/[^\p{Letter}\p{Number}]+/gu, ' ')
    .replace(/\s+/g, ' ')
    .trim();

const sameStop = (a: string, b: string) => {
  const x = normalKey(a);
  const y = normalKey(b);
  return x && y && (x === y || x.includes(y) || y.includes(x));
};

function fullStops(route: BusRoute): StopRow[] {
  const rows: StopRow[] = [];

  if (route.source) {
    rows.push({ name: route.source, up_time: '', down_time: '' });
  }

  for (const stop of route.route_data || []) {
    const name = clean(stop.stoppage_name);
    if (!name) continue;

    const last = rows[rows.length - 1];

    if (last && sameStop(last.name, name)) {
      if (!last.up_time && stop.up_time) last.up_time = clean(stop.up_time);
      if (!last.down_time && stop.down_time) last.down_time = clean(stop.down_time);
      continue;
    }

    rows.push({
      name,
      up_time: clean(stop.up_time),
      down_time: clean(stop.down_time),
    });
  }

  if (route.destination) {
    const last = rows[rows.length - 1];
    if (!last || !sameStop(last.name, route.destination)) {
      rows.push({ name: route.destination, up_time: '', down_time: '' });
    }
  }

  return rows;
}

function findStopIndex(stops: StopRow[], stopName: string) {
  return stops.findIndex((stop) => sameStop(stop.name, stopName));
}

function routeContains(route: BusRoute, fromName: string, toName: string) {
  const stops = fullStops(route);
  const fromIndex = findStopIndex(stops, fromName);
  const toIndex = findStopIndex(stops, toName);
  return fromIndex !== -1 && toIndex !== -1 && fromIndex !== toIndex;
}

function makeBusCard(route: BusRoute, fromName: string, toName: string): BusCard | null {
  const stops = fullStops(route);
  const fromIndex = findStopIndex(stops, fromName);
  const toIndex = findStopIndex(stops, toName);

  if (fromIndex === -1 || toIndex === -1 || fromIndex === toIndex) return null;

  const isDown = fromIndex > toIndex;
  const departureStop = stops[fromIndex];
  const arrivalStop = stops[toIndex];

  return {
    id: route.id,
    bus_name: clean(route.bus_name) || 'Bus',
    bus_type: clean(route.bus_type) || 'Bus',
    image_url: route.image_url,
    source: departureStop.name,
    destination: arrivalStop.name,
    departure: isDown ? departureStop.down_time || 'Time not available' : departureStop.up_time || 'Time not available',
    arrival: isDown ? arrivalStop.down_time || 'Time not available' : arrivalStop.up_time || 'Time not available',
    direction: isDown ? 'down' : 'up',
    stops,
  };
}

export async function getStaticPaths() {
  const url =
    'https://ytxtyphbguszjndtpakm.supabase.co/rest/v1/bus_routes?select=id,bus_name,source,destination,bus_type,image_url,route_data&limit=3000';

  const anonKey =
    'sb_publishable_NCILoAG5w2kh9ciKd3QM8w_TTUfHkC4';
  const clean = (value: string | null | undefined) => String(value || '').trim();

  const slugify = (value: string) =>
    clean(value)
      .normalize('NFKD')
      .toLowerCase()
      .replace(/[^\p{Letter}\p{Number}]+/gu, '-')
      .replace(/^-+|-+$/g, '');

  const sameStop = (a: string | null | undefined, b: string | null | undefined) => {
    const x = clean(a)
      .normalize('NFKD')
      .toLowerCase()
      .replace(/[^\p{Letter}\p{Number}]+/gu, ' ')
      .replace(/\s+/g, ' ')
      .trim();

    const y = clean(b)
      .normalize('NFKD')
      .toLowerCase()
      .replace(/[^\p{Letter}\p{Number}]+/gu, ' ')
      .replace(/\s+/g, ' ')
      .trim();

    return Boolean(x && y && (x === y || x.includes(y) || y.includes(x)));
  };
  let routes: BusRoute[] = [];

  try {
    const res = await fetch(url, {
      headers: {
        apikey: anonKey,
        Authorization: `Bearer ${anonKey}`,
      },
    });

    if (res.ok) {
      routes = (await res.json()) as BusRoute[];
    }
  } catch {
    routes = [];
  }

  const pairMap = new Map<string, { source: string; destination: string; routes: BusRoute[] }>();

  const addMainPair = (sourceRaw: string | null, destinationRaw: string | null) => {
    const source = clean(sourceRaw);
    const destination = clean(destinationRaw);

    if (!source || !destination) return;
    if (sameStop(source, destination)) return;

    const slug = `${slugify(source)}-to-${slugify(destination)}`;
    if (!slug || slug.includes('--')) return;

    const matchedRoutes = routes.filter((route) => {
      const routeSource = clean(route.source);
      const routeDestination = clean(route.destination);

      return (
        (sameStop(routeSource, source) && sameStop(routeDestination, destination)) ||
        (sameStop(routeSource, destination) && sameStop(routeDestination, source))
      );
    });

    if (matchedRoutes.length === 0) return;

    if (!pairMap.has(slug)) {
      pairMap.set(slug, {
        source,
        destination,
        routes: matchedRoutes,
      });
    }
  };

  for (const route of routes) {
    addMainPair(route.source, route.destination);
    addMainPair(route.destination, route.source);
  }

  return Array.from(pairMap.entries()).map(([slug, value]) => ({
    params: { slug },
    props: value,
  }));
}
const { slug } = Astro.params;

const { source, destination, routes } = Astro.props as {
  source: string;
  destination: string;
  routes: BusRoute[];
};
const busCards = routes
  .map((route) => makeBusCard(route, source, destination))
  .filter(Boolean) as BusCard[];

const selectedBusId = Astro.url.searchParams.get('bus_id') || '';

const firstBus = selectedBusId
  ? busCards.find((bus) => bus.id === selectedBusId) || busCards[0]
  : busCards[0];

const uniqueStops = Array.from(
  new Set(
    busCards
      .flatMap((bus) => bus.stops.map((stop) => clean(stop.name)))
      .filter(Boolean)
  )
);

const importantStops = uniqueStops.slice(0, 10);
const busNames = busCards.map((bus) => bus.bus_name).filter(Boolean).slice(0, 6);

const upTimes = busCards
  .map((bus) => bus.departure)
  .filter((time) => time && time !== 'Time not available')
  .slice(0, 5);

const downTimes = busCards
  .map((bus) => bus.arrival)
  .filter((time) => time && time !== 'Time not available')
  .slice(0, 5);

const stopText = importantStops.length ? importantStops.join(', ') : `${source}, ${destination}`;
const busText = busNames.length ? busNames.join(', ') : 'available route buses';
const upTimeText = upTimes.length ? upTimes.join(', ') : 'available route timing';
const downTimeText = downTimes.length ? downTimes.join(', ') : 'available return-side timing';

const pageTitle = `${source} to ${destination} Bus Timetable`;
const pageDescription = `Check ${source} to ${destination} bus timetable with bus names, stop-wise up time, down time and route details on SoniaBuddy.`;
const canonical = `/bus-timetable/${slug}/`;
const canonicalUrl = `${SITE_URL}${canonical}`;

const breadcrumbJson = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: SITE_URL,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Bus Search',
      item: `${SITE_URL}/bus-search/`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: pageTitle,
      item: canonicalUrl,
    },
  ],
};

const faqJson = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: `How can I check ${source} to ${destination} bus timetable?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `You can check ${source} to ${destination} bus timetable on this page. The page shows available buses, stop-wise up time, down time and route details where data is available.`,
      },
    },
    {
      '@type': 'Question',
      name: `Are up time and down time available for ${source} to ${destination}?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `Yes, up time and down time are shown where timing data is available in the route database. Timing can change due to traffic, road conditions or operator updates.`,
      },
    },
    {
      '@type': 'Question',
      name: `Can I search reverse route from ${destination} to ${source}?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `Yes, you can search the reverse route from ${destination} to ${source} using SoniaBuddy bus search or route finder.`,
      },
    },
  ],
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
>
  <section class="timetable-page">
    <div class="container">
      <div class="hero-card">
        <p class="eyebrow" data-en="🚌 Bus Timetable" data-bn="🚌 বাস টাইমটেবিল">🚌 Bus Timetable</p>
<h1>{pageTitle}</h1>
<p
  data-en="Check available buses, bus names, route stops, up time and down time for this route."
  data-bn="এই রুটের উপলব্ধ বাস, বাসের নাম, স্টপ লিস্ট, আপ টাইম ও ডাউন টাইম দেখুন।"
>
  Check available buses, bus names, route stops, up time and down time for this route.
</p>
<p class="bn-line">এই রুটের bus timing, stop list এবং up/down time দেখুন।</p>
      </div>

      <div class="summary-grid">
        <div>
          <span data-en="From" data-bn="কোথা থেকে">From</span>
          <strong>{source}</strong>
        </div>
        <div>
          <span data-en="To" data-bn="কোথায়">To</span>
          <strong>{destination}</strong>
        </div>
        <div>
          <span data-en="Buses" data-bn="বাস">Buses</span>
          <strong>{busCards.length}</strong>
        </div>
        <div>
          <span data-en="Stops" data-bn="স্টপ">Stops</span>
          <strong>{uniqueStops.length}</strong>
        </div>
      </div>

      {firstBus ? (
        <section class="selected-card" id="selected-bus">
          <div class="bus-photo">
            {firstBus.image_url ? (
              <img src={firstBus.image_url} alt={firstBus.bus_name} loading="lazy" />
            ) : (
              <span>🚌</span>
            )}
          </div>

          <div class="bus-info">
            <p class="selected-label" data-en="Selected Bus" data-bn="নির্বাচিত বাস">Selected Bus</p>
            <h2>{firstBus.bus_name}</h2>
            <p class="route-line">{firstBus.source} → {firstBus.destination}</p>

            <div class="time-grid">
              <div>
                <small data-en="Departure" data-bn="ছাড়ার সময়">Departure</small>
                <strong>{firstBus.departure}</strong>
              </div>
              <div>
                <small data-en="Arrival" data-bn="পৌঁছানোর সময়">Arrival</small>
                <strong>{firstBus.arrival}</strong>
              </div>
              <div>
                <small data-en="Type" data-bn="ধরন">Type</small>
                <strong>{firstBus.bus_type}</strong>
              </div>
              <div>
                <small data-en="Direction" data-bn="দিক">Direction</small>
                <strong>{firstBus.direction === 'down' ? 'Down' : 'Up'}</strong>
              </div>
            </div>
          </div>
        </section>
      ) : (
        <section class="empty-card">
  <h2 data-en="No bus timetable found" data-bn="কোনো বাস টাইমটেবিল পাওয়া যায়নি">
    No bus timetable found
  </h2>

  <p
    data-en="Try another spelling, reverse direction, or search nearby stops."
    data-bn="অন্য বানান, উল্টো দিক, বা কাছাকাছি স্টপ দিয়ে সার্চ করুন।"
  >
    Try another spelling, reverse direction, or search nearby stops.
  </p>

  <div class="empty-actions">
    <a
      href="/bus-search"
      class="empty-btn secondary"
      data-en="Back to Bus Search"
      data-bn="বাস সার্চে ফিরে যান"
    >
      Back to Bus Search
    </a>

    <a
      href="/rent-vehicle?tab=find"
      class="empty-btn primary"
      data-en="Find Rent Car / Cab"
      data-bn="ভাড়া গাড়ি / ক্যাব খুঁজুন"
    >
      Find Rent Car / Cab
    </a>
  </div>
</section>
      )}

      {busCards.length > 1 && (
        <section class="section-card">
          <h2>
  <span data-en="All Buses on" data-bn="সব বাস">All Buses on</span>
  {source} to {destination}
  <span data-en="Route" data-bn="রুটে">Route</span>
</h2>
          <div class="bus-list">
            {busCards.map((bus) => (
              <a
                href={`${canonical}?bus_id=${bus.id}&from=${encodeURIComponent(source)}&to=${encodeURIComponent(destination)}#selected-bus`}
                class={`mini-bus-card ${bus.id === selectedBusId ? 'active' : ''}`}
              >
                <span>{bus.bus_name}</span>
                <small>{bus.departure} → {bus.arrival}</small>
              </a>
            ))}
          </div>
        </section>
      )}

      {firstBus && (
        <section class="section-card timetable-section">
          <h2>
  {firstBus.bus_name}
  <span data-en="Stop-wise Timetable" data-bn="স্টপ অনুযায়ী টাইমটেবিল">Stop-wise Timetable</span>
</h2>
<p
  class="table-note"
  data-en="Mobile view shows each stop as a clean card: stop name, up time and down time."
  data-bn="মোবাইলে প্রতিটি স্টপ কার্ড আকারে দেখাবে: স্টপ নাম, আপ টাইম ও ডাউন টাইম।"
>
  Mobile view shows each stop as a clean card: stop name, up time and down time.
</p>

          <div class="desktop-table">
            <table>
              <thead>
                <tr>
                  <th data-en="Stop" data-bn="স্টপ">Stop</th>
<th data-en="Up Time" data-bn="আপ টাইম">Up Time</th>
<th data-en="Down Time" data-bn="ডাউন টাইম">Down Time</th>
                </tr>
              </thead>
              <tbody>
                {firstBus.stops.map((stop) => (
                  <tr class={sameStop(stop.name, source) || sameStop(stop.name, destination) ? 'highlight-row' : ''}>
                    <td>{stop.name}</td>
                    <td>{stop.up_time || '--'}</td>
                    <td>{stop.down_time || '--'}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <div class="mobile-stop-list">
            {firstBus.stops.map((stop, index) => (
              <article class={`stop-card ${sameStop(stop.name, source) || sameStop(stop.name, destination) ? 'active-stop' : ''}`}>
                <div class="stop-top">
                  <span>{index + 1}</span>
                  <strong>{stop.name}</strong>
                </div>
                <div class="stop-times">
                  <div>
                   <small data-en="Up Time" data-bn="আপ টাইম">Up Time</small>
                    <b>{stop.up_time || '--'}</b>
                  </div>
                  <div>
                    <small data-en="Down Time" data-bn="ডাউন টাইম">Down Time</small>
                    <b>{stop.down_time || '--'}</b>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </section>
      )}

      <section class="section-card seo-summary">
        <h2>{source} to {destination} Bus Route Summary</h2>

        <p>
          The {source} to {destination} bus timetable page on SoniaBuddy is created from available route data,
          bus details and stop-wise timing information. This route currently shows {busCards.length} listed
          {busCards.length === 1 ? 'bus option' : 'bus options'} for passengers travelling from {source} to {destination}.
          Available buses on this route include {busText}. The page shows important stop information, up timing and down timing
          wherever that data is available.
        </p>

        <p>
          Important stops found for this route include {stopText}. Passengers can use this page to compare bus names,
          check departure timing, arrival timing, direction and stop-wise timetable before planning the journey.
          For the selected bus, SoniaBuddy highlights the source stop, destination stop and available up/down timing in a mobile-friendly layout.
        </p>

        <p>
          Available departure timing examples for this route include {upTimeText}. Arrival or return-side timing information includes
          {downTimeText}. Bus timing may change because of traffic, weather, road conditions, local route updates or operator changes.
          Please reach the bus stop early and confirm important travel details locally before starting the journey.
        </p>
      </section>

      <section class="section-card faq-card">
        <h2>{source} to {destination} Bus FAQ</h2>

        <details open>
          <summary>How can I check {source} to {destination} bus timetable?</summary>
          <p>
            You can check the {source} to {destination} bus timetable on this page. It shows available bus names,
            departure time, arrival time and stop-wise up/down time where data is available.
          </p>
        </details>

        <details>
          <summary>Are up time and down time available on this route?</summary>
          <p>
            Yes, up time and down time are shown in the stop-wise timetable when the timing exists in the database.
            If a time is missing, the page shows “--” or “Time not available” instead of fake timing.
          </p>
        </details>

        <details>
          <summary>Can I search {destination} to {source} reverse route?</summary>
          <p>
            Yes. You can search the reverse route from {destination} to {source} using SoniaBuddy bus search.
            Reverse timing is shown where down-time data is available.
          </p>
        </details>

        <details>
          <summary>Why can bus timing change?</summary>
          <p>
            Bus timing can change due to traffic, weather, route updates, road condition or operator changes.
            Please confirm locally before travelling.
          </p>
        </details>
      </section>

      <div class="back-row">
        <a
  href={`/bus-search?from=${encodeURIComponent(source)}&to=${encodeURIComponent(destination)}`}
  data-en="← Back to Bus Search"
  data-bn="← বাস সার্চে ফিরে যান"
>
  ← Back to Bus Search
</a>
<a href="/all-routes/" data-en="See All Routes →" data-bn="সব রুট দেখুন →">See All Routes →</a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJson)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqJson)} />

  <style>
    .timetable-page {
      min-height: 100vh;
      padding: 1rem 0 2.5rem;
      background: linear-gradient(180deg, #f8fbff 0%, #eef7ff 45%, #ffffff 100%);
    }

    .hero-card,
    .selected-card,
    .section-card,
    .empty-card {
      background: white;
      border: 1px solid #dbeafe;
      border-radius: 1.25rem;
      padding: 1rem;
      box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
      margin-bottom: 1rem;
    }

    .eyebrow {
      margin: 0 0 0.35rem;
      color: #2563eb;
      font-size: 0.8rem;
      font-weight: 800;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .hero-card h1 {
      margin: 0 0 0.5rem;
      color: #0f172a;
      font-size: clamp(1.55rem, 4vw, 2.35rem);
      line-height: 1.1;
    }

    .hero-card p,
    .section-card p,
    .empty-card p {
      color: #475569;
      line-height: 1.55;
      margin: 0.35rem 0 0;
    }

    .bn-line {
      color: #0369a1 !important;
      font-weight: 650;
    }

    .summary-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0.7rem;
      margin-bottom: 1rem;
    }

    .summary-grid div {
      background: white;
      border: 1px solid #dbeafe;
      border-radius: 1rem;
      padding: 0.8rem;
      box-shadow: 0 6px 18px rgba(15, 23, 42, 0.04);
    }

    .summary-grid span,
    .time-grid small {
      display: block;
      color: #64748b;
      font-size: 0.75rem;
      margin-bottom: 0.15rem;
    }

    .summary-grid strong,
    .time-grid strong {
      color: #0f172a;
      font-size: 0.95rem;
    }

    .selected-card {
      display: grid;
      grid-template-columns: 96px 1fr;
      gap: 0.9rem;
      align-items: start;
    }

    .bus-photo {
      width: 96px;
      height: 96px;
      border-radius: 1rem;
      background: #e0f2fe;
      overflow: hidden;
      display: grid;
      place-items: center;
      font-size: 2.2rem;
    }

    .bus-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .selected-label {
      margin: 0 0 0.2rem !important;
      color: #2563eb !important;
      font-size: 0.75rem;
      font-weight: 800;
      text-transform: uppercase;
    }

    .bus-info h2,
    .section-card h2,
    .empty-card h2 {
      margin: 0 0 0.45rem;
      color: #0f172a;
      font-size: 1.25rem;
    }

    .route-line {
      margin: 0 0 0.7rem !important;
      color: #475569 !important;
      font-weight: 700;
    }

