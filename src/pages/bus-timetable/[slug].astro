      color: #0f172a;
      font-size: 0.95rem;
    }

    .selected-card {
      display: grid;
      grid-template-columns: 96px 1fr;
      gap: 0.9rem;
      align-items: start;
    }

    .bus-photo {
  width: 120px;
  height: 120px;
  border-radius: 1rem;
  background: #20145a;
