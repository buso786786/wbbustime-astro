---
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
	return [
		{ params: { slug: 'tarakeswar-to-digha' } },
		{ params: { slug: 'result' } }
	];
}

const { slug } = Astro.params;

// Check if this is the result page
const isResultPage = slug === 'result';

// Read query params for result page
const url = new URL(Astro.request.url);
const busId = url.searchParams.get('bus_id') || '';
const busName = url.searchParams.get('bus_name') || '';
const from = url.searchParams.get('from') || '';
const to = url.searchParams.get('to') || '';

// Static demo route data - database-ready structure
const routeData = {
	slug: "tarakeswar-to-digha",
	source_name_en: "Tarakeswar",
	source_name_bn: "তারকেশ্বর",
	destination_name_en: "Digha",
	destination_name_bn: "দীঘা",
	seo_title_en: "Tarakeswar to Digha Bus Timetable",
	seo_description_en: "Complete bus timetable from Tarakeswar to Digha. View all stops, departure times, arrival times, fare, and duration.",
	travel_guide_en: "The route from Tarakeswar to Digha covers 185 km and takes approximately 4 hours 15 minutes. Buses run daily with multiple departures throughout the day.",
	travel_guide_bn: "তারকেশ্বর থেকে দিঘা পর্যন্ত রুটটি ১৮৫ কিলোমিটার এবং প্রায় ৪ ঘণ্টা ১৫ মিনিট সময় নেয়। দিনে একাধিকবার বাস চলাচল করে।",
	fare_min: 150,
	fare_max: 180,
	distance_text: "185 km",
	duration_text: "4h 15m",
	stops: [
		{ name_en: "Tarakeswar", name_bn: "তারকেশ্বর", up_time: "05:00 AM", down_time: "11:15 AM" },
		{ name_en: "Haripal", name_bn: "হরিপাল", up_time: "05:25 AM", down_time: "10:50 AM" },
		{ name_en: "Jangipara", name_bn: "জাঙ্গিপাড়া", up_time: "--:--", down_time: "--:--" },
		{ name_en: "Arambagh", name_bn: "আরামবাগ", up_time: "06:10 AM", down_time: "10:05 AM" },
		{ name_en: "Goghat", name_bn: "গোঘাট", up_time: "06:35 AM", down_time: "09:40 AM" },
		{ name_en: "Digha", name_bn: "দীঘা", up_time: "10:15 AM", down_time: "04:30 PM" }
	],
	buses: [
		{
			id: 1,
			name: "Tarakeswar Express",
			reg_number: "WB 12 4567",
			departure: "05:00 AM",
			arrival: "10:15 AM",
			fare: "₹150",
			duration: "5h 15m",
			slug: "tarakeswar-express",
			stop_times: [
				{ up_time: "05:00 AM", down_time: "11:15 AM" },
				{ up_time: "05:25 AM", down_time: "10:50 AM" },
				{ up_time: "--:--", down_time: "--:--" },
				{ up_time: "06:10 AM", down_time: "10:05 AM" },
				{ up_time: "06:35 AM", down_time: "09:40 AM" },
				{ up_time: "10:15 AM", down_time: "04:30 PM" }
			],
			photo: "/bus-placeholder.jpg"
		},
		{
			id: 2,
			name: "Maa Tara Travels",
			reg_number: "WB 27 0999",
			departure: "06:30 AM",
			arrival: "11:45 AM",
			fare: "₹170",
			duration: "5h 15m",
			slug: "maa-tara-travels",
			stop_times: [
				{ up_time: "06:30 AM", down_time: "12:00 PM" },
				{ up_time: "06:55 AM", down_time: "11:35 AM" },
				{ up_time: "07:15 AM", down_time: "11:10 AM" },
				{ up_time: "07:45 AM", down_time: "10:40 AM" },
				{ up_time: "08:10 AM", down_time: "10:15 AM" },
				{ up_time: "11:45 AM", down_time: "05:00 PM" }
			],
			photo: "/bus-placeholder.jpg"
		},
		{
			id: 3,
			name: "Digha Local",
			reg_number: "WB 41 2233",
			departure: "08:00 AM",
			arrival: "01:30 PM",
			fare: "₹140",
			duration: "5h 30m",
			slug: "digha-local",
			stop_times: [
				{ up_time: "08:00 AM", down_time: "01:15 PM" },
				{ up_time: "08:30 AM", down_time: "12:50 PM" },
				{ up_time: "--:--", down_time: "--:--" },
