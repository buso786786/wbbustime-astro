  'cooch behar': 'কোচবিহার',
};

const stopBn = (name: string) => STOP_BN_MAP[normalKey(name)] || name;

const isSearchStop = (name: string) => sameStop(name, queryFrom) || sameStop(name, queryTo);

const timeToMinutesSafe = (value: string) => {
  const raw = clean(value).toLowerCase();
  if (!raw || raw === '--' || raw.includes('not available')) return 99999;

  const match = raw.match(/(\d{1,2})[:.](\d{2})\s*(am|pm)?/i);
  if (!match) return 99999;

  let hour = Number(match[1]);
  const minute = Number(match[2]);
  const meridiem = match[3];

  if (meridiem === 'pm' && hour !== 12) hour += 12;
  if (meridiem === 'am' && hour === 12) hour = 0;

  return hour * 60 + minute;
};

const dayPartEn = (value: string) => {
  const minutes = timeToMinutesSafe(value);
  if (minutes === 99999) return '';
  if (minutes < 360) return 'Night';
  if (minutes < 720) return 'Morning';
  if (minutes < 1020) return 'Day';
  if (minutes < 1200) return 'Evening';
  return 'Night';
};

const dayPartBn = (value: string) => {
  const part = dayPartEn(value);
  if (part === 'Morning') return 'সকাল';
  if (part === 'Day') return 'দিন';
  if (part === 'Evening') return 'সন্ধ্যা';
  if (part === 'Night') return 'রাত';
  return '';
};

const uniqueText = (items: string[]) =>
  Array.from(new Set(items.map((item) => clean(item)).filter(Boolean)));

const listText = (items: string[], fallback: string, limit = 8) => {
  const values = uniqueText(items).slice(0, limit);

  if (values.length === 0) return fallback;
  if (values.length === 1) return values[0];
  if (values.length === 2) return `${values[0]} and ${values[1]}`;

  return `${values.slice(0, -1).join(', ')} and ${values[values.length - 1]}`;
};

const timeText = (items: string[], fallback: string, limit = 5) => {
  const values = uniqueText(items)
    .filter((time) => time && time !== 'Time not available')
    .slice(0, limit)
    .map((time) => {
      const part = dayPartEn(time);
      return part ? `${time} (${part})` : time;
    });

  return values.length ? values.join(', ') : fallback;
};

const getSegmentStops = () => {
  if (!firstBus?.stops?.length) return importantStops;

  const fromIndex = findStopIndex(firstBus.stops, source);
  const toIndex = findStopIndex(firstBus.stops, destination);

  if (fromIndex === -1 || toIndex === -1 || fromIndex === toIndex) {
    return importantStops;
  }

  const start = Math.min(fromIndex, toIndex);
  const end = Math.max(fromIndex, toIndex);

  const segment = firstBus.stops
    .slice(start, end + 1)
    .map((stop) => clean(stop.name))
    .filter(Boolean);

  return fromIndex > toIndex ? segment.reverse() : segment;
};

const segmentStops = getSegmentStops();
const busNameSummary = listText(busCards.map((bus) => bus.bus_name), 'available buses', 6);
const busTypeSummary = listText(busCards.map((bus) => bus.bus_type), 'local bus services', 4);
const segmentStopSummary = listText(segmentStops, `${source} and ${destination}`, 10);

const departureSummary = timeText(
  busCards.map((bus) => bus.departure),
  'available departure timing'
);

const arrivalSummary = timeText(
  busCards.map((bus) => bus.arrival),
  'available arrival timing'
);

const directionLabel =
  firstBus?.direction === 'down'
    ? 'return/down-side'
    : 'going/up-side';

const directionIntro =
  firstBus?.direction === 'down'
    ? `${source} to ${destination} is shown as the return/down-side journey for this bus route. This page focuses on the opposite direction timing, down-time values and reverse stop order where data is available.`
    : `${source} to ${destination} is shown as the going/up-side journey for this bus route. This page focuses on forward direction timing, up-time values and stop order from source towards destination.`;

const timetableFocus =
  firstBus?.direction === 'down'
    ? 'down time, return-side stop order and reverse journey timing'
    : 'up time, forward stop order and going-side journey timing';

const reverseRouteText = `${destination} to ${source}`;

const pageTitle = `${source} to ${destination} Bus Timetable`;
const pageDescription = `Check ${source} to ${destination} bus timetable with bus names, stop-wise up time, down time and route details on SoniaBuddy.`;

const seoSummaryParagraphs = [
  `${pageTitle} on SoniaBuddy is built from available bus route records, listed bus names and stop-wise timing data. ${directionIntro} This page currently shows ${busCards.length} ${busCards.length === 1 ? 'bus option' : 'bus options'} for passengers travelling from ${source} towards ${destination}. Available service information includes ${busNameSummary}, with bus type data such as ${busTypeSummary}.`,

  `For this ${source} to ${destination} route segment, important stops include ${segmentStopSummary}. The page is focused on ${timetableFocus}, so passengers can understand the correct travel side instead of only seeing the full route name. Use the stop-wise timetable to check where the bus starts, which major stops are covered, and where ${destination} appears in the route order.`,

  `Timing examples for ${source} to ${destination} include departure around ${departureSummary} and arrival around ${arrivalSummary}. These timings are based on the route data currently available in the database and may change because of traffic, road condition, weather, local updates or operator changes. Before travelling, confirm the latest timing locally and reach the stop early.`
];

const canonical = `/bus-timetable/${slug}/`;
const canonicalUrl = `${SITE_URL}${canonical}`;

const breadcrumbJson = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: SITE_URL,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Bus Search',
      item: `${SITE_URL}/bus-search/`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: pageTitle,
      item: canonicalUrl,
    },
  ],
};

const faqJson = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: `How can I check ${source} to ${destination} bus timetable?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `You can check ${source} to ${destination} bus timetable on this page. The page shows available buses, stop-wise up time, down time and route details where data is available.`,
      },
    },
    {
      '@type': 'Question',
      name: `Are up time and down time available for ${source} to ${destination}?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `Yes, up time and down time are shown where timing data is available in the route database. Timing can change due to traffic, road conditions or operator updates.`,
      },
    },
    {
      '@type': 'Question',
      name: `Can I search reverse route from ${destination} to ${source}?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `Yes, you can search the reverse route from ${destination} to ${source} using SoniaBuddy bus search or route finder.`,
      },
    },
  ],
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonicalUrl}
  disableLangScript={true}
>
  <section class="timetable-page">
    <div class="container">
      <div class="hero-card">
        <p class="eyebrow" data-en="🚌 Bus Timetable" data-bn="🚌 বাস টাইমটেবিল">🚌 Bus Timetable</p>
<h1><span data-en={`${source} to ${destination} Bus Timetable`} data-bn={`${stopBn(source)} থেকে ${stopBn(destination)} বাস টাইমটেবিল`}>{pageTitle}</span></h1>
<p
  data-en="Check available buses, bus names, route stops, up time and down time for this route."
  data-bn="এই রুটের উপলব্ধ বাস, বাসের নাম, স্টপ লিস্ট, আপ টাইম ও ডাউন টাইম দেখুন।"
>
  Check available buses, bus names, route stops, up time and down time for this route.
</p>
<p class="bn-line">এই রুটের bus timing, stop list এবং ছাড়ার সময় দেখুন।</p>
      </div>

      <a class="rent-emoji-strip" href="/rent-vehicle?tab=find" aria-label="Find rent vehicle">
        <span data-en="🚗 Tour car · 💍 Wedding car · 🚌 Bus rent · 🚑 Emergency vehicle · 🛺 Toto near you" data-bn="🚗 ট্যুর গাড়ি · 💍 বিয়ের গাড়ি · 🚌 বাস ভাড়া · 🚑 জরুরি গাড়ি · 🛺 কাছাকাছি টোটো এখানে ক্লিক করুন">
          🚗 Tour car · 💍 Wedding car · 🚌 Bus rent · 🚑 Emergency vehicle · 🛺 Toto near you
        </span>
      </a>

      <div class="summary-grid">
        <div>
          <span data-en="From" data-bn="কোথা থেকে">From</span>
          <strong data-en={source} data-bn={stopBn(source)}>{source}</strong>
        </div>
        <div>
          <span data-en="To" data-bn="কোথায়">To</span>
          <strong data-en={destination} data-bn={stopBn(destination)}>{destination}</strong>
        </div>
        <div>
          <span data-en="Buses" data-bn="বাস">Buses</span>
          <strong>{busCards.length}</strong>
        </div>
        <div>
          <span data-en="Stops" data-bn="স্টপ">Stops</span>
          <strong>{uniqueStops.length}</strong>
        </div>
      </div>

      {firstBus ? (
        <section class="selected-card" id="selected-bus">
          <div class="bus-photo">
            {selectedPhoto ? (
  <img src={selectedPhoto} alt={firstBus.bus_name} loading="lazy" decoding="async" />
) : (
  <span>🚌</span>
)}
          </div>

          <div class="bus-info">
            <p class="selected-label" data-en="Selected Bus" data-bn="নির্বাচিত বাস">Selected Bus</p>
            <h2>{firstBus.bus_name}</h2>
            <p class="route-line">
                <span data-en={firstBus.source} data-bn={stopBn(firstBus.source)}>{firstBus.source}</span>
                <span>→</span>
                <span data-en={firstBus.destination} data-bn={stopBn(firstBus.destination)}>{firstBus.destination}</span>
              </p>

            <div class="time-grid">
              <div>
                <small data-en="Departure" data-bn="ছাড়ার সময়">Departure</small>
                <strong>{firstBus.departure}</strong>
              </div>
              <div>
                <small data-en="Arrival" data-bn="পৌঁছানোর সময়">Arrival</small>
                <strong>{firstBus.arrival}</strong>
              </div>
              <div>
                <small data-en="Type" data-bn="ধরন">Type</small>
                <strong>{firstBus.bus_type}</strong>
              </div>
              <div>
                <small data-en="Direction" data-bn="দিক">Direction</small>
                <strong data-en={firstBus.direction === "down" ? "Down" : "Up"} data-bn={firstBus.direction === "down" ? "ডাউন" : "আপ"}>{firstBus.direction === "down" ? "Down" : "Up"}</strong>
              </div>
            </div>
          </div>
        </section>
      ) : (
        <section class="empty-card">
  <h2 data-en="No bus timetable found" data-bn="কোনো বাস টাইমটেবিল পাওয়া যায়নি">
    No bus timetable found
  </h2>

  <p
    data-en="Try another spelling, reverse direction, or search nearby stops."
    data-bn="অন্য বানান, উল্টো দিক, বা কাছাকাছি স্টপ দিয়ে সার্চ করুন।"
  >
    Try another spelling, reverse direction, or search nearby stops.
  </p>

  <div class="empty-actions">
    <a
      href="/bus-search"
      class="empty-btn secondary"
      data-en="Back to Bus Search"
      data-bn="বাস সার্চে ফিরে যান"
    >
      Back to Bus Search
    </a>

    <a
      href="/rent-vehicle?tab=find"
      class="empty-btn primary"
      data-en="Find Rent Car / Cab"
      data-bn="ভাড়া গাড়ি / ক্যাব খুঁজুন"
    >
      Find Rent Car / Cab
    </a>
  </div>
</section>
      )}

      {busCards.length > 1 && (
        <section class="section-card">
          <h2>
  <span data-en="All Buses on" data-bn="সব বাস">All Buses on</span>
  <span data-en={`${source} to ${destination}`} data-bn={`${stopBn(source)} থেকে ${stopBn(destination)}`}>{source} to {destination}</span>
  <span data-en="Route" data-bn="রুটে">Route</span>
</h2>
          <div class="bus-list">
            {busCards.map((bus) => (
              <a
                href={`${canonical}?bus_id=${bus.id}&from=${encodeURIComponent(source)}&to=${encodeURIComponent(destination)}#selected-bus`}
                class={`mini-bus-card ${bus.id === selectedBusId ? 'active' : ''}`}
              >
                <span>{bus.bus_name}</span>
                <small>{bus.departure} → {bus.arrival}</small>
              </a>
            ))}
          </div>
        </section>
      )}

      {firstBus && (
        <section class="section-card timetable-section">
          <h2>
  {firstBus.bus_name}
  <span data-en="Stop-wise Timetable" data-bn="স্টপ অনুযায়ী টাইমটেবিল">Stop-wise Timetable</span>
</h2>
<p
  class="table-note"
  data-en="Mobile view shows each stop as a clean card: stop name, up time and down time."
  data-bn="মোবাইলে প্রতিটি স্টপ কার্ড আকারে দেখাবে: স্টপ নাম, আপ টাইম ও ডাউন টাইম।"
>
  Mobile view shows each stop as a clean card: stop name, up time and down time.
</p>

          <div class="desktop-table">
            <table>
              <thead>
                <tr>
                  <th data-en="Stop" data-bn="স্টপ">Stop</th>
<th data-en="Up Time" data-bn="যাওয়ার সময়">Up Time</th>
<th data-en="Down Time" data-bn="আসার সময়">Down Time</th>
                </tr>
              </thead>
              <tbody>
                {displayStopRows.map((stop) => (
                  <tr class={isSearchStop(stop.name) ? 'highlight-row exact-search-row' : ''}>
                    <td>
                      <span class={isSearchStop(stop.name) ? 'exact-stop-name stop-name' : 'stop-name'} data-en={stop.name} data-bn={stopBn(stop.name)}>
                        {stop.name}
                      </span>
                    </td>
                    <td>
                      <span class="time-cell-value">{stop.up_time || '--'}</span>
                      {dayPartEn(stop.up_time) && (
                        <span class="time-day-pill" data-en={dayPartEn(stop.up_time)} data-bn={dayPartBn(stop.up_time)}>
                          {dayPartEn(stop.up_time)}
                        </span>
                      )}
                    </td>
                    <td>
                      <span class="time-cell-value">{stop.down_time || '--'}</span>
                      {dayPartEn(stop.down_time) && (
                        <span class="time-day-pill" data-en={dayPartEn(stop.down_time)} data-bn={dayPartBn(stop.down_time)}>
                          {dayPartEn(stop.down_time)}
                        </span>
                      )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <div class="mobile-stop-list">
            {displayStopRows.map((stop, index) => (
              <article class={`stop-card thin-stop-card ${isSearchStop(stop.name) ? 'active-stop exact-search-row' : ''}`}>
                <div class="stop-top">
                  <span>{index + 1}</span>
                  <strong class={isSearchStop(stop.name) ? 'exact-stop-name stop-name' : 'stop-name'} data-en={stop.name} data-bn={stopBn(stop.name)}>
                    {stop.name}
                  </strong>
                </div>
                <div class="stop-times">
                  <div>
                    <small data-en="Up Time" data-bn="যাওয়ার সময়">Up Time</small>
                    <b>{stop.up_time || '--'}</b>
                    {dayPartEn(stop.up_time) && (
                      <em class="time-day-pill" data-en={dayPartEn(stop.up_time)} data-bn={dayPartBn(stop.up_time)}>
                        {dayPartEn(stop.up_time)}
                      </em>
                    )}
                  </div>
                  <div>
                    <small data-en="Down Time" data-bn="আসার সময়">Down Time</small>
                    <b>{stop.down_time || '--'}</b>
                    {dayPartEn(stop.down_time) && (
                      <em class="time-day-pill" data-en={dayPartEn(stop.down_time)} data-bn={dayPartBn(stop.down_time)}>
                        {dayPartEn(stop.down_time)}
                      </em>
                    )}
                  </div>
                </div>
              </article>
            ))}
          </div>
        </section>
      )}

      <section class="section-card seo-summary">
  <h2>{source} to {destination} Bus Route Summary</h2>

  {seoSummaryParagraphs.map((paragraph) => (
    <p>{paragraph}</p>
  ))}
</section>

      <section class="section-card faq-card">
        <h2>{source} to {destination} Bus FAQ</h2>

        <details open>
          <summary>How can I check {source} to {destination} bus timetable?</summary>
          <p>
            You can check the {source} to {destination} bus timetable on this page. It shows available bus names,
            departure time, arrival time and stop-wise up/down time where data is available.
          </p>
        </details>

        <details>
          <summary>Are up time and down time available on this route?</summary>
          <p>
            Yes, up time and down time are shown in the stop-wise timetable when the timing exists in the database.
            If a time is missing, the page shows “--” or “Time not available” instead of fake timing.
          </p>
        </details>

        <details>
          <summary>Can I search {destination} to {source} reverse route?</summary>
          <p>
            Yes. You can search the reverse route from {destination} to {source} using SoniaBuddy bus search.
            Reverse timing is shown where down-time data is available.
          </p>
        </details>

        <details>
          <summary>Why can bus timing change?</summary>
          <p>
            Bus timing can change due to traffic, weather, route updates, road condition or operator changes.
            Please confirm locally before travelling.
          </p>
        </details>
      </section>

      <div class="back-row">
        <a
  href={`/bus-search?from=${encodeURIComponent(source)}&to=${encodeURIComponent(destination)}`}
  data-en="← Back to Bus Search"
  data-bn="← বাস সার্চে ফিরে যান"
>
  ← Back to Bus Search
</a>
<a href="/all-routes/" data-en="See All Routes →" data-bn="সব রুট দেখুন →">See All Routes →</a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJson)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqJson)} />

  <style is:global>
    .timetable-page {
      min-height: 100vh;
      padding: 1rem 0 2.5rem;
      background: linear-gradient(180deg, #f8fbff 0%, #eef7ff 45%, #ffffff 100%);
    }
    .timetable-page {
  cursor: default;
}

.timetable-page a,
.timetable-page button,
.timetable-page summary {
  cursor: pointer;
}
    .hero-card,
    .selected-card,
    .section-card,
    .empty-card {
      background: white;
      border: 1px solid #dbeafe;
      border-radius: 1.25rem;
      padding: 1rem;
      box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
      margin-bottom: 1rem;
    }

    .eyebrow {
      margin: 0 0 0.35rem;
      color: #2563eb;
      font-size: 0.8rem;
      font-weight: 800;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .hero-card h1 {
      margin: 0 0 0.5rem;
