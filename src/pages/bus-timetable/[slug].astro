				{ up_time: "09:45 AM", down_time: "11:40 AM" },
				{ up_time: "01:30 PM", down_time: "06:30 PM" }
			],
			photo: "/bus-placeholder.jpg"
		},
		{
			id: 4,
			name: "Morning Star Bus",
			reg_number: "WB 39 7788",
			departure: "10:15 AM",
			arrival: "03:45 PM",
			fare: "₹180",
			duration: "5h 30m",
			slug: "morning-star-bus",
			stop_times: [
				{ up_time: "10:15 AM", down_time: "03:00 PM" },
				{ up_time: "10:40 AM", down_time: "02:35 PM" },
				{ up_time: "11:05 AM", down_time: "02:10 PM" },
				{ up_time: "11:30 AM", down_time: "01:40 PM" },
				{ up_time: "12:00 PM", down_time: "01:10 PM" },
				{ up_time: "03:45 PM", down_time: "08:30 PM" }
			],
			photo: "/bus-placeholder.jpg"
		}
	],
	faq_items: [
		{
			question_en: "What is the fare from Tarakeswar to Digha?",
			question_bn: "তারকেশ্বর থেকে দিঘা এর ভাড়া কত?",
			answer_en: "The fare ranges from ₹150 to ₹180 depending on the bus type and service.",
			answer_bn: "বাসের ধরন ও সার্ভিস অনুযায়ী ভাড়া ₹150 থেকে ₹180 পর্যন্ত হতে পারে।"
		}
	],
	related_routes: [
		{ from_en: "Kolkata", from_bn: "কলকাতা", to_en: "Digha", to_bn: "দীঘা" }
	]
};

const routeTitle = isResultPage ? 'Bus Timetable' : routeData.seo_title_en;
const routeDescription = isResultPage ? 'View bus timetable details.' : routeData.seo_description_en;
const canonical = `/bus-timetable/${slug}/`;
---

<BaseLayout
	title={routeTitle}
	description={routeDescription}
	canonical={canonical}
>
	<div class="debug-label">PAGE: TIMETABLE</div>
	{isResultPage ? (
		<section class="hero">
			<div class="container">
				<h1>Bus Timetable</h1>
			</div>
		</section>
	) : (
		<section class="hero">
			<div class="container">
				<h1>Tarakeswar to Digha Bus Timetable</h1>
			</div>
		</section>
	)}

	{isResultPage ? (
		<section>
			<div class="container">
				<div class="card" style="text-align: center; padding: 2rem;">
					<h3 style="margin-bottom: 1rem;">Selected Bus</h3>

<p id="result-bus-name" style="font-size: 1.25rem; font-weight: 500; margin-bottom: 0.5rem;">
	Selected bus
</p>

<p id="result-route" style="color: #64748b; margin-bottom: 0.5rem;"></p>

<p id="result-bus-id" style="color: #64748b; margin-bottom: 1.5rem; font-size: 0.875rem;"></p>

<p style="color: #64748b;">Detailed stop timetable will be connected here.</p>
				</div>
			</div>
		</section>
	) : (
		<section>
			<div class="container">
				<div class="route-summary">
					<div class="summary-item">
						<span class="summary-label">
							<span class="lang-en">Source</span>
							<span class="lang-bn">উৎস</span>
						</span>
						<span class="summary-value">
							<span class="lang-en">{routeData.source_name_en}</span>
							<span class="lang-bn">{routeData.source_name_bn}</span>
						</span>
					</div>
					<div class="summary-item">
						<span class="summary-label">
							<span class="lang-en">Destination</span>
							<span class="lang-bn">গন্তব্য</span>
						</span>
						<span class="summary-value">
							<span class="lang-en">{routeData.destination_name_en}</span>
							<span class="lang-bn">{routeData.destination_name_bn}</span>
						</span>
					</div>
					<div class="summary-item">
						<span class="summary-label">
							<span class="lang-en">Distance</span>
							<span class="lang-bn">দূরত্ব</span>
						</span>
						<span class="summary-value">{routeData.distance_text}</span>
					</div>
					<div class="summary-item">
						<span class="summary-label">
							<span class="lang-en">Duration</span>
							<span class="lang-bn">সময়কাল</span>
						</span>
						<span class="summary-value">{routeData.duration_text}</span>
					</div>
					<div class="summary-item">
						<span class="summary-label">
							<span class="lang-en">Fare</span>
							<span class="lang-bn">ভাড়া</span>
						</span>
						<span class="summary-value">₹{routeData.fare_min} - ₹{routeData.fare_max}</span>
					</div>
				</div>
			</div>
		</section>
	)}

	{!isResultPage && (
		<>
		<section>
			<div class="container">
				<div class="bus-summary-header">
					<p class="selected-bus-text">Selected Bus: <span id="selected-bus-name">{routeData.buses[0].name}</span></p>
					<p class="search-segment-text" id="search-segment-container" class="hidden">
						Search Segment: <span id="search-segment-from"></span> → <span id="search-segment-to"></span> |
						Direction: <span id="search-direction"></span>
					</p>
				</div>
				<div class="bus-card">
					<div class="bus-photo">
						<span class="bus-photo-emoji">🚌</span>
					</div>
					<div class="bus-info">
						<h3 id="bus-name">{routeData.buses[0].name}</h3>
						<p class="bus-reg" id="bus-reg">{routeData.buses[0].reg_number}</p>
						<p class="bus-route">
							{routeData.source_name_en} → {routeData.destination_name_en}
						</p>
						<div class="bus-timing-row">
							<div class="timing-item">
								<span class="timing-label">Departure</span>
								<span class="timing-value" id="bus-departure">{routeData.buses[0].departure}</span>
							</div>
							<div class="timing-item">
								<span class="timing-label">Arrival</span>
								<span class="timing-value" id="bus-arrival">{routeData.buses[0].arrival}</span>
							</div>
							<div class="timing-item">
								<span class="timing-label">Fare</span>
								<span class="timing-value" id="bus-fare">{routeData.buses[0].fare}</span>
							</div>
							<div class="timing-item">
								<span class="timing-label">Duration</span>
								<span class="timing-value" id="bus-duration">{routeData.buses[0].duration}</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section>
			<div class="container">
				<a href="/bus-search" class="back-link">← Back to Bus Search</a>
			</div>
		</section>

		<section>
			<div class="container">
				<div class="section-title">
					<h2>Select Bus</h2>
				</div>
				<div class="bus-selection">
					{routeData.buses.map((bus: any) => (
						<a href={`/bus-timetable/${slug}/?bus=${bus.slug}`} class="bus-select-btn" data-bus-slug={bus.slug}>
							{bus.name}
						</a>
					))}
				</div>
			</div>
		</section>

		<section>
			<div class="container">
				<div class="section-title">
					<h2>Full Stops Timetable</h2>
				</div>
				<div class="timetable-table">
					<table>
						<thead>
							<tr>
								<th>Stop No</th>
								<th>Stop Name</th>
								<th>Up Time</th>
								<th>Down Time</th>
							</tr>
						</thead>
						<tbody>
							{routeData.stops.map((stop, index) => (
								<tr id={`stop-row-${index}`}>
									<td>{index + 1}</td>
									<td>{stop.name_en}</td>
									<td id={`stop-up-${index}`}>{stop.up_time}</td>
									<td id={`stop-down-${index}`}>{stop.down_time}</td>
								</tr>
							))}
						</tbody>
					</table>
				</div>
			</div>
		</section>

		<section>
			<div class="container">
				<div class="section-title">
					<h2>Travel Guide</h2>
				</div>
				<div class="card">
					<p>{routeData.travel_guide_en}</p>
				</div>
			</div>
		</section>

		<section>
			<div class="container">
				<div class="section-title">
					<h2>Fare Information</h2>
				</div>
				<div class="card">
					<p>Fare Range: ₹{routeData.fare_min} - ₹{routeData.fare_max}</p>
				</div>
			</div>
		</section>

		<section>
			<div class="container">
				<div class="section-title">
					<h2>FAQ</h2>
				</div>
				<div class="faq-list">
					{routeData.faq_items.map(faq => (
						<div class="faq-item">
							<h3>{faq.question_en}</h3>
							<p>{faq.answer_en}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "BreadcrumbList",
			"itemListElement": [
				{
					"@type": "ListItem",
					"position": 1,
					"name": "Home",
					"item": "https://soniabuddy.com"
				},
				{
					"@type": "ListItem",
					"position": 2,
					"name": "Bus Search",
					"item": "https://soniabuddy.com/bus-search"
				},
				{
					"@type": "ListItem",
					"position": 3,
					"name": routeTitle,
					"item": `https://soniabuddy.com${canonical}`
				}
			]
		})}>
		</script>

		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "FAQPage",
			"mainEntity": routeData.faq_items.map(faq => ({
				"@type": "Question",
				"name": faq.question_en,
				"acceptedAnswer": {
					"@type": "Answer",
					"text": faq.answer_en
				}
			}))
		})}>
		</script>

		<script>
		(function() {
		const buses = [
			{
				slug: "tarakeswar-express",
				name: "Tarakeswar Express",
				reg_number: "WB 12 4567",
				departure: "05:00 AM",
				arrival: "10:15 AM",
				fare: "₹150",
				duration: "5h 15m",
				stop_times: [
					{ up_time: "05:00 AM", down_time: "11:15 AM" },
					{ up_time: "05:25 AM", down_time: "10:50 AM" },
					{ up_time: "--:--", down_time: "--:--" },
					{ up_time: "06:10 AM", down_time: "10:05 AM" },
					{ up_time: "06:35 AM", down_time: "09:40 AM" },
					{ up_time: "10:15 AM", down_time: "04:30 PM" }
				]
			},
			{
				slug: "maa-tara-travels",
				name: "Maa Tara Travels",
				reg_number: "WB 27 0999",
				departure: "06:30 AM",
				arrival: "11:45 AM",
				fare: "₹170",
				duration: "5h 15m",
				stop_times: [
					{ up_time: "06:30 AM", down_time: "12:00 PM" },
					{ up_time: "06:55 AM", down_time: "11:35 AM" },
					{ up_time: "07:15 AM", down_time: "11:10 AM" },
					{ up_time: "07:45 AM", down_time: "10:40 AM" },
					{ up_time: "08:10 AM", down_time: "10:15 AM" },
					{ up_time: "11:45 AM", down_time: "05:00 PM" }
				]
			},
			{
				slug: "digha-local",
				name: "Digha Local",
				reg_number: "WB 41 2233",
				departure: "08:00 AM",
				arrival: "01:30 PM",
				fare: "₹140",
				duration: "5h 30m",
				stop_times: [
					{ up_time: "08:00 AM", down_time: "01:15 PM" },
					{ up_time: "08:30 AM", down_time: "12:50 PM" },
					{ up_time: "--:--", down_time: "--:--" },
					{ up_time: "09:15 AM", down_time: "12:10 PM" },
					{ up_time: "09:45 AM", down_time: "11:40 AM" },
					{ up_time: "01:30 PM", down_time: "06:30 PM" }
				]
			},
			{
				slug: "morning-star-bus",
				name: "Morning Star Bus",
				reg_number: "WB 39 7788",
				departure: "10:15 AM",
				arrival: "03:45 PM",
				fare: "₹180",
				duration: "5h 30m",
				stop_times: [
					{ up_time: "10:15 AM", down_time: "03:00 PM" },
					{ up_time: "10:40 AM", down_time: "02:35 PM" },
					{ up_time: "11:05 AM", down_time: "02:10 PM" },
					{ up_time: "11:30 AM", down_time: "01:40 PM" },
					{ up_time: "12:00 PM", down_time: "01:10 PM" },
					{ up_time: "03:45 PM", down_time: "08:30 PM" }
				]
			}
		];

		const params = new URLSearchParams(window.location.search);
		const busSlug = params.get("bus");
		const from = params.get("from");
		const to = params.get("to");

		const selectedBus = busSlug ? buses.find(b => b.slug === busSlug) : buses[0];

		if (selectedBus) {
			const busName = document.getElementById('bus-name');
			const busReg = document.getElementById('bus-reg');
			const busDeparture = document.getElementById('bus-departure');
			const busArrival = document.getElementById('bus-arrival');
			const busFare = document.getElementById('bus-fare');
			const busDuration = document.getElementById('bus-duration');
			const selectedBusName = document.getElementById('selected-bus-name');

			if (busName) busName.textContent = selectedBus.name;
			if (busReg) busReg.textContent = selectedBus.reg_number;
			if (busFare) busFare.textContent = selectedBus.fare;
			if (busDuration) busDuration.textContent = selectedBus.duration;
			if (selectedBusName) selectedBusName.textContent = selectedBus.name;

			// Update stop table
			if (selectedBus.stop_times) {
				selectedBus.stop_times.forEach((stopTime, index) => {
					const stopUp = document.getElementById(`stop-up-${index}`);
					const stopDown = document.getElementById(`stop-down-${index}`);
					if (stopUp) stopUp.textContent = stopTime.up_time;
					if (stopDown) stopDown.textContent = stopTime.down_time;
				});
			}

			// Handle from/to query params for segment search
			if (from && to) {
				const normalizeStop = (value: string) =>
					value.toLowerCase().trim().replace(/\s+/g, " ");

				const stopOrder = [
					"tarakeswar",
					"haripal",
					"jangipara",
					"arambagh",
					"goghat",
					"digha"
				];

				const fromIndex = stopOrder.indexOf(normalizeStop(from));
				const toIndex = stopOrder.indexOf(normalizeStop(to));

				if (fromIndex !== -1 && toIndex !== -1 && fromIndex !== toIndex) {
					const isReverse = fromIndex > toIndex;
					const direction = isReverse ? "Down" : "Up";

					// Show search segment container
					const searchSegmentContainer = document.getElementById('search-segment-container');
					if (searchSegmentContainer) {
						searchSegmentContainer.classList.remove('hidden');
					}

					// Update search segment text
					const searchSegmentFrom = document.getElementById('search-segment-from');
					const searchSegmentTo = document.getElementById('search-segment-to');
					const searchDirection = document.getElementById('search-direction');

					if (searchSegmentFrom) searchSegmentFrom.textContent = from;
					if (searchSegmentTo) searchSegmentTo.textContent = to;
					if (searchDirection) searchDirection.textContent = direction;

					// Update departure and arrival with segment times
					if (busDeparture && selectedBus.stop_times[fromIndex]) {
						busDeparture.textContent = isReverse ? selectedBus.stop_times[fromIndex].down_time : selectedBus.stop_times[fromIndex].up_time;
					}
					if (busArrival && selectedBus.stop_times[toIndex]) {
						busArrival.textContent = isReverse ? selectedBus.stop_times[toIndex].down_time : selectedBus.stop_times[toIndex].up_time;
					}

					// Highlight from and to rows
					const fromRow = document.getElementById(`stop-row-${fromIndex}`);
					const toRow = document.getElementById(`stop-row-${toIndex}`);
					if (fromRow) fromRow.classList.add('highlight-row');
					if (toRow) toRow.classList.add('highlight-row');
				}
			}

			// Update bus selector links to preserve from/to query
			const busSelectBtns = document.querySelectorAll('.bus-select-btn');
			busSelectBtns.forEach((btn) => {
				const busSlug = btn.getAttribute('data-bus-slug');
				if (busSlug) {
					let href = `/bus-timetable/${slug}/?bus=${busSlug}`;
					if (from && to) {
						href += `&from=${from}&to=${to}`;
					}
					btn.setAttribute('href', href);
				}
			});
		}
	})();
</script>
		</>
	)}
	{isResultPage && (
	<script>
		const params = new URLSearchParams(window.location.search);

		const busId = params.get("bus_id") || "";
		const busName = params.get("bus_name") || params.get("busName") || "";
		const from = params.get("from") || "";
		const to = params.get("to") || "";

		const busNameEl = document.getElementById("result-bus-name");
		const routeEl = document.getElementById("result-route");
		const busIdEl = document.getElementById("result-bus-id");

		if (busNameEl) {
			busNameEl.textContent = busName || "Selected bus";
		}

		if (routeEl) {
			routeEl.textContent = from && to ? `${from} → ${to}` : "";
		}

		if (busIdEl) {
			busIdEl.textContent = busId ? `Bus ID: ${busId}` : "";
		}
	</script>
)}
</BaseLayout>
