---
import BaseLayout from '../../layouts/BaseLayout.astro';

const SITE_URL = 'https://soniabuddy.in';

const SUPABASE_URL =
  import.meta.env.VITE_SUPABASE_URL || 'https://ytxtyphbguszjndtpakm.supabase.co';

const SUPABASE_ANON_KEY =
  import.meta.env.VITE_SUPABASE_ANON_KEY ||
  'sb_publishable_NCILoAG5w2kh9ciKd3QM8w_TTUfHkC4';

type StopTime = {
  stoppage_name?: string | null;
  up_time?: string | null;
  down_time?: string | null;
};

type BusRoute = {
  id: string;
  bus_name: string | null;
  source: string | null;
  destination: string | null;
  bus_type: string | null;
  image_url: string | null;
  route_data: StopTime[] | null;
};
type MajorStop = {
  canonical_name: string;
  slug: string;
  display_name: string | null;
  seo_priority: number | null;
  aliases: string[] | null;
};
type StopRow = {
  name: string;
  up_time: string;
  down_time: string;
};

type BusCard = {
  id: string;
  bus_name: string;
  bus_type: string;
  image_url: string | null;
  source: string;
  destination: string;
  departure: string;
  arrival: string;
  direction: 'up' | 'down';
  stops: StopRow[];
};

const clean = (value: string | null | undefined) => String(value || '').trim();

const slugify = (value: string) =>
  clean(value)
    .normalize('NFKD')
    .toLowerCase()
    .replace(/[^\p{Letter}\p{Number}]+/gu, '-')
    .replace(/^-+|-+$/g, '');

const normalKey = (value: string) =>
  clean(value)
    .normalize('NFKD')
    .toLowerCase()
    .replace(/[^\p{Letter}\p{Number}]+/gu, ' ')
    .replace(/\s+/g, ' ')
    .trim();

const sameStop = (a: string, b: string) => {
  const x = normalKey(a);
  const y = normalKey(b);
  return x && y && (x === y || x.includes(y) || y.includes(x));
};

function fullStops(route: BusRoute): StopRow[] {
  const rows: StopRow[] = [];

  if (route.source) {
    rows.push({ name: route.source, up_time: '', down_time: '' });
  }

  for (const stop of route.route_data || []) {
    const name = clean(stop.stoppage_name);
    if (!name) continue;

    const last = rows[rows.length - 1];

    if (last && sameStop(last.name, name)) {
      if (!last.up_time && stop.up_time) last.up_time = clean(stop.up_time);
      if (!last.down_time && stop.down_time) last.down_time = clean(stop.down_time);
      continue;
    }

    rows.push({
      name,
      up_time: clean(stop.up_time),
      down_time: clean(stop.down_time),
    });
  }

  if (route.destination) {
    const last = rows[rows.length - 1];
    if (!last || !sameStop(last.name, route.destination)) {
      rows.push({ name: route.destination, up_time: '', down_time: '' });
    }
  }

  return rows;
}

function findStopIndex(stops: StopRow[], stopName: string) {
  return stops.findIndex((stop) => sameStop(stop.name, stopName));
}

function routeContains(route: BusRoute, fromName: string, toName: string) {
  const stops = fullStops(route);
  const fromIndex = findStopIndex(stops, fromName);
  const toIndex = findStopIndex(stops, toName);
  return fromIndex !== -1 && toIndex !== -1 && fromIndex !== toIndex;
}

function makeBusCard(route: BusRoute, fromName: string, toName: string): BusCard | null {
  const stops = fullStops(route);
  const fromIndex = findStopIndex(stops, fromName);
  const toIndex = findStopIndex(stops, toName);

  if (fromIndex === -1 || toIndex === -1 || fromIndex === toIndex) return null;

  const isDown = fromIndex > toIndex;
  const departureStop = stops[fromIndex];
  const arrivalStop = stops[toIndex];

  return {
    id: route.id,
    bus_name: clean(route.bus_name) || 'Bus',
    bus_type: clean(route.bus_type) || 'Bus',
    image_url: route.image_url,
    source: departureStop.name,
    destination: arrivalStop.name,
    departure: isDown ? departureStop.down_time || 'Time not available' : departureStop.up_time || 'Time not available',
    arrival: isDown ? arrivalStop.down_time || 'Time not available' : arrivalStop.up_time || 'Time not available',
    direction: isDown ? 'down' : 'up',
    stops,
  };
}

export async function getStaticPaths() {
  const MAX_STATIC_BUS_PAGES = Number(import.meta.env.MAX_STATIC_BUS_PAGES || 3000);
  const routesUrl =
    'https://ytxtyphbguszjndtpakm.supabase.co/rest/v1/bus_routes?select=id,bus_name,source,destination,bus_type,image_url,route_data&limit=3000';

  const majorStopsUrl =
    'https://ytxtyphbguszjndtpakm.supabase.co/rest/v1/major_bus_stops?select=canonical_name,slug,display_name,seo_priority,aliases&active=eq.true&order=seo_priority.desc&limit=500';

  const anonKey =
    'sb_publishable_NCILoAG5w2kh9ciKd3QM8w_TTUfHkC4';

  const cleanPath = (value: string | null | undefined) => String(value || '').trim();

  const slugifyPath = (value: string | null | undefined) =>
    cleanPath(value)
      .normalize('NFKD')
      .toLowerCase()
      .replace(/[^\p{Letter}\p{Number}]+/gu, '-')
      .replace(/^-+|-+$/g, '');

  const normalPath = (value: string | null | undefined) =>
    cleanPath(value)
      .normalize('NFKD')
      .toLowerCase()
      .replace(/[^\p{Letter}\p{Number}]+/gu, ' ')
      .replace(/\s+/g, ' ')
      .trim();

  const sameStopPath = (a: string | null | undefined, b: string | null | undefined) => {
    const x = normalPath(a);
    const y = normalPath(b);
    return Boolean(x && y && (x === y || x.includes(y) || y.includes(x)));
  };

  let routes: BusRoute[] = [];
  let majorStops: MajorStop[] = [];

  try {
    const [routesRes, majorStopsRes] = await Promise.all([
      fetch(routesUrl, {
        headers: {
          apikey: anonKey,
          Authorization: `Bearer ${anonKey}`,
        },
      }),
      fetch(majorStopsUrl, {
        headers: {
          apikey: anonKey,
          Authorization: `Bearer ${anonKey}`,
        },
      }),
    ]);

    if (routesRes.ok) {
      routes = (await routesRes.json()) as BusRoute[];
    }

    if (majorStopsRes.ok) {
      majorStops = (await majorStopsRes.json()) as MajorStop[];
    }
  } catch {
    routes = [];
    majorStops = [];
  }

  const pairMap = new Map<
  string,
  { source: string; destination: string; routes: BusRoute[]; isMiddle: boolean }
>();

  const addPair = (
  sourceRaw: string | null | undefined,
  destinationRaw: string | null | undefined,
  route: BusRoute,
  isMiddlePage = false
) => {
  const source = cleanPath(sourceRaw);
  const destination = cleanPath(destinationRaw);

  if (!source || !destination) return;
  if (sameStopPath(source, destination)) return;

  const slug = `${slugifyPath(source)}-to-${slugifyPath(destination)}`;
  if (!slug || slug.includes('--')) return;

  const existing =
    pairMap.get(slug) ||
    {
      source,
      destination,
      routes: [] as BusRoute[],
      isMiddle: isMiddlePage,
    };

  if (!existing.routes.some((item) => item.id === route.id)) {
    existing.routes.push(route);
  }

  existing.isMiddle = existing.isMiddle || isMiddlePage;

  pairMap.set(slug, existing);
};
    
  
    const fullStopsPath = (route: BusRoute): StopRow[] => {
    const rows: StopRow[] = [];

    if (route.source) {
      rows.push({ name: route.source, up_time: '', down_time: '' });
    }

    for (const stop of route.route_data || []) {
      const name = cleanPath(stop.stoppage_name);
      if (!name) continue;

      const last = rows[rows.length - 1];

      if (last && sameStopPath(last.name, name)) {
        if (!last.up_time && stop.up_time) last.up_time = cleanPath(stop.up_time);
        if (!last.down_time && stop.down_time) last.down_time = cleanPath(stop.down_time);
        continue;
      }

      rows.push({
        name,
        up_time: cleanPath(stop.up_time),
        down_time: cleanPath(stop.down_time),
      });
    }

    if (route.destination) {
      const last = rows[rows.length - 1];

      if (!last || !sameStopPath(last.name, route.destination)) {
        rows.push({ name: route.destination, up_time: '', down_time: '' });
      }
    }

    return rows;
  };
       const findMajorStop = (stopName: string) => {
    const name = cleanPath(stopName);
    if (!name) return null;

    return (
      majorStops.find((major) => {
        if (sameStopPath(name, major.canonical_name)) return true;
        if (major.display_name && sameStopPath(name, major.display_name)) return true;

        return (major.aliases || []).some((alias) => sameStopPath(name, alias));
      }) || null
    );
  };

    

  const addMiddlePairsForRoute = (route: BusRoute) => {
    const routeStart = cleanPath(route.source);
    const routeEnd = cleanPath(route.destination);

    if (!routeStart || !routeEnd) return;

    const routeStops = fullStopsPath(route);
    if (routeStops.length < 4) return;

    const mainSlug = `${slugifyPath(routeStart)}-to-${slugifyPath(routeEnd)}`;
    const reverseSlug = `${slugifyPath(routeEnd)}-to-${slugifyPath(routeStart)}`;

    const majorInRoute: {
      index: number;
      canonical_name: string;
      slug: string;
      seo_priority: number;
    }[] = [];

    const seenMajor = new Set<string>();

    routeStops.forEach((stop, index) => {
      const major = findMajorStop(stop.name);
      if (!major?.slug || !major?.canonical_name) return;

      // Start and final destination already handled by existing SEO system.
      if (sameStopPath(major.canonical_name, routeStart)) return;
      if (sameStopPath(major.canonical_name, routeEnd)) return;

      if (seenMajor.has(major.slug)) return;
      seenMajor.add(major.slug);

      majorInRoute.push({
        index,
        canonical_name: major.canonical_name,
        slug: major.slug,
        seo_priority: Number(major.seo_priority || 50),
      });
    });
   
      
    if (majorInRoute.length === 0) return;

    majorInRoute.sort((a, b) => a.index - b.index);
       const usedSlugs = new Set<string>();
    const candidates: {
      source: string;
      destination: string;
      score: number;
    }[] = [];

    const pushCandidate = (source: string, destination: string, score: number) => {
      if (!source || !destination) return;
      if (sameStopPath(source, destination)) return;

      const slug = `${slugifyPath(source)}-to-${slugifyPath(destination)}`;

      // Do not recreate existing start-end or reverse page.
      if (slug === mainSlug || slug === reverseSlug) return;

      // Middle reverse default OFF. Only forward route-order section pages.
      candidates.push({ source, destination, score });
    };

            const orderedMajors = [...majorInRoute].sort((a, b) => a.index - b.index);

    const firstMajor = orderedMajors[0];
    const secondMajor = orderedMajors[1];

    // 1) First middle stop → final destination
    // Example: Arambagh → Itaberia
    if (firstMajor) {
      pushCandidate(
        firstMajor.canonical_name,
        routeEnd,
        1000 + firstMajor.seo_priority
      );
    }

    // 2) Second major stop → final destination
    // Example: Ghatal → Itaberia
    if (secondMajor) {
      pushCandidate(
        secondMajor.canonical_name,
        routeEnd,
        900 + secondMajor.seo_priority
      );
    }

    // 3) First major stop → second major stop
    // Example: Arambagh → Ghatal
    if (firstMajor && secondMajor) {
      pushCandidate(
        firstMajor.canonical_name,
        secondMajor.canonical_name,
        800 + firstMajor.seo_priority + secondMajor.seo_priority
      );
    }

    // Backup: if route has more major stops, keep useful fallback candidates
    for (const major of orderedMajors.slice(2)) {
      pushCandidate(
        major.canonical_name,
        routeEnd,
        500 + major.seo_priority
      );
    }

    

    candidates
      .sort((a, b) => b.score - a.score)
      .filter((pair) => {
        const slug = `${slugifyPath(pair.source)}-to-${slugifyPath(pair.destination)}`;
        if (usedSlugs.has(slug)) return false;
        usedSlugs.add(slug);
        return true;
      })
      .slice(0, 5)
      .forEach((pair) => {
        addPair(pair.source, pair.destination, route, true);
      });
  };

  for (const route of routes) {
    // Existing main route page: Tarakeswar → Digha
    addPair(route.source, route.destination, route);

    // Existing reverse route page: Digha → Tarakeswar
    addPair(route.destination, route.source, route);

    // New middle SEO pages, max 3 per route
    addMiddlePairsForRoute(route);
    
  }

  const staticPaths = Array.from(pairMap.entries())
  .filter(([, value]) => value.routes.length > 0)
  .sort((a, b) => {
    const aMiddle = a[1].isMiddle ? 1 : 0;
    const bMiddle = b[1].isMiddle ? 1 : 0;

    // Main/reverse pages first, middle pages later
    if (aMiddle !== bMiddle) return aMiddle - bMiddle;

    // Routes with more buses first
    return b[1].routes.length - a[1].routes.length;
  })
  .slice(0, MAX_STATIC_BUS_PAGES)
  .map(([slug, value]) => ({
    params: { slug },
    props: value,
  }));

console.log(
  `[bus-timetable] Generated ${staticPaths.length} static SEO pages. Max limit: ${MAX_STATIC_BUS_PAGES}`
);

return staticPaths;


}
const { slug } = Astro.params;
const { source, destination, routes, isMiddle = false } = Astro.props as {
  source: string;
  destination: string;
  routes: BusRoute[];
  isMiddle?: boolean;
};
const busCards = routes
  .map((route) => makeBusCard(route, source, destination))
  .filter(Boolean) as BusCard[];

const selectedBusId = Astro.url.searchParams.get('bus_id') || '';

const firstBus = selectedBusId
  ? busCards.find((bus) => bus.id === selectedBusId) || busCards[0]
  : busCards[0];
  const getSegmentStopRows = (bus: BusCard | undefined) => {
  if (!bus?.stops?.length) return [];

  const fromIndex = findStopIndex(bus.stops, source);
  const toIndex = findStopIndex(bus.stops, destination);

  if (fromIndex === -1 || toIndex === -1 || fromIndex === toIndex) {
    return bus.stops;
  }

  const start = Math.min(fromIndex, toIndex);
  const end = Math.max(fromIndex, toIndex);

  const segment = bus.stops.slice(start, end + 1);

  return fromIndex > toIndex ? segment.reverse() : segment;
};

const segmentStopRows = getSegmentStopRows(firstBus);
const displayStopRows = isMiddle
  ? segmentStopRows
  : firstBus?.direction === 'down'
    ? [...(firstBus?.stops || [])].reverse()
    : firstBus?.stops || [];
const selectedPhoto =
  firstBus?.image_url || busCards.find((bus) => bus.image_url)?.image_url || '';
const uniqueStops = Array.from(
  new Set(
    busCards
      .flatMap((bus) => bus.stops.map((stop) => clean(stop.name)))
      .filter(Boolean)
  )
);

const importantStops = uniqueStops.slice(0, 10);
const busNames = busCards.map((bus) => bus.bus_name).filter(Boolean).slice(0, 6);

const upTimes = busCards
  .map((bus) => bus.departure)
  .filter((time) => time && time !== 'Time not available')
  .slice(0, 5);

const downTimes = busCards
  .map((bus) => bus.arrival)
  .filter((time) => time && time !== 'Time not available')
  .slice(0, 5);

const stopText = importantStops.length ? importantStops.join(', ') : `${source}, ${destination}`;
const busText = busNames.length ? busNames.join(', ') : 'available route buses';
const upTimeText = upTimes.length ? upTimes.join(', ') : 'available route timing';
const downTimeText = downTimes.length ? downTimes.join(', ') : 'available return-side timing';

const queryFrom = clean(Astro.url.searchParams.get('from')) || source;
const queryTo = clean(Astro.url.searchParams.get('to')) || destination;

const STOP_BN_MAP: Record<string, string> = {
