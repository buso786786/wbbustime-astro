      margin-bottom: 0.15rem;
    }

    .stop-times b {
      color: #0f172a;
      font-size: 0.9rem;
    }

    .active-stop {
      background: #fff7ed;
      border-color: #fed7aa;
    }

    .seo-summary p {
      margin-top: 0.7rem;
      color: #334155;
