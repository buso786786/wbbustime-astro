---
import BaseLayout from "../layouts/BaseLayout.astro";
import { listRentCities } from "../lib/rentCities";

const cities = await listRentCities({ onlyActive: true });
---

<BaseLayout
  title="Test Rent Cities UI"
  description="Test page for rent city selector UI"
>
  <div class="debug-label">PAGE: TEST RENT CITIES UI</div>

  <section class="test-page">
    <div class="container test-container">
      <div class="test-header">
        <h1>Test Rent Cities UI</h1>
        <p>Searchable city selector with main city, nearby cities, base city, and service cities</p>
      </div>

      <div class="selector-section">
        <h2>Main City (Single Select)</h2>
        <div class="search-box">
          <input
            type="text"
            id="main-city-search"
            placeholder="Search city name, district, or keywords..."
            class="search-input"
            autocomplete="off"
          />
          <div id="main-city-dropdown" class="city-dropdown hidden"></div>
        </div>
        <div id="main-city-selected" class="selected-cities"></div>
      </div>

      <div class="selector-section">
        <h2>Nearby Cities (Multi Select, Max 3)</h2>
        <div class="search-box">
          <input
            type="text"
            id="nearby-cities-search"
            placeholder="Search city name, district, or keywords..."
            class="search-input"
            autocomplete="off"
          />
          <div id="nearby-cities-dropdown" class="city-dropdown hidden"></div>
        </div>
        <div id="nearby-cities-selected" class="selected-cities"></div>
      </div>

      <div class="selector-section">
        <h2>Base City (Single Select)</h2>
        <div class="search-box">
          <input
            type="text"
            id="base-city-search"
            placeholder="Search city name, district, or keywords..."
            class="search-input"
            autocomplete="off"
          />
          <div id="base-city-dropdown" class="city-dropdown hidden"></div>
        </div>
        <div id="base-city-selected" class="selected-cities"></div>
      </div>

      <div class="selector-section">
        <h2>Service Cities (Multi Select, Max 3)</h2>
        <div class="search-box">
          <input
            type="text"
            id="service-cities-search"
            placeholder="Search city name, district, or keywords..."
            class="search-input"
            autocomplete="off"
          />
          <div id="service-cities-dropdown" class="city-dropdown hidden"></div>
        </div>
        <div id="service-cities-selected" class="selected-cities"></div>
      </div>

      <div class="debug-section">
        <h2>Debug Info</h2>
        <pre id="debug-output"></pre>
      </div>
    </div>
  </section>

  <script define:vars={{ cities }}>
    window.rentCitiesData = cities;
  </script>

  <script>
    const cities = Array.isArray(window.rentCitiesData) ? window.rentCitiesData : [];

    const selectorIdMap = {
      mainCity: {
        search: "main-city-search",
        dropdown: "main-city-dropdown",
        selected: "main-city-selected",
        multi: false,
      },
      nearbyCities: {
        search: "nearby-cities-search",
        dropdown: "nearby-cities-dropdown",
        selected: "nearby-cities-selected",
        multi: true,
      },
      baseCity: {
        search: "base-city-search",
        dropdown: "base-city-dropdown",
        selected: "base-city-selected",
        multi: false,
      },
      serviceCities: {
        search: "service-cities-search",
        dropdown: "service-cities-dropdown",
        selected: "service-cities-selected",
        multi: true,
      },
    };

    const state = {
      mainCity: null,
      nearbyCities: [],
      baseCity: null,
      serviceCities: [],
    };

    function getDisplayName(city) {
      if (!city) return "";
      return city.name_en || city.name_bn || city.name || "";
    }

    function getDistrictName(city) {
      if (!city) return "";
      return city.district_en || city.district_bn || "";
    }

    function includesText(value, term) {
      return String(value || "").toLowerCase().includes(term);
    }

    function cityMatchesSearch(city, searchTerm) {
      const term = String(searchTerm || "").trim().toLowerCase();
      if (!term) return true;

      return (
        includesText(city.name, term) ||
        includesText(city.name_en, term) ||
        includesText(city.name_bn, term) ||
        includesText(city.district_en, term) ||
        includesText(city.district_bn, term) ||
        includesText(city.search_keywords_en, term) ||
        includesText(city.search_keywords_bn, term)
      );
    }

    function getSelectedForType(type) {
      if (type === "mainCity") return state.mainCity ? [state.mainCity] : [];
      if (type === "nearbyCities") return state.nearbyCities;
      if (type === "baseCity") return state.baseCity ? [state.baseCity] : [];
      if (type === "serviceCities") return state.serviceCities;
      return [];
    }

    function getSelectedIdsForType(type) {
      return getSelectedForType(type).map((city) => city.id);
    }

    function filterCities(searchTerm, type) {
      const selectedIds = getSelectedIdsForType(type);

      return cities
        .filter((city) => city && city.id)
        .filter((city) => !selectedIds.includes(city.id))
        .filter((city) => cityMatchesSearch(city, searchTerm))
        .slice(0, 30);
    }

    function renderDropdown(filteredCities, dropdown, selectorType) {
      dropdown.innerHTML = "";

      if (!filteredCities.length) {
        const noResults = document.createElement("div");
        noResults.className = "dropdown-no-results";
        noResults.textContent = "No cities found";
        dropdown.appendChild(noResults);
        return;
      }

      filteredCities.forEach((city) => {
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "dropdown-item";
        btn.dataset.cityId = city.id;
        btn.dataset.selectorType = selectorType;

        const displayName = getDisplayName(city);
        const districtName = getDistrictName(city);

        btn.innerHTML = `
          <span class="city-name">${displayName}</span>
          ${districtName ? `<span class="city-district">${districtName}</span>` : ""}
        `;

        dropdown.appendChild(btn);
      });
    }

    function closeDropdown(type) {
      const ids = selectorIdMap[type];
      const dropdown = document.getElementById(ids.dropdown);
      if (dropdown) dropdown.classList.add("hidden");
    }

    function clearSearch(type) {
      const ids = selectorIdMap[type];
      const input = document.getElementById(ids.search);
      if (input) input.value = "";
    }

    function updateSelectedDisplay(type) {
      const ids = selectorIdMap[type];
      const container = document.getElementById(ids.selected);
      if (!container) return;

      const selectedCities = getSelectedForType(type);
      container.innerHTML = "";

      if (!selectedCities.length) {
        container.innerHTML = `<div class="no-selection">No city selected</div>`;
        return;
      }

      selectedCities.forEach((city) => {
        const tag = document.createElement("span");
        tag.className = "city-tag";
        tag.innerHTML = `
          <span>${getDisplayName(city)}</span>
          <button type="button" class="remove-btn" data-city-id="${city.id}" data-type="${type}" aria-label="Remove city">×</button>
        `;
        container.appendChild(tag);
      });
    }

    function updateDebugInfo() {
      const debugOutput = document.getElementById("debug-output");
      if (!debugOutput) return;

      debugOutput.textContent = JSON.stringify(
        {
          mainCity: state.mainCity ? getDisplayName(state.mainCity) : null,
          mainCityId: state.mainCity ? state.mainCity.id : null,
          nearbyCities: state.nearbyCities.map(getDisplayName),
          nearbyCityIds: state.nearbyCities.map((c) => c.id),
          baseCity: state.baseCity ? getDisplayName(state.baseCity) : null,
          baseCityId: state.baseCity ? state.baseCity.id : null,
          serviceCities: state.serviceCities.map(getDisplayName),
          serviceCityIds: state.serviceCities.map((c) => c.id),
        },
        null,
        2
      );
    }

    function refreshAllSelectedDisplays() {
      updateSelectedDisplay("mainCity");
      updateSelectedDisplay("nearbyCities");
      updateSelectedDisplay("baseCity");
      updateSelectedDisplay("serviceCities");
      updateDebugInfo();
    }

    function handleCitySelection(cityId, selectorType) {
      const city = cities.find((c) => c.id === cityId);
      if (!city) return;

      console.log("selected city", selectorType, cityId);

      if (selectorType === "mainCity") {
        state.mainCity = city;
      }

      if (selectorType === "baseCity") {
        state.baseCity = city;
      }

      if (selectorType === "nearbyCities") {
        if (state.nearbyCities.some((c) => c.id === city.id)) return;
        if (state.nearbyCities.length >= 3) {
          alert("Maximum 3 nearby cities allowed");
          return;
        }
        state.nearbyCities.push(city);
      }

      if (selectorType === "serviceCities") {
        if (state.serviceCities.some((c) => c.id === city.id)) return;
        if (state.serviceCities.length >= 3) {
          alert("Maximum 3 service cities allowed");
          return;
        }
        state.serviceCities.push(city);
      }

      clearSearch(selectorType);
      closeDropdown(selectorType);
      refreshAllSelectedDisplays();
    }

    function removeSelected(cityId, type) {
      if (type === "mainCity") state.mainCity = null;
      if (type === "baseCity") state.baseCity = null;
      if (type === "nearbyCities") {
        state.nearbyCities = state.nearbyCities.filter((c) => c.id !== cityId);
      }
      if (type === "serviceCities") {
        state.serviceCities = state.serviceCities.filter((c) => c.id !== cityId);
      }

      refreshAllSelectedDisplays();
    }

    function setupSelector(type) {
      const ids = selectorIdMap[type];
      const searchInput = document.getElementById(ids.search);
      const dropdown = document.getElementById(ids.dropdown);

      if (!searchInput || !dropdown) return;

      function showFiltered() {
        const filtered = filterCities(searchInput.value, type);
        renderDropdown(filtered, dropdown, type);
        dropdown.classList.remove("hidden");
      }

      searchInput.addEventListener("focus", showFiltered);
      searchInput.addEventListener("input", showFiltered);

      searchInput.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          dropdown.classList.add("hidden");
        }
      });
    }

    document.addEventListener("DOMContentLoaded", () => {
      setupSelector("mainCity");
      setupSelector("nearbyCities");
      setupSelector("baseCity");
      setupSelector("serviceCities");

      document.addEventListener("mousedown", (event) => {
        const target = event.target;

        const cityOption = target.closest(".dropdown-item");
        if (cityOption) {
          event.preventDefault();
          const cityId = cityOption.dataset.cityId;
          const selectorType = cityOption.dataset.selectorType;
          if (cityId && selectorType) {
            handleCitySelection(cityId, selectorType);
          }
          return;
        }

        const removeBtn = target.closest(".remove-btn");
        if (removeBtn) {
          event.preventDefault();
          const cityId = removeBtn.dataset.cityId;
          const type = removeBtn.dataset.type;
          if (cityId && type) {
            removeSelected(cityId, type);
          }
          return;
        }

        if (!target.closest(".search-box")) {
          Object.keys(selectorIdMap).forEach(closeDropdown);
        }
      });

      refreshAllSelectedDisplays();
    });
  </script>

  <style>
    .test-page {
      background: linear-gradient(135deg, #0b0628 0%, #13084a 55%, #1e103f 100%);
      min-height: 100vh;
      padding: 2rem 0 4rem;
      color: white;
    }

    .test-container {
      max-width: 800px;
      margin: 0 auto;
      padding: 0 1rem;
    }

    .test-header {
      margin-bottom: 2rem;
    }

    .test-header h1 {
      font-size: 2rem;
      margin: 0 0 0.5rem;
      color: white;
    }

    .test-header p {
      margin: 0;
      color: rgba(255, 255, 255, 0.7);
      font-size: 1rem;
    }

    .selector-section {
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.14);
      border-radius: 1rem;
      padding: 1.5rem;
      margin-bottom: 1.5rem;
    }

    .selector-section h2 {
      margin: 0 0 1rem;
      font-size: 1.25rem;
      color: #ff8a00;
    }

    .search-box {
      position: relative;
    }

    .search-input {
      width: 100%;
      background: rgba(10, 7, 42, 0.72);
      color: white;
      border: 1px solid rgba(255, 255, 255, 0.18);
      border-radius: 0.75rem;
      padding: 0.875rem 1rem;
      font-size: 0.95rem;
      outline: none;
      box-sizing: border-box;
    }

    .search-input:focus {
      border-color: rgba(255, 107, 0, 0.8);
    }

    .city-dropdown {
      position: absolute;
      top: calc(100% + 0.35rem);
      left: 0;
      right: 0;
      background: rgba(10, 7, 42, 0.98);
      border: 1px solid rgba(255, 255, 255, 0.18);
      border-radius: 0.75rem;
      max-height: 280px;
      overflow-y: auto;
      z-index: 9999;
      box-shadow: 0 16px 40px rgba(0, 0, 0, 0.35);
    }

    .city-dropdown.hidden {
      display: none;
    }

    .dropdown-item {
      width: 100%;
      display: block;
      text-align: left;
      background: transparent;
      border: 0;
      color: white;
      padding: 0.75rem 1rem;
      cursor: pointer;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      font: inherit;
    }

    .dropdown-item:hover {
      background: rgba(255, 107, 0, 0.18);
    }

    .dropdown-item:last-child {
      border-bottom: none;
    }

    .city-name {
      display: block;
      font-weight: 700;
      color: white;
    }

    .city-district {
      display: block;
      font-size: 0.82rem;
      color: rgba(255, 255, 255, 0.65);
      margin-top: 0.2rem;
    }

    .dropdown-no-results {
      padding: 1rem;
      text-align: center;
      color: rgba(255, 255, 255, 0.5);
    }

    .selected-cities {
      margin-top: 1rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      min-height: 1.6rem;
    }

    .no-selection {
      color: rgba(255, 255, 255, 0.55);
      font-size: 0.9rem;
    }

    .city-tag {
      background: linear-gradient(135deg, #ff6b00, #ff8a00);
      color: white;
      padding: 0.5rem 0.75rem;
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.9rem;
      font-weight: 700;
    }

    .remove-btn {
      background: rgba(255, 255, 255, 0.18);
      border: none;
      color: white;
      font-size: 1rem;
      cursor: pointer;
      padding: 0;
      line-height: 1;
      width: 20px;
      height: 20px;
      border-radius: 999px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .remove-btn:hover {
      background: rgba(255, 255, 255, 0.3);
    }

    .debug-section {
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.14);
      border-radius: 1rem;
      padding: 1.5rem;
      margin-top: 2rem;
    }

    .debug-section h2 {
      margin: 0 0 1rem;
      font-size: 1.25rem;
      color: #ff8a00;
    }

    #debug-output {
      background: rgba(0, 0, 0, 0.3);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 0.5rem;
      padding: 1rem;
      color: #4ade80;
      font-size: 0.85rem;
      overflow-x: auto;
      white-space: pre-wrap;
    }

    @media (max-width: 768px) {
      .test-page {
        padding: 1.5rem 0 3rem;
      }

      .test-header h1 {
        font-size: 1.5rem;
      }

      .selector-section {
        padding: 1.25rem;
      }

      .selector-section h2 {
        font-size: 1.05rem;
      }

      .city-dropdown {
        max-height: 240px;
      }

      .city-tag {
        font-size: 0.85rem;
      }
    }
  </style>
</BaseLayout>