---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Vehicle Listing Dashboard - SoniaBuddy"
	description="Manage your vehicle listings, verified badge, visibility boost and enquiry analytics."
>
	<div class="debug-label">PAGE: RENT DASHBOARD</div>
	<section class="dashboard-page">
		<div class="container dashboard-container">
			<!-- 1. Page header -->
			<div class="dashboard-header">
				<div class="header-content">
					<h1>Vehicle Listing Dashboard</h1>
					<p>Manage your listings, verified badge, visibility boost and enquiry analytics.</p>
				</div>
				<a href="/rent-vehicle" class="btn btn-outline">Back to Rent</a>
			</div>

			<!-- 2. Login/session card -->
			<div class="logged-in-card">
				<div class="login-info">
					<p class="login-label">Logged in as</p>
					<p class="login-email">demo-owner@example.com</p>
				</div>
				<button class="btn btn-outline btn-small">Logout</button>
			</div>

			<!-- 3. First 3 Months Free notice -->
			<div class="free-notice">
				<span class="notice-icon">🎉</span>
				<div class="notice-content">
					<h3>First 3 Months Free</h3>
					<p>Every new rental listing gets first 3 months free. After the free trial, choose Verified Badge for trust or Visibility Boost for sponsored placement.</p>
				</div>
			</div>

			<!-- 4. Pricing / plan cards -->
			<div class="section-title">
				<h2>Pricing Plans</h2>
			</div>
			<div class="plan-cards">
				<div class="plan-card">
					<h3>✅ Verified Badge</h3>
					<div class="plan-price">₹299</div>
					<p class="plan-duration">for 3 months</p>
					<p class="plan-description">Trust badge only. No ads boost included.</p>
					<button class="btn btn-small btn-orange">See features</button>
				</div>
				<div class="plan-card">
					<h3>🚀 Small Vehicle Visibility</h3>
					<div class="plan-price">₹199</div>
					<p class="plan-duration">for 3 months</p>
					<p class="plan-description">For Toto and Auto. Sponsored visibility + ad tracking.</p>
					<button class="btn btn-small btn-orange">See features</button>
				</div>
				<div class="plan-card">
					<h3>🚀 Car / Pickup / Ambulance Visibility</h3>
					<div class="plan-price">₹1000</div>
					<p class="plan-duration">for 3 months</p>
					<p class="plan-description">Sponsored visibility for car, pickup and ambulance.</p>
					<button class="btn btn-small btn-orange">See features</button>
				</div>
				<div class="plan-card">
					<h3>🚀 Bus Visibility</h3>
					<div class="plan-price">₹1500</div>
					<p class="plan-duration">for 3 months</p>
					<p class="plan-description">For bus, wedding bus, tour bus and school bus.</p>
					<button class="btn btn-small btn-orange">See features</button>
				</div>
			</div>

			<!-- 5. Action buttons -->
			<div class="dashboard-actions">
				<a href="/rent-vehicle?tab=register" class="btn btn-primary">+ Add New Vehicle Listing</a>
				<a href="#" class="btn btn-outline">View My Vehicle Listings</a>
			</div>

			<!-- 6. My Listing card -->
			<div class="section-title">
				<h2>My Listings</h2>
			</div>
			<div class="listing-card">
				<div class="listing-image">
					<div class="listing-placeholder">🚗</div>
				</div>
				<div class="listing-details">
					<h3>sffd</h3>
					<p>Car · 7 seats · hgighjh</p>
					<div class="listing-meta">
						<span class="listing-status status-active">active</span>
						<span class="listing-badge badge-free">Free Trial</span>
					</div>
				</div>
				<button class="btn btn-outline btn-small">Edit Listing</button>
			</div>

			<!-- 7. Listing Performance -->
			<div class="section-title">
				<h2>📊 Listing Performance</h2>
			</div>
			<div class="performance-stats">
				<div class="stat-card">
					<h4>Views</h4>
					<p class="stat-value">7</p>
				</div>
				<div class="stat-card">
					<h4>Calls</h4>
					<p class="stat-value">0</p>
				</div>
				<div class="stat-card">
					<h4>WhatsApp</h4>
					<p class="stat-value">0</p>
				</div>
				<div class="stat-card">
					<h4>Photo opens</h4>
					<p class="stat-value">0</p>
				</div>
				<div class="stat-card">
					<h4>Details</h4>
					<p class="stat-value">4</p>
				</div>
				<div class="stat-card">
					<h4>Paid action clicks</h4>
					<p class="stat-value">2</p>
				</div>
			</div>

			<!-- 8. Visibility / Ads Performance -->
			<div class="section-title">
				<h2>⭐ Visibility / Ads Performance</h2>
			</div>
			<div class="ads-performance-card">
				<span class="ads-badge">No ads data</span>
				<div class="ads-stats">
					<div class="ad-stat">
						<h4>Ad impressions</h4>
						<p class="stat-value">0</p>
					</div>
					<div class="ad-stat">
						<h4>Ad clicks</h4>
						<p class="stat-value">0</p>
					</div>
					<div class="ad-stat">
						<h4>CTR</h4>
						<p class="stat-value">0%</p>
					</div>
				</div>
			</div>

			<!-- 9. Payment/upgrade cards -->
			<div class="payment-cards">
				<!-- Card A: Verified Badge -->
				<div class="payment-card">
					<h3>🗓️ Verified Badge</h3>
					<p class="payment-amount">₹299 · 3 months</p>
					<p class="payment-status">Not active</p>
					<p class="free-expiry">Free trial expiry: 11 Sept 2026</p>
					<div class="collapsible-row">
						<span>▶ See features & disclaimer</span>
					</div>
					<label class="checkbox-label">
						<input type="checkbox" />
						<span>I understand this is a trust badge only and does not guarantee calls, bookings, impressions or clicks.</span>
					</label>
					<button class="btn btn-primary btn-small btn-disabled">Get Verified Badge</button>
				</div>

				<!-- Card B: Visibility Boost -->
				<div class="payment-card">
					<h3>⭐ Visibility Boost</h3>
					<p class="selected-plan">Auto selected plan: Car Plan · ₹1000</p>
					<p class="payment-status">Not active</p>
					<div class="collapsible-row">
						<span>▶ See features & disclaimer</span>
					</div>
					<label class="checkbox-label">
						<input type="checkbox" />
						<span>I understand impressions, clicks, calls, bookings and revenue are not guaranteed.</span>
					</label>
					<button class="btn btn-primary btn-small btn-disabled">Boost Visibility</button>
				</div>
			</div>
		</div>
	</section>

	<style>
		.dashboard-page {
			background: linear-gradient(135deg, #0b0628 0%, #13084a 55%, #1e103f 100%);
			min-height: 100vh;
			padding: 2rem 0 4rem;
			color: white;
		}

		.dashboard-container {
			max-width: 1100px;
			margin: 0 auto;
			padding: 0 1rem;
		}

		/* 1. Page header */
		.dashboard-header {
			display: flex;
			justify-content: space-between;
			align-items: center;
			margin-bottom: 1.5rem;
			gap: 1rem;
		}

		.header-content h1 {
			font-size: 1.75rem;
			margin: 0 0 0.5rem;
			color: white;
		}

		.header-content p {
			margin: 0;
			color: rgba(255, 255, 255, 0.7);
			font-size: 0.95rem;
		}

		/* 2. Login card */
		.logged-in-card {
			background: rgba(255, 255, 255, 0.06);
			border: 1px solid rgba(255, 255, 255, 0.14);
			border-radius: 1rem;
			padding: 1.25rem;
			display: flex;
			justify-content: space-between;
			align-items: center;
			margin-bottom: 1.5rem;
		}

		.login-label {
			margin: 0 0 0.25rem;
			color: rgba(255, 255, 255, 0.6);
			font-size: 0.85rem;
		}

		.login-email {
			margin: 0;
			color: white;
			font-size: 1rem;
			font-weight: 600;
		}

		/* 3. Free notice */
		.free-notice {
			background: linear-gradient(135deg, rgba(255, 107, 0, 0.15), rgba(255, 138, 0, 0.1));
			border: 1px solid rgba(255, 107, 0, 0.3);
			border-radius: 1rem;
			padding: 1.25rem;
			display: flex;
			align-items: flex-start;
			gap: 1rem;
			margin-bottom: 1.5rem;
		}

		.notice-icon {
			font-size: 1.75rem;
			flex-shrink: 0;
		}

		.notice-content h3 {
			margin: 0 0 0.5rem;
			font-size: 1.1rem;
			color: #ff8a00;
		}

		.notice-content p {
			margin: 0;
			color: rgba(255, 255, 255, 0.85);
			font-size: 0.9rem;
			line-height: 1.5;
		}

		/* Buttons */
		.btn {
			padding: 0.75rem 1.5rem;
			border-radius: 0.75rem;
			font-weight: 700;
			text-decoration: none;
			display: inline-block;
			cursor: pointer;
			transition: all 0.2s;
			text-align: center;
			font-size: 0.95rem;
		}

		.btn-primary {
			background: linear-gradient(135deg, #ff6b00, #ff8a00);
			color: white;
			border: none;
		}

		.btn-primary:hover {
			background: linear-gradient(135deg, #e65a00, #ff6b00);
			transform: translateY(-2px);
		}

		.btn-outline {
			background: transparent;
			color: white;
			border: 2px solid rgba(255, 255, 255, 0.3);
		}

		.btn-outline:hover {
			background: rgba(255, 255, 255, 0.1);
			border-color: rgba(255, 255, 255, 0.5);
		}

		.btn-orange {
			background: linear-gradient(135deg, #ff6b00, #ff8a00);
			color: white;
			border: none;
		}

		.btn-small {
			padding: 0.5rem 1rem;
			font-size: 0.85rem;
		}

		.btn-disabled {
			opacity: 0.5;
			cursor: not-allowed;
		}

		/* Section titles */
		.section-title {
			margin-bottom: 1rem;
		}

		.section-title h2 {
			margin: 0;
			font-size: 1.25rem;
			color: white;
		}

		/* 4. Plan cards */
		.plan-cards {
			display: grid;
			grid-template-columns: repeat(4, 1fr);
			gap: 1rem;
			margin-bottom: 2rem;
		}

		.plan-card {
			background: rgba(255, 255, 255, 0.06);
			border: 1px solid rgba(255, 255, 255, 0.14);
			border-radius: 1rem;
			padding: 1.25rem;
			display: flex;
			flex-direction: column;
		}

		.plan-card h3 {
			margin: 0 0 0.5rem;
			font-size: 1rem;
		}

		.plan-price {
			font-size: 1.75rem;
			font-weight: 800;
			margin-bottom: 0.25rem;
			color: #ff8a00;
		}

		.plan-duration {
			margin: 0 0 0.75rem;
			color: rgba(255, 255, 255, 0.6);
			font-size: 0.85rem;
		}

		.plan-description {
			margin: 0 0 1rem;
			color: rgba(255, 255, 255, 0.75);
			font-size: 0.85rem;
			line-height: 1.4;
			flex: 1;
		}

		/* 5. Action buttons */
		.dashboard-actions {
			display: flex;
			gap: 1rem;
			margin-bottom: 2rem;
		}

		/* 6. Listing card */
		.listing-card {
			background: rgba(255, 255, 255, 0.06);
			border: 1px solid rgba(255, 255, 255, 0.14);
			border-radius: 1rem;
			padding: 1.25rem;
			display: flex;
			gap: 1rem;
			align-items: center;
			margin-bottom: 2rem;
		}

		.listing-image {
			width: 70px;
			height: 70px;
			border-radius: 0.75rem;
			background: rgba(255, 255, 255, 0.04);
			display: flex;
			align-items: center;
			justify-content: center;
			flex-shrink: 0;
		}

		.listing-placeholder {
			font-size: 1.75rem;
		}

		.listing-details {
			flex: 1;
		}

		.listing-details h3 {
			margin: 0 0 0.25rem;
			font-size: 1.1rem;
		}

		.listing-details p {
			margin: 0 0 0.5rem;
			color: rgba(255, 255, 255, 0.7);
			font-size: 0.9rem;
		}

		.listing-meta {
			display: flex;
			gap: 0.5rem;
			align-items: center;
			flex-wrap: wrap;
		}

		.listing-status {
			padding: 0.25rem 0.75rem;
			border-radius: 999px;
			font-size: 0.75rem;
			font-weight: 700;
		}

		.status-active {
			background: rgba(34, 197, 94, 0.2);
			color: #22c55e;
		}

		.listing-badge {
			padding: 0.25rem 0.75rem;
			border-radius: 999px;
			font-size: 0.75rem;
			font-weight: 700;
		}

		.badge-free {
			background: rgba(255, 107, 0, 0.2);
			color: #ff8a00;
		}

		/* 7. Performance stats */
		.performance-stats {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 1rem;
			margin-bottom: 2rem;
		}

		.stat-card {
			background: rgba(255, 255, 255, 0.06);
			border: 1px solid rgba(255, 255, 255, 0.14);
			border-radius: 1rem;
			padding: 1.25rem;
			text-align: center;
		}

		.stat-card h4 {
			margin: 0 0 0.5rem;
			font-size: 0.85rem;
			color: rgba(255, 255, 255, 0.8);
		}

		.stat-value {
			margin: 0;
			font-size: 1.75rem;
			font-weight: 800;
			color: #ff8a00;
		}

		/* 8. Ads performance */
		.ads-performance-card {
			background: rgba(255, 255, 255, 0.06);
			border: 2px solid rgba(255, 107, 0, 0.3);
			border-radius: 1rem;
			padding: 1.25rem;
			margin-bottom: 2rem;
		}

		.ads-badge {
			display: inline-block;
			background: rgba(255, 107, 0, 0.2);
			color: #ff8a00;
			padding: 0.25rem 0.75rem;
			border-radius: 999px;
			font-size: 0.8rem;
			font-weight: 700;
			margin-bottom: 1rem;
		}

		.ads-stats {
			display: flex;
			gap: 2rem;
		}

		.ad-stat h4 {
			margin: 0 0 0.25rem;
			font-size: 0.85rem;
			color: rgba(255, 255, 255, 0.8);
		}

		.ad-stat .stat-value {
			font-size: 1.5rem;
		}

		/* 9. Payment cards */
		.payment-cards {
			display: grid;
			grid-template-columns: repeat(2, 1fr);
			gap: 1rem;
		}

		.payment-card {
			background: rgba(255, 255, 255, 0.06);
			border: 1px solid rgba(255, 255, 255, 0.14);
			border-radius: 1rem;
			padding: 1.25rem;
		}

		.payment-card h3 {
			margin: 0 0 0.5rem;
			font-size: 1.1rem;
		}

		.payment-amount {
			margin: 0 0 0.25rem;
			color: #ff8a00;
			font-weight: 600;
			font-size: 1rem;
		}

		.payment-status {
			margin: 0 0 0.5rem;
			color: rgba(255, 255, 255, 0.7);
			font-size: 0.85rem;
		}

		.free-expiry {
			margin: 0 0 1rem;
			color: rgba(255, 255, 255, 0.6);
			font-size: 0.85rem;
		}

		.selected-plan {
			margin: 0 0 0.5rem;
			color: rgba(255, 255, 255, 0.7);
			font-size: 0.85rem;
		}

		.collapsible-row {
			background: rgba(255, 107, 0, 0.15);
			border: 1px solid rgba(255, 107, 0, 0.3);
			border-radius: 0.5rem;
			padding: 0.75rem;
			margin-bottom: 1rem;
			cursor: pointer;
			font-size: 0.85rem;
			color: #ff8a00;
			font-weight: 600;
		}

		.checkbox-label {
			display: flex;
			align-items: flex-start;
			gap: 0.75rem;
			cursor: pointer;
			margin-bottom: 1rem;
		}

		.checkbox-label input[type="checkbox"] {
			width: auto;
			margin-top: 0.25rem;
			flex-shrink: 0;
		}

		.checkbox-label span {
			color: rgba(255, 255, 255, 0.85);
			line-height: 1.4;
			font-size: 0.85rem;
		}

		/* Mobile responsive */
		@media (max-width: 1024px) {
			.plan-cards {
				grid-template-columns: repeat(2, 1fr);
			}

			.performance-stats {
				grid-template-columns: repeat(2, 1fr);
			}
		}

		@media (max-width: 768px) {
			.dashboard-page {
				padding: 1.5rem 0 3rem;
			}

			.dashboard-header {
				flex-direction: column;
				align-items: flex-start;
			}

			.dashboard-header .btn {
				width: 100%;
			}

			.logged-in-card {
				flex-direction: column;
				align-items: flex-start;
				gap: 1rem;
			}

			.logged-in-card .btn {
				width: 100%;
			}

			.dashboard-actions {
				flex-direction: column;
			}

			.dashboard-actions .btn {
				width: 100%;
			}

			.plan-cards {
				grid-template-columns: 1fr;
			}

			.listing-card {
				flex-direction: column;
				align-items: flex-start;
			}

			.listing-image {
				width: 100%;
				height: 100px;
			}

			.performance-stats {
				grid-template-columns: repeat(2, 1fr);
			}

			.ads-stats {
				flex-direction: column;
				gap: 1rem;
			}

			.payment-cards {
				grid-template-columns: 1fr;
			}

			.payment-card .btn {
				width: 100%;
			}
		}
	</style>
</BaseLayout>
