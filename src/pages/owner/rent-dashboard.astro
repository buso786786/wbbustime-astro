---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/admin-compact.css';
---

<BaseLayout
  title="Vehicle Listing Dashboard - SoniaBuddy"
  description="Manage your vehicle listings, verified badge, visibility boost and enquiry analytics."
>
  <section class="dashboard-page">
    <div class="container dashboard-container">
      <div class="dashboard-header">
        <div class="header-content">
          <h1>🚕 Vehicle Listing Dashboard</h1>
          <p>Manage your listings, verified badge, visibility boost and enquiry analytics.</p>
        </div>
        <a href="/rent-vehicle" class="btn btn-outline">Back to Rent</a>
      </div>

      <div id="auth-card" class="logged-in-card">
        <div class="login-info">
          <p class="login-label">Logged in as</p>
          <p id="login-email" class="login-email">Checking login...</p>
        </div>
        <div class="auth-actions">
          <button id="login-btn" class="btn btn-primary btn-small" type="button">Login with Google</button>
          <button id="logout-btn" class="btn btn-outline btn-small hidden" type="button">Logout</button>
        </div>
      </div>

      <div id="dashboard-message" class="dashboard-message hidden"></div>

      <div id="owner-brand-panel" class="owner-brand-panel hidden">
        <div class="brand-cover"></div>
        <div class="brand-main-row">
          <div id="owner-brand-avatar" class="owner-brand-avatar"><span>🏢</span></div>
          <div class="brand-copy">
            <h2 id="owner-brand-display">Owner Brand</h2>
            <p>One brand name and logo for this owner. This same logo will show on all your vehicle cards.</p>
          </div>
        </div>
        <div class="brand-form-row">
          <label>
            Brand / Company Name
            <input id="owner-brand-name-input" type="text" placeholder="e.g., Majhi Travels" />
          </label>
          <label>
            Logo Photo
            <input id="owner-brand-logo-input" type="file" accept="image/*" />
          </label>
          <button id="save-owner-brand-btn" class="btn btn-primary btn-small" type="button">Save Brand</button>
        </div>
      </div>

      <div class="free-notice">
        <span class="notice-icon">🎉</span>
        <div class="notice-content">
          <h3>First 3 Months Free</h3>
          <p>Every new rental listing gets first 3 months free. After the free trial, choose Verified Badge for trust or Visibility Boost for sponsored placement.</p>
        </div>
      </div>

      <div class="section-title">
        <h2>Pricing Plans</h2>
      </div>

      <div class="plan-cards">
        <div class="plan-card">
          <h3>✅ Verified Badge</h3>
          <div class="plan-price">₹299</div>
          <p class="plan-duration">for 3 months</p>
          <p class="plan-description">Trust badge only. No ads boost included.</p>
          <button class="btn btn-small btn-orange plan-feature-btn" type="button" data-feature="verified">▶ See features</button>
        </div>
        <div class="plan-card">
          <h3>🚀 Small Vehicle Visibility</h3>
          <div class="plan-price">₹199</div>
          <p class="plan-duration">for 3 months</p>
          <p class="plan-description">For Toto and Auto. Sponsored visibility + ad tracking.</p>
          <button class="btn btn-small btn-orange plan-feature-btn" type="button" data-feature="small">▶ See features</button>
        </div>
        <div class="plan-card">
          <h3>🚀 Car / Pickup / Ambulance Visibility</h3>
          <div class="plan-price">₹1000</div>
          <p class="plan-duration">for 3 months</p>
          <p class="plan-description">Sponsored visibility for car, pickup and ambulance.</p>
          <button class="btn btn-small btn-orange plan-feature-btn" type="button" data-feature="medium">▶ See features</button>
        </div>
        <div class="plan-card">
          <h3>🚀 Bus Visibility</h3>
          <div class="plan-price">₹1500</div>
          <p class="plan-duration">for 3 months</p>
          <p class="plan-description">For bus, wedding bus, tour bus and school bus.</p>
          <button class="btn btn-small btn-orange plan-feature-btn" type="button" data-feature="bus">▶ See features</button>
        </div>
      </div>

      <div class="dashboard-actions">
        <a href="/rent-vehicle?tab=register" class="btn btn-primary">+ Add New Vehicle Listing</a>
        <a href="#my-listings" class="btn btn-outline">View My Vehicle Listings</a>
        <button id="refresh-stats-btn" class="btn btn-outline" type="button">🔄 Refresh Stats</button>
      </div>
      <div id="feature-note" class="feature-note hidden"></div>

      <div class="section-title" id="my-listings">
        <h2>My Listings</h2>
      </div>

      <div id="listings-loader" class="loading-card">Loading your listings...</div>
      <div id="my-listings-grid" class="my-listings-grid"></div>
    </div>
  </section>

  <script>
    import { supabase } from '../../lib/supabase';

    const PHOTO_BUCKET = 'rent-listing-photos';
    let currentUser = null;
    let currentListings = [];
    let eventCountsByListing = {};
    let membershipRequests = [];
    let activeMembershipsByListing = {};
    let allAdMembershipsByListing = {};
    let eventsByListing = {};
    let ownerProfile = null;

    function esc(value) {
      return String(value || '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');
    }

    function onlyDigits(value) {
      return String(value || '').replace(/\D/g, '');
    }

    function photoUrl(path) {
      if (!path) return '';
      if (path.startsWith('http://') || path.startsWith('https://')) return path;
      const { data } = supabase.storage.from(PHOTO_BUCKET).getPublicUrl(path);
      return data.publicUrl;
    }

    function showMessage(message, type = 'info') {
      const box = document.getElementById('dashboard-message');
      if (!box) return;
      box.textContent = message;
      box.classList.remove('hidden', 'success', 'error', 'info');
      box.classList.add(type);
    }

    function hideMessage() {
      const box = document.getElementById('dashboard-message');
      if (box) box.classList.add('hidden');
    }

    function formatDate(value) {
      if (!value) return '';
      try {
        return new Intl.DateTimeFormat('en-IN', {
          day: '2-digit',
          month: 'short',
          year: 'numeric',
        }).format(new Date(value));
      } catch {
        return '';
      }
    }

    function addMonths(value, months) {
      try {
        const date = value ? new Date(value) : new Date();
        date.setMonth(date.getMonth() + months);
        return formatDate(date.toISOString());
      } catch {
        return '';
      }
    }

    function statusClass(status) {
      if (status === 'active') return 'status-active';
      if (status === 'cancelled') return 'status-cancelled';
      if (status === 'rejected') return 'status-rejected';
      return 'status-pending';
    }

    function listingTitle(listing) {
      return listing.vehicle_model || listing.owner_name || 'Rental vehicle';
    }

    function countFor(listingId, eventType) {
      return eventCountsByListing?.[listingId]?.[eventType] || 0;
    }

    function normalStats(listing) {
      return {
        views: countFor(listing.id, 'listing_view'),
        calls: countFor(listing.id, 'call_click'),
        whatsapp: countFor(listing.id, 'whatsapp_click'),
        photos: countFor(listing.id, 'photo_open'),
        details: countFor(listing.id, 'view_details_click'),
      };
    }

    function visibilityPlanForListing(listing) {
      const type = String(listing.vehicle_type || '').toLowerCase();
      if (type === 'toto' || type === 'auto') return { plan_type: 'small_visibility', amount_inr: 199, label: 'Small Vehicle Visibility' };
      if (type === 'bus') return { plan_type: 'bus_visibility', amount_inr: 1500, label: 'Bus Visibility' };
      return { plan_type: 'car_pickup_ambulance_visibility', amount_inr: 1000, label: 'Car / Pickup / Ambulance Visibility' };
    }

    function hasMembershipRequest(listingId, planType) {
      return membershipRequests.some((item) => item.listing_id === listingId && item.plan_type === planType && item.status !== 'cancelled');
    }

    function renderRequestButton(listing, planType, amount, label, extraClass = '') {
      const requested = hasMembershipRequest(listing.id, planType);
      const text = requested ? 'Requested' : `${label} · ₹${amount}`;
      const disabled = requested ? 'disabled' : '';
      const disabledClass = requested ? 'btn-disabled' : '';
      return `<button class="btn btn-primary btn-small request-plan-btn ${extraClass} ${disabledClass}" type="button" data-listing-id="${esc(listing.id)}" data-plan-type="${esc(planType)}" data-amount="${amount}" ${disabled}>${esc(text)}</button>`;
    }

    function getActiveMemberships(listingId) {
      return activeMembershipsByListing[listingId] || [];
    }

    function getVerifiedMembership(listingId) {
      return getActiveMemberships(listingId).find((item) => item.plan_type === 'verified' || item.plan_type === 'verified_badge') || null;
    }

    function getAdMembership(listingId) {
      return getActiveMemberships(listingId).find((item) => item.plan_type === 'featured' && item.ads_status === 'active') || null;
    }

    function campaignStartMs(campaign) {
      const value = campaign?.starts_at || campaign?.created_at;
      const ms = value ? new Date(value).getTime() : 0;
      return Number.isFinite(ms) ? ms : 0;
    }

    function campaignEndMs(campaign) {
      const value = campaign?.expires_at;
      const ms = value ? new Date(value).getTime() : Number.MAX_SAFE_INTEGER;
      return Number.isFinite(ms) ? ms : Number.MAX_SAFE_INTEGER;
    }

    function eventInsideCampaign(event, campaign) {
      if (!event?.created_at || !campaign) return false;
      const eventMs = new Date(event.created_at).getTime();
      if (!Number.isFinite(eventMs)) return false;
      return eventMs >= campaignStartMs(campaign) && eventMs <= campaignEndMs(campaign);
    }

    function adStatsForCampaign(listingId, campaign) {
      if (!campaign) return { impressions: 0, clicks: 0, ctr: 0 };

      const events = eventsByListing[listingId] || [];
      let impressions = 0;
      let clicks = 0;

      events.forEach((event) => {
        if (!eventInsideCampaign(event, campaign)) return;
        if (event.event_type === 'ad_impression') impressions += 1;
        if (event.event_type === 'ad_click') clicks += 1;
      });

      const ctr = impressions > 0 ? Math.round((clicks / impressions) * 100) : 0;
      return { impressions, clicks, ctr };
    }

    function currentAdStats(listingId) {
      const activeAd = getAdMembership(listingId);
      if (!activeAd) return { impressions: 0, clicks: 0, ctr: 0 };
      return adStatsForCampaign(listingId, activeAd);
    }

    function renderAdsHistory(listingId, activeAd) {
      const campaigns = allAdMembershipsByListing[listingId] || [];

      const oldCampaigns = campaigns
        .filter((item) => item.plan_type === 'featured')
        .filter((item) => !activeAd || item.id !== activeAd.id)
        .sort((a, b) => campaignStartMs(b) - campaignStartMs(a));

      if (!oldCampaigns.length) {
        return '<p class="ads-history-empty">No old ads history yet.</p>';
      }

      return oldCampaigns.map((campaign) => {
        const stats = adStatsForCampaign(listingId, campaign);
        const start = formatDate(campaign.starts_at || campaign.created_at);
        const end = formatDate(campaign.expires_at);

        return `
          <div class="ads-history-row">
            <div>
              <strong>${esc(start || '-')} → ${esc(end || '-')}</strong>
              <span>${esc(campaign.status || '-')} / ${esc(campaign.ads_status || '-')}</span>
            </div>
            <div><b>${stats.impressions}</b><span>Imp</span></div>
            <div><b>${stats.clicks}</b><span>Clicks</span></div>
            <div><b>${stats.ctr}%</b><span>CTR</span></div>
          </div>
        `;
      }).join('');
    }


    function renderListingCard(listing) {
      const photos = Array.isArray(listing.photos) ? listing.photos : [];
      const photoCells = [0, 1, 2, 3].map((index) => {
        const url = photoUrl(photos[index]);
        if (!url) return `<div class="listing-photo-empty">+</div>`;
        return `<button type="button" class="listing-photo-thumb dashboard-photo-open" data-photo-url="${esc(url)}"><img src="${esc(url)}" alt="${esc(listingTitle(listing))} photo ${index + 1}" loading="lazy" /></button>`;
      }).join('');

      const phone = onlyDigits(listing.owner_phone);
      const whatsappRaw = onlyDigits(listing.owner_whatsapp || listing.owner_phone);
      const whatsapp = whatsappRaw.length === 10 ? `91${whatsappRaw}` : whatsappRaw;
      const purposes = Array.isArray(listing.purposes) ? listing.purposes.filter(Boolean) : [];
      const serviceIds = Array.isArray(listing.service_city_ids) ? listing.service_city_ids : [];
      const status = listing.status || 'active';
      const stats = normalStats(listing);
      const visibilityPlan = visibilityPlanForListing(listing);
      const trialExpiry = addMonths(listing.created_at, 3);
      const brandName = ownerProfile?.company_name || listing.owner_name || listingTitle(listing);
      const brandLogoUrl = ownerProfile?.company_logo ? photoUrl(ownerProfile.company_logo) : '';
      const firstPhotoUrl = photoUrl(photos[0]);
      const avatarUrl = brandLogoUrl || firstPhotoUrl;
      const verified = getVerifiedMembership(listing.id);
      const ad = getAdMembership(listing.id);
      const hasVerifiedRequest = hasMembershipRequest(listing.id, 'verified_badge');
      const hasBoostRequest = hasMembershipRequest(listing.id, visibilityPlan.plan_type);
      const currentAds = currentAdStats(listing.id);
      const adImpressions = currentAds.impressions;
      const adClicks = currentAds.clicks;
      const ctr = currentAds.ctr;
      const adsHistoryHtml = renderAdsHistory(listing.id, ad);

      const verifiedBadge = verified
        ? `<span class="listing-badge badge-verified">✓ Verified Active · ${esc(formatDate(verified.expires_at))}</span>`
        : hasVerifiedRequest
          ? `<span class="listing-badge badge-verified-requested">✓ Verified Requested</span>`
          : '';

      const adBadge = ad
        ? `<span class="listing-badge badge-boost">🚀 Ads Active · ${esc(formatDate(ad.expires_at))}</span>`
        : hasBoostRequest
          ? `<span class="listing-badge badge-boost-requested">🚀 Ads Requested</span>`
          : '';

      return `
        <article class="dashboard-listing-card" data-listing-id="${esc(listing.id)}">
          <div class="listing-head">
            <div class="listing-brand-avatar">
              ${avatarUrl ? `<img src="${esc(avatarUrl)}" alt="${esc(brandName)}" loading="lazy" />` : `<span>🚕</span>`}
            </div>
            <div class="listing-head-content">
              <div class="listing-title-row">
                <div>
                  <h3>${esc(brandName)}</h3>
                  <p class="listing-main-line">${esc(listing.vehicle_type || 'Vehicle')}${listing.seats ? ` · ${esc(listing.seats)} seats` : ''}${listing.reg_number ? ` · ${esc(listing.reg_number)}` : ''}</p>
                </div>
                <span class="listing-status ${statusClass(status)}">${esc(status)}</span>
              </div>
              <div class="listing-meta listing-status-badges">
                <span class="listing-badge badge-free">Free Trial</span>
                ${verifiedBadge}
                ${adBadge}
                <span class="listing-badge">Photos: ${photos.length}</span>
                <span class="listing-badge">Service cities: ${serviceIds.length}</span>
                ${listing.created_at ? `<span class="listing-badge">${esc(formatDate(listing.created_at))}</span>` : ''}
              </div>
              <p class="listing-sub-line"><strong>Owner:</strong> ${esc(listing.owner_name || '-')}</p>
              <p class="listing-sub-line"><strong>Price:</strong> ${esc(listing.price_text || '-')}</p>
              ${purposes.length ? `<p class="listing-sub-line"><strong>Purpose:</strong> ${esc(purposes.join(' • '))}</p>` : ''}
              ${listing.description ? `<p class="listing-desc">${esc(listing.description)}</p>` : ''}
              <div class="listing-photo-strip">${photoCells}</div>
            </div>
          </div>

          <div class="listing-edit-row">
            <div class="contact-edit-box hidden" id="contact-edit-${esc(listing.id)}">
              <div class="contact-edit-grid">
                <label>Phone<input type="tel" class="edit-phone-input" data-listing-id="${esc(listing.id)}" value="${esc(listing.owner_phone || '')}" placeholder="10 digit phone" /></label>
                <label>WhatsApp<input type="tel" class="edit-whatsapp-input" data-listing-id="${esc(listing.id)}" value="${esc(listing.owner_whatsapp || '')}" placeholder="10 digit WhatsApp" /></label>
              </div>
              <div class="contact-edit-actions">
                <button class="btn btn-primary btn-small save-contact-btn" type="button" data-listing-id="${esc(listing.id)}">Save Contact</button>
                <button class="btn btn-outline btn-small cancel-contact-edit-btn" type="button" data-listing-id="${esc(listing.id)}">Cancel</button>
              </div>
            </div>
            <button class="btn btn-outline btn-small edit-contact-btn" type="button" data-listing-id="${esc(listing.id)}">✎ Edit Contact</button>
          </div>

          <div class="performance-box">
            <h4>📊 Listing Performance</h4>
            <div class="performance-grid">
              <div class="mini-stat"><span>👁 Views</span><strong>${stats.views}</strong></div>
              <div class="mini-stat"><span>📞 Calls</span><strong>${stats.calls}</strong></div>
              <div class="mini-stat"><span>💬 WhatsApp</span><strong>${stats.whatsapp}</strong></div>
              <div class="mini-stat"><span>🖼 Photo opens</span><strong>${stats.photos}</strong></div>
              <div class="mini-stat"><span>ℹ️ Details</span><strong>${stats.details}</strong></div>
            </div>
          </div>

          <div class="ads-box ${ad ? 'ads-box-active' : ''}">
            <div class="ads-title-row">
              <h4>⭐ Current Ads Performance</h4>
              <span class="ads-badge">${ad ? 'Ads running' : hasBoostRequest ? 'Ads requested' : 'Ads off'}</span>
            </div>
            <div class="ads-grid">
              <div class="mini-stat"><span>👁 Ad impressions</span><strong>${adImpressions}</strong></div>
              <div class="mini-stat"><span>📊 Ad clicks</span><strong>${adClicks}</strong></div>
              <div class="mini-stat"><span>☆ CTR</span><strong>${ctr}%</strong></div>
            </div>
            <div class="ads-tools-row">
              <button class="btn btn-outline btn-small ads-history-toggle" type="button" data-listing-id="${esc(listing.id)}">📜 Ads History</button>
              ${ad ? `<button class="btn btn-danger btn-small expire-ads-btn" type="button" data-listing-id="${esc(listing.id)}">Stop Ads</button>` : ''}
            </div>
            <div id="ads-history-${esc(listing.id)}" class="ads-history-box hidden">
              ${adsHistoryHtml}
            </div>
          </div>

          <div class="payment-cards per-listing-payment">
            <div class="payment-card">
              <h3>🗓️ Verified Badge</h3>
              <p class="payment-amount">₹299 · 3 months</p>
              <p class="payment-status">Status: ${verified ? 'Active' : hasVerifiedRequest ? 'Requested' : 'Not active'}</p>
              <p class="free-expiry">Free listing trial expiry: ${esc(trialExpiry || '-')}</p>
              <label class="checkbox-label"><input type="checkbox" class="verified-disclaimer" data-listing-id="${esc(listing.id)}" /><span>I understand this badge helps users trust my listing. Calls and bookings depend on user demand, location and availability.</span></label>
              ${renderRequestButton(listing, 'verified_badge', 299, 'Get Verified Badge')}
            </div>
            <div class="payment-card boost-card">
              <h3>⭐ Visibility Boost</h3>
              <p class="selected-plan">Auto selected plan: ${esc(visibilityPlan.label)} · ₹${visibilityPlan.amount_inr}</p>
              <p class="payment-status">Status: ${ad ? 'Active' : hasBoostRequest ? 'Requested' : 'Not active'}</p>
              <label class="checkbox-label"><input type="checkbox" class="visibility-disclaimer" data-listing-id="${esc(listing.id)}" /><span>I understand boost can help my listing appear with more visibility. Results depend on city, vehicle type and user demand.</span></label>
              ${renderRequestButton(listing, visibilityPlan.plan_type, visibilityPlan.amount_inr, 'Boost Visibility')}
            </div>
          </div>

          <div class="listing-actions">
            ${phone ? `<a class="btn btn-primary btn-small" href="tel:${phone}">Call</a>` : `<button class="btn btn-small btn-disabled" disabled>No Call</button>`}
            ${whatsapp ? `<a class="btn btn-outline btn-small" href="https://wa.me/${whatsapp}" target="_blank" rel="noopener noreferrer">WhatsApp</a>` : `<button class="btn btn-small btn-disabled" disabled>No WhatsApp</button>`}
            <a class="btn btn-outline btn-small" href="/rent-vehicle?tab=register">Add New</a>
            ${status !== 'cancelled' ? `<button class="btn btn-danger btn-small delete-listing-btn" type="button" data-listing-id="${esc(listing.id)}">Delete</button>` : ''}
          </div>
        </article>`;
    }

    function renderOwnerBrandPanel() {
      const panel = document.getElementById('owner-brand-panel');
      const avatar = document.getElementById('owner-brand-avatar');
      const display = document.getElementById('owner-brand-display');
      const input = document.getElementById('owner-brand-name-input');
      if (!panel || !currentUser?.email) return;
      const name = ownerProfile?.company_name || 'Owner Brand';
      const logo = ownerProfile?.company_logo ? photoUrl(ownerProfile.company_logo) : '';
      panel.classList.remove('hidden');
      if (display) display.textContent = name;
      if (input) input.value = ownerProfile?.company_name || '';
      if (avatar) avatar.innerHTML = logo ? `<img src="${esc(logo)}" alt="${esc(name)}" />` : '<span>🏢</span>';
    }

    function renderListings() {
      const grid = document.getElementById('my-listings-grid');
      const loader = document.getElementById('listings-loader');
      if (loader) loader.classList.add('hidden');
      if (!grid) return;
      if (!currentUser) {
        grid.innerHTML = '<div class="empty-card"><h3>Login required</h3><p>Please login with Google to view your vehicle listings.</p></div>';
        return;
      }
      const visibleListings = currentListings.filter((item) => item.status !== 'cancelled');
      if (!visibleListings.length) {
        grid.innerHTML = '<div class="empty-card"><h3>No listings yet</h3><p>Create your first vehicle listing and it will appear here.</p><a href="/rent-vehicle?tab=register" class="btn btn-primary">+ Add New Vehicle Listing</a></div>';
        return;
      }
      grid.innerHTML = visibleListings.map(renderListingCard).join('');
    }

    async function refreshSession() {
      const { data, error } = await supabase.auth.getSession();
      currentUser = error ? null : data.session?.user || null;
      const loginEmail = document.getElementById('login-email');
      const loginBtn = document.getElementById('login-btn');
      const logoutBtn = document.getElementById('logout-btn');
      if (currentUser?.email) {
        if (loginEmail) loginEmail.textContent = currentUser.email;
        loginBtn?.classList.add('hidden');
        logoutBtn?.classList.remove('hidden');
      } else {
        if (loginEmail) loginEmail.textContent = 'Not logged in';
        loginBtn?.classList.remove('hidden');
        logoutBtn?.classList.add('hidden');
      }
      return currentUser;
    }

    async function loginWithGoogle() {
      const { error } = await supabase.auth.signInWithOAuth({ provider: 'google', options: { redirectTo: `${window.location.origin}/owner/rent-dashboard` } });
      if (error) showMessage(error.message, 'error');
    }

    async function logout() {
      const { error } = await supabase.auth.signOut();
      if (error) return showMessage(error.message, 'error');
      currentUser = null;
      currentListings = [];
      ownerProfile = null;
      await refreshSession();
      renderOwnerBrandPanel();
      renderListings();
      showMessage('Logged out successfully.', 'success');
    }

    async function loadMyListings() {
      const loader = document.getElementById('listings-loader');
      if (loader) {
        loader.textContent = 'Loading your listings...';
        loader.classList.remove('hidden');
      }
      if (!currentUser?.id) {
        currentListings = [];
        renderListings();
        return;
      }
      const { data, error } = await supabase
        .from('rent_listings')
        .select('id,owner_user_id,owner_email,owner_name,owner_phone,owner_whatsapp,reg_number,vehicle_type,vehicle_model,seats,purposes,base_city_id,service_city_ids,price_text,photos,description,status,created_at,updated_at,is_verified')
        .or(`owner_user_id.eq.${currentUser.id},owner_email.eq.${currentUser.email}`)
        .order('updated_at', { ascending: false });
      if (error) {
        showMessage(error.message, 'error');
        currentListings = [];
        renderListings();
        return;
      }
      currentListings = Array.isArray(data) ? data : [];
      await Promise.all([loadEventCounts(), loadMembershipRequests(), loadActiveMemberships(), loadOwnerProfile()]);
      renderOwnerBrandPanel();
      hideMessage();
      renderListings();
    }

    async function loadOwnerProfile() {
      ownerProfile = null;
      if (!currentUser?.email) return;
      const { data, error } = await supabase
        .from('rent_owner_profiles')
        .select('owner_email,company_name,company_logo,status')
        .eq('owner_email', currentUser.email)
        .eq('status', 'active')
        .maybeSingle();
      if (error) {
        console.warn('Owner profile load failed:', error);
        return;
      }
      ownerProfile = data || null;
    }

    async function loadEventCounts() {
      eventCountsByListing = {};
      eventsByListing = {};

      const listingIds = currentListings.map((item) => item.id).filter(Boolean);
      if (!listingIds.length) return;

      const { data, error } = await supabase
        .from('rent_listing_events')
        .select('listing_id,event_type,created_at')
        .in('listing_id', listingIds);

      if (error) {
        console.warn('Event count load failed:', error);
        return;
      }

      (data || []).forEach((event) => {
        if (!event.listing_id || !event.event_type) return;

        if (!eventsByListing[event.listing_id]) {
          eventsByListing[event.listing_id] = [];
        }
        eventsByListing[event.listing_id].push(event);

        if (!eventCountsByListing[event.listing_id]) {
          eventCountsByListing[event.listing_id] = {};
        }

        eventCountsByListing[event.listing_id][event.event_type] =
          (eventCountsByListing[event.listing_id][event.event_type] || 0) + 1;
      });
    }

async function refreshDashboardStats() {
  const btn = document.getElementById('refresh-stats-btn');

  if (btn) {
    btn.disabled = true;
    btn.textContent = 'Refreshing...';
  }

  try {
    await loadEventCounts();
    await loadActiveMemberships();
    renderListings();
    showMessage('Stats refreshed.', 'success');
  } catch (error) {
    console.warn('Refresh stats failed:', error);
    showMessage('Stats refresh failed. Please try again.', 'error');
  } finally {
    if (btn) {
      btn.disabled = false;
      btn.textContent = '🔄 Refresh Stats';
    }
  }
}

    async function stopCurrentAds(listingId) {
      const ad = getAdMembership(listingId);

      if (!ad) {
        showMessage('No active ads found for this listing.', 'info');
        return;
      }

      if (!confirm('Stop ads for this listing? Current ads stats will become 0 and old data will move to history.')) {
        return;
      }

      showMessage('Stopping ads...', 'info');

      const now = new Date().toISOString();

      const { error } = await supabase
        .from('rent_memberships')
        .update({
          ads_status: 'inactive',
          expires_at: now,
          updated_at: now,
        })
        .eq('id', ad.id);

      if (error) {
        showMessage(error.message, 'error');
        return;
      }

      await loadActiveMemberships();
      await loadEventCounts();
      renderListings();

      showMessage('Ads stopped. Current ads stats are now 0. Old campaign moved to history.', 'success');
    }

    async function loadMembershipRequests() {
      membershipRequests = [];
      if (!currentUser?.id) return;
      const { data, error } = await supabase
        .from('rent_membership_requests')
        .select('id,listing_id,plan_type,amount_inr,status,created_at,duration_months')
        .eq('owner_user_id', currentUser.id)
        .order('created_at', { ascending: false });
      if (error) {
        console.warn('Membership request load failed:', error);
        return;
      }
      membershipRequests = Array.isArray(data) ? data : [];
    }

    async function loadActiveMemberships() {
      activeMembershipsByListing = {};
      allAdMembershipsByListing = {};

      const listingIds = currentListings.map((item) => item.id).filter(Boolean);
      if (!listingIds.length) return;

      const { data, error } = await supabase
        .from('rent_memberships')
        .select('id,listing_id,plan_type,status,ads_status,starts_at,expires_at,created_at,payment_status')
        .in('listing_id', listingIds);

      if (error) {
        console.warn('Active membership load failed:', error);
        return;
      }

      const now = Date.now();

      (data || []).forEach((item) => {
        if (!item.listing_id) return;

        if (item.plan_type === 'featured') {
          if (!allAdMembershipsByListing[item.listing_id]) {
            allAdMembershipsByListing[item.listing_id] = [];
          }
          allAdMembershipsByListing[item.listing_id].push(item);
        }

        const startsOk =
          !item.starts_at || new Date(item.starts_at).getTime() <= now;

        const expiresOk =
          item.expires_at && new Date(item.expires_at).getTime() > now;

        if (item.status !== 'active' || !startsOk || !expiresOk) return;

        if (!activeMembershipsByListing[item.listing_id]) {
          activeMembershipsByListing[item.listing_id] = [];
        }

        activeMembershipsByListing[item.listing_id].push(item);
      });
    }

    async function requestMembership(listingId, planType, amountInr) {
      if (!currentUser?.id || !currentUser?.email) return showMessage('Please login first.', 'error');
      const listing = currentListings.find((item) => item.id === listingId);
      if (!listing) return showMessage('Listing not found.', 'error');
      const checkboxClass = planType === 'verified_badge' ? '.verified-disclaimer' : '.visibility-disclaimer';
      const checkbox = document.querySelector(`${checkboxClass}[data-listing-id="${CSS.escape(listingId)}"]`);
      if (!checkbox?.checked) return showMessage('Please tick disclaimer first.', 'error');
      if (hasMembershipRequest(listingId, planType)) return showMessage('Request already exists for this plan.', 'info');
      showMessage('Saving request...', 'info');
      const { error } = await supabase.from('rent_membership_requests').insert({
        listing_id: listingId,
        owner_user_id: currentUser.id,
        owner_email: currentUser.email,
        plan_type: planType,
        amount_inr: Number(amountInr || 0),
        duration_months: 3,
        status: 'requested',
        note: 'Owner requested membership from dashboard. Payment gateway/admin activation pending.',
        updated_at: new Date().toISOString(),
      });
      if (error) return showMessage(error.message, 'error');
      showMessage(planType === 'verified_badge' ? 'Verified Badge request submitted.' : 'Visibility Boost request submitted.', 'success');
      await loadMembershipRequests();
      renderListings();
    }

    function cleanPhone(value) {
      const digits = String(value || '').replace(/\D/g, '');
      if (digits.length === 12 && digits.startsWith('91')) return digits.slice(2);
      if (digits.length === 11 && digits.startsWith('0')) return digits.slice(1);
      return digits;
    }

    async function saveListingContact(listingId) {
      if (!currentUser?.id || !currentUser?.email) return showMessage('Please login first.', 'error');
      const phoneInput = document.querySelector(`.edit-phone-input[data-listing-id="${CSS.escape(listingId)}"]`);
      const whatsappInput = document.querySelector(`.edit-whatsapp-input[data-listing-id="${CSS.escape(listingId)}"]`);
      const phone = cleanPhone(phoneInput?.value || '');
      const whatsapp = cleanPhone(whatsappInput?.value || '');
      if (!/^\d{10}$/.test(phone)) return showMessage('Please enter valid 10 digit phone number.', 'error');
      if (!/^\d{10}$/.test(whatsapp)) return showMessage('Please enter valid 10 digit WhatsApp number.', 'error');
      showMessage('Updating contact...', 'info');
      const { error } = await supabase
        .from('rent_listings')
        .update({ owner_phone: phone, owner_whatsapp: whatsapp, updated_at: new Date().toISOString() })
        .eq('id', listingId)
        .or(`owner_user_id.eq.${currentUser.id},owner_email.eq.${currentUser.email}`);
      if (error) return showMessage(error.message, 'error');
      showMessage('Contact updated successfully.', 'success');
      await loadMyListings();
    }

    async function saveOwnerBrand() {
      if (!currentUser?.id || !currentUser?.email) return showMessage('Please login first.', 'error');
      const nameInput = document.getElementById('owner-brand-name-input');
      const logoInput = document.getElementById('owner-brand-logo-input');
      const companyName = String(nameInput?.value || '').trim();
      const file = logoInput?.files?.[0] || null;
      let companyLogo = ownerProfile?.company_logo || '';
      try {
        if (file) {
          if (!file.type.startsWith('image/')) return showMessage('Please upload an image file.', 'error');
          const ext = file.type === 'image/png' ? 'png' : file.type === 'image/webp' ? 'webp' : 'jpg';
          const path = `${currentUser.id}/logos/${Date.now()}-company-logo.${ext}`;
          const { error: uploadError } = await supabase.storage.from(PHOTO_BUCKET).upload(path, file, {
            cacheControl: '31536000',
            upsert: false,
            contentType: file.type || 'image/jpeg',
          });
          if (uploadError) throw uploadError;
          companyLogo = path;
        }
        const { error } = await supabase.from('rent_owner_profiles').upsert(
          {
            owner_user_id: currentUser.id,
            owner_email: currentUser.email,
            company_name: companyName,
            company_logo: companyLogo,
            logo_bucket: PHOTO_BUCKET,
            status: 'active',
            updated_at: new Date().toISOString(),
          },
          { onConflict: 'owner_email' }
        );
        if (error) throw error;
        showMessage('Brand/logo saved successfully.', 'success');
        await loadOwnerProfile();
        renderOwnerBrandPanel();
        renderListings();
      } catch (error) {
        console.error('Save brand error:', error);
        showMessage(error?.message || 'Logo save failed.', 'error');
      }
    }

    async function deleteListing(listingId) {
      if (!currentUser?.id) return showMessage('Please login first.', 'error');
      if (!confirm('Delete this listing? It will be removed from public search.')) return;
      showMessage('Deleting listing...', 'info');
      const { error } = await supabase
        .from('rent_listings')
        .update({ status: 'cancelled', updated_at: new Date().toISOString() })
        .eq('id', listingId)
        .or(`owner_user_id.eq.${currentUser.id},owner_email.eq.${currentUser.email}`);
      if (error) return showMessage(error.message, 'error');
      currentListings = currentListings.map((item) => item.id === listingId ? { ...item, status: 'cancelled' } : item);
      showMessage('Listing deleted from public search.', 'success');
      renderListings();
    }

    function showFeatureNote(type) {
      const box = document.getElementById('feature-note');
      if (!box) return;
      const notes = {
        verified: 'Verified Badge is a trust badge only. Admin/payment activation will come later. It does not guarantee calls or bookings.',
        small: 'Small Vehicle Visibility is for Toto/Auto paid boost. Paid ads tracking is pending until payment activation.',
        medium: 'Car/Pickup/Ambulance Visibility will start only after payment integration is connected.',
        bus: 'Bus Visibility will start only after payment integration is connected.',
      };
      box.textContent = notes[type] || 'Feature details coming soon.';
      box.classList.remove('hidden');
      box.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    document.addEventListener('DOMContentLoaded', async () => {
      document.getElementById('login-btn')?.addEventListener('click', loginWithGoogle);
      document.getElementById('logout-btn')?.addEventListener('click', logout);
      document.getElementById('refresh-stats-btn')?.addEventListener('click', refreshDashboardStats);
      document.getElementById('save-owner-brand-btn')?.addEventListener('click', saveOwnerBrand);
      document.getElementById('owner-brand-logo-input')?.addEventListener('change', (event) => {
        const file = event.target?.files?.[0];
        if (!file || !file.type.startsWith('image/')) return;
        const avatar = document.getElementById('owner-brand-avatar');
        if (avatar) avatar.innerHTML = `<img src="${URL.createObjectURL(file)}" alt="Selected logo preview" />`;
      });
      document.querySelectorAll('.plan-feature-btn').forEach((btn) => btn.addEventListener('click', () => showFeatureNote(btn.dataset.feature)));
      document.addEventListener('click', async (event) => {
        const target = event.target;

        const historyBtn = target.closest('.ads-history-toggle');
        if (historyBtn) {
          const listingId = historyBtn.dataset.listingId;
          const box = document.getElementById(`ads-history-${listingId}`);
          box?.classList.toggle('hidden');
          return;
        }

        const expireBtn = target.closest('.expire-ads-btn');
        if (expireBtn) {
          const listingId = expireBtn.dataset.listingId;
          if (listingId) await stopCurrentAds(listingId);
          return;
        }

        const requestBtn = target.closest('.request-plan-btn');
        if (requestBtn && !requestBtn.disabled) {
          const listingId = requestBtn.dataset.listingId;
          const planType = requestBtn.dataset.planType;
          const amount = Number(requestBtn.dataset.amount || 0);
          if (listingId && planType) requestMembership(listingId, planType, amount);
          return;
        }
        const editBtn = target.closest('.edit-contact-btn');
        if (editBtn) {
          const box = document.getElementById(`contact-edit-${editBtn.dataset.listingId}`);
          if (box) box.classList.toggle('hidden');
          return;
        }
        const cancelEditBtn = target.closest('.cancel-contact-edit-btn');
        if (cancelEditBtn) {
          const box = document.getElementById(`contact-edit-${cancelEditBtn.dataset.listingId}`);
          if (box) box.classList.add('hidden');
          return;
        }
        const saveContactBtn = target.closest('.save-contact-btn');
        if (saveContactBtn) {
          const listingId = saveContactBtn.dataset.listingId;
          if (listingId) saveListingContact(listingId);
          return;
        }
        const deleteBtn = target.closest('.delete-listing-btn');
        if (deleteBtn) {
          const listingId = deleteBtn.dataset.listingId;
          if (listingId) deleteListing(listingId);
          return;
        }
        const photoBtn = target.closest('.dashboard-photo-open');
        if (photoBtn) {
          const url = photoBtn.dataset.photoUrl;
          if (url) window.open(url, '_blank', 'noopener,noreferrer');
        }
      });
      await refreshSession();
await loadMyListings();

setInterval(async () => {
  if (!currentUser?.id || !currentListings.length) return;
  await loadEventCounts();
  await loadActiveMemberships();
  renderListings();
}, 15000);
    });
  </script>

