---

<BaseLayout
	title="All Bus Routes - West Bengal Bus Timetable"
	description="Complete list of all bus routes in West Bengal. View timetables, fares, and schedules for all major routes."
>
	<div class="debug-label">PAGE: ALL ROUTES</div>
	<section class="hero">
		<div class="container">
			<h1>All Bus Routes</h1>
			<p>Complete list of all bus routes in West Bengal with timetables, fares, and schedules.</p>
		</div>
	</section>

	<section>
		<div class="container">
			<div class="section-title">
				<h2>Available Routes</h2>
			</div>
			<div class="grid grid-3">
				{routes.map(route => (
					<a href={`/bus-timetable/${route.slug}/`} class="popular-item">
						<h4>{route.from_en} to {route.to_en}</h4>
						<p>{route.distance} • {route.duration} • ₹{route.fare_min} - ₹{route.fare_max}</p>
					</a>
				))}
			</div>
		</div>
	</section>
</BaseLayout>
