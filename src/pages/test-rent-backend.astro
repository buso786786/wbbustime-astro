---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Rent Backend Test"
  description="Supabase rent backend connection test"
>
  <section style="min-height:100vh;background:#0b0628;color:white;padding:32px;">
    <div style="max-width:900px;margin:auto;">
      <h1>Rent Backend Test</h1>
      <p>This page checks Supabase rent tables.</p>

      <div style="display:grid;gap:16px;margin-top:24px;">
        <div style="border:1px solid rgba(255,255,255,.2);border-radius:16px;padding:16px;">
          <h2>Rent Cities</h2>
          <pre id="cities-result">Loading...</pre>
        </div>

        <div style="border:1px solid rgba(255,255,255,.2);border-radius:16px;padding:16px;">
          <h2>Rent Listings</h2>
          <pre id="listings-result">Loading...</pre>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { supabase } from "../lib/supabase";

    const citiesEl = document.getElementById("cities-result");
    const listingsEl = document.getElementById("listings-result");

    async function testBackend() {
      try {
        const { data: cities, error: cityError } = await supabase
          .from("rent_cities")
          .select("id, name_en, name_bn, district_en, district_bn, active")
          .limit(10);

        if (cityError) {
          citiesEl.textContent = "CITY ERROR:\n" + cityError.message;
        } else {
          citiesEl.textContent =
            "OK ✅ rent_cities loaded\n\n" +
            JSON.stringify(cities, null, 2);
        }

        const { data: listings, error: listingError } = await supabase
          .from("rent_listings")
          .select("id, owner_name, vehicle_type, vehicle_model, seats, status, created_at")
          .limit(10);

        if (listingError) {
          listingsEl.textContent = "LISTING ERROR:\n" + listingError.message;
        } else {
          listingsEl.textContent =
            "OK ✅ rent_listings loaded\n\n" +
            JSON.stringify(listings, null, 2);
        }
      } catch (error) {
        citiesEl.textContent = "JS ERROR:\n" + String(error);
        listingsEl.textContent = "JS ERROR:\n" + String(error);
      }
    }

    testBackend();
  </script>
</BaseLayout>
