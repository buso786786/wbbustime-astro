---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildBusSeoRoutes } from '../lib/busSeoLinks';

const seoRoutes = await buildBusSeoRoutes();
const topRoutes = seoRoutes.slice(0, 12);
---

<BaseLayout
  title="West Bengal Bus Route Finder"
  description="Find West Bengal bus routes by source and destination. Browse real bus timetable SEO links generated from database route data."
>
  <main class="route-finder-page">
    <div class="container">
      <section class="hero-card">
        <p class="eyebrow" data-en="🚌 Route Finder" data-bn="🚌 রুট ফাইন্ডার">🚌 Route Finder</p>

        <h1
          data-en="West Bengal Bus Route Finder"
          data-bn="পশ্চিমবঙ্গ বাস রুট ফাইন্ডার"
        >
          West Bengal Bus Route Finder
        </h1>

        <p
          data-en="Browse real bus timetable links generated from database route data. Open any route to view buses, stops, up time and down time."
          data-bn="ডাটাবেস রুট ডেটা থেকে তৈরি আসল বাস টাইমটেবিল লিংক দেখুন। যেকোনো রুট খুলে বাস, স্টপ, আপ টাইম ও ডাউন টাইম দেখুন।"
        >
          Browse real bus timetable links generated from database route data. Open any route to view buses, stops, up time and down time.
        </p>

        <p class="bn-line">নিচের লিংকগুলো Google crawl করার জন্য static timetable URL।</p>
      </section>

      <section class="quick-links">
        <a
          href="/all-routes/"
          class="btn-soft"
          data-en="All Routes"
          data-bn="সব রুট"
        >
          All Routes
        </a>

        <a
          href="/bus-search/"
          class="btn-soft"
          data-en="Live Bus Search"
          data-bn="লাইভ বাস সার্চ"
        >
          Live Bus Search
        </a>
      </section>

      <section class="route-list-card">
        <div class="section-title-row">
          <div>
            <h2
              data-en="Real Bus Timetable Links"
              data-bn="আসল বাস টাইমটেবিল লিংক"
            >
              Real Bus Timetable Links
            </h2>

            <p
              data-en="These crawlable links are generated from real database source-destination route data."
              data-bn="এই crawlable লিংকগুলো ডাটাবেসের আসল source-destination রুট ডেটা থেকে তৈরি।"
            >
              These crawlable links are generated from real database source-destination route data.
            </p>
          </div>

          <a
            href="/all-routes/"
            class="small-link"
            data-en="See All"
            data-bn="সব দেখুন"
          >
            See All
          </a>
        </div>

        {topRoutes.length > 0 ? (
          <div class="route-grid">
            {topRoutes.map((route) => (
              <a href={route.href} class="route-card">
                <strong>{route.source} to {route.destination}</strong>

                <span class="route-meta">
                  <span data-en="View timetable" data-bn="টাইমটেবিল দেখুন">View timetable</span>
                  {route.busNames.length > 0 && (
                    <span> · {route.busNames.slice(0, 2).join(', ')}</span>
                  )}
                </span>
              </a>
            ))}
          </div>
        ) : (
          <div class="empty-card">
            <h3
              data-en="No real bus timetable links found"
              data-bn="কোনো আসল বাস টাইমটেবিল লিংক পাওয়া যায়নি"
            >
              No real bus timetable links found
            </h3>

            <p
              data-en="Public build could not read bus route data from Supabase."
              data-bn="Public build Supabase থেকে bus route data পড়তে পারেনি।"
            >
              Public build could not read bus route data from Supabase.
            </p>
          </div>
        )}
      </section>
    </div>
  </main>

  <style>
    .route-finder-page {
      min-height: 100vh;
      padding: 1rem 0 2.5rem;
      background: linear-gradient(180deg, #f8fbff 0%, #eef7ff 45%, #ffffff 100%);
    }

    .hero-card,
    .route-list-card,
    .empty-card {
      background: #ffffff;
      border: 1px solid #dbeafe;
      border-radius: 1.25rem;
      padding: 1rem;
      box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
      margin-bottom: 1rem;
    }

    .eyebrow {
      margin: 0 0 0.35rem;
      color: #2563eb;
      font-size: 0.8rem;
      font-weight: 900;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .hero-card h1 {
      margin: 0 0 0.5rem;
      color: #0f172a;
      font-size: clamp(1.55rem, 4vw, 2.35rem);
      line-height: 1.1;
    }

    .hero-card p,
    .route-list-card p,
    .empty-card p {
      margin: 0.35rem 0 0;
      color: #475569;
      line-height: 1.55;
    }

    .bn-line {
      color: #0369a1 !important;
      font-weight: 800;
    }

    .quick-links {
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
      margin-bottom: 1rem;
    }

    .btn-soft,
    .small-link {
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      background: #eff6ff;
      border: 1px solid #bfdbfe;
      color: #075985;
      text-decoration: none;
      font-weight: 900;
      padding: 0.55rem 0.85rem;
    }

    .section-title-row {
      display: flex;
      justify-content: space-between;
      gap: 0.75rem;
      align-items: flex-start;
      margin-bottom: 0.85rem;
    }

    .section-title-row h2 {
      margin: 0;
      color: #0f172a;
      font-size: 1.2rem;
    }

    .route-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 0.65rem;
    }

    .route-card {
      display: block;
      background: #f8fbff;
      border: 1px solid #bfdbfe;
      border-radius: 0.95rem;
      padding: 0.8rem;
      color: #0f172a;
      text-decoration: none;
    }

    .route-card:hover {
      background: #eff6ff;
    }

    .route-card strong {
      display: block;
      font-size: 0.98rem;
      margin-bottom: 0.25rem;
    }

    .route-meta {
      display: block;
      color: #64748b;
      font-size: 0.82rem;
      line-height: 1.35;
    }

    .route-meta span {
      display: inline;
    }

    @media (max-width: 800px) {
      .section-title-row {
        flex-direction: column;
      }
    }
  </style>
</BaseLayout>