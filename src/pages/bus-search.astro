    async function runSearch(from, to) {
      const source = String(from || '').trim();
      const destination = String(to || '').trim();

      if (!source || !destination) return;

      lastSearchSource = source;
      lastSearchDestination = destination;
      saveSearchPair(source, destination);
      resetResults();
      setHidden(popularSection, true);
      setStatus('Searching bus routes...', 'loading');

      if (searchBtn) searchBtn.disabled = true;

      const url = new URL(window.location.href);
      url.searchParams.set('from', source);
      url.searchParams.set('to', destination);
      window.history.replaceState({}, '', url);

      try {
        const plan = await findJourney(source, destination);

        const direct = sortByDeparture(plan.direct || []);
        const indirect = plan.kind === 'indirect' ? plan.indirect || [] : [];
        const alternativeIndirect = plan.alternativeIndirect || [];
        const allIndirect = [...indirect, ...alternativeIndirect].slice(0, 6);

        setHidden(statusBox, true);

        if (direct.length && directResults) {
          setHidden(directSection, false);
          if (directSubtitle) directSubtitle.textContent = `${plan.source} to ${plan.destination}`;
          directResults.innerHTML = direct.map((bus) => busCard(bus, source, destination)).join('');
        }

        if (allIndirect.length && indirectResults) {
          setHidden(indirectSection, false);
          if (indirectSubtitle) {
            indirectSubtitle.textContent = direct.length
              ? t(
                  'Indirect bus suggestions are shown below, even though direct buses are available.',
                  'সরাসরি বাস পাওয়া গেছে, তবুও নিচে সংযোগ রুটের সাজেশন দেখানো হয়েছে।'
                )
              : t(
                  'No direct bus matched. Use these indirect bus suggestions with middle-stop transfer.',
                  'সরাসরি বাস মেলেনি। মাঝের স্টপ দিয়ে এই সংযোগ রুটের সাজেশন ব্যবহার করুন।'
                );
          }
          indirectResults.innerHTML = allIndirect.map((option) => indirectCard(option, source, destination)).join('');
        }

        if (!direct.length && allIndirect.length) {
          setHidden(rentSection, false);
          const rentTitle = rentSection?.querySelector('h2');
          const rentText = rentSection?.querySelector('p');

          if (rentTitle) rentTitle.textContent = 'No direct bus found';
          if (rentText) {
            rentText.textContent =
              'Direct bus is not available for this search. Please check the indirect bus suggestions below, or use a rent car/cab if urgent.';
          }
        }

        if (!direct.length && !allIndirect.length) {
          setHidden(rentSection, false);
          const rentTitle = rentSection?.querySelector('h2');
          const rentText = rentSection?.querySelector('p');

          if (rentTitle) rentTitle.textContent = 'No bus route found';
          if (rentText) {
            rentText.textContent =
              'We could not find direct or indirect bus routes for this search. You can try another spelling, reverse direction, or find a car with driver.';
          }
        }
      } catch (error) {
        console.error(error);
        setStatus('Search failed. Please try again.', 'error');
      } finally {
        if (searchBtn) searchBtn.disabled = false;
      }
    }

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      runSearch(fromInput?.value, toInput?.value);
    });

    const params = new URLSearchParams(window.location.search);
    const initialFrom = params.get('from');
    const initialTo = params.get('to');

    if (initialFrom && fromInput) fromInput.value = initialFrom;
    if (initialTo && toInput) toInput.value = initialTo;

    if (initialFrom && initialTo) {
      runSearch(initialFrom, initialTo);
    }
    window.addEventListener('storage', () => {
      if (lastSearchSource && lastSearchDestination) {
        runSearch(lastSearchSource, lastSearchDestination);
      }
    });
  </script>

