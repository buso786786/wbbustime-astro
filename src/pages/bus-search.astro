---
import BaseLayout from '../layouts/BaseLayout.astro';

const from = Astro.url.searchParams.get('from') || '';
const to = Astro.url.searchParams.get('to') || '';

const SUPABASE_URL =
  import.meta.env.VITE_SUPABASE_URL || 'https://ytxtyphbguszjndtpakm.supabase.co';

const SUPABASE_ANON_KEY =
  import.meta.env.VITE_SUPABASE_ANON_KEY ||
  'sb_publishable_NCILoAG5w2kh9ciKd3QM8w_TTUfHkC4';

type BusRouteRow = {
  source?: string | null;
  destination?: string | null;
  route_data?: Array<{ stoppage_name?: string | null }> | null;
};

async function loadStopSuggestions() {
  const fallback = [
    'Arambagh', 'আরামবাগ',
    'Tarakeswar', 'তারকেশ্বর',
    'Digha', 'দীঘা',
    'Ghatal', 'ঘাটাল',
    'Kolkata', 'কলকাতা',
    'Howrah', 'হাওড়া',
  ];

  try {
    const url = `${SUPABASE_URL.replace(/\/$/, '')}/rest/v1/bus_routes?select=source,destination,route_data&limit=2000`;
    const res = await fetch(url, {
      headers: {
        apikey: SUPABASE_ANON_KEY,
        Authorization: `Bearer ${SUPABASE_ANON_KEY}`,
      },
    });

    if (!res.ok) return fallback;

    const rows = (await res.json()) as BusRouteRow[];
    const set = new Set<string>();

    for (const row of rows) {
      if (row.source) set.add(row.source.trim());
      if (row.destination) set.add(row.destination.trim());

      for (const stop of row.route_data || []) {
        if (stop.stoppage_name) set.add(stop.stoppage_name.trim());
      }
    }

    return Array.from(set)
      .filter(Boolean)
      .sort((a, b) => a.localeCompare(b))
      .slice(0, 600);
  } catch {
    return fallback;
  }
}

const stopSuggestions = await loadStopSuggestions();
---

<BaseLayout
  title="Bus Search"
  description="Search West Bengal bus timetable, direct buses, indirect bus routes, middle stop connections and route finder results."
>
  <section class="bus-search-page">
    <div class="container">
      <div class="bus-search-hero">
        <p class="eyebrow">🚌 Bus Route Finder</p>
        <h1
  data-en="Search Bus Timetable in West Bengal"
  data-bn="পশ্চিমবঙ্গে বাস টাইমটেবিল খুঁজুন"
>
  Search Bus Timetable in West Bengal
</h1>
       <p
  data-en="Search direct buses first. If no direct bus is found, SoniaBuddy suggests indirect bus routes with middle-stop connections."
  data-bn="আগে সরাসরি বাস খুঁজুন। সরাসরি বাস না পেলে SoniaBuddy মাঝের স্টপ দিয়ে সংযোগ রুট দেখাবে।"
>
  Search direct buses first. If no direct bus is found, SoniaBuddy suggests indirect bus routes with middle-stop connections.
</p>
        <p class="bn-line">বাংলা বা English stop name লিখে bus route খুঁজুন।</p>
      </div>

      <div class="search-card">
        <form id="bus-search-form">
          <div class="search-grid">
            <label>
              <span data-en="From" data-bn="কোথা থেকে">From</span>
              <input
                id="bus-from"
                name="from"
                type="text"
                list="stop-suggestions"
                placeholder="Arambagh / আরামবাগ"
                data-placeholder-en="Arambagh"
               data-placeholder-bn="আরামবাগ"
                value={from}
                autocomplete="off"
                required
              />
            </label>

            <label>
              <span data-en="To" data-bn="কোথায়">To</span>
              <input
                id="bus-to"
                name="to"
                type="text"
                list="stop-suggestions"
                placeholder="Digha / দীঘা"
                data-placeholder-en="Digha"
                data-placeholder-bn="দীঘা"
                value={to}
                autocomplete="off"
                required
              />
            </label>

            <button type="submit" id="search-btn" data-en="Search" data-bn="খুঁজুন">Search</button>
          </div>

          <datalist id="stop-suggestions">
            {stopSuggestions.map((stop) => <option value={stop} />)}
          </datalist>
        </form>
      </div>

      <div id="status-box" class="status-box hidden"></div>

      <section id="direct-section" class="result-section hidden">
        <div class="section-head">
          <h2 data-en="Direct buses found" data-bn="সরাসরি বাস পাওয়া গেছে">Direct buses found</h2>
          <p id="direct-subtitle"></p>
        </div>
        <div id="direct-results" class="result-list"></div>
      </section>

      <section id="indirect-section" class="result-section hidden">
        <div class="section-head">
          <h2 data-en="Suggested indirect routes" data-bn="প্রস্তাবিত সংযোগ রুট">Suggested indirect routes</h2>
          <p
  data-en="Use these routes when direct bus is not available or when middle-stop travel is better."
  data-bn="সরাসরি বাস না থাকলে বা মাঝের স্টপ দিয়ে যাত্রা ভালো হলে এই রুটগুলো ব্যবহার করুন।"
>
  Use these routes when direct bus is not available or when middle-stop travel is better.
</p>
        </div>
        <div id="indirect-results" class="result-list"></div>
      </section>

      <section id="rent-section" class="rent-help hidden">
        <h2 data-en="No bus route found" data-bn="কোনো বাস রুট পাওয়া যায়নি">No bus route found</h2>
        <p>
          We could not find direct or indirect bus routes for this search. You can try another spelling, reverse direction,
          or find a car with driver.
        </p>
        <a
  href="/rent-vehicle?tab=find"
  class="rent-btn"
  data-en="Find Rent Car / Cab"
  data-bn="ভাড়া গাড়ি / ক্যাব খুঁজুন"
>
  Find Rent Car / Cab
</a>
      </section>

      <section id="popular-section" class="popular-routes">
        <h2 data-en="Popular searches" data-bn="জনপ্রিয় সার্চ">Popular searches</h2>
        <div class="popular-grid">
          <a href="/bus-search?from=Arambagh&to=Tarakeswar">Arambagh to Tarakeswar</a>
          <a href="/bus-search?from=Arambagh&to=Digha">Arambagh to Digha</a>
          <a href="/bus-search?from=Ghatal&to=Digha">Ghatal to Digha</a>
          <a href="/bus-search?from=Digha&to=Arambagh">Digha to Arambagh</a>
        </div>
      </section>
    </div>
  </section>

  <script>
    import { findJourney } from '../lib/routeFinder';

    const form = document.getElementById('bus-search-form');
    const fromInput = document.getElementById('bus-from');
    const toInput = document.getElementById('bus-to');
    const searchBtn = document.getElementById('search-btn');

    const statusBox = document.getElementById('status-box');
    const directSection = document.getElementById('direct-section');
    const indirectSection = document.getElementById('indirect-section');
    const rentSection = document.getElementById('rent-section');
    const popularSection = document.getElementById('popular-section');

    const directResults = document.getElementById('direct-results');
    const indirectResults = document.getElementById('indirect-results');
    const directSubtitle = document.getElementById('direct-subtitle');

    const escapeHtml = (value) =>
      String(value || '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');

    const slugify = (value) =>
      String(value || '')
        .normalize('NFKD')
        .toLowerCase()
        .trim()
        .replace(/[^\p{Letter}\p{Number}]+/gu, '-')
        .replace(/^-+|-+$/g, '');

   const timetableUrl = (item, toArg, busIdArg) => {
  const isBusObject = item && typeof item === 'object';

  const displayFrom = isBusObject ? toArg : item;
  const displayTo = isBusObject ? busIdArg : toArg;

  const routeFrom = isBusObject
    ? item.route_source || item.routeSource || item.main_source || item.mainSource || item.source || item.from || displayFrom
    : item;

  const routeTo = isBusObject
    ? item.route_destination || item.routeDestination || item.main_destination || item.mainDestination || item.destination || item.to || displayTo
    : toArg;

  const busId = isBusObject ? item.bus_id : busIdArg;

  const slug = `${slugify(routeFrom)}-to-${slugify(routeTo)}`;
  let base = '/bus-timetable/result/';

  if (slug.length > 4) {
    base = `/bus-timetable/${slug}/`;
  }

  const params = new URLSearchParams();
  if (busId) params.set('bus_id', busId);
  params.set('from', displayFrom || routeFrom || '');
  params.set('to', displayTo || routeTo || '');

  return `${base}?${params.toString()}#selected-bus`;
};

    const setHidden = (el, hidden) => {
      if (!el) return;
      el.classList.toggle('hidden', hidden);
    };

    const setStatus = (message, type = 'info') => {
      if (!statusBox) return;
      statusBox.textContent = message;
      statusBox.className = `status-box ${type}`;
      setHidden(statusBox, false);
    };

    const resetResults = () => {
      setHidden(statusBox, true);
      setHidden(directSection, true);
      setHidden(indirectSection, true);
      setHidden(rentSection, true);
      if (directResults) directResults.innerHTML = '';
      if (indirectResults) indirectResults.innerHTML = '';
    };

    const busCard = (bus, searchFrom, searchTo) => {
      const from = bus.from || searchFrom;
      const to = bus.to || searchTo;
      const url = timetableUrl(bus, from, to);

      return `
        <article class="bus-card">
          <div class="bus-photo">
            ${
              bus.image_url
                ? `<img src="${escapeHtml(bus.image_url)}" alt="${escapeHtml(bus.bus_name || 'Bus')}" loading="lazy" />`
                : `<span>🚌</span>`
            }
          </div>

          <div class="bus-info">
            <div class="bus-title-row">
              <h3>${escapeHtml(bus.bus_name || 'Bus')}</h3>
              <span>${escapeHtml(bus.bus_type || 'Bus')}</span>
            </div>

            <p class="route-line">${escapeHtml(from)} → ${escapeHtml(to)}</p>

            <div class="time-grid">
              <div>
                <small>Departure</small>
                <strong>${escapeHtml(bus.departure || 'Time not available')}</strong>
              </div>
              <div>
                <small>Arrival</small>
                <strong>${escapeHtml(bus.arrival || 'Time not available')}</strong>
              </div>
              <div>
                <small>Fare</small>
                <strong>${escapeHtml(bus.fare || '--')}</strong>
              </div>
              <div>
                <small>Match</small>
                <strong>${escapeHtml(bus.matchReason || 'direct')}</strong>
              </div>
            </div>

            <a class="view-btn" href="${url}">View Timetable</a>
          </div>
        </article>
      `;
    };

    const indirectCard = (option, searchFrom, searchTo) => {
      const step1 = option.step1 || {};
      const step2 = option.step2 || {};
      const mid = option.midpoint || option.midpointA || step1.to || step2.from || 'Middle stop';

      return `
        <article class="indirect-card">
          <div class="indirect-head">
            <h3>Via ${escapeHtml(mid)}</h3>
            ${option.waitMin ? `<span>Wait ${escapeHtml(option.waitMin)} min</span>` : ''}
          </div>

          <div class="step-box">
            <b>Step 1</b>
            <p>${escapeHtml(step1.bus_name || 'Bus 1')}</p>
            <small>${escapeHtml(step1.from || searchFrom)} → ${escapeHtml(step1.to || mid)}</small>
            <small>${escapeHtml(step1.departure || 'Time not available')} → ${escapeHtml(step1.arrival || 'Time not available')}</small>
            ${
             step1.bus_id
            ? `<a href="${timetableUrl(step1.from || searchFrom, step1.to || mid, step1.bus_id)}">Step 1 Timetable</a>`
                : ''
            }
          </div>

          <div class="step-box">
            <b>Step 2</b>
            <p>${escapeHtml(step2.bus_name || 'Bus 2')}</p>
            <small>${escapeHtml(step2.from || mid)} → ${escapeHtml(step2.to || searchTo)}</small>
            <small>${escapeHtml(step2.departure || 'Time not available')} → ${escapeHtml(step2.arrival || 'Time not available')}</small>
            ${
          step2.bus_id
                ? `<a href="${timetableUrl(step2.from || mid, step2.to || searchTo, step2.bus_id)}">Step 2 Timetable</a>`
                : ''
            }
          </div>
        </article>
      `;
    };

    async function runSearch(from, to) {
      const source = String(from || '').trim();
      const destination = String(to || '').trim();
      if (!source || !destination) return;

      resetResults();
      setHidden(popularSection, true);
      setStatus('Searching bus routes...', 'loading');

      if (searchBtn) searchBtn.disabled = true;

      const url = new URL(window.location.href);
      url.searchParams.set('from', source);
      url.searchParams.set('to', destination);
      window.history.replaceState({}, '', url);

      try {
        const plan = await findJourney(source, destination);

        const direct = plan.direct || [];
        const indirect = plan.kind === 'indirect' ? plan.indirect || [] : [];
        const alternativeIndirect = plan.alternativeIndirect || [];
        const allIndirect = [...indirect, ...alternativeIndirect].slice(0, 4);

        setHidden(statusBox, true);

        if (direct.length && directResults) {
          setHidden(directSection, false);
          if (directSubtitle) directSubtitle.textContent = `${plan.source} to ${plan.destination}`;
          directResults.innerHTML = direct.map((bus) => busCard(bus, source, destination)).join('');
        }

        if (allIndirect.length && indirectResults) {
          setHidden(indirectSection, false);
          indirectResults.innerHTML = allIndirect.map((option) => indirectCard(option, source, destination)).join('');
        }

        if (!direct.length && !allIndirect.length) {
          setHidden(rentSection, false);
        }
      } catch (error) {
        console.error(error);
        setStatus('Search failed. Please try again.', 'error');
      } finally {
        if (searchBtn) searchBtn.disabled = false;
      }
    }

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      runSearch(fromInput?.value, toInput?.value);
    });

    const params = new URLSearchParams(window.location.search);
    const initialFrom = params.get('from');
    const initialTo = params.get('to');

    if (initialFrom && fromInput) fromInput.value = initialFrom;
    if (initialTo && toInput) toInput.value = initialTo;

    if (initialFrom && initialTo) {
      runSearch(initialFrom, initialTo);
    }
  </script>

  <style>
    .bus-search-page {
      background: linear-gradient(180deg, #f8fbff 0%, #eef7ff 45%, #ffffff 100%);
      min-height: 100vh;
      padding: 1rem 0 2.5rem;
    }

    .bus-search-hero {
      background: white;
      border: 1px solid #dbeafe;
      border-radius: 1.25rem;
      padding: 1.35rem;
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
      margin-bottom: 1rem;
    }

    .eyebrow {
      margin: 0 0 0.4rem;
      font-size: 0.8rem;
      font-weight: 800;
      color: #2563eb;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .bus-search-hero h1 {
      margin: 0 0 0.5rem;
      color: #0f172a;
      font-size: clamp(1.6rem, 4vw, 2.4rem);
      line-height: 1.1;
    }

    .bus-search-hero p {
      margin: 0.35rem 0 0;
      color: #475569;
      line-height: 1.55;
    }

    .bn-line {
      color: #0369a1 !important;
      font-weight: 650;
    }

    .search-card,
    .result-section,
    .rent-help,
    .popular-routes {
      background: white;
      border: 1px solid #dbeafe;
      border-radius: 1rem;
      padding: 1rem;
      box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
      margin-top: 1rem;
    }

    .search-grid {
      display: grid;
      grid-template-columns: 1fr 1fr auto;
      gap: 0.75rem;
      align-items: end;
    }

    .search-grid label {
      display: grid;
      gap: 0.35rem;
      color: #0f172a;
      font-weight: 700;
      font-size: 0.9rem;
    }

    .search-grid input {
      width: 100%;
      border: 1px solid #bfdbfe;
      border-radius: 0.75rem;
      padding: 0.8rem 0.9rem;
      font: inherit;
      color: #0f172a;
      background: #f8fbff;
    }

    .search-grid input:focus {
      outline: none;
      border-color: #38bdf8;
      box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.18);
      background: white;
    }

    #search-btn,
    .view-btn,
    .rent-btn,
    .step-box a {
      border: none;
      border-radius: 0.75rem;
      background: linear-gradient(135deg, #ff6b00, #ff8a00);
      color: white;
      font-weight: 800;
      text-decoration: none;
      padding: 0.82rem 1.15rem;
      cursor: pointer;
      display: inline-flex;
      justify-content: center;
      align-items: center;
      min-height: 44px;
    }

    #search-btn:disabled {
      opacity: 0.65;
      cursor: wait;
    }

    .hidden {
      display: none !important;
    }

    .status-box {
      margin-top: 1rem;
      padding: 1rem;
      border-radius: 1rem;
      background: #eff6ff;
      border: 1px solid #bfdbfe;
      color: #1e40af;
      font-weight: 700;
    }

    .status-box.error {
      background: #fff1f2;
      border-color: #fecdd3;
      color: #be123c;
    }

    .section-head h2,
    .popular-routes h2,
    .rent-help h2 {
      margin: 0 0 0.35rem;
      color: #0f172a;
      font-size: 1.25rem;
    }

    .section-head p,
    .rent-help p {
      margin: 0 0 1rem;
      color: #64748b;
    }

    .result-list {
      display: grid;
      gap: 0.85rem;
    }

    .bus-card,
    .indirect-card {
      display: grid;
      grid-template-columns: 88px 1fr;
      gap: 0.85rem;
      border: 1px solid #e2e8f0;
      border-radius: 1rem;
      padding: 0.85rem;
      background: #ffffff;
    }

    .bus-photo {
      width: 88px;
      height: 88px;
      border-radius: 0.9rem;
      background: #e0f2fe;
      display: grid;
      place-items: center;
      overflow: hidden;
      font-size: 2rem;
    }

    .bus-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .bus-title-row {
      display: flex;
      gap: 0.5rem;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
    }

    .bus-title-row h3 {
      margin: 0;
      color: #0f172a;
      font-size: 1rem;
    }

    .bus-title-row span,
    .indirect-head span {
      background: #e0f2fe;
      color: #0369a1;
      border: 1px solid #bae6fd;
      border-radius: 999px;
      padding: 0.25rem 0.55rem;
      font-size: 0.75rem;
      font-weight: 800;
    }

    .route-line {
      margin: 0.35rem 0 0.65rem;
      color: #475569;
      font-weight: 650;
    }

    .time-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0.45rem;
      margin-bottom: 0.75rem;
    }

    .time-grid div {
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 0.7rem;
      padding: 0.5rem;
    }

    .time-grid small,
    .step-box small {
      display: block;
      color: #64748b;
      font-size: 0.72rem;
      margin-bottom: 0.15rem;
    }

    .time-grid strong {
      color: #0f172a;
      font-size: 0.85rem;
    }

    .indirect-card {
      grid-template-columns: 1fr;
    }

    .indirect-head {
      display: flex;
      justify-content: space-between;
      gap: 0.75rem;
      align-items: center;
      flex-wrap: wrap;
    }

    .indirect-head h3 {
      margin: 0;
      color: #0f172a;
    }

    .step-box {
      border: 1px solid #e2e8f0;
      border-radius: 0.85rem;
      padding: 0.75rem;
      background: #f8fbff;
      display: grid;
      gap: 0.25rem;
      margin-top: 0.6rem;
    }

    .step-box p {
      margin: 0;
      font-weight: 800;
      color: #0f172a;
    }

    .step-box a {
      margin-top: 0.4rem;
      width: fit-content;
      padding: 0.55rem 0.8rem;
      min-height: auto;
      font-size: 0.8rem;
    }

    .popular-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
    }

    .popular-grid a {
      border: 1px solid #bfdbfe;
      border-radius: 999px;
      padding: 0.55rem 0.8rem;
      color: #0f172a;
      background: #eff6ff;
      text-decoration: none;
      font-weight: 750;
      font-size: 0.9rem;
    }

    @media (max-width: 760px) {
      .search-grid {
        grid-template-columns: 1fr;
      }

      #search-btn {
        width: 100%;
      }

      .bus-card {
        grid-template-columns: 76px 1fr;
      }

      .bus-photo {
        width: 76px;
        height: 76px;
      }

      .time-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }
  </style>
</BaseLayout>