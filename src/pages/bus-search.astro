---

<BaseLayout title="Bus Search" description="Search bus timetables in West Bengal. Find departure and arrival times for local bus routes across the state.">
	<div class="debug-label">PAGE: BUS SEARCH</div>
	<section class="hero">
		<div class="container">
			<h1>Bus Search Results</h1>
			<p>
				<span class="lang-en">Find bus schedules and timings across West Bengal</span>
				<span class="lang-bn">পশ্চিমবঙ্গ জুড়ে বাসের সময়সূচী খুঁজুন</span>
			</p>
		</div>
	</section>

	<section>
		<div class="container">
			<div class="search-card">
				<h3>
					<span class="lang-en">Search Bus</span>
					<span class="lang-bn">বাস খুঁজুন</span>
				</h3>
				<form id="bus-search-form" action="/bus-search" method="get">
					<div class="form-row">
						<div class="form-group">
							<label for="bus-from">
								<span class="lang-en">From</span>
								<span class="lang-bn">কোথা থেকে</span>
							</label>
							<input type="text" id="bus-from" name="from" list="stop-suggestions" placeholder="Enter departure city" value={from || ''} required />
							<datalist id="stop-suggestions">
								{demoStops.map(stop => (
									<option value={stop.en}>{stop.en} / {stop.bn}</option>
								))}
							</datalist>
						</div>
						<div class="form-group">
							<label for="bus-to">
								<span class="lang-en">To</span>
								<span class="lang-bn">কোথায় যাবেন</span>
							</label>
							<input type="text" id="bus-to" name="to" list="stop-suggestions" placeholder="Enter destination city" value={to || ''} required />
						</div>
					</div>
					<button type="submit" class="btn btn-full">
						<span class="lang-en">Search Bus</span>
						<span class="lang-bn">বাস খুঁজুন</span>
					</button>
				</form>
			</div>

			<div id="bus-results-section" class="hidden">
				<div class="section-title mt-3">
					<p class="search-info">
						<span class="lang-en">Showing buses for <span id="search-from"></span> to <span id="search-to"></span></span>
						<span class="lang-bn"><span id="search-from-bn"></span> থেকে <span id="search-to-bn"></span> এর জন্য বাস দেখানো হচ্ছে</span>
					</p>
					<h2>
						<span class="lang-en">Available Buses</span>
						<span class="lang-bn">উপলব্ধ বাস</span>
					</h2>
				</div>
				<div class="bus-results" id="dynamic-bus-results">
					<!-- Dynamic results from route-finder will be inserted here -->
				</div>
				<div class="bus-results" id="demo-bus-results">
					<p class="demo-note" style="display: none; color: #64748b; font-size: 0.875rem; margin-bottom: 1rem;">
						Demo result shown because live route data is unavailable.
					</p>
					{routeData.buses.map((bus: any, index: number) => (
						<div class="bus-result-card">
							<div class="bus-photo">
								<span class="bus-photo-emoji">🚌</span>
							</div>
							<div class="bus-info">
								<div class="bus-header">
									<h4>{bus.name}</h4>
									<span class="direction-badge" id={`bus-direction-${index}`}>Up</span>
								</div>
								<p class="bus-reg">{bus.reg_number}</p>
								<p class="bus-route-full">
									<span class="lang-en">Full Route:</span>
									<span class="lang-bn">সম্পূর্ণ রুট:</span>
									{routeData.source_name_en} → {routeData.destination_name_en}
								</p>
								<p class="bus-route-segment">
									<span class="lang-en">Your Search:</span>
									<span class="lang-bn">আপনার অনুসন্ধান:</span>
									<span id="search-segment-from"></span> → <span id="search-segment-to"></span>
								</p>
								<div class="bus-timing-row">
									<div class="timing-item">
										<span class="timing-label">Departure</span>
										<span class="timing-value" id={`bus-departure-${index}`}>{bus.departure}</span>
									</div>
									<div class="timing-item">
										<span class="timing-label">Arrival</span>
										<span class="timing-value" id={`bus-arrival-${index}`}>{bus.arrival}</span>
									</div>
									<div class="timing-item">
										<span class="timing-label">Fare</span>
										<span class="timing-value">{bus.fare}</span>
									</div>
									<div class="timing-item">
										<span class="timing-label">Duration</span>
										<span class="timing-value">{bus.duration}</span>
									</div>
								</div>
								<a href={`/bus-timetable/${routeData.slug}/?bus=${bus.slug}&from=${from}&to=${to}`} class="btn btn-full">
									<span class="lang-en">View Timetable</span>
									<span class="lang-bn">টাইমটেবিল দেখুন</span>
								</a>
							</div>
						</div>
					))}
				</div>
			</div>

			<div id="indirect-routes-section" class="hidden">
				<div class="section-title mt-3">
					<h2>
						<span class="lang-en">Suggested Indirect Routes</span>
						<span class="lang-bn">পরোক্ষ রুটের পরামর্শ</span>
					</h2>
				</div>
				<div class="bus-results" id="indirect-routes-results">
					<!-- Indirect routes will be inserted here -->
				</div>
			</div>

			<div id="no-bus-section" class="hidden">
				<div class="section-title mt-3">
					<p class="search-info">
						<span class="lang-en">Showing buses for <span id="search-from-no"></span> to <span id="search-to-no"></span></span>
						<span class="lang-bn"><span id="search-from-no-bn"></span> থেকে <span id="search-to-no-bn"></span> এর জন্য বাস দেখানো হচ্ছে</span>
					</p>
					<h2>
						<span class="lang-en">Available Buses</span>
						<span class="lang-bn">উপলব্ধ বাস</span>
					</h2>
				</div>
				<div class="card">
					<p>
						<span class="lang-en">No direct bus found. Try reverse direction or another stop.</span>
						<span class="lang-bn">কোনো সরাসরি বাস পাওয়া যায়নি। বিপরীত দিক বা অন্য স্টপ চেষ্টা করুন।</span>
					</p>
				</div>
			</div>

			<div id="popular-routes-section">
				<div class="section-title mt-3">
					<h2>
						<span class="lang-en">Popular Bus Routes</span>
						<span class="lang-bn">জনপ্রিয় বাস রুট</span>
					</h2>
				</div>
				<div class="grid grid-3">
					<a href="/bus-search?from=Kolkata&to=Siliguri" class="popular-item">
						<h4>
							<span class="lang-en">Kolkata to Siliguri</span>
							<span class="lang-bn">কলকাতা থেকে শিলিগুড়ি</span>
						</h4>
						<p>
							<span class="lang-en">Daily bus service available</span>
							<span class="lang-bn">প্রতিদিন বাস সার্ভিস আছে</span>
						</p>
					</a>
					<a href="/bus-search?from=Kolkata&to=Durgapur" class="popular-item">
						<h4>
							<span class="lang-en">Kolkata to Durgapur</span>
							<span class="lang-bn">কলকাতা থেকে দুর্গাপুর</span>
						</h4>
						<p>
							<span class="lang-en">Frequent bus service</span>
							<span class="lang-bn">ঘন ঘন বাস সার্ভিস</span>
						</p>
					</a>
					<a href="/bus-search?from=Siliguri&to=Darjeeling" class="popular-item">
						<h4>
							<span class="lang-en">Siliguri to Darjeeling</span>
							<span class="lang-bn">শিলিগুড়ি থেকে দার্জিলিং</span>
						</h4>
						<p>
							<span class="lang-en">Hill route bus service</span>
							<span class="lang-bn">পাহাড়ি রুট বাস সার্ভিস</span>
						</p>
					</a>
					<a href="/bus-search?from=Kolkata&to=Asansol" class="popular-item">
						<h4>
							<span class="lang-en">Kolkata to Asansol</span>
							<span class="lang-bn">কলকাতা থেকে আসানসোল</span>
						</h4>
						<p>
							<span class="lang-en">Regular bus service</span>
							<span class="lang-bn">নিয়মিত বাস সার্ভিস</span>
						</p>
					</a>
					<a href="/bus-search?from=Durgapur&to=Asansol" class="popular-item">
						<h4>
							<span class="lang-en">Durgapur to Asansol</span>
							<span class="lang-bn">দুর্গাপুর থেকে আসানসোল</span>
						</h4>
						<p>
							<span class="lang-en">Short distance service</span>
							<span class="lang-bn">ছোট দূরত্বের সার্ভিস</span>
						</p>
					</a>
					<a href="/bus-search?from=Kolkata&to=Burdwan" class="popular-item">
						<h4>
							<span class="lang-en">Kolkata to Burdwan</span>
							<span class="lang-bn">কলকাতা থেকে বর্ধমান</span>
						</h4>
						<p>
							<span class="lang-en">Frequent connections</span>
							<span class="lang-bn">ঘন ঘন সংযোগ</span>
						</p>
					</a>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<script>
	import { findRoutes } from '../lib/routeFinder';

	const busFromInput = document.getElementById('bus-from') as HTMLInputElement;
	const busToInput = document.getElementById('bus-to') as HTMLInputElement;
	const busSearchForm = document.getElementById('bus-search-form');
	const busResultsSection = document.getElementById('bus-results-section');
	const noBusSection = document.getElementById('no-bus-section');
	const popularRoutesSection = document.getElementById('popular-routes-section');
	const dynamicBusResults = document.getElementById('dynamic-bus-results');
	const demoBusResults = document.getElementById('demo-bus-results');
	const demoNote = document.querySelector('.demo-note');
	const indirectRoutesSection = document.getElementById('indirect-routes-section');
	const indirectRoutesResults = document.getElementById('indirect-routes-results');

	// Function to perform search
	async function performSearch(from: string, to: string) {
		if (!from || !to) return;

		// Update URL
		const url = new URL(window.location.href);
		url.searchParams.set('from', from);
		url.searchParams.set('to', to);
		window.history.replaceState({}, '', url.toString());

		// Hide popular routes
		if (popularRoutesSection) {
			popularRoutesSection.classList.add('hidden');
		}

		// Show results section
		if (busResultsSection) {
			busResultsSection.classList.remove('hidden');
		}
		if (noBusSection) {
			noBusSection.classList.add('hidden');
		}

		// Update search display
		const searchFrom = document.getElementById('search-from');
		const searchTo = document.getElementById('search-to');
		const searchFromBn = document.getElementById('search-from-bn');
		const searchToBn = document.getElementById('search-to-bn');
		const searchSegmentFrom = document.getElementById('search-segment-from');
		const searchSegmentTo = document.getElementById('search-segment-to');

		if (searchFrom) searchFrom.textContent = from;
		if (searchTo) searchTo.textContent = to;
		if (searchFromBn) searchFromBn.textContent = from;
		if (searchToBn) searchToBn.textContent = to;
		if (searchSegmentFrom) searchSegmentFrom.textContent = from;
		if (searchSegmentTo) searchSegmentTo.textContent = to;

		// Hide demo results initially
		if (demoBusResults) demoBusResults.style.display = 'none';
		if (demoNote) demoNote.style.display = 'none';
		if (indirectRoutesSection) indirectRoutesSection.classList.add('hidden');

		// Show loading
		if (dynamicBusResults) {
			dynamicBusResults.innerHTML = '<p style="text-align: center; padding: 2rem; color: #64748b;">Loading...</p>';
		}

		try {
			const result = await findRoutes(from, to);

			// Handle different response kinds
			if (result.kind === 'direct' && result.data?.options?.length > 0) {
				// Show direct bus cards
				if (dynamicBusResults) {
					dynamicBusResults.innerHTML = `
						<h3 style="margin-bottom: 1rem;">Direct buses found</h3>
						${result.data.options.map((bus: any) => `
						<div class="bus-result-card">
							<div class="bus-photo">
								${bus.image_url ? `<img src="${bus.image_url}" alt="${bus.bus_name}" />` : '<span class="bus-photo-emoji">🚌</span>'}
							</div>
							<div class="bus-info">
								<div class="bus-header">
									<h4>${bus.bus_name || 'Bus'}</h4>
									<span class="direction-badge">${bus.bus_type || 'Bus'}</span>
								</div>
								<p class="bus-reg">${bus.reg_number || ''}</p>
								<p class="bus-route-full">
									Full Route: ${bus.full_route || bus.from + ' → ' + bus.to}
								</p>
								<p class="bus-route-segment">
									Your Search: ${bus.from || from} → ${bus.to || to}
								</p>
								<div class="bus-timing-row">
									<div class="timing-item">
										<span class="timing-label">Departure</span>
										<span class="timing-value">${bus.departure || 'Time not available'}</span>
									</div>
									<div class="timing-item">
										<span class="timing-label">Arrival</span>
										<span class="timing-value">${bus.arrival || 'Time not available'}</span>
									</div>
									<div class="timing-item">
										<span class="timing-label">Fare</span>
										<span class="timing-value">${bus.fare || '--'}</span>
									</div>
									<div class="timing-item">
										<span class="timing-label">Duration</span>
										<span class="timing-value">${bus.duration || '--'}</span>
									</div>
								</div>
								${bus.bus_id ? `<a href="/bus-timetable/result/?bus_id=${encodeURIComponent(bus.bus_id)}&bus_name=${encodeURIComponent(bus.bus_name || 'Bus')}&from=${encodeURIComponent(bus.from || from)}&to=${encodeURIComponent(bus.to || to)}" class="btn btn-full">
									View Timetable
								</a>` : ''}
							</div>
						</div>
					`).join('')}
					`;
				}
			} else if (result.kind === 'indirect' && result.data && result.data.options) {
				// Show no direct bus found block with rent car button
				if (dynamicBusResults) {
					dynamicBusResults.innerHTML = `
						<div class="card" style="text-align: center; padding: 2rem; margin-bottom: 2rem;">
							<h3 style="color: #f97316; margin-bottom: 0.5rem;">No direct bus found</h3>
							<p style="color: #64748b; margin-bottom: 1.5rem;">Direct bus is not available for this route right now. You can try alternative indirect bus routes below.</p>
							<a href="/rent-vehicle" class="btn" style="background: #f97316; color: white; text-decoration: none; padding: 0.75rem 1.5rem; border-radius: 0.375rem; display: inline-block; margin-bottom: 0.5rem;">
								Find Rent Car / Cab
							</a>
							<p style="font-size: 0.875rem; color: #64748b;">Need faster travel? Book a car with driver.</p>
						</div>
						<h3 style="margin-bottom: 1rem;">Alternative indirect bus routes</h3>
					`;
				}

				// Show max 2 indirect cards
				const indirectOptions = result.data.options.slice(0, 2);
				if (indirectRoutesSection) {
					indirectRoutesSection.classList.remove('hidden');
				}
				if (indirectRoutesResults) {
					indirectRoutesResults.innerHTML = indirectOptions.map((option: any) => `
						<div class="bus-result-card">
							<div class="bus-info">
								<h4>Via ${option.midpoint || 'Midpoint'}</h4>
								<p class="bus-route-segment">
									Step 1: ${option.step1?.bus_name || 'Bus 1'} (${option.step1?.from || from} → ${option.step1?.to || option.midpoint})
								</p>
								<p class="bus-route-segment">
									${option.step1?.departure || 'Time not available'} → ${option.step1?.arrival || 'Time not available'}
								</p>
								<p class="bus-route-segment">
									Step 2: ${option.step2?.bus_name || 'Bus 2'} (${option.step2?.from || option.midpoint} → ${option.step2?.to || to})
								</p>
								<p class="bus-route-segment">
									${option.step2?.departure || 'Time not available'} → ${option.step2?.arrival || 'Time not available'}
								</p>
								${option.waitMin ? `<p class="bus-reg">Wait: ${option.waitMin} min</p>` : ''}
								<div style="margin-top: 1rem; display: flex; gap: 0.5rem; flex-wrap: wrap;">
									${option.step1?.bus_id ? `<a href="/bus-timetable/result/?bus_id=${encodeURIComponent(option.step1.bus_id)}&bus_name=${encodeURIComponent(option.step1.bus_name || 'Bus 1')}&from=${encodeURIComponent(option.step1.from || from)}&to=${encodeURIComponent(option.step1.to || option.midpoint)}" class="btn" style="font-size: 0.875rem; padding: 0.5rem 1rem;">
										Step 1 Timetable
									</a>` : ''}
									${option.step2?.bus_id ? `<a href="/bus-timetable/result/?bus_id=${encodeURIComponent(option.step2.bus_id)}&bus_name=${encodeURIComponent(option.step2.bus_name || 'Bus 2')}&from=${encodeURIComponent(option.step2.from || option.midpoint)}&to=${encodeURIComponent(option.step2.to || to)}" class="btn" style="font-size: 0.875rem; padding: 0.5rem 1rem;">
										Step 2 Timetable
									</a>` : ''}
								</div>
							</div>
						</div>
					`).join('');
				}
			} else if (result.kind === 'none') {
				// Show no bus route found with rent car button
				if (dynamicBusResults) {
					dynamicBusResults.innerHTML = `
						<div class="card" style="text-align: center; padding: 2rem;">
							<h3 style="color: #f97316; margin-bottom: 0.5rem;">No bus route found</h3>
							<p style="color: #64748b; margin-bottom: 1.5rem;">We could not find a bus route for this search right now.</p>
							<a href="/rent-vehicle" class="btn" style="background: #f97316; color: white; text-decoration: none; padding: 0.75rem 1.5rem; border-radius: 0.375rem; display: inline-block; margin-bottom: 0.5rem;">
								Find Rent Car / Cab
							</a>
							<p style="font-size: 0.875rem; color: #64748b;">Need faster travel? Book a car with driver.</p>
						</div>
					`;
				}
			} else {
				// Show demo results as fallback
				if (demoBusResults) demoBusResults.style.display = 'flex';
				if (demoNote) demoNote.style.display = 'block';
			}
		} catch (error) {
			console.error('Error calling route-finder:', error);
			// Show demo results as fallback
			if (demoBusResults) demoBusResults.style.display = 'flex';
			if (demoNote) demoNote.style.display = 'block';
		}
	}

	// Form submit handler
	if (busSearchForm) {
		busSearchForm.addEventListener('submit', (e) => {
			e.preventDefault();
			if (busFromInput && busToInput) {
				const from = busFromInput.value.trim();
				const to = busToInput.value.trim();
				if (from && to) {
					performSearch(from, to);
				}
			}
		});
	}

	// Read query params on page load and auto-search if they exist
	const params = new URLSearchParams(window.location.search);
	const fromParam = params.get('from');
	const toParam = params.get('to');

	if (busFromInput && fromParam) {
		busFromInput.value = fromParam;
	}
	if (busToInput && toParam) {
		busToInput.value = toParam;
	}

	if (fromParam && toParam) {
	window.setTimeout(() => {
		performSearch(fromParam, toParam);
	}, 100);
}
</script>
