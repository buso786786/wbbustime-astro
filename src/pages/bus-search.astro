---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildBusStopSuggestions } from '../lib/busSeoLinks';

const from = Astro.url.searchParams.get('from') || '';
const to = Astro.url.searchParams.get('to') || '';

const stopSuggestions = await buildBusStopSuggestions();
---

<BaseLayout
  title="Bus Search"
  description="Search West Bengal bus timetable, direct buses, indirect bus routes, middle stop connections and route finder results."
>
  <section class="bus-search-page">
    <div class="container">
      <div class="bus-search-hero">
        <p class="eyebrow">🚌 Bus Route Finder</p>

        <h1
          data-en="Search Bus Timetable in West Bengal"
          data-bn="পশ্চিমবঙ্গে বাস টাইমটেবিল খুঁজুন"
        >
          Search Bus Timetable in West Bengal
        </h1>

        <p
          data-en="Search direct buses first. If no direct bus is found, SoniaBuddy suggests indirect bus routes with middle-stop connections."
          data-bn="আগে সরাসরি বাস খুঁজুন। সরাসরি বাস না পেলে SoniaBuddy মাঝের স্টপ দিয়ে সংযোগ রুট দেখাবে।"
        >
          Search direct buses first. If no direct bus is found, SoniaBuddy suggests indirect bus routes with middle-stop connections.
        </p>

        <p class="bn-line">বাংলা বা English stop name লিখে bus route খুঁজুন।</p>
      </div>

      <div class="search-card">
        <form id="bus-search-form">
          <div class="search-grid">
            <label class="field-wrap">
              <span data-en="From" data-bn="কোথা থেকে">From</span>
              <input
                id="bus-from"
                name="from"
                type="text"
                placeholder="Arambagh / আরামবাগ"
                data-placeholder-en="Arambagh"
                data-placeholder-bn="আরামবাগ"
                value={from}
                autocomplete="off"
                required
              />
              <div class="suggest-box" id="from-suggestions" hidden></div>
            </label>

            <label class="field-wrap">
              <span data-en="To" data-bn="কোথায়">To</span>
              <input
                id="bus-to"
                name="to"
                type="text"
                placeholder="Digha / দীঘা"
                data-placeholder-en="Digha"
                data-placeholder-bn="দীঘা"
                value={to}
                autocomplete="off"
                required
              />
              <div class="suggest-box" id="to-suggestions" hidden></div>
            </label>

            <button type="submit" id="search-btn" data-en="Search" data-bn="খুঁজুন">
              Search
            </button>
          </div>
        </form>
      </div>
       <div class="rent-promo-strip">
  <span
    data-en="Need a car for tour, wedding, local trip, school-office or emergency? Check rent vehicles available near your city."
    data-bn="ট্যুর, বিয়ে, লোকাল ট্রিপ, স্কুল-অফিস বা জরুরি কাজে গাড়ি লাগবে? আপনার শহরের কাছে ভাড়া গাড়ি দেখুন।"
  >
    Need a car for tour, wedding, local trip, school-office or emergency? Check rent vehicles available near your city.
  </span>

  <a
    href="/rent-vehicle?tab=find"
    data-en="Find Rent Vehicle"
    data-bn="ভাড়া গাড়ি খুঁজুন"
  >
    Find Rent Vehicle
  </a>
</div>
      <div id="disclaimer-modal" class="sb-modal hidden" aria-hidden="true">
        <div class="sb-modal-backdrop" data-close-disclaimer></div>

        <div class="sb-modal-panel" role="dialog" aria-modal="true" aria-labelledby="disclaimer-title">
          <div class="sb-modal-head">
            <span class="sb-alert-icon">⚠️</span>
            <h2 id="disclaimer-title">Important Disclaimer</h2>
            <button type="button" class="sb-modal-close" data-close-disclaimer>×</button>
          </div>

          <div class="sb-modal-body">
            <p>Bus timing, route, stop, fare and availability may change without notice.</p>
            <p>Please verify the latest timing from the bus operator, counter or local source before travelling.</p>
            <p>Indirect route suggestions are guidance only. Transfer timing may vary due to traffic, delay, weather or route change.</p>
            <p>বাসের সময়, রুট ও উপলব্ধতা পরিবর্তন হতে পারে। যাত্রার আগে কাউন্টার বা বাস অপারেটরের কাছ থেকে নিশ্চিত হয়ে নিন।</p>
          </div>

          <div class="sb-modal-foot">
            <button type="button" data-close-disclaimer>Close</button>
          </div>
        </div>
      </div>
      <div id="photo-zoom-modal" class="photo-zoom-modal hidden" aria-hidden="true">
        <div class="photo-zoom-backdrop" data-close-photo-zoom></div>

        <div class="photo-zoom-panel">
          <button type="button" class="photo-zoom-close" data-close-photo-zoom>×</button>
          <img id="photo-zoom-img" alt="Bus photo" />
        </div>
      </div>

      <div id="status-box" class="status-box hidden"></div>

      <section id="rent-section" class="rent-help hidden">
        <h2 data-en="No bus route found" data-bn="কোনো বাস রুট পাওয়া যায়নি">
          No bus route found
        </h2>
        <p>
          We could not find direct or indirect bus routes for this search. You can try another spelling,
          reverse direction, or find a car with driver.
        </p>
        <a
          href="/rent-vehicle?tab=find"
          class="rent-btn"
          data-en="Find Rent Car / Cab"
          data-bn="ভাড়া গাড়ি / ক্যাব খুঁজুন"
        >
          Find Rent Car / Cab
        </a>
      </section>

      <section id="direct-section" class="result-section hidden">
        <div class="section-head">
          <h2 data-en="Direct buses found" data-bn="সরাসরি বাস পাওয়া গেছে">
            Direct buses found
          </h2>
          <p id="direct-subtitle"></p>
        </div>
        <div id="direct-results" class="result-list"></div>
      </section>

      <section id="indirect-section" class="result-section hidden">
        <div class="section-head">
          <h2 data-en="Suggested indirect routes" data-bn="প্রস্তাবিত সংযোগ রুট">
            Suggested indirect routes
          </h2>
          <p
            id="indirect-subtitle"
            class="indirect-note"
            data-en="Indirect bus suggestions are shown below. Use these when direct timing does not match or middle-stop travel is better."
            data-bn="নিচে সংযোগ রুটের সাজেশন দেখানো হয়েছে। সরাসরি বাসের সময় না মিললে বা মাঝের স্টপ দিয়ে যাত্রা ভালো হলে এগুলো ব্যবহার করুন।"
          >
            Indirect bus suggestions are shown below. Use these when direct timing does not match or middle-stop travel is better.
          </p>
        </div>
        <div id="indirect-results" class="result-list"></div>
      </section>

      <section id="popular-section" class="popular-routes">
        <h2 data-en="Popular searches" data-bn="জনপ্রিয় সার্চ">Popular searches</h2>
        <div class="popular-grid">
          <a href="/bus-search?from=Arambagh&to=Tarakeswar">Arambagh to Tarakeswar</a>
          <a href="/bus-search?from=Arambagh&to=Digha">Arambagh to Digha</a>
          <a href="/bus-search?from=Ghatal&to=Digha">Ghatal to Digha</a>
          <a href="/bus-search?from=Digha&to=Arambagh">Digha to Arambagh</a>
        </div>
      </section>
    </div>
  </section>

  <script define:vars={{ stopSuggestions }}>
    window.__STOP_SUGGESTIONS__ = stopSuggestions;
  </script>

  <script>
    import { findJourney } from '../lib/routeFinder';

    const form = document.getElementById('bus-search-form');
    const fromInput = document.getElementById('bus-from');
    const toInput = document.getElementById('bus-to');
    const searchBtn = document.getElementById('search-btn');

    const fromSuggestBox = document.getElementById('from-suggestions');
    const toSuggestBox = document.getElementById('to-suggestions');
    const stopSuggestions = window.__STOP_SUGGESTIONS__ || [];

    const statusBox = document.getElementById('status-box');
    const directSection = document.getElementById('direct-section');
    const indirectSection = document.getElementById('indirect-section');
    const rentSection = document.getElementById('rent-section');
    const popularSection = document.getElementById('popular-section');
    const directSubtitle = document.getElementById('direct-subtitle');
    const indirectSubtitle = document.getElementById('indirect-subtitle');
    const directResults = document.getElementById('direct-results');
    const indirectResults = document.getElementById('indirect-results');

    let lastSearchSource = '';
    let lastSearchDestination = '';
    const escapeHtml = (value) =>
      String(value || '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');
    const getLang = () => {
      try {
        return (
          document.body.getAttribute('data-lang') ||
          localStorage.getItem('soniabuddy_lang') ||
          localStorage.getItem('soniabuddy_rent_lang_v1') ||
          'en'
        );
      } catch {
        return document.body.getAttribute('data-lang') || 'en';
      }
    };

    const t = (en, bn) => (getLang() === 'bn' ? bn : en);

    const SEARCH_HISTORY_KEY = 'soniabuddy_bus_search_history_v1';

    const readSearchHistory = () => {
      try {
        const saved = JSON.parse(localStorage.getItem(SEARCH_HISTORY_KEY) || '[]');
        return Array.isArray(saved) ? saved.slice(0, 8) : [];
      } catch {
        return [];
      }
    };

    const saveSearchPair = (source, destination) => {
      const from = String(source || '').trim();
      const to = String(destination || '').trim();
      if (!from || !to) return;

      try {
        const old = readSearchHistory();
        const next = [
          { from, to, label: `${from} → ${to}` },
          ...old.filter((item) => !(item.from === from && item.to === to)),
        ].slice(0, 8);

        localStorage.setItem(SEARCH_HISTORY_KEY, JSON.stringify(next));
      } catch {
        // ignore
      }
    };
    const slugify = (value) =>
      String(value || '')
        .normalize('NFKD')
        .toLowerCase()
        .trim()
        .replace(/[^\p{Letter}\p{Number}]+/gu, '-')
        .replace(/^-+|-+$/g, '');

    const normalizeSearch = (value) =>
      String(value || '')
        .normalize('NFKC')
        .toLowerCase()
        .replace(/[\u200B-\u200D\uFEFF]/g, '')
        .replace(/[.,/\\&_+|:;'"!?\-]/g, ' ')
        .replace(/\bbus\s*stand\b/g, ' ')
        .replace(/\bbus\s*stop\b/g, ' ')
        .replace(/\bbus\s*station\b/g, ' ')
        .replace(/\bstand\b/g, ' ')
        .replace(/বাস\s*স্ট্যান্ড/g, ' ')
        .replace(/বাসস্ট্যান্ড/g, ' ')
        .replace(/বাস\s*স্টপ/g, ' ')
        .replace(/বাসস্টপ/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();

    const extractBengaliText = (value) => {
      const text = String(value || '');
      const parenMatch = text.match(/\(([^)]*[\u0980-\u09FF][^)]*)\)/);
      if (parenMatch) return parenMatch[1].trim();

      const bnMatch = text.match(/[\u0980-\u09FF][\u0980-\u09FF\s\u09E6-\u09EF.,-]*/);
      return bnMatch ? bnMatch[0].trim() : '';
    };

    const displayStopName = (value) => {
      const raw = String(value || '').trim();
      if (!raw || getLang() !== 'bn') return raw;

      const key = normalizeSearch(raw);
      const found = stopSuggestions.find((item) => {
        const itemValue = normalizeSearch(item.value || '');
        const itemLabel = normalizeSearch(item.label || '');
        const itemSearch = normalizeSearch(item.search || '');
        return itemValue === key || itemLabel === key || itemSearch.includes(key) || key.includes(itemValue);
      });

      return extractBengaliText(found?.label) || extractBengaliText(found?.search) || extractBengaliText(found?.value) || raw;
    };

    const renderStop = (value) => escapeHtml(displayStopName(value));
    const isSameStopName = (a, b) => {
  const x = normalizeSearch(a);
  const y = normalizeSearch(b);
  return Boolean(x && y && (x === y || x.includes(y) || y.includes(x)));
};

const renderStopMarked = (value, searchFrom, searchTo) => {
  const isSearchStop = isSameStopName(value, searchFrom) || isSameStopName(value, searchTo);
  const className = isSearchStop ? 'searched-stop-name' : '';

  return `<span class="${className}">${renderStop(value)}</span>`;
};

    const getSuggestionScore = (item, query) => {
      const value = String(item.value || '').trim();
      const label = String(item.label || value).trim();
      const search = String(item.search || `${value} ${label}`).trim();

      const valueText = normalizeSearch(value);
      const labelText = normalizeSearch(label);
      const searchText = normalizeSearch(search);

      let score = 0;

      if (valueText === query) score += 1000;
      if (labelText === query) score += 950;

      if (valueText.startsWith(query)) score += 850;
      if (labelText.startsWith(query)) score += 820;

      if (valueText.split(' ').some((part) => part.startsWith(query))) score += 720;
      if (labelText.split(' ').some((part) => part.startsWith(query))) score += 700;
      if (searchText.split(' ').some((part) => part.startsWith(query))) score += 650;

      if (searchText.includes(query)) score += 260;
      if (valueText.includes(query)) score += 240;
      if (labelText.includes(query)) score += 220;

      return score;
    };

    const showSuggestList = (input, box) => {
  if (!input || !box) return;

  const rawQuery = String(input.value || '').trim();
  const query = normalizeSearch(rawQuery);
  const history = readSearchHistory();

  if (!query) {
    if (!history.length) {
      box.hidden = true;
      box.innerHTML = '';
      return;
    }

    box.innerHTML = history
      .map(
        (item) => `
          <button
            type="button"
            class="suggest-item history-suggest"
            data-value="${escapeHtml(input === fromInput ? item.from : item.to)}"
          >
            <span class="suggest-pin">🕘</span>
            <span class="suggest-label">${escapeHtml(item.label)}</span>
          </button>
        `
      )
      .join('');

    box.hidden = false;
    return;
  }

  const scored = stopSuggestions
    .map((item) => {
      const value = String(item.value || '').trim();
      const label = String(item.label || value).trim();
      const score = getSuggestionScore(item, query);

      return {
        ...item,
        value,
        label,
        score,
      };
    })
    .filter((item) => item.score > 0)
    .sort((a, b) => {
      if (b.score !== a.score) return b.score - a.score;
      return String(a.label).localeCompare(String(b.label));
    })
    .slice(0, 8);

  if (!scored.length) {
    box.hidden = true;
    box.innerHTML = '';
    return;
  }

  box.innerHTML = scored
    .map(
      (item) => `
        <button type="button" class="suggest-item" data-value="${escapeHtml(item.value)}">
          <span class="suggest-pin">⌖</span>
          <span class="suggest-label">${escapeHtml(item.label)}</span>
        </button>
      `
    )
    .join('');

  box.hidden = false;
};

    const bindSuggest = (input, box) => {
      if (!input || !box) return;

      input.addEventListener('input', () => showSuggestList(input, box));
      input.addEventListener('focus', () => showSuggestList(input, box));

      box.addEventListener('click', (event) => {
        const target = event.target;
        const button = target?.closest?.('.suggest-item');
        if (!button) return;

        input.value = button.getAttribute('data-value') || '';
        box.hidden = true;
        input.focus();
      });
    };

    bindSuggest(fromInput, fromSuggestBox);
    bindSuggest(toInput, toSuggestBox);

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (target?.closest?.('[data-close-photo-zoom]')) {
  event.preventDefault();
  closePhotoZoom();
  return;
}

const zoomBtn = target?.closest?.('.photo-zoom-trigger');
if (zoomBtn) {
  event.preventDefault();
  event.stopPropagation();

  const src = zoomBtn.getAttribute('data-zoom-src');
  if (src && src.trim()) {
    openPhotoZoom(src);
  }

  return;
}

      if (target?.closest?.('[data-open-disclaimer]')) {
        event.preventDefault();
        openDisclaimer();
        return;
      }

      if (target?.closest?.('[data-close-disclaimer]')) {
        event.preventDefault();
        closeDisclaimer();
        return;
      }

      if (!target?.closest?.('.field-wrap')) {
        if (fromSuggestBox) fromSuggestBox.hidden = true;
        if (toSuggestBox) toSuggestBox.hidden = true;
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeDisclaimer();
        closePhotoZoom();
      }
    });

    const disclaimerModal = document.getElementById('disclaimer-modal');

    const openDisclaimer = () => {
      if (!disclaimerModal) return;
      disclaimerModal.classList.remove('hidden');
      disclaimerModal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    };

    const closeDisclaimer = () => {
      if (!disclaimerModal) return;
      disclaimerModal.classList.add('hidden');
      disclaimerModal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    };

    const photoZoomModal = document.getElementById('photo-zoom-modal');
    const photoZoomImg = document.getElementById('photo-zoom-img');

    let previousBodyOverflow = '';

    const openPhotoZoom = (src) => {
  if (!photoZoomModal || !photoZoomImg || !src) return;

  previousBodyOverflow = document.body.style.overflow || '';
  photoZoomImg.removeAttribute('src');
  photoZoomImg.src = src;

  photoZoomModal.classList.remove('hidden');
  photoZoomModal.setAttribute('aria-hidden', 'false');

  document.documentElement.classList.add('photo-zoom-open');
  document.body.classList.add('photo-zoom-open');
  document.body.style.overflow = 'hidden';
};

    const closePhotoZoom = () => {
  if (!photoZoomModal || !photoZoomImg) return;

  photoZoomModal.classList.add('hidden');
  photoZoomModal.setAttribute('aria-hidden', 'true');
  photoZoomImg.removeAttribute('src');

  document.documentElement.classList.remove('photo-zoom-open');
  document.body.classList.remove('photo-zoom-open');
  document.body.style.overflow = previousBodyOverflow || '';
  previousBodyOverflow = '';
};

    photoZoomImg?.addEventListener('error', () => {
      closePhotoZoom();
    });

    const timetableUrl = (item, fromArg, toArg) => {
  const isBusObject = item && typeof item === 'object';

  const busId = isBusObject ? item.bus_id : '';
  const displayFrom = fromArg || '';
  const displayTo = toArg || '';

  const params = new URLSearchParams();

  if (busId) params.set('bus_id', busId);
  params.set('from', displayFrom);
  params.set('to', displayTo);

  return `/bus-timetable/result/?${params.toString()}#selected-bus`;
};

    const setHidden = (el, hidden) => {
      if (!el) return;
      el.classList.toggle('hidden', hidden);
    };

    const setStatus = (message, type = 'info') => {
      if (!statusBox) return;
      statusBox.textContent = message;
      statusBox.className = `status-box ${type}`;
      setHidden(statusBox, false);
    };

    const resetResults = () => {
      setHidden(statusBox, true);
      setHidden(directSection, true);
      setHidden(indirectSection, true);
      setHidden(rentSection, true);
      if (directResults) directResults.innerHTML = '';
      if (indirectResults) indirectResults.innerHTML = '';
    };

    const timeToMinutes = (value) => {
      const raw = String(value || '').trim().toLowerCase();
      if (!raw || raw.includes('not available')) return 99999;

      const match = raw.match(/(\d{1,2})[:.](\d{2})\s*(am|pm)?/i);
      if (!match) return 99999;

      let hour = Number(match[1]);
      const minute = Number(match[2]);
      const meridiem = match[3];

      if (meridiem === 'pm' && hour !== 12) hour += 12;
      if (meridiem === 'am' && hour === 12) hour = 0;

      return hour * 60 + minute;
    };

    const sortByDeparture = (items) =>
      [...items].sort((a, b) => timeToMinutes(a.departure) - timeToMinutes(b.departure));

    const busCard = (bus, searchFrom, searchTo) => {
      const from = bus.from || searchFrom;
      const to = bus.to || searchTo;
      const url = timetableUrl(bus, from, to);

      return `
        <article class="old-bus-card">
          <button
            type="button"
            class="old-bus-photo photo-zoom-trigger"
            data-zoom-src="${escapeHtml(bus.image_url || '')}"
            aria-label="Open bus photo"
          >
            ${
              bus.image_url
                ? `<img src="${escapeHtml(bus.image_url)}" alt="${escapeHtml(bus.bus_name || 'Bus')}" loading="eager" decoding="async" onerror="this.remove()" />`
                : ''
            }
            <span class="photo-fallback">🚌</span>
          </button>

          <div class="old-bus-body">
            <div class="old-bus-top">
              <div>
                <h3>${escapeHtml(bus.bus_name || 'Bus')}</h3>
                <div class="old-bus-type">
                  ${escapeHtml(bus.bus_type || 'Bus')}
                  <span class="old-day-pill">${escapeHtml(t(getDayPart(bus.departure), getDayPartBn(bus.departure)))}</span>
                </div>
              </div>

              <button type="button" class="old-warning-btn" data-open-disclaimer title="Disclaimer">
                ⚠️
              </button>
            </div>

            <div class="old-route-line">
              <span class="green-dot"></span>
              <b>${renderStopMarked(from, searchFrom, searchTo)}</b>
<span class="arrow">→</span>
<span class="red-dot"></span>
<b>${renderStopMarked(to, searchFrom, searchTo)}</b>
            </div>

            <div class="old-time-row">
              <div>
                <small>${t('Departure', 'ছাড়বে')}</small>
                <strong>${escapeHtml(bus.departure || 'Time not available')}</strong>
              </div>
              <div>
                <small>${t('Arrival', 'পৌঁছাবে')}</small>
                <strong>${escapeHtml(bus.arrival || 'Time not available')}</strong>
              </div>
              ${
                bus.duration
                  ? `<div>
                      <small>${t('Duration', 'সময়')}</small>
                      <strong>${escapeHtml(bus.duration)}</strong>
                    </div>`
                  : ''
              }
              ${
                bus.distance
                  ? `<div>
                      <small>${t('Distance', 'দূরত্ব')}</small>
                      <strong>${escapeHtml(bus.distance)}</strong>
                    </div>`
                  : ''
              }
            </div>

            <div class="old-card-actions">
  <a class="old-schedule-btn" href="${url}">
    ${t('View Full Schedule →', 'পুরো সময়সূচি দেখুন →')}
  </a>
</div>
          </div>
        </article>
      `;
    };
    const getDayPart = (value) => {
  const minutes = timeToMinutes(value);

  if (minutes === 99999) return 'Time';
  if (minutes < 360) return 'Night';
  if (minutes < 720) return 'Morning';
  if (minutes < 1020) return 'Day';
  if (minutes < 1200) return 'Evening';
  return 'Night';
};
const getDayPartBn = (value) => {
  const part = getDayPart(value);

  if (part === 'Morning') return 'সকাল';
  if (part === 'Day') return 'দিন';
  if (part === 'Evening') return 'সন্ধ্যা';
  if (part === 'Night') return 'রাত';
  return 'সময়';
};
    const indirectCard = (option, searchFrom, searchTo) => {
      const step1 = option.step1 || {};
      const step2 = option.step2 || {};
      const mid = option.midpoint || option.midpointA || step1.to || step2.from || 'Middle stop';

      return `
        <article class="old-indirect-card">
          <div class="old-transfer-head">
            <div>
              <span class="old-transfer-pill">${t('TRANSFER ROUTE', 'সংযোগ রুট')}</span>
              <h3>${t('Travel via', 'মাঝের স্টপ')} ${renderStop(mid)}</h3>
            </div>

            <div class="old-transfer-actions">
              ${option.waitMin ? `<span class="old-wait-pill">${t('Wait', 'অপেক্ষা')} ${escapeHtml(option.waitMin)} ${t('min', 'মিনিট')}</span>` : ''}
              <button type="button" class="old-warning-btn" data-open-disclaimer title="Disclaimer">⚠️</button>
            </div>
          </div>

          <div class="old-step-grid">
            <div class="old-step-card">
              <div class="old-step-head">
                <span>${t('STEP 1', 'ধাপ ১')}</span>
                <b>${t('BUS LEG', 'বাস অংশ')}</b>
              </div>

              <div class="old-step-main">
                <button
                  type="button"
                  class="old-step-photo photo-zoom-trigger"
                  data-zoom-src="${escapeHtml(step1.image_url || '')}"
                  aria-label="Open bus photo"
                >
                  ${
                    step1.image_url
                      ? `<img src="${escapeHtml(step1.image_url)}" alt="${escapeHtml(step1.bus_name || 'Bus')}" loading="eager" decoding="async" onerror="this.remove()" />`
                      : ''
                  }
                  <span class="photo-fallback">🚌</span>
                </button>

                <div class="old-step-info">
                  <h4>${escapeHtml(step1.bus_name || 'Bus 1')}</h4>
                  <span class="old-day-pill">${escapeHtml(t(getDayPart(step1.departure), getDayPartBn(step1.departure)))}</span>
                </div>
              </div>

              <div class="old-board-box">
                <small>${t('BOARD', 'উঠুন')}</small>
                <strong>${renderStopMarked(step1.from || searchFrom, searchFrom, searchTo)}</strong>
                <span>${escapeHtml(step1.departure || 'Time not available')}</span>
              </div>

              <div class="old-off-box">
                <small>${t('GET OFF', 'নামুন')}</small>
                <strong>${renderStopMarked(step1.to || mid, searchFrom, searchTo)}</strong>
                <span>${escapeHtml(step1.arrival || 'Time not available')}</span>
              </div>

              ${
                step1.bus_id
                  ? `<a href="${timetableUrl(step1, step1.from || searchFrom, step1.to || mid)}">${t('View Schedule', 'সময়সূচি দেখুন')}</a>`
                  : ''
              }
            </div>

            <div class="old-step-card">
              <div class="old-step-head">
                <span>${t('STEP 2', 'ধাপ ২')}</span>
                <b>${t('BUS LEG', 'বাস অংশ')}</b>
              </div>

              <div class="old-step-main">
                <button
                  type="button"
                  class="old-step-photo photo-zoom-trigger"
                  data-zoom-src="${escapeHtml(step2.image_url || '')}"
                  aria-label="Open bus photo"
                >
                  ${
                    step2.image_url
                      ? `<img src="${escapeHtml(step2.image_url)}" alt="${escapeHtml(step2.bus_name || 'Bus')}" loading="eager" decoding="async" onerror="this.remove()" />`
                      : ''
                  }
                  <span class="photo-fallback">🚌</span>
                </button>

                <div class="old-step-info">
                  <h4>${escapeHtml(step2.bus_name || 'Bus 2')}</h4>
