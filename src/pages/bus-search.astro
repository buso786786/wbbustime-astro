              </div>

              <div class="old-off-box">
                <small>${t('GET OFF', 'নামুন')}</small>
                <strong>${renderStopMarked(step2.to || searchTo, searchFrom, searchTo)}</strong>
                <span>${escapeHtml(step2.arrival || 'Time not available')}</span>
              </div>

              ${
                step2.bus_id
                  ? `<a href="${timetableUrl(step2, step2.from || mid, step2.to || searchTo)}">${t('View Schedule', 'সময়সূচি দেখুন')}</a>`
                  : ''
